@using Microsoft.AspNetCore.Components.Authorization
@inject IConfiguration Configuration

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center gap-2">
            <span class="text-light">
                <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
            </span>
            @if (UseEntraId)
            {
                <a href="/MicrosoftIdentity/Account/SignOut" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>Sign out
                </a>
            }
            else if (UseDevAuth)
            {
                <span class="badge bg-info text-dark">Dev Mode</span>
            }
            else
            {
                <form method="post" action="/account-action/Logout" class="d-inline">
                    <AntiforgeryToken />
                    <button type="submit" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Sign out
                    </button>
                </form>
            }
        </div>
    </Authorized>
    <NotAuthorized>
        @if (UseEntraId)
        {
            <a href="/MicrosoftIdentity/Account/SignIn" class="btn btn-outline-light btn-sm">
                <i class="bi bi-person me-1"></i>Sign in
            </a>
        }
        else if (UseDevAuth)
        {
            <span class="badge bg-info text-dark">Dev Mode</span>
        }
        else
        {
            <div class="d-flex align-items-center gap-2">
                <a href="/Account/Register" class="btn btn-outline-light btn-sm">Register</a>
                <a href="/Account/Login" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-person me-1"></i>Sign in
                </a>
            </div>
        }
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool UseEntraId => Configuration.GetValue<bool>("Auth:UseEntraId");
    private bool UseDevAuth => Configuration.GetValue<bool>("Auth:UseDevAuth");
}
