@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable" role="document">
            <div class="modal-content">
                <div class="modal-header border-bottom" style="border-color: var(--bs-border-color) !important;">
                    <h5 class="modal-title d-flex align-items-center gap-2">
                        <i class="bi bi-megaphone text-primary-ss"></i>
                        <span>@Title @(!string.IsNullOrEmpty(Version) ? $"in v{Version}" : "")</span>
                    </h5>
                    <button type="button" class="btn-close" @onclick="HandleDismiss"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(Content))
                    {
                        @((MarkupString)Content)
                    }
                    else
                    {
                        <p class="text-muted-ss ss-body2">No release notes available.</p>
                    }
                </div>
                <div class="modal-footer border-top" style="border-color: var(--bs-border-color) !important;">
                    <button type="button" class="btn btn-ss-primary" @onclick="HandleDismiss">
                        <i class="bi bi-check-circle me-1"></i> Got it!
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnDismissed { get; set; }
    [Parameter] public string Title { get; set; } = "What's New";
    [Parameter] public string Version { get; set; } = "";
    [Parameter] public string Content { get; set; } = "";

    private async Task HandleDismiss()
    {
        await OnDismissed.InvokeAsync();
    }
}
