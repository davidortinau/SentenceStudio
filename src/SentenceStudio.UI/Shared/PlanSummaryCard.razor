@using SentenceStudio.Services.Progress
@using SentenceStudio.Data

<div class="mt-3 pt-3 border-top">
    <div class="d-flex justify-content-between mb-2">
        <span class="ss-body1 fw-bold">@Day.Date.ToString("ddd, MMM d")</span>
        <span class="badge @(Day.AllPlansCompleted ? "bg-success" : "bg-secondary")">
            @GetCompletedCount()/@GetTotalCount() completed
        </span>
    </div>

    @{
        var planIndex = 1;
    }
    @foreach (var plan in Day.Plans)
    {
        @if (Day.Plans.Count > 1)
        {
            <div class="ss-caption1 text-secondary-ss mt-2 mb-1">
                Plan @planIndex (@plan.GeneratedAt.ToLocalTime().ToString("h:mm tt"))
            </div>
        }

        @foreach (var item in plan.Items)
        {
            <div class="d-flex align-items-center gap-2 py-1">
                <i class="bi @(item.IsCompleted ? "bi-check-circle-fill text-success" : "bi-circle text-secondary-ss")"
                   style="font-size: 0.8rem;"></i>
                <span class="activity-dot activity-dot-sm @GetDotClass(item.Category)"></span>
                <span class="ss-body2 @(!item.IsCompleted ? "text-secondary-ss" : "")">
                    @GetActivityDisplayName(item.ActivityType)
                </span>
                <span class="ms-auto ss-caption1 text-secondary-ss">
                    @item.MinutesSpent/@item.EstimatedMinutes min
                </span>
            </div>
        }

        <div class="d-flex justify-content-between mt-1 pt-1 border-top" style="border-color: var(--bs-border-color) !important;">
            <span class="ss-caption1 text-secondary-ss">Total time</span>
            <span class="ss-caption1 fw-bold">@plan.TotalMinutesSpent min</span>
        </div>

        planIndex++;
    }
</div>

@code {
    [Parameter] public ActivityLogDay Day { get; set; } = default!;

    private int GetCompletedCount() =>
        Day.Plans.Sum(p => p.CompletedCount);

    private int GetTotalCount() =>
        Day.Plans.Sum(p => p.TotalCount);

    private string GetDotClass(ActivityCategory category) => category switch
    {
        ActivityCategory.Input => "activity-dot-input",
        ActivityCategory.Output => "activity-dot-output",
        _ => ""
    };

    private string GetActivityDisplayName(PlanActivityType type) => type switch
    {
        PlanActivityType.VocabularyReview => "Vocabulary Review",
        PlanActivityType.Reading => "Reading",
        PlanActivityType.Listening => "Listening",
        PlanActivityType.VideoWatching => "Video Watching",
        PlanActivityType.Shadowing => "Shadowing",
        PlanActivityType.Cloze => "Cloze",
        PlanActivityType.Translation => "Translation",
        PlanActivityType.Writing => "Writing",
        PlanActivityType.SceneDescription => "Scene Description",
        PlanActivityType.Conversation => "Conversation",
        PlanActivityType.VocabularyGame => "Vocabulary Game",
        _ => type.ToString()
    };
}
