@page "/skills/add"
@attribute [Authorize]
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

<PageHeader Title='@Localize["SkillAdd_Title"]' ShowBack="true" OnBack="Cancel">
    <PrimaryActions>
        <button class="btn btn-ss-primary" @onclick="SaveProfile" disabled="@isSaving">
            @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            @Localize["Common_Save"]
        </button>
    </PrimaryActions>
    <SecondaryActions>
        <li><button class="dropdown-item" @onclick="SaveProfile" disabled="@isSaving"><i class="bi bi-check-lg me-2"></i>@Localize["Common_Save"]</button></li>
    </SecondaryActions>
</PageHeader>

<div class="card card-ss p-4 mb-3">
    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["SkillAdd_TitleLabel"]</label>
        <input type="text" class="form-control form-control-ss" @bind="title" placeholder='@Localize["SkillAdd_TitlePlaceholder"]' />
    </div>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["SkillAdd_DescriptionLabel"]</label>
        <textarea class="form-control form-control-ss" @bind="description" rows="6"
                  placeholder='@Localize["SkillAdd_DescriptionPlaceholder"]'></textarea>
    </div>
</div>

<div class="d-flex gap-2 mb-5">
    <button class="btn btn-ss-primary flex-grow-1" @onclick="SaveProfile" disabled="@isSaving">
        @if (isSaving)
        {
            <span class="spinner-border spinner-border-sm me-1"></span>
        }
        @Localize["SkillAdd_SaveSkillProfile"]
    </button>
</div>

@code {
    [Inject] private SkillProfileRepository SkillRepo { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;

    private string title = "";
    private string description = "";
    private bool isSaving;

    private void Cancel() => NavManager.NavigateTo("/skills");

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(title))
        {
            Toast.ShowError($"{Localize["SkillAdd_TitleRequired"]}");
            return;
        }

        isSaving = true;
        try
        {
            var profile = new SkillProfile
            {
                Title = title,
                Description = description
            };

            await SkillRepo.SaveAsync(profile);
            Toast.ShowSuccess($"{Localize["SkillAdd_SavedSuccess"]}");
            NavManager.NavigateTo("/skills");
        }
        catch (Exception ex)
        {
            Toast.ShowError(string.Format(Localize["SkillAdd_SaveFailed"], ex.Message));
        }
        finally
        {
            isSaving = false;
        }
    }

    protected override void OnInitialized()
    {
        Localize.CultureChanged += OnCultureChanged;
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }
}
