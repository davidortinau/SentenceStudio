@page "/import/channel/{Id?}"
@attribute [Authorize]
@using SentenceStudio.Shared.Models
@using SentenceStudio.Services

<PageHeader Title="@(IsNewChannel ? "Add Channel" : "Edit Channel")" 
            ShowBack="true" 
            OnBack="NavigateBack" />

@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="card card-ss p-4">
        <div class="mb-3">
            <label class="form-label text-secondary-ss">Channel URL *</label>
            <input type="text" class="form-control form-control-ss"
                   @bind="channelUrl" @bind:event="oninput"
                   placeholder="https://www.youtube.com/@@My_easykorean" />
            <small class="text-secondary-ss">
                Enter the full YouTube channel URL (e.g., https://www.youtube.com/@@channelname)
            </small>
        </div>

        <div class="mb-3">
            <label class="form-label text-secondary-ss">Language *</label>
            <select class="form-select form-control-ss" @bind="language">
                <option value="">-- Select Language --</option>
                @foreach (var lang in SentenceStudio.Common.Constants.Languages)
                {
                    <option value="@lang">@lang</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label text-secondary-ss">Check Interval</label>
            <select class="form-select form-control-ss" @bind="checkIntervalHours">
                <option value="6">Every 6 hours</option>
                <option value="12">Every 12 hours</option>
                <option value="24">Every 24 hours</option>
                <option value="48">Every 48 hours</option>
            </select>
        </div>

        <div class="mb-4">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="activeToggle" @bind="isActive" />
                <label class="form-check-label ss-body2" for="activeToggle">
                    Monitor this channel (check for new videos automatically)
                </label>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mb-3">
                <i class="bi bi-exclamation-circle me-1"></i>@errorMessage
            </div>
        }

        @if (isResolving)
        {
            <div class="alert alert-info d-flex align-items-center gap-2">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>Resolving channel information...</span>
            </div>
        }

        <div class="d-flex gap-2">
            <button class="btn btn-ss-secondary" @onclick="NavigateBack" disabled="@isSaving">
                Cancel
            </button>
            <button class="btn btn-ss-primary flex-grow-1" @onclick="SaveChannel" 
                    disabled="@(isSaving || isResolving || string.IsNullOrWhiteSpace(channelUrl) || string.IsNullOrWhiteSpace(language))">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                <i class="bi bi-save me-1"></i> Save Channel
            </button>
        </div>
    </div>

    @* ============ VIDEO DISCOVERY (edit mode only) ============ *@
    @if (!IsNewChannel && channel != null)
    {
        <div class="card card-ss p-4 mt-4">
            <h6 class="ss-title3 mb-3"><i class="bi bi-search me-1"></i> Discover Videos</h6>

            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-ss-secondary" @onclick="CheckForNewVideos"
                        disabled="@(isCheckingVideos || string.IsNullOrEmpty(channel.YouTubeChannelId))">
                    @if (isCheckingVideos)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>Checking...</span>
                    }
                    else
                    {
                        <i class="bi bi-arrow-repeat me-1"></i>
                        <span>Check for New Videos</span>
                    }
                </button>

                @if (discoveredVideos.Count > 0)
                {
                    var selectedCount = selectedVideoIds.Count;
                    <button class="btn btn-ss-primary" @onclick="ImportSelectedVideos"
                            disabled="@(isImportingVideos || selectedCount == 0)">
                        @if (isImportingVideos)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                            <span>Importing...</span>
                        }
                        else
                        {
                            <i class="bi bi-download me-1"></i>
                            <span>Import Selected (@selectedCount)</span>
                        }
                    </button>
                }
            </div>

            @if (string.IsNullOrEmpty(channel.YouTubeChannelId))
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    Save the channel first so its YouTube ID can be resolved.
                </div>
            }
            else if (discoveredVideos.Count > 0)
            {
                <div class="d-flex align-items-center gap-2 mb-2">
                    <small class="text-secondary-ss">@discoveredVideos.Count videos found</small>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSelectAll">
                        @(selectedVideoIds.Count == discoveredVideos.Count(v => !v.AlreadyImported) ? "Select None" : "Select All New")
                    </button>
                </div>

                <div class="list-group">
                    @foreach (var video in discoveredVideos)
                    {
                        <label class="list-group-item d-flex align-items-center gap-3 py-2 @(video.AlreadyImported ? "opacity-50" : "")">
                            <input class="form-check-input flex-shrink-0" type="checkbox"
                                   checked="@selectedVideoIds.Contains(video.VideoId)"
                                   disabled="@video.AlreadyImported"
                                   @onchange="() => ToggleVideoSelection(video.VideoId)" />
                            <span class="flex-grow-1 text-truncate">@video.Title</span>
                            @if (video.AlreadyImported)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Imported</span>
                            }
                        </label>
                    }
                </div>
            }
            else if (hasCheckedVideos && !isCheckingVideos)
            {
                <p class="text-secondary-ss ss-body2 mb-0">No videos found. Try again later.</p>
            }

            @if (!string.IsNullOrEmpty(discoveryError))
            {
                <div class="alert alert-danger mt-2 mb-0">
                    <i class="bi bi-exclamation-circle me-1"></i>@discoveryError
                </div>
            }
        </div>
    }
}

@code {
    [Parameter] public string? Id { get; set; }
    
    [Inject] private ChannelMonitorService? ChannelMonitorSvc { get; set; }
    [Inject] private YouTubeImportService? ImportSvc { get; set; }
    [Inject] private VideoImportPipelineService? VideoImportPipelineSvc { get; set; }
    [Inject] private UserProfileRepository ProfileRepo { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private ILogger<ChannelDetail> Logger { get; set; } = default!;

    private bool IsNewChannel => string.IsNullOrEmpty(Id);
    
    private bool isLoading = true;
    private bool isSaving;
    private bool isResolving;
    private string errorMessage = "";

    // Form fields
    private string channelUrl = "";
    private string language = "";
    private int checkIntervalHours = 24;
    private bool isActive = true;

    // Loaded channel (for edit)
    private MonitoredChannel? channel;

    // Video discovery state
    private record DiscoveredVideo(string VideoId, string Title, string Url, bool AlreadyImported);
    private List<DiscoveredVideo> discoveredVideos = new();
    private HashSet<string> selectedVideoIds = new();
    private bool isCheckingVideos;
    private bool isImportingVideos;
    private bool hasCheckedVideos;
    private string discoveryError = "";

    protected override async Task OnInitializedAsync()
    {
        if (!IsNewChannel && ChannelMonitorSvc != null)
        {
            // Load existing channel
            try
            {
                channel = await ChannelMonitorSvc.GetByIdAsync(Id!);
                if (channel != null)
                {
                    channelUrl = channel.ChannelUrl ?? "";
                    language = channel.Language ?? "";
                    checkIntervalHours = channel.CheckIntervalHours;
                    isActive = channel.IsActive;
                }
                else
                {
                    errorMessage = "Channel not found";
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to load channel");
                errorMessage = "Failed to load channel";
            }
        }
        else
        {
            // Pre-populate language from user profile
            try
            {
                var profile = await ProfileRepo.GetAsync();
                language = profile?.TargetLanguage ?? "";
            }
            catch { }
        }

        isLoading = false;
    }

    private async Task SaveChannel()
    {
        if (ChannelMonitorSvc == null)
        {
            Toast.ShowError("Channel monitoring service not available");
            return;
        }

        if (string.IsNullOrWhiteSpace(channelUrl) || string.IsNullOrWhiteSpace(language))
        {
            errorMessage = "Channel URL and Language are required";
            return;
        }

        isSaving = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            // For new channels, resolve metadata
            if (IsNewChannel)
            {
                isResolving = true;
                StateHasChanged();

                try
                {
                    var userId = Preferences.Get("active_profile_id", "");
                    var newChannel = new MonitoredChannel
                    {
                        ChannelUrl = channelUrl,
                        Language = language,
                        CheckIntervalHours = checkIntervalHours,
                        IsActive = isActive,
                        ChannelHandle = ExtractChannelHandle(channelUrl),
                        UserProfileId = userId
                    };

                    // AddAsync resolves channel metadata via YoutubeExplode
                    await ChannelMonitorSvc.AddAsync(newChannel);
                    Toast.ShowSuccess($"Channel added: {newChannel.ChannelName ?? newChannel.ChannelHandle}");
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Failed to add channel");
                    errorMessage = "Failed to add channel. Check the URL and try again.";
                    isSaving = false;
                    isResolving = false;
                    StateHasChanged();
                    return;
                }
                finally
                {
                    isResolving = false;
                }
            }
            else if (channel != null)
            {
                // Update existing channel
                channel.ChannelUrl = channelUrl;
                channel.Language = language;
                channel.CheckIntervalHours = checkIntervalHours;
                channel.IsActive = isActive;

                await ChannelMonitorSvc.UpdateAsync(channel);
                Toast.ShowSuccess("Channel updated successfully!");
            }

            NavManager.NavigateTo("/import");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save channel");
            errorMessage = $"Failed to save channel: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void NavigateBack()
    {
        NavManager.NavigateTo("/import");
    }

    private static string ExtractChannelHandle(string url)
    {
        // Extract @handle from URL like https://www.youtube.com/@My_easykorean
        if (url.Contains("/@"))
        {
            var parts = url.Split("/@");
            if (parts.Length > 1)
            {
                var handle = parts[1].Split('/')[0].Split('?')[0];
                return "@" + handle;
            }
        }
        return "";
    }

    private static string ExtractVideoUrlFromChannel(string channelUrl)
    {
        return channelUrl;
    }

    // ============ VIDEO DISCOVERY ============

    private async Task CheckForNewVideos()
    {
        if (ChannelMonitorSvc == null || channel == null) return;

        isCheckingVideos = true;
        discoveryError = "";
        discoveredVideos.Clear();
        selectedVideoIds.Clear();
        StateHasChanged();

        try
        {
            var videos = await ChannelMonitorSvc.GetRecentVideosAsync(channel, maxResults: 20);
            var userId = Preferences.Get("active_profile_id", "");

            foreach (var (videoId, title, url) in videos)
            {
                var alreadyImported = await ChannelMonitorSvc.IsVideoAlreadyImportedAsync(videoId, userId);
                discoveredVideos.Add(new DiscoveredVideo(videoId, title, url, alreadyImported));
            }

            // Auto-select all new (not yet imported) videos
            foreach (var v in discoveredVideos.Where(v => !v.AlreadyImported))
            {
                selectedVideoIds.Add(v.VideoId);
            }

            hasCheckedVideos = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to check for new videos");
            discoveryError = $"Failed to check for videos: {ex.Message}";
        }
        finally
        {
            isCheckingVideos = false;
        }
    }

    private void ToggleVideoSelection(string videoId)
    {
        if (!selectedVideoIds.Remove(videoId))
            selectedVideoIds.Add(videoId);
    }

    private void ToggleSelectAll()
    {
        var newVideoIds = discoveredVideos.Where(v => !v.AlreadyImported).Select(v => v.VideoId).ToList();
        if (selectedVideoIds.Count == newVideoIds.Count)
            selectedVideoIds.Clear();
        else
            selectedVideoIds = new HashSet<string>(newVideoIds);
    }

    private async Task ImportSelectedVideos()
    {
        if (VideoImportPipelineSvc == null || channel == null || selectedVideoIds.Count == 0) return;

        isImportingVideos = true;
        discoveryError = "";
        StateHasChanged();

        try
        {
            var userId = Preferences.Get("active_profile_id", "");
            var importCount = 0;

            foreach (var video in discoveredVideos.Where(v => selectedVideoIds.Contains(v.VideoId)))
            {
                var import = new VideoImport
                {
                    UserProfileId = userId,
                    MonitoredChannelId = channel.Id,
                    VideoId = video.VideoId,
                    VideoTitle = video.Title,
                    VideoUrl = video.Url,
                    Language = channel.Language,
                    CreatedAt = DateTime.UtcNow
                };

                _ = Task.Run(async () =>
                {
                    try
                    {
                        await VideoImportPipelineSvc.RunPipelineAsync(import);
                    }
                    catch (Exception ex)
                    {
                        Logger.LogError(ex, "Pipeline failed for video {Title}", video.Title);
                    }
                });

                importCount++;
            }

            Toast.ShowSuccess($"Started import for {importCount} video(s). Check Import History for progress.");
            selectedVideoIds.Clear();

            // Refresh the discovery list to show newly-importing videos
            await CheckForNewVideos();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to import selected videos");
            discoveryError = $"Import failed: {ex.Message}";
        }
        finally
        {
            isImportingVideos = false;
        }
    }
}
