@page "/vocabulary"
@attribute [Authorize]
@using SentenceStudio.Models
@using SentenceStudio.Shared.Models
@using SentenceStudio.Data
@using SentenceStudio.Services
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

<PageHeader Title='@Localize["Vocabulary_Title"]'>
    <ToolbarActions>
        <button class="btn btn-sm btn-icon text-primary-ss d-md-none"
                data-bs-toggle="offcanvas" data-bs-target="#vocabFilterPanel">
            <i class="bi @(HasActiveFilters ? "bi-funnel-fill" : "bi-funnel")" style="font-size: 1.25rem;"></i>
        </button>
    </ToolbarActions>
    <PrimaryActions>
        <button class="btn btn-ss-primary" @onclick="AddWord">
            <i class="bi bi-plus-lg me-1"></i> @Localize["Vocabulary_Add"]
        </button>
    </PrimaryActions>
    <SecondaryActions>
        <li><button class="dropdown-item" @onclick="AddWord"><i class="bi bi-plus-lg me-2"></i>@Localize["Vocabulary_Add"]</button></li>
        <li><hr class="dropdown-divider"></li>
        <li><button class="dropdown-item" @onclick="ToggleViewMode">
            <i class="bi @ViewToggleIcon me-2"></i>@ViewToggleLabel</button></li>
        <li><hr class="dropdown-divider"></li>
        <li><button class="dropdown-item" @onclick="FindDuplicates"><i class="bi bi-files me-2"></i>@Localize["Vocabulary_FindDuplicates"]</button></li>
        <li><button class="dropdown-item" @onclick="PopulateLemmas"><i class="bi bi-book me-2"></i>@Localize["Vocabulary_PopulateLemmas"]</button></li>
        <li><button class="dropdown-item" @onclick="FixSwappedLanguages"><i class="bi bi-arrow-left-right me-2"></i>@Localize["Vocabulary_FixSwappedLanguages"]</button></li>
        <li><button class="dropdown-item" @onclick="AssignOrphanedWords"><i class="bi bi-box-arrow-in-right me-2"></i>@Localize["Vocabulary_AssignOrphanedWords"]</button></li>
        <li><hr class="dropdown-divider"></li>
        <li><button class="dropdown-item" @onclick="EnterBulkEditMode"><i class="bi bi-check2-square me-2"></i>@Localize["Vocabulary_BulkEdit"]</button></li>
    </SecondaryActions>
</PageHeader>

<div class="list-page">
@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    @* Stats bar — hidden on mobile *@
    <div class="d-none d-md-flex gap-3 mb-3 overflow-auto flex-nowrap align-items-center" style="-webkit-overflow-scrolling: touch;">
        <span class="badge bg-dark rounded-pill flex-shrink-0">@string.Format(Localize["Vocabulary_StatsTotal"], filteredWords.Count, statTotal)</span>
        <span class="badge bg-secondary rounded-pill flex-shrink-0">@string.Format(Localize["Vocabulary_StatsUnknown"], statUnknown)</span>
        <span class="badge bg-primary rounded-pill flex-shrink-0">@string.Format(Localize["Vocabulary_StatsLearning"], statLearning)</span>
        <span class="badge bg-warning text-dark rounded-pill flex-shrink-0">@string.Format(Localize["Vocabulary_StatsFamiliar"], statFamiliar)</span>
        <span class="badge bg-success rounded-pill flex-shrink-0">@string.Format(Localize["Vocabulary_StatsKnown"], statKnown)</span>
        <div class="ms-auto d-flex gap-2 flex-shrink-0">
            <div class="btn-group btn-group-sm" role="group" aria-label="Sort">
                <button class="btn @(sortField == "added" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => SetSort("added")' title="@Localize["Vocabulary_SortAddedTooltip"]">
                    @Localize["Vocabulary_SortAdded"]@if (sortField == "added")
                    {<i class="bi @(sortDescending ? "bi-arrow-down" : "bi-arrow-up") ms-1"></i>}
                </button>
                <button class="btn @(sortField == "updated" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => SetSort("updated")' title="@Localize["Vocabulary_SortUpdatedTooltip"]">
                    @Localize["Vocabulary_SortUpdated"]@if (sortField == "updated")
                    {<i class="bi @(sortDescending ? "bi-arrow-down" : "bi-arrow-up") ms-1"></i>}
                </button>
            </div>
            <div class="btn-group btn-group-sm" role="group">
                <button class="btn @(viewMode == "grid" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => SetViewMode("grid")' title="Grid view">
                    <i class="bi bi-grid-3x3-gap"></i>
                </button>
                <button class="btn @(viewMode == "list" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => SetViewMode("list")' title="List view">
                    <i class="bi bi-list-ul"></i>
                </button>
            </div>
        </div>
    </div>

    @if (isBulkEditMode)
    {
        <div class="d-flex flex-wrap gap-2 mb-3 align-items-center bg-body-tertiary rounded p-2 border">
            <span class="fw-semibold">@string.Format(Localize["Vocabulary_BulkSelected"], selectedWordIds.Count)</span>

            <select class="form-select form-select-sm" style="max-width:170px;" @bind="bulkAction">
                <option value="status">@Localize["Vocabulary_BulkActionSetStatus"]</option>
                <option value="language">@Localize["Vocabulary_BulkActionSetLanguage"]</option>
                <option value="tags">@Localize["Vocabulary_BulkActionAddTags"]</option>
                <option value="delete">@Localize["Vocabulary_BulkActionDelete"]</option>
            </select>

            @if (bulkAction == "status")
            {
                <select class="form-select form-select-sm" style="max-width:160px;" @bind="bulkStatus">
                    <option value="">@Localize["Vocabulary_SetStatus"]</option>
                    <option value="Unknown">@Localize["VocabWordEdit_Unknown"]</option>
                    <option value="Learning">@Localize["VocabWordEdit_Learning"]</option>
                    <option value="Familiar">@Localize["VocabWordEdit_Familiar"]</option>
                </select>
            }
            else if (bulkAction == "language")
            {
                <select class="form-select form-select-sm" style="max-width:180px;" @bind="bulkLanguage">
                    <option value="">@Localize["Vocabulary_BulkSetLanguagePlaceholder"]</option>
                    @foreach (var lang in SentenceStudio.Common.Constants.Languages)
                    {
                        <option value="@lang">@lang</option>
                    }
                </select>
            }
            else if (bulkAction == "tags")
            {
                <input type="text" class="form-control form-control-sm" style="max-width:240px;"
                       placeholder="@Localize["Vocabulary_BulkAddTagsPlaceholder"]"
                       @bind="bulkTagsInput" />
            }

            @if (bulkAction == "delete")
            {
                <button class="btn btn-sm btn-danger" disabled="@(selectedWordIds.Count == 0 || isBulkSaving)" @onclick="RequestBulkDelete">
                    <i class="bi bi-trash me-1"></i>@Localize["Vocabulary_BulkApplyDelete"]
                </button>
            }
            else
            {
                <button class="btn btn-sm btn-primary" disabled="@(!CanApplyBulkAction() || isBulkSaving)" @onclick="ApplyBulkAction">
                    @if (isBulkSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    @Localize["Vocabulary_BulkApply"]
                </button>
            }

            <button class="btn btn-sm btn-outline-secondary" @onclick="ExitBulkEditMode" disabled="@isBulkSaving">@Localize["Common_Cancel"]</button>
            <div class="w-100 d-flex gap-2 d-md-inline-flex w-md-auto">
                <button class="btn btn-sm btn-outline-secondary" @onclick="SelectAll">@Localize["Vocabulary_SelectAll"]</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="SelectNone">@Localize["Vocabulary_SelectNone"]</button>
            </div>
        </div>
    }

    @* Unified search bar with filter syntax *@
    <div class="d-flex gap-2 mb-2">
        <div class="flex-grow-1 position-relative">
            <input type="text" class="form-control form-control-ss"
                   placeholder='@Localize["Vocabulary_SearchPlaceholder"]'
                   @bind="searchQuery" @bind:event="oninput" @bind:after="OnSearchChanged" />

            @* Autocomplete dropdown *@
            @if (showAutocomplete && autocompleteSuggestions.Count > 0)
            {
                <div class="dropdown-menu show w-100 shadow-sm" style="max-height: 250px; overflow-y: auto;">
                    @foreach (var suggestion in autocompleteSuggestions)
                    {
                        <button class="dropdown-item d-flex justify-content-between" @onclick="() => AcceptSuggestion(suggestion)">
                            <span>
                                <span class="badge @GetFilterTypeBadgeClass(suggestion.Type) me-1">@suggestion.Type</span>
                                @suggestion.DisplayText
                            </span>
                            @if (suggestion.Count.HasValue)
                            {
                                <small class="text-secondary-ss">@suggestion.Count</small>
                            }
                        </button>
                    }
                </div>
            }
        </div>

        @if (HasActiveFilters)
        {
            <button class="btn btn-ss-secondary" @onclick="ClearFilters" title="Clear all filters">
                <i class="bi bi-x-lg"></i>
            </button>
        }
    </div>

    @* Active filter chips — hidden on mobile *@
    @if (parsedQuery?.Filters.Count > 0)
    {
        <div class="d-none d-md-flex gap-2 mb-3 flex-wrap">
            @foreach (var filter in parsedQuery.Filters)
            {
                <span class="badge @GetFilterTypeBadgeClass(filter.Type) d-flex align-items-center gap-1 py-2 px-3"
                      style="font-size: 0.85rem;">
                    <i class="@GetFilterTypeIcon(filter.Type)"></i>
                    @filter.Type:@filter.Value
                    <button class="btn-close btn-close-white ms-1" style="font-size: 0.5rem;"
                            @onclick="() => RemoveFilter(filter)" @onclick:stopPropagation="true"></button>
                </span>
            }
        </div>
    }

    @* Dropdown filter shortcuts — selecting writes into the search query (hidden on mobile, shown md+) *@
    <div class="d-none d-md-flex gap-2 mb-4 flex-wrap">
        <select class="form-select form-control-ss" style="max-width: 160px;"
                value="@CurrentAssociation" @onchange="OnAssociationDropdown">
            <option value="">All Words</option>
            <option value="associated">Associated</option>
            <option value="orphaned">Orphaned</option>
        </select>

        <select class="form-select form-control-ss" style="max-width: 160px;"
                value="@CurrentType" @onchange="OnTypeDropdown">
            <option value="">@Localize["Vocabulary_FilterTypeAll"]</option>
            <option value="word">@Localize["Vocabulary_FilterTypeWord"]</option>
            <option value="phrase">@Localize["Vocabulary_FilterTypePhrase"]</option>
            <option value="sentence">@Localize["Vocabulary_FilterTypeSentence"]</option>
        </select>

        <select class="form-select form-control-ss" style="max-width: 160px;"
                value="@CurrentStatus" @onchange="OnStatusDropdown">
            <option value="">All Status</option>
            <option value="known">Known</option>
            <option value="familiar">Familiar</option>
            <option value="learning">Learning</option>
            <option value="unknown">Unknown</option>
        </select>

        @if (availableResources.Count > 0)
        {
            <select class="form-select form-control-ss" style="max-width: 220px;"
                    value="@CurrentResource" @onchange="OnResourceDropdown">
                <option value="">All Resources</option>
                @foreach (var r in availableResources)
                {
                    <option value="@r.Title">@TruncateTitle(r.Title, 30)</option>
                }
            </select>
        }

        @if (availableTags.Count > 0)
        {
            <select class="form-select form-control-ss" style="max-width: 160px;"
                    value="@CurrentTag" @onchange="OnTagDropdown">
                <option value="">All Tags</option>
                @foreach (var tag in availableTags)
                {
                    <option value="@tag">@tag</option>
                }
            </select>
        }

        @if (availableLemmas.Count > 0)
        {
            <select class="form-select form-control-ss" style="max-width: 160px;"
                    value="@CurrentLemma" @onchange="OnLemmaDropdown">
                <option value="">All Lemmas</option>
                @foreach (var lemma in availableLemmas)
                {
                    <option value="@lemma">@lemma</option>
                }
            </select>
        }

        @if (availableLanguages.Count > 0)
        {
            <select class="form-select form-control-ss" style="max-width: 160px;"
                    value="@CurrentLanguage" @onchange="OnLanguageDropdown">
                <option value="">All Languages</option>
                @foreach (var lang in availableLanguages)
                {
                    <option value="@lang">@lang</option>
                }
            </select>
        }

        <select class="form-select form-control-ss" style="max-width: 180px;"
                value="@CurrentEncoding" @onchange="OnEncodingDropdown">
            <option value="">All Encoding</option>
            <option value="strong">Strong</option>
            <option value="good">Good</option>
            <option value="basic">Basic</option>
        </select>
    </div>

    @* Mobile filter offcanvas — slides up from bottom on small screens *@
    <div class="offcanvas offcanvas-bottom offcanvas-ss d-md-none" tabindex="-1"
         id="vocabFilterPanel" aria-labelledby="vocabFilterPanelLabel"
         style="height: auto; max-height: 85vh; border-radius: 1rem 1rem 0 0;">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title" id="vocabFilterPanelLabel">
                <i class="bi bi-funnel me-2"></i>Filters
                @if (ActiveFilterCount > 0)
                {
                    <span class="badge bg-primary ms-2">@ActiveFilterCount</span>
                }
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div class="d-flex flex-column gap-3">
                <div>
                    <label class="form-label fw-semibold">Association</label>
                    <select class="form-select form-control-ss"
                            value="@CurrentAssociation" @onchange="OnAssociationDropdown">
                        <option value="">All Words</option>
                        <option value="associated">Associated</option>
                        <option value="orphaned">Orphaned</option>
                    </select>
                </div>

                <div>
                    <label class="form-label fw-semibold">Type</label>
                    <select class="form-select form-control-ss"
                            value="@CurrentType" @onchange="OnTypeDropdown">
                        <option value="">@Localize["Vocabulary_FilterTypeAll"]</option>
                        <option value="word">@Localize["Vocabulary_FilterTypeWord"]</option>
                        <option value="phrase">@Localize["Vocabulary_FilterTypePhrase"]</option>
                        <option value="sentence">@Localize["Vocabulary_FilterTypeSentence"]</option>
                    </select>
                </div>

                <div>
                    <label class="form-label fw-semibold">Status</label>
                    <select class="form-select form-control-ss"
                            value="@CurrentStatus" @onchange="OnStatusDropdown">
                        <option value="">All Status</option>
                        <option value="known">Known</option>
                        <option value="familiar">Familiar</option>
                        <option value="learning">Learning</option>
                        <option value="unknown">Unknown</option>
                    </select>
                </div>

                @if (availableResources.Count > 0)
                {
                    <div>
                        <label class="form-label fw-semibold">Resource</label>
                        <select class="form-select form-control-ss"
                                value="@CurrentResource" @onchange="OnResourceDropdown">
                            <option value="">All Resources</option>
                            @foreach (var r in availableResources)
                            {
                                <option value="@r.Title">@TruncateTitle(r.Title, 40)</option>
                            }
                        </select>
                    </div>
                }

                @if (availableTags.Count > 0)
                {
                    <div>
                        <label class="form-label fw-semibold">Tag</label>
                        <select class="form-select form-control-ss"
                                value="@CurrentTag" @onchange="OnTagDropdown">
                            <option value="">All Tags</option>
                            @foreach (var tag in availableTags)
                            {
                                <option value="@tag">@tag</option>
                            }
                        </select>
                    </div>
                }

                @if (availableLemmas.Count > 0)
                {
                    <div>
                        <label class="form-label fw-semibold">Lemma</label>
                        <select class="form-select form-control-ss"
                                value="@CurrentLemma" @onchange="OnLemmaDropdown">
                            <option value="">All Lemmas</option>
                            @foreach (var lemma in availableLemmas)
                            {
                                <option value="@lemma">@lemma</option>
                            }
                        </select>
                    </div>
                }

                @if (availableLanguages.Count > 0)
                {
                    <div>
                        <label class="form-label fw-semibold">Language</label>
                        <select class="form-select form-control-ss"
                                value="@CurrentLanguage" @onchange="OnLanguageDropdown">
                            <option value="">All Languages</option>
                            @foreach (var lang in availableLanguages)
                            {
                                <option value="@lang">@lang</option>
                            }
                        </select>
                    </div>
                }

                <div>
                    <label class="form-label fw-semibold">Encoding Strength</label>
                    <select class="form-select form-control-ss"
                            value="@CurrentEncoding" @onchange="OnEncodingDropdown">
                        <option value="">All Encoding</option>
                        <option value="strong">Strong</option>
                        <option value="good">Good</option>
                        <option value="basic">Basic</option>
                    </select>
                </div>
            </div>

            @if (HasActiveFilters)
            {
                <div class="mt-4 pt-3 border-top">
                    <button class="btn btn-ss-secondary w-100" @onclick="ClearFilters">
                        <i class="bi bi-x-lg me-1"></i> Clear All Filters
                    </button>
                </div>
            }
        </div>
    </div>

    @if (showCleanupPanel)
    {
        <div class="card mb-4" id="vocabulary-cleanup-panel">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">@cleanupTitle</h6>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseCleanupPanel">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="card-body">
                @if (isCleanupRunning)
                {
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span>@cleanupStatus</span>
                    </div>
                    @if (cleanupTotal > 0)
                    {
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width: @((cleanupProgress * 100.0 / cleanupTotal).ToString("F0"))%"
                                 aria-valuenow="@cleanupProgress" aria-valuemin="0" aria-valuemax="@cleanupTotal">
                                @cleanupProgress / @cleanupTotal
                            </div>
                        </div>
                    }
                }

                @if (showDuplicatePanel)
                {
                    <div class="mb-3">
                        <p class="mb-2">@cleanupStatus</p>
                        @if (!string.IsNullOrWhiteSpace(duplicateFocusLabel))
                        {
                            <div class="small text-secondary-ss mb-2">
                                Focused on <strong>@duplicateFocusLabel</strong> so you can manage this word's copies faster.
                            </div>
                        }
                        <div class="small text-secondary-ss mb-2">
                            Learning progress and resource associations are combined automatically. The keeper is chosen by encoding strength and memory aids.
                        </div>
                        @if (string.IsNullOrWhiteSpace(duplicateFocusLabel) && duplicateGroups.Count > 1)
                        {
                            <button class="btn btn-primary btn-sm me-2" @onclick="AutoMergeAllDuplicates" disabled="@(isCleanupRunning || !duplicateGroups.Any(g => g.CanMergeAutomatically))">
                                Merge all safe groups using recommendations
                            </button>
                        }
                    </div>

                    @if (!isCleanupRunning && duplicateGroups.Count == 0)
                    {
                        <div class="alert alert-secondary py-2 mb-0">
                            No duplicate records matched this scan.
                        </div>
                    }
                    else if (!isCleanupRunning)
                    {
                        <div class="list-group" style="max-height: 60vh; overflow-y: auto;">
                            @foreach (var group in duplicateGroups)
                            {
                                <div class="list-group-item @(IsFocusedDuplicateGroup(group) ? "border border-primary-subtle bg-primary-subtle" : "")">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div>
                                            <strong>@group.DisplayTerm</strong>
                                            <span class="badge bg-secondary ms-2">@group.Words.Count copies</span>
                                            @if (!group.CanMergeAutomatically)
                                            {
                                                <span class="badge bg-warning text-dark ms-2">Edit before merge</span>
                                            }
                                        </div>
                                        @if (IsFocusedDuplicateGroup(group))
                                        {
                                            <span class="badge bg-primary">Focused</span>
                                        }
                                    </div>
                                    <div class="mt-2">
                                       @foreach (var wordInfo in VocabularyDuplicateGroup.OrderWordsByMergePreference(group.Words))
                                        {
                                           <div class="border rounded p-2 mb-2">
                                               <div class="d-flex flex-wrap align-items-center gap-2">
                                                   <strong>@wordInfo.Word.NativeLanguageTerm</strong>
                                                   <span class="badge @GetEncodingBadgeClass(wordInfo.EncodingScore)">@GetEncodingLabel(wordInfo.EncodingScore)</span>
                                                   @if (wordInfo.Word.Id == group.RecommendedKeeperId)
                                                   {
                                                       <span class="badge bg-success">Recommended keeper</span>
                                                   }
                                                   @if (wordInfo.Word.Id == focusedDuplicateWordId)
                                                   {
                                                       <span class="badge bg-primary">Current word</span>
                                                   }
                                               </div>
                                               <div class="small text-secondary-ss mt-1">
                                                   @GetMemoryAidSummary(wordInfo)
                                               </div>
                                               @if (wordInfo.Word.Id == group.RecommendedKeeperId)
                                               {
                                                   <div class="small text-success mt-1">Best retained version based on encoding strength and memory aids.</div>
                                               }
                                               @if (!group.CanMergeAutomatically)
                                               {
                                                   <button class="btn btn-sm btn-outline-secondary mt-2"
                                                           @onclick="() => EditWord(wordInfo.Word.Id)" disabled="@isCleanupRunning">
                                                       <i class="bi bi-pencil-square me-1"></i>Edit record
                                                   </button>
                                               }
                                           </div>
                                       }
                                    </div>
                                    @if (!group.CanMergeAutomatically)
                                    {
                                        <div class="alert alert-warning py-2 mt-2 mb-2">
                                            <div class="fw-semibold">Merge is not available yet.</div>
                                            <div class="small">
                                                @(group.MergeBlockedReason ?? "Edit these records so language and lexical type match before merging.")
                                            </div>
                                            <div class="small mt-1">
                                                Use <strong>Edit record</strong> above to align the fields, then run <strong>Find Duplicates</strong> again.
                                            </div>
                                        </div>
                                    }
                                    @if (group.CanMergeAutomatically)
                                    {
                                        <button class="btn btn-sm btn-outline-primary mt-1"
                                                @onclick="() => MergeDuplicateGroup(group)" disabled="@isCleanupRunning">
                                            Merge duplicates, keeping recommended
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                        @if (duplicateGroups.Count < duplicateTotalGroupCount)
                        {
                            <div class="text-center mt-2">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="ShowMoreDuplicates" disabled="@isCleanupRunning">
                                    Show more (@(duplicateTotalGroupCount - duplicateGroups.Count) remaining)
                                </button>
                            </div>
                        }
                    }
                }

                @if (cleanupResults.Count > 0 && !isCleanupRunning)
                {
                    <div class="mt-3">
                        @foreach (var result in cleanupResults)
                        {
                            <div class="alert alert-info py-2 mb-1">@result</div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (filteredWords.Count == 0)
    {
        <div class="text-center p-5">
            <p class="ss-body1 text-secondary-ss mb-4">
                @(allWords.Count > 0 ? $"{Localize["Vocabulary_NoMatchFilter"]}" : $"{Localize["Vocabulary_NoWordsYet"]}")
            </p>
            @if (allWords.Count == 0)
            {
                <button class="btn btn-ss-primary" @onclick="AddWord">@Localize["Vocabulary_AddFirstWord"]</button>
            }
        </div>
    }
    else
    {
        @if (viewMode == "grid")
        {
        <div class="row g-3">
            <Virtualize Items="filteredWords" Context="item">
                <div class="col-12 col-md-6 col-lg-4 mb-3">
                    <div class="card card-ss p-3" role="button" @onclick="() => OnCardClick(item)">
                        @if (isBulkEditMode)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" checked="@(selectedWordIds.Contains(item.Word.Id))" @onclick:stopPropagation="true" @onchange="() => ToggleWordSelection(item.Word.Id)" />
                            </div>
                        }
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="ss-title3 mb-1">@(item.Word.TargetLanguageTerm ?? "")</h6>
                                <span class="ss-body2 text-secondary-ss">@(item.Word.NativeLanguageTerm ?? "")</span>
                            </div>
                            <div class="d-flex gap-1 flex-shrink-0 align-items-center">
                                <span class="badge @GetEncodingBadgeClass(item)">@item.EncodingLabel</span>
                                @if (item.IsKnown)
                                {
                                    <span class="badge bg-success" title="Mastered through practice and verified">Known</span>
                                }
                                else
                                {
                                    <span class="badge @GetStatusBadgeClass(item)" title="@GetStatusTooltip(item)">@item.StatusText</span>
                                }
                            </div>
                        </div>
                        <div class="mt-2 d-flex gap-2 flex-wrap">
                            @if (item.IsOrphaned)
                            {
                                <small class="text-warning"><i class="bi bi-exclamation-triangle"></i> Orphaned</small>
                            }
                            else
                            {
                                <small class="text-secondary-ss"><i class="bi bi-book me-1"></i>@item.AssociatedResources.Count resource(s)</small>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Word.Lemma))
                            {
                                <small class="text-secondary-ss"><i class="bi bi-braces me-1"></i>@item.Word.Lemma</small>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Word.Tags))
                            {
                                @foreach (var tag in item.Word.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(3))
                                {
                                    <span class="badge bg-secondary bg-opacity-50 fw-normal">@tag</span>
                                }
                            }
                        </div>
                    </div>
                </div>
            </Virtualize>
        </div>
        }
        else
        {
        <div class="list-group">
            <Virtualize Items="filteredWords" Context="item">
                <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2" @onclick="() => OnCardClick(item)">
                        @if (isBulkEditMode)
                        {
                            <input class="form-check-input me-1 flex-shrink-0" type="checkbox" checked="@(selectedWordIds.Contains(item.Word.Id))" @onclick:stopPropagation="true" @onchange="() => ToggleWordSelection(item.Word.Id)" />
                        }
                        <span class="fw-semibold" style="min-width:140px;">@(item.Word.TargetLanguageTerm ?? "")</span>
                        <span class="text-secondary-ss flex-grow-1">@(item.Word.NativeLanguageTerm ?? "")</span>
                        <span class="badge @GetEncodingBadgeClass(item)">@item.EncodingLabel</span>
                        @if (item.IsKnown)
                        {
                            <span class="badge bg-success">Known</span>
                        }
                        else
                        {
                            <span class="badge @GetStatusBadgeClass(item)">@item.StatusText</span>
                        }
                    </button>
            </Virtualize>
        </div>
        }
    }
}
</div>

@if (showBulkDeleteConfirm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content bg-surface">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-error-ss">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localize["Vocabulary_BulkConfirmDeleteTitle"]
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelBulkDelete" disabled="@isBulkSaving"></button>
                </div>
                <div class="modal-body">
                    <p class="ss-body2">@string.Format(Localize["Vocabulary_BulkConfirmDeleteMessage"], selectedWordIds.Count)</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-ss-secondary" @onclick="CancelBulkDelete" disabled="@isBulkSaving">@Localize["Common_Cancel"]</button>
                    <button type="button" class="btn btn-ss-danger" @onclick="ConfirmBulkDelete" disabled="@isBulkSaving">
                        @if (isBulkSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @Localize["Common_Delete"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private VocabularyProgressService ProgressService { get; set; } = default!;
    [Inject] private ISearchQueryParser SearchParser { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private ILogger<Vocabulary> Logger { get; set; } = default!;
    [Inject] private AiService AiSvc { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Progress.ProgressCacheService CacheService { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "q")]
    public string? QueryFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "duplicateTerm")]
    public string? DuplicateTermFromUrl { get; set; }

    [SupplyParameterFromQuery(Name = "focusWordId")]
    public string? FocusWordIdFromUrl { get; set; }

    private List<VocabularyCardItem> allWords = new();
    private List<VocabularyCardItem> filteredWords = new();
    private int statTotal, statUnknown, statLearning, statFamiliar, statKnown;
    private bool isLoading = true;
    private string viewMode = "grid"; // "grid" or "list"
    private string sortField = "added"; // "added" (CreatedAt) | "updated" (UpdatedAt)
    private bool sortDescending = true; // true = newest / most-recently-updated first
    private bool isBulkEditMode;
    private HashSet<string> selectedWordIds = new();
    private string bulkAction = "status"; // status | language | tags | delete
    private string bulkStatus = "";
    private string bulkLanguage = "";
    private string bulkTagsInput = "";
    private bool isBulkSaving;
    private bool showBulkDeleteConfirm;

    // Search query (unified with filter syntax)
    private string searchQuery = "";
    private ParsedQuery? parsedQuery;

    // Autocomplete
    private bool showAutocomplete;
    private List<AutocompleteSuggestion> autocompleteSuggestions = new();

    // Lookup data for autocomplete and filter matching
    private List<LearningResource> availableResources = new();
    private List<string> availableTags = new();
    private List<string> availableLemmas = new();
    private List<string> availableLanguages = new();

    // Cleanup state
    private bool showCleanupPanel;
    private bool showDuplicatePanel;
    private bool isCleanupRunning;
    private string cleanupTitle = "";
    private string cleanupStatus = "";
    private int cleanupProgress;
    private int cleanupTotal;
    private List<VocabularyDuplicateGroup> duplicateGroups = new();
    private List<string> cleanupResults = new();
    private string? duplicateFocusLabel;
    private string? duplicateFocusNormalizedTerm;
    private string? focusedDuplicateWordId;
    private int duplicatePageSize = 20;
    private int duplicateTotalGroupCount;
    private int duplicateExtraRecordCount;
    private bool pendingCleanupScroll;

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(searchQuery);
    private int ActiveFilterCount => parsedQuery?.Filters.Count ?? 0;

    // Computed dropdown values — read from the parsed search query
    private string CurrentAssociation => GetFilterValue("association");
    private string CurrentStatus => GetFilterValue("status");
    private string CurrentResource => GetFilterValue("resource");
    private string CurrentTag => GetFilterValue("tag");
    private string CurrentLemma => GetFilterValue("lemma");
    private string CurrentLanguage => GetFilterValue("language");
    private string CurrentEncoding => GetFilterValue("encoding");
    private string CurrentType => GetFilterValue("type");

    private string GetFilterValue(string type) =>
        parsedQuery?.Filters.FirstOrDefault(f => f.Type.Equals(type, StringComparison.OrdinalIgnoreCase))?.Value ?? "";

    protected override async Task OnInitializedAsync()
    {
        Localize.CultureChanged += OnCultureChanged;
        if (!string.IsNullOrWhiteSpace(QueryFromUrl))
        {
            searchQuery = QueryFromUrl;
            parsedQuery = SearchParser.Parse(searchQuery);
        }
        await LoadData();

        if (!string.IsNullOrWhiteSpace(DuplicateTermFromUrl))
        {
            await OpenDuplicateManagerAsync(DuplicateTermFromUrl, FocusWordIdFromUrl);
        }
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var wordsTask = ResourceRepo.GetAllVocabularyWordsWithResourcesAsync();
            var progressTask = ProgressService.GetAllProgressDictionaryAsync();
            var resourcesTask = ResourceRepo.GetAllResourcesLightweightAsync();

            await Task.WhenAll(wordsTask, progressTask, resourcesTask);

            var words = await wordsTask;
            var progressData = await progressTask;
            availableResources = await resourcesTask;

            var userResourceIds = new HashSet<string>(availableResources.Select(r => r.Id));

            allWords = words.Select(w =>
            {
                var progress = progressData.TryGetValue(w.Id, out var p) ? p : null;
                var exampleCount = w.ExampleSentences?.Count ?? 0;
                var (score, label) = EncodingScoreHelper.CalculateWithLabel(w, exampleCount);
                return new VocabularyCardItem
                {
                    Word = w,
                    AssociatedResources = w.LearningResources?
                        .Where(r => userResourceIds.Contains(r.Id))
                        .ToList() ?? new(),
                    Progress = progress,
                    EncodingScore = score,
                    EncodingLabel = label
                };
            }).ToList();

            statTotal = allWords.Count;

            // Extract unique tags and lemmas for autocomplete
            availableTags = allWords
                .Where(w => !string.IsNullOrWhiteSpace(w.Word.Tags))
                .SelectMany(w => w.Word.Tags!.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(t => t)
                .ToList();

            availableLemmas = allWords
                .Where(w => !string.IsNullOrWhiteSpace(w.Word.Lemma))
                .Select(w => w.Word.Lemma!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(l => l)
                .ToList();

            availableLanguages = allWords
                .Select(w => w.Word.Language
                    ?? w.AssociatedResources.FirstOrDefault(r => !string.IsNullOrWhiteSpace(r.Language))?.Language)
                .Where(lang => !string.IsNullOrWhiteSpace(lang))
                .Select(lang => lang!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(l => l)
                .ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["Vocabulary_LoadFailed"], ex.Message)}");
            Logger.LogError(ex, "Failed to load vocabulary data");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearchChanged()
    {
        parsedQuery = SearchParser.Parse(searchQuery);
        UpdateAutocomplete();
        ApplyFilters();
        SyncUrlWithFilters();
    }

    private void UpdateAutocomplete()
    {
        autocompleteSuggestions.Clear();
        showAutocomplete = false;

        if (string.IsNullOrWhiteSpace(searchQuery)) return;

        var (filterType, partialValue) = SearchParser.DetectActiveFilter(searchQuery, searchQuery.Length);
        if (filterType == null) return;

        var partial = partialValue?.ToLower() ?? "";

        switch (filterType)
        {
            case "tag":
                autocompleteSuggestions = availableTags
                    .Where(t => string.IsNullOrEmpty(partial) || t.ToLower().Contains(partial))
                    .Take(10)
                    .Select(t => AutocompleteSuggestion.ForTag(t, allWords.Count(w =>
                        w.Word.Tags?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                            .Any(tag => tag.Equals(t, StringComparison.OrdinalIgnoreCase)) == true)))
                    .ToList();
                break;

            case "resource":
                autocompleteSuggestions = availableResources
                    .Where(r => string.IsNullOrEmpty(partial) || (r.Title?.ToLower().Contains(partial) == true))
                    .Take(10)
                    .Select(r => AutocompleteSuggestion.ForResource(r.Title ?? "Unknown"))
                    .ToList();
                break;

            case "lemma":
                autocompleteSuggestions = availableLemmas
                    .Where(l => string.IsNullOrEmpty(partial) || l.ToLower().Contains(partial))
                    .Take(10)
                    .Select(l => AutocompleteSuggestion.ForLemma(l, allWords.Count(w =>
                        w.Word.Lemma?.Equals(l, StringComparison.OrdinalIgnoreCase) == true)))
                    .ToList();
                break;

            case "status":
                var statuses = new[] { ("known", "Known"), ("learning", "Learning"), ("unknown", "Unknown") };
                autocompleteSuggestions = statuses
                    .Where(s => string.IsNullOrEmpty(partial) || s.Item1.Contains(partial))
                    .Select(s => AutocompleteSuggestion.ForStatus(s.Item1, s.Item2))
                    .ToList();
                break;
        }

        showAutocomplete = autocompleteSuggestions.Count > 0;
    }

    private void AcceptSuggestion(AutocompleteSuggestion suggestion)
    {
        var value = suggestion.Value.Contains(' ') ? $"\"{suggestion.Value}\"" : suggestion.Value;
        searchQuery = SearchParser.InsertFilter(searchQuery, searchQuery.Length, suggestion.Type, suggestion.Value);
        showAutocomplete = false;
        parsedQuery = SearchParser.Parse(searchQuery);
        ApplyFilters();
    }

    private void RemoveFilter(FilterToken filter)
    {
        searchQuery = SearchParser.RemoveFilter(searchQuery, filter);
        parsedQuery = SearchParser.Parse(searchQuery);
        showAutocomplete = false;
        ApplyFilters();
    }

    private void OnAssociationDropdown(ChangeEventArgs e) => OnDropdownChanged("association", e);
    private void OnStatusDropdown(ChangeEventArgs e) => OnDropdownChanged("status", e);
    private void OnResourceDropdown(ChangeEventArgs e) => OnDropdownChanged("resource", e);
    private void OnTagDropdown(ChangeEventArgs e) => OnDropdownChanged("tag", e);
    private void OnLemmaDropdown(ChangeEventArgs e) => OnDropdownChanged("lemma", e);
    private void OnLanguageDropdown(ChangeEventArgs e) => OnDropdownChanged("language", e);
    private void OnEncodingDropdown(ChangeEventArgs e) => OnDropdownChanged("encoding", e);
    private void OnTypeDropdown(ChangeEventArgs e) => OnDropdownChanged("type", e);

    private void OnDropdownChanged(string filterType, ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";

        // Remove existing filter of this type
        var existing = parsedQuery?.Filters.FirstOrDefault(f => f.Type.Equals(filterType, StringComparison.OrdinalIgnoreCase));
        if (existing != null)
            searchQuery = SearchParser.RemoveFilter(searchQuery, existing);

        // Add new filter if a value was selected (not "All"/"")
        if (!string.IsNullOrEmpty(newValue))
        {
            var valueStr = newValue.Contains(' ') ? $"\"{newValue}\"" : newValue;
            searchQuery = (searchQuery.TrimEnd() + $" {filterType}:{valueStr}").Trim();
        }

        parsedQuery = SearchParser.Parse(searchQuery);
        showAutocomplete = false;
        ApplyFilters();
        SyncUrlWithFilters();
    }

    private void SyncUrlWithFilters()
    {
        var url = string.IsNullOrWhiteSpace(searchQuery)
            ? "/vocabulary"
            : $"/vocabulary?q={Uri.EscapeDataString(searchQuery)}";
        NavManager.NavigateTo(url, replace: true);
    }

    private void ApplyFilters()
    {
        var filtered = allWords.AsEnumerable();

        if (parsedQuery != null)
        {
            foreach (var filter in parsedQuery.Filters)
            {
                var val = filter.Value.ToLower();
                filtered = filter.Type.ToLower() switch
                {
                    "association" => val switch
                    {
                        "associated" => filtered.Where(v => v.AssociatedResources.Any()),
                        "orphaned" => filtered.Where(v => !v.AssociatedResources.Any()),
                        _ => filtered
                    },
                    "status" => val switch
                    {
                        "known" => filtered.Where(v => v.StatusText == "Known"),
                        "familiar" => filtered.Where(v => v.StatusText == "Familiar"),
                        "learning" => filtered.Where(v => v.StatusText == "Learning"),
                        "unknown" => filtered.Where(v => v.StatusText == "Unknown"),
                        _ => filtered
                    },
                    "tag" => filtered.Where(v =>
                        v.Word.Tags != null &&
                        v.Word.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                            .Any(t => t.Equals(filter.Value, StringComparison.OrdinalIgnoreCase))),
                    "resource" => filtered.Where(v =>
                        v.AssociatedResources.Any(r =>
                            r.Title != null && r.Title.Equals(filter.Value, StringComparison.OrdinalIgnoreCase))),
                    "lemma" => filtered.Where(v =>
                        v.Word.Lemma != null &&
                        v.Word.Lemma.Equals(filter.Value, StringComparison.OrdinalIgnoreCase)),
                    "language" => filtered.Where(v =>
                        (v.Word.Language != null && v.Word.Language.Equals(filter.Value, StringComparison.OrdinalIgnoreCase))
                        || (v.Word.Language == null && v.AssociatedResources.Any(r =>
                            r.Language != null && r.Language.Equals(filter.Value, StringComparison.OrdinalIgnoreCase)))),
                    "encoding" => filtered.Where(v =>
                        v.EncodingLabel.Equals(filter.Value, StringComparison.OrdinalIgnoreCase)),
                    "type" => val switch
                    {
                        "word" => filtered.Where(v => v.Word.LexicalUnitType == LexicalUnitType.Word),
                        "phrase" => filtered.Where(v => v.Word.LexicalUnitType == LexicalUnitType.Phrase),
                        "sentence" => filtered.Where(v => v.Word.LexicalUnitType == LexicalUnitType.Sentence),
                        _ => filtered
                    },
                    _ => filtered
                };
            }

            // Free text search (non-filter terms)
            foreach (var term in parsedQuery.FreeTextTerms)
            {
                var search = term.ToLower();
                filtered = filtered.Where(v =>
                    (v.Word.TargetLanguageTerm?.ToLower().Contains(search) == true) ||
                    (v.Word.NativeLanguageTerm?.ToLower().Contains(search) == true) ||
                    (v.Word.Tags?.ToLower().Contains(search) == true) ||
                    (v.Word.Lemma?.ToLower().Contains(search) == true));
            }
        }

        filtered = (sortField, sortDescending) switch
        {
            ("updated", true) => filtered.OrderByDescending(v => v.Word.UpdatedAt),
            ("updated", false) => filtered.OrderBy(v => v.Word.UpdatedAt),
            (_, false) => filtered.OrderBy(v => v.Word.CreatedAt),
            _ => filtered.OrderByDescending(v => v.Word.CreatedAt),
        };

        filteredWords = filtered.ToList();

        statUnknown = filteredWords.Count(w => w.StatusText == "Unknown");
        statLearning = filteredWords.Count(w => w.StatusText == "Learning");
        statFamiliar = filteredWords.Count(w => w.StatusText == "Familiar");
        statKnown = filteredWords.Count(w => w.StatusText == "Known");
    }

    private void ClearFilters()
    {
        searchQuery = "";
        parsedQuery = null;
        showAutocomplete = false;
        ApplyFilters();
    }

    private static string TruncateTitle(string? title, int maxLen) =>
        title == null ? "" : title.Length <= maxLen ? title : title[..maxLen] + "…";

    private void AddWord()
    {
        var initialTargetTerm = GetInitialTargetTermForAdd();
        NavManager.NavigateTo(BuildEditUrl("0", initialTargetTerm));
    }

    private void EditWord(string id) => NavManager.NavigateTo(BuildEditUrl(id));

    private string? GetInitialTargetTermForAdd()
    {
        if (filteredWords.Count != 0 || parsedQuery?.FreeTextTerms.Count is not > 0)
            return null;

        var term = string.Join(" ", parsedQuery.FreeTextTerms).Trim();
        return string.IsNullOrWhiteSpace(term) ? null : term;
    }

    private void OnCardClick(VocabularyCardItem item)
    {
        if (isBulkEditMode)
            ToggleWordSelection(item.Word.Id);
        else
            EditWord(item.Word.Id);
    }

    private void EnterBulkEditMode()
    {
        isBulkEditMode = true;
        selectedWordIds.Clear();
        bulkAction = "status";
        bulkStatus = "";
        bulkLanguage = "";
        bulkTagsInput = "";
        showBulkDeleteConfirm = false;
    }

    private void ExitBulkEditMode()
    {
        isBulkEditMode = false;
        selectedWordIds.Clear();
        bulkAction = "status";
        bulkStatus = "";
        bulkLanguage = "";
        bulkTagsInput = "";
        showBulkDeleteConfirm = false;
    }

    private void ToggleWordSelection(string wordId)
    {
        if (!selectedWordIds.Remove(wordId))
            selectedWordIds.Add(wordId);
    }

    private void SelectAll()
    {
        selectedWordIds = new HashSet<string>(filteredWords.Select(w => w.Word.Id));
    }

    private void SelectNone()
    {
        selectedWordIds.Clear();
    }

    private bool CanApplyBulkAction()
    {
        if (selectedWordIds.Count == 0) return false;
        return bulkAction switch
        {
            "status" => !string.IsNullOrEmpty(bulkStatus),
            "language" => !string.IsNullOrWhiteSpace(bulkLanguage),
            "tags" => ParseTagInput(bulkTagsInput).Count > 0,
            _ => false
        };
    }

    private static List<string> ParseTagInput(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return new List<string>();
        return input
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private async Task ApplyBulkAction()
    {
        if (!CanApplyBulkAction()) return;

        switch (bulkAction)
        {
            case "status":
                await SaveBulkStatus();
                break;
            case "language":
                await SaveBulkLanguage();
                break;
            case "tags":
                await SaveBulkTags();
                break;
        }
    }

    private void RequestBulkDelete()
    {
        if (selectedWordIds.Count == 0) return;
        showBulkDeleteConfirm = true;
    }

    private void CancelBulkDelete()
    {
        if (isBulkSaving) return;
        showBulkDeleteConfirm = false;
    }

    private async Task ConfirmBulkDelete()
    {
        if (selectedWordIds.Count == 0) return;

        isBulkSaving = true;
        try
        {
            var ids = selectedWordIds.ToList();
            var ok = await ResourceRepo.BulkDeleteVocabularyWordsAsync(ids);
            if (ok)
            {
                CacheService.InvalidateVocabSummary();
                await LoadData();
                Toast.ShowSuccess($"{string.Format(Localize["Vocabulary_BulkDeleteSuccess"], ids.Count)}");
                showBulkDeleteConfirm = false;
                ExitBulkEditMode();
            }
            else
            {
                Toast.ShowError($"{Localize["Vocabulary_BulkDeleteFailedGeneric"]}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Bulk delete failed");
            Toast.ShowError($"{string.Format(Localize["Vocabulary_BulkDeleteFailed"], ex.Message)}");
        }
        finally
        {
            isBulkSaving = false;
        }
    }

    private async Task SaveBulkStatus()
    {
        if (selectedWordIds.Count == 0 || string.IsNullOrEmpty(bulkStatus)) return;

        var status = bulkStatus switch
        {
            "Unknown" => LearningStatus.Unknown,
            "Learning" => LearningStatus.Learning,
            "Familiar" => LearningStatus.Familiar,
            _ => LearningStatus.Unknown
        };

        isBulkSaving = true;
        try
        {
            var userId = Preferences.Get("active_profile_id", "");
            if (string.IsNullOrEmpty(userId))
            {
                Toast.ShowError($"{Localize["Vocabulary_NoActiveProfile"]}");
                return;
            }

            int successCount = 0;
            int failCount = 0;
            foreach (var wordId in selectedWordIds)
            {
                try
                {
                    await ProgressService.SetUserDeclaredStatusAsync(wordId, userId, status);
                    successCount++;
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Failed to update status for word {WordId}", wordId);
                    failCount++;
                }
            }

            CacheService.InvalidateVocabSummary();
            await LoadData();

            if (failCount == 0)
                Toast.ShowSuccess($"{string.Format(Localize["Vocabulary_BulkUpdateSuccess"], successCount, bulkStatus)}");
            else
                Toast.ShowWarning($"{string.Format(Localize["Vocabulary_BulkUpdatePartial"], successCount, failCount)}");

            ExitBulkEditMode();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Bulk status update failed");
            Toast.ShowError($"{string.Format(Localize["Vocabulary_BulkUpdateFailed"], ex.Message)}");
        }
        finally
        {
            isBulkSaving = false;
        }
    }

    private async Task SaveBulkLanguage()
    {
        if (selectedWordIds.Count == 0 || string.IsNullOrWhiteSpace(bulkLanguage)) return;

        isBulkSaving = true;
        try
        {
            var ids = selectedWordIds.ToList();
            var updated = await ResourceRepo.BulkSetLanguageAsync(ids, bulkLanguage);

            CacheService.InvalidateVocabSummary();
            await LoadData();

            Toast.ShowSuccess($"{string.Format(Localize["Vocabulary_BulkLanguageSuccess"], updated, bulkLanguage)}");
            ExitBulkEditMode();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Bulk language update failed");
            Toast.ShowError($"{string.Format(Localize["Vocabulary_BulkLanguageFailed"], ex.Message)}");
        }
        finally
        {
            isBulkSaving = false;
        }
    }

    private async Task SaveBulkTags()
    {
        var tags = ParseTagInput(bulkTagsInput);
        if (selectedWordIds.Count == 0 || tags.Count == 0) return;

        isBulkSaving = true;
        try
        {
            var ids = selectedWordIds.ToList();
            var updated = await ResourceRepo.BulkAddTagsAsync(ids, tags);

            CacheService.InvalidateVocabSummary();
            await LoadData();

            Toast.ShowSuccess($"{string.Format(Localize["Vocabulary_BulkTagsSuccess"], updated)}");
            ExitBulkEditMode();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Bulk tags update failed");
            Toast.ShowError($"{string.Format(Localize["Vocabulary_BulkTagsFailed"], ex.Message)}");
        }
        finally
        {
            isBulkSaving = false;
        }
    }

    private string ViewToggleIcon => viewMode == "grid" ? "bi-list-ul" : "bi-grid-3x3-gap";
    private string ViewToggleLabel => viewMode == "grid" ? $"{Localize["Vocabulary_ListView"]}" : $"{Localize["Vocabulary_GridView"]}";

    private Task ToggleViewMode() => SetViewMode(viewMode == "grid" ? "list" : "grid");

    private async Task SetViewMode(string mode)
    {
        viewMode = mode;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "vocab-view-mode", mode);
        }
        catch { /* ignore if JS not available */ }
    }

    private async Task SetSort(string field)
    {
        if (sortField == field)
            sortDescending = !sortDescending; // toggle direction on the active field
        else
        {
            sortField = field;
            sortDescending = true; // default to newest / most-recently-updated first
        }

        ApplyFilters();

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "vocab-sort", $"{sortField}:{(sortDescending ? "desc" : "asc")}");
        }
        catch { /* ignore if JS not available */ }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedMode = await JS.InvokeAsync<string>("localStorage.getItem", "vocab-view-mode");
                if (savedMode == "grid" || savedMode == "list")
                {
                    viewMode = savedMode;
                    StateHasChanged();
                }
            }
            catch { /* ignore if JS not available */ }

            try
            {
                var savedSort = await JS.InvokeAsync<string>("localStorage.getItem", "vocab-sort");
                if (!string.IsNullOrEmpty(savedSort) && savedSort.Contains(':'))
                {
                    var parts = savedSort.Split(':');
                    var field = parts[0];
                    if (field == "added" || field == "updated")
                    {
                        sortField = field;
                        sortDescending = parts[1] != "asc";
                        ApplyFilters();
                        StateHasChanged();
                    }
                }
            }
            catch { /* ignore if JS not available */ }
        }

        if (pendingCleanupScroll)
        {
            pendingCleanupScroll = false;
            await ScrollCleanupPanelIntoViewAsync();
        }
    }

