    private async Task OpenDuplicateManagerAsync(string? focusTerm = null, string? focusWordId = null)
    {
        showCleanupPanel = true;
        showDuplicatePanel = true;
        isCleanupRunning = true;
        duplicateGroups.Clear();
        duplicateTotalGroupCount = 0;
        duplicateExtraRecordCount = 0;
        cleanupTotal = 0;
        cleanupProgress = 0;
        duplicateFocusLabel = string.IsNullOrWhiteSpace(focusTerm) ? null : focusTerm.Trim();
        duplicateFocusNormalizedTerm = VocabularyDuplicatePolicy.NormalizeTargetTerm(focusTerm);
        focusedDuplicateWordId = string.IsNullOrWhiteSpace(focusWordId) ? null : focusWordId;
        cleanupTitle = string.IsNullOrWhiteSpace(duplicateFocusLabel)
            ? "Find Duplicates"
            : $"Find Duplicates for “{duplicateFocusLabel}”";
        cleanupStatus = string.IsNullOrWhiteSpace(duplicateFocusLabel)
            ? "Scanning for duplicates..."
            : $"Scanning for duplicates matching “{duplicateFocusLabel}”...";
        cleanupResults.Clear();
        StateHasChanged();

        try
        {
            await LoadDuplicateGroupsAsync(append: false);

            if (duplicateGroups.Count > 0)
                Toast.ShowSuccess(cleanupStatus);
            else
                Toast.ShowInfo(cleanupStatus);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error finding duplicates");
            cleanupResults.Add($"Error: {ex.Message}");
        }
        finally
        {
            isCleanupRunning = false;
            StateHasChanged();
            await Task.Delay(100); // let results render before scrolling
            await ScrollCleanupPanelIntoViewAsync();
        }
    }

    private async Task MergeDuplicateGroup(VocabularyDuplicateGroup group)
    {
        if (!group.CanMergeAutomatically)
        {
            Toast.ShowInfo(group.MergeBlockedReason ?? "This duplicate group needs review before merging.");
            return;
        }

        isCleanupRunning = true;
        cleanupStatus = $"Merging group: {group.NormalizedTerm}...";
        StateHasChanged();

        try
        {
            var sorted = VocabularyDuplicateGroup.OrderWordsByMergePreference(group.Words);

            var keeper = sorted.First();
            var deleteIds = sorted.Skip(1).Select(w => w.Word.Id).ToList();

            int deleted = await ResourceRepo.MergeVocabularyWordsAsync(keeper.Word.Id, deleteIds);
            cleanupResults.Add($"Merged '{group.DisplayTerm}': kept 1, removed {deleted}");
            CacheService.InvalidateVocabSummary();
            await LoadData();
            await LoadDuplicateGroupsAsync(append: false);
            if (deleted > 0)
                Toast.ShowSuccess($"Merged {deleted} duplicate record(s) for '{group.DisplayTerm}'.");
            else
                Toast.ShowInfo($"No merge was needed for '{group.DisplayTerm}'.");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error merging duplicate group {Term}", group.NormalizedTerm);
            cleanupResults.Add($"Error merging '{group.DisplayTerm}': {ex.Message}");
        }
        finally
        {
            isCleanupRunning = false;
            StateHasChanged();
        }
    }

    private async Task AutoMergeAllDuplicates()
    {
        isCleanupRunning = true;
        var groupsToProcess = duplicateGroups.Where(g => g.CanMergeAutomatically).ToList();
        cleanupTotal = groupsToProcess.Count;
        cleanupProgress = 0;
        cleanupStatus = "Merging safe duplicate groups using recommendations...";
        cleanupResults.Clear();
        StateHasChanged();

        int totalMerged = 0;
        int errors = 0;

        foreach (var group in groupsToProcess)
        {
            try
            {
                var sorted = VocabularyDuplicateGroup.OrderWordsByMergePreference(group.Words);

                var keeper = sorted.First();
                var deleteIds = sorted.Skip(1).Select(w => w.Word.Id).ToList();

                int deleted = await ResourceRepo.MergeVocabularyWordsAsync(keeper.Word.Id, deleteIds);
                totalMerged += deleted;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error merging duplicate group {Term}", group.NormalizedTerm);
                errors++;
            }

            cleanupProgress++;
            StateHasChanged();
        }

        duplicateGroups.Clear();
        cleanupResults.Add($"Merge complete: removed {totalMerged} duplicate(s)" + (errors > 0 ? $", {errors} error(s)" : ""));
        isCleanupRunning = false;

        CacheService.InvalidateVocabSummary();
        await LoadData();
        await LoadDuplicateGroupsAsync(append: false);
        Toast.ShowSuccess($"Merge complete: removed {totalMerged} duplicate(s).");
        StateHasChanged();
    }

    // ===== POPULATE LEMMAS =====

    private class LemmaResponse
    {
        public List<LemmaItem> Lemmas { get; set; } = new();
    }

    private class LemmaItem
    {
        public int Id { get; set; }
        public string Lemma { get; set; } = "";
    }

    private async Task PopulateLemmas()
    {
        showCleanupPanel = true;
        showDuplicatePanel = false;
        isCleanupRunning = true;
        cleanupTitle = "Populate Lemmas";
        cleanupResults.Clear();
        StateHasChanged();

        try
        {
            var wordsNeedingLemma = allWords
                .Where(w => string.IsNullOrWhiteSpace(w.Word.Lemma))
                .Select(w => w.Word)
                .ToList();

            cleanupTotal = wordsNeedingLemma.Count;
            cleanupProgress = 0;
            cleanupStatus = $"Processing {cleanupTotal} words missing lemmas...";
            StateHasChanged();

            if (cleanupTotal == 0)
            {
                cleanupResults.Add("All words already have lemmas.");
                isCleanupRunning = false;
                StateHasChanged();
                return;
            }

            int updated = 0;
            int batchSize = 50;
            var batches = wordsNeedingLemma
                .Select((word, index) => new { word, index })
                .GroupBy(x => x.index / batchSize)
                .Select(g => g.Select(x => x.word).ToList())
                .ToList();

            foreach (var batch in batches)
            {
                cleanupStatus = $"Processing batch {cleanupProgress / batchSize + 1} of {batches.Count}...";
                StateHasChanged();

                try
                {
                    var wordList = string.Join("\n", batch.Select((w, i) =>
                        $"{i + 1}. {w.TargetLanguageTerm} ({w.NativeLanguageTerm})"));

                    var prompt = $@"For each word below, return its dictionary form (lemma). If the word is already in dictionary form, return it unchanged. Return ONLY a JSON object with a ""lemmas"" array where each item has ""id"" (the number) and ""lemma"" (the dictionary form in the target language).

Words:
{wordList}

Return JSON like: {{""lemmas"": [{{""id"": 1, ""lemma"": ""dictionary form""}}, ...]}}";

                    var response = await AiSvc.SendPrompt<LemmaResponse>(prompt);

                    if (response?.Lemmas != null)
                    {
                        var lemmaUpdates = new Dictionary<string, string>();
                        foreach (var item in response.Lemmas)
                        {
                            var idx = item.Id - 1; // 0-based index
                            if (idx >= 0 && idx < batch.Count && !string.IsNullOrWhiteSpace(item.Lemma))
                            {
                                lemmaUpdates[batch[idx].Id] = item.Lemma;
                            }
                        }

                        if (lemmaUpdates.Any())
                        {
                            int batchUpdated = await ResourceRepo.BulkUpdateLemmasAsync(lemmaUpdates);
                            updated += batchUpdated;
                        }
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Error processing lemma batch");
                    cleanupResults.Add($"Batch error: {ex.Message}");
                }

                cleanupProgress += batch.Count;
                StateHasChanged();

                await Task.Delay(500);
            }

            cleanupResults.Add($"Lemma population complete: updated {updated} of {cleanupTotal} words");

            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error populating lemmas");
            cleanupResults.Add($"Error: {ex.Message}");
        }
        finally
        {
            isCleanupRunning = false;
            StateHasChanged();
        }
    }

    // ===== FIX SWAPPED LANGUAGES =====
    private static bool IsEnglish(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return false;
        return text.All(c => c <= 127 || char.IsWhiteSpace(c));
    }

    private static bool IsKorean(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return false;
        return text.Any(c =>
            (c >= 0xAC00 && c <= 0xD7AF) ||  // Hangul Syllables
            (c >= 0x1100 && c <= 0x11FF) ||   // Hangul Jamo
            (c >= 0x3130 && c <= 0x318F));    // Hangul Compatibility Jamo
    }

    private async Task FixSwappedLanguages()
    {
        showCleanupPanel = true;
        showDuplicatePanel = false;
        isCleanupRunning = true;
        cleanupTitle = "Fix Swapped Languages";
        cleanupResults.Clear();
        cleanupStatus = "Scanning for swapped language entries...";
        StateHasChanged();

        try
        {
            int swappedCount = 0;
            int mergedCount = 0;

            var wordsToSwap = new List<(string Id, string NewTarget, string NewNative)>();
            var wordsToMerge = new List<(string FromId, string ToId)>();

            foreach (var item in allWords)
            {
                var word = item.Word;
                if (string.IsNullOrWhiteSpace(word.TargetLanguageTerm) ||
                    string.IsNullOrWhiteSpace(word.NativeLanguageTerm))
                    continue;

                bool targetIsEnglish = IsEnglish(word.TargetLanguageTerm);
                bool nativeIsKorean = IsKorean(word.NativeLanguageTerm);

                if (targetIsEnglish && nativeIsKorean)
                {
                    var swappedTarget = word.NativeLanguageTerm;
                    var swappedNative = word.TargetLanguageTerm;

                    var existingWord = await ResourceRepo.FindDuplicateVocabularyWordAsync(swappedTarget, swappedNative);

                    if (existingWord != null && existingWord.Id != word.Id)
                    {
                        wordsToMerge.Add((word.Id, existingWord.Id));
                    }
                    else
                    {
                        wordsToSwap.Add((word.Id, swappedTarget, swappedNative));
                    }
                }
            }

            cleanupTotal = wordsToSwap.Count + wordsToMerge.Count;
            cleanupProgress = 0;
            cleanupStatus = $"Fixing {cleanupTotal} entries...";
            StateHasChanged();

            foreach (var (fromId, toId) in wordsToMerge)
            {
                var wordResources = await ResourceRepo.GetResourcesContainingWordAsync(fromId);
                foreach (var resource in wordResources)
                {
                    await ResourceRepo.BulkAssociateWordsWithResourceAsync(resource.Id, new List<string> { toId });
                }
                await ResourceRepo.DeleteVocabularyWordAsync(fromId);
                mergedCount++;
                cleanupProgress++;
                StateHasChanged();
            }

            foreach (var (id, newTarget, newNative) in wordsToSwap)
            {
                await ResourceRepo.UpdateVocabularyWordTermsAsync(id, newTarget, newNative);
                swappedCount++;
                cleanupProgress++;
                StateHasChanged();
            }

            cleanupResults.Add($"Swapped {swappedCount} word(s), merged {mergedCount} duplicate(s)");

            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error fixing swapped languages");
            cleanupResults.Add($"Error: {ex.Message}");
        }
        finally
        {
            isCleanupRunning = false;
            StateHasChanged();
        }
    }

    // ===== ASSIGN ORPHANED WORDS =====
    private async Task AssignOrphanedWords()
    {
        showCleanupPanel = true;
        showDuplicatePanel = false;
        isCleanupRunning = true;
        cleanupTitle = "Assign Orphaned Words";
        cleanupResults.Clear();
        cleanupStatus = "Finding orphaned words...";
        StateHasChanged();

        try
        {
            var orphanedWords = await ResourceRepo.GetOrphanedVocabularyWordsAsync();

            if (!orphanedWords.Any())
            {
                cleanupResults.Add("No orphaned words found.");
                isCleanupRunning = false;
                StateHasChanged();
                return;
            }

            cleanupStatus = $"Assigning {orphanedWords.Count} orphaned words...";
            StateHasChanged();

            var allResources = availableResources;
            var generalResource = allResources.FirstOrDefault(r =>
                r.Title == "General Vocabulary" && r.MediaType == "Vocabulary List");

            if (generalResource == null)
            {
                generalResource = new LearningResource
                {
                    Id = Guid.NewGuid().ToString(),
                    Title = "General Vocabulary",
                    Description = "Catch-all vocabulary list for words without a specific learning resource",
                    MediaType = "Vocabulary List",
                    Language = "Korean",
                    Tags = "general,unassigned",
                    CreatedAt = DateTime.UtcNow,
                    UpdatedAt = DateTime.UtcNow
                };
                await ResourceRepo.SaveResourceAsync(generalResource);
            }

            var orphanIds = orphanedWords.Select(w => w.Id).ToList();
            await ResourceRepo.BulkAssociateWordsWithResourceAsync(generalResource.Id, orphanIds);

            cleanupResults.Add($"Assigned {orphanIds.Count} orphaned word(s) to 'General Vocabulary'");

            await LoadData();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error assigning orphaned words");
            cleanupResults.Add($"Error: {ex.Message}");
        }
        finally
        {
            isCleanupRunning = false;
            StateHasChanged();
        }
    }

