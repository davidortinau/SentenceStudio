    private static string GetMemoryAidSummary(VocabularyDuplicateWordInfo wordInfo)
    {
        var word = wordInfo.Word;
        var aids = new List<string>();

        if (!string.IsNullOrWhiteSpace(word.MnemonicText))
        {
            aids.Add($"Memory aid: {Truncate(word.MnemonicText, 120)}");
        }

        if (!string.IsNullOrWhiteSpace(word.MnemonicImageUri))
        {
            aids.Add("image aid");
        }

        if (!string.IsNullOrWhiteSpace(word.AudioPronunciationUri))
        {
            aids.Add("audio");
        }

        return aids.Count > 0
            ? string.Join(" | ", aids)
            : "No memory aids on this copy.";
    }

    private static string Truncate(string value, int maxLength)
    {
        var trimmed = value.Trim();
        return trimmed.Length <= maxLength ? trimmed : $"{trimmed[..maxLength]}...";
    }

