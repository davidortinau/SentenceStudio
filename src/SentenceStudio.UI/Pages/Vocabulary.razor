    private string BuildEditUrl(string id, string? initialTargetTerm = null)
    {
        var queryParts = new List<string>();

        if (!string.IsNullOrWhiteSpace(searchQuery))
            queryParts.Add($"returnQuery={Uri.EscapeDataString(searchQuery)}");

        if (!string.IsNullOrWhiteSpace(duplicateFocusLabel))
            queryParts.Add($"returnDuplicateTerm={Uri.EscapeDataString(duplicateFocusLabel)}");

        if (!string.IsNullOrWhiteSpace(focusedDuplicateWordId))
            queryParts.Add($"returnFocusWordId={Uri.EscapeDataString(focusedDuplicateWordId)}");

        if (!string.IsNullOrWhiteSpace(initialTargetTerm))
            queryParts.Add($"initialTargetTerm={Uri.EscapeDataString(initialTargetTerm)}");

        return queryParts.Count == 0
            ? $"/vocabulary/edit/{id}"
            : $"/vocabulary/edit/{id}?{string.Join("&", queryParts)}";
    }

    private async Task LoadDuplicateGroupsAsync(bool append)
    {
        var result = await ResourceRepo.FindDuplicateVocabularyGroupsAsync(
            duplicateFocusLabel,
            append ? duplicateGroups.Count : 0,
            duplicatePageSize);

        if (append)
            duplicateGroups.AddRange(result.Groups);
        else
            duplicateGroups = result.Groups.ToList();

        duplicateTotalGroupCount = result.TotalGroupCount;
        duplicateExtraRecordCount = result.ExtraRecordCount;

        cleanupStatus = duplicateTotalGroupCount > 0
            ? $"Found {duplicateTotalGroupCount} group(s) of duplicate words with {duplicateExtraRecordCount} extra record(s). Showing {duplicateGroups.Count}."
            : string.IsNullOrWhiteSpace(duplicateFocusLabel)
                ? "No duplicates found."
                : $"No duplicates found for '{duplicateFocusLabel}'.";
    }

    private bool IsFocusedDuplicateGroup(VocabularyDuplicateGroup group) =>
        !string.IsNullOrWhiteSpace(duplicateFocusNormalizedTerm)
        && group.NormalizedTerm == duplicateFocusNormalizedTerm;

