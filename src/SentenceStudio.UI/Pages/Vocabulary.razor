@page "/vocabulary"
@attribute [Authorize]
@using SentenceStudio.Models
@using SentenceStudio.Shared.Models
@using SentenceStudio.Data
@using SentenceStudio.Services

<PageHeader Title="Vocabulary">
    <PrimaryActions>
        <button class="btn btn-ss-primary" @onclick="AddWord">
            <i class="bi bi-plus-lg me-1"></i> Add Word
        </button>
    </PrimaryActions>
    <SecondaryActions>
        <li><button class="dropdown-item" @onclick="AddWord"><i class="bi bi-plus-lg me-2"></i>Add Word</button></li>
        <li><hr class="dropdown-divider"></li>
        <li><button class="dropdown-item" @onclick="FindDuplicates"><i class="bi bi-files me-2"></i>Find Duplicates</button></li>
        <li><button class="dropdown-item" @onclick="PopulateLemmas"><i class="bi bi-book me-2"></i>Populate Lemmas</button></li>
        <li><button class="dropdown-item" @onclick="FixSwappedLanguages"><i class="bi bi-arrow-left-right me-2"></i>Fix Swapped Languages</button></li>
        <li><button class="dropdown-item" @onclick="AssignOrphanedWords"><i class="bi bi-box-arrow-in-right me-2"></i>Assign Orphaned Words</button></li>
        <li><hr class="dropdown-divider"></li>
        <li><button class="dropdown-item" @onclick="EnterBulkEditMode"><i class="bi bi-check2-square me-2"></i>Bulk Edit Status</button></li>
    </SecondaryActions>
</PageHeader>

@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    @* Stats bar — horizontal scroll on mobile *@
    <div class="d-flex gap-3 mb-3 overflow-auto flex-nowrap align-items-center" style="-webkit-overflow-scrolling: touch;">
        <span class="badge bg-dark rounded-pill flex-shrink-0">@filteredWords.Count of @statTotal</span>
        <span class="badge bg-secondary rounded-pill flex-shrink-0">Unknown: @statUnknown</span>
        <span class="badge bg-primary rounded-pill flex-shrink-0">Learning: @statLearning</span>
        <span class="badge bg-warning text-dark rounded-pill flex-shrink-0">Familiar: @statFamiliar</span>
        <span class="badge bg-success rounded-pill flex-shrink-0">Known: @statKnown</span>
        <div class="ms-auto btn-group btn-group-sm flex-shrink-0" role="group">
            <button class="btn @(viewMode == "grid" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => SetViewMode("grid")' title="Grid view">
                <i class="bi bi-grid-3x3-gap"></i>
            </button>
            <button class="btn @(viewMode == "list" ? "btn-secondary" : "btn-outline-secondary")" @onclick='() => SetViewMode("list")' title="List view">
                <i class="bi bi-list-ul"></i>
            </button>
        </div>
    </div>

    @if (isBulkEditMode)
    {
        <div class="d-flex gap-2 mb-3 align-items-center bg-body-tertiary rounded p-2 border">
            <span class="fw-semibold me-2">@selectedWordIds.Count selected</span>
            <select class="form-select form-select-sm" style="max-width:160px;" @bind="bulkStatus">
                <option value="">Set Status...</option>
                <option value="Unknown">Unknown</option>
                <option value="Learning">Learning</option>
                <option value="Familiar">Familiar</option>
            </select>
            <button class="btn btn-sm btn-primary" disabled="@(selectedWordIds.Count == 0 || string.IsNullOrEmpty(bulkStatus) || isBulkSaving)" @onclick="SaveBulkStatus">
                @if (isBulkSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Save
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ExitBulkEditMode" disabled="@isBulkSaving">Cancel</button>
            <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="SelectAll">Select All</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="SelectNone">Select None</button>
        </div>
    }

    @* Unified search bar with filter syntax *@
    <div class="d-flex gap-2 mb-2">
        <div class="flex-grow-1 position-relative">
            <input type="text" class="form-control form-control-ss"
                   placeholder="Search... (try tag:clothing status:learning resource:'Starter')"
                   @bind="searchQuery" @bind:event="oninput" @bind:after="OnSearchChanged" />

            @* Autocomplete dropdown *@
            @if (showAutocomplete && autocompleteSuggestions.Count > 0)
            {
                <div class="dropdown-menu show w-100 shadow-sm" style="max-height: 250px; overflow-y: auto;">
                    @foreach (var suggestion in autocompleteSuggestions)
                    {
                        <button class="dropdown-item d-flex justify-content-between" @onclick="() => AcceptSuggestion(suggestion)">
                            <span>
                                <span class="badge @GetFilterTypeBadgeClass(suggestion.Type) me-1">@suggestion.Type</span>
                                @suggestion.DisplayText
                            </span>
                            @if (suggestion.Count.HasValue)
                            {
                                <small class="text-secondary-ss">@suggestion.Count</small>
                            }
                        </button>
                    }
                </div>
            }
        </div>

        @if (HasActiveFilters)
        {
            <button class="btn btn-ss-secondary" @onclick="ClearFilters" title="Clear all filters">
                <i class="bi bi-x-lg"></i>
            </button>
        }
    </div>

    @* Active filter chips *@
    @if (parsedQuery?.Filters.Count > 0)
    {
        <div class="d-flex gap-2 mb-3 flex-wrap">
            @foreach (var filter in parsedQuery.Filters)
            {
                <span class="badge @GetFilterTypeBadgeClass(filter.Type) d-flex align-items-center gap-1 py-2 px-3"
                      style="font-size: 0.85rem;">
                    <i class="@GetFilterTypeIcon(filter.Type)"></i>
                    @filter.Type:@filter.Value
                    <button class="btn-close btn-close-white ms-1" style="font-size: 0.5rem;"
                            @onclick="() => RemoveFilter(filter)" @onclick:stopPropagation="true"></button>
                </span>
            }
        </div>
    }

    @* Dropdown filter shortcuts — selecting writes into the search query *@
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <select class="form-select form-control-ss" style="max-width: 160px;"
                value="@CurrentAssociation" @onchange="OnAssociationDropdown">
            <option value="">All Words</option>
            <option value="associated">Associated</option>
            <option value="orphaned">Orphaned</option>
        </select>

        <select class="form-select form-control-ss" style="max-width: 160px;"
                value="@CurrentStatus" @onchange="OnStatusDropdown">
            <option value="">All Status</option>
            <option value="known">Known</option>
            <option value="familiar">Familiar</option>
            <option value="learning">Learning</option>
            <option value="unknown">Unknown</option>
        </select>

        @if (availableResources.Count > 0)
        {
            <select class="form-select form-control-ss" style="max-width: 220px;"
                    value="@CurrentResource" @onchange="OnResourceDropdown">
                <option value="">All Resources</option>
                @foreach (var r in availableResources)
                {
                    <option value="@r.Title">@TruncateTitle(r.Title, 30)</option>
                }
            </select>
        }

        @if (availableTags.Count > 0)
        {
            <select class="form-select form-control-ss" style="max-width: 160px;"
                    value="@CurrentTag" @onchange="OnTagDropdown">
                <option value="">All Tags</option>
                @foreach (var tag in availableTags)
                {
                    <option value="@tag">@tag</option>
                }
            </select>
        }

        @if (availableLemmas.Count > 0)
        {
            <select class="form-select form-control-ss" style="max-width: 160px;"
                    value="@CurrentLemma" @onchange="OnLemmaDropdown">
                <option value="">All Lemmas</option>
                @foreach (var lemma in availableLemmas)
                {
                    <option value="@lemma">@lemma</option>
                }
            </select>
        }

        @if (availableLanguages.Count > 1)
        {
            <select class="form-select form-control-ss" style="max-width: 160px;"
                    value="@CurrentLanguage" @onchange="OnLanguageDropdown">
                <option value="">All Languages</option>
                @foreach (var lang in availableLanguages)
                {
                    <option value="@lang">@lang</option>
                }
            </select>
        }

        <select class="form-select form-control-ss" style="max-width: 180px;"
                value="@CurrentEncoding" @onchange="OnEncodingDropdown">
            <option value="">All Encoding</option>
            <option value="strong">Strong</option>
            <option value="good">Good</option>
            <option value="basic">Basic</option>
        </select>
    </div>

    @if (showCleanupPanel)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">@cleanupTitle</h6>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CloseCleanupPanel">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="card-body">
                @if (isCleanupRunning)
                {
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span>@cleanupStatus</span>
                    </div>
                    @if (cleanupTotal > 0)
                    {
                        <div class="progress mb-2" style="height: 20px;">
                            <div class="progress-bar" role="progressbar"
                                 style="width: @((cleanupProgress * 100.0 / cleanupTotal).ToString("F0"))%"
                                 aria-valuenow="@cleanupProgress" aria-valuemin="0" aria-valuemax="@cleanupTotal">
                                @cleanupProgress / @cleanupTotal
                            </div>
                        </div>
                    }
                }

                @if (showDuplicatePanel)
                {
                    <div class="mb-3">
                        <p>Found <strong>@duplicateGroups.Count</strong> groups of duplicate words (@duplicateGroups.Sum(g => g.Words.Count - 1) extra records).</p>
                        <button class="btn btn-primary btn-sm me-2" @onclick="AutoMergeAllDuplicates" disabled="@isCleanupRunning">
                            Auto-merge All
                        </button>
                    </div>

                    <div class="list-group" style="max-height: 400px; overflow-y: auto;">
                        @foreach (var group in duplicateGroups)
                        {
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>@group.NormalizedTerm</strong>
                                        <span class="badge bg-secondary ms-2">@group.Words.Count copies</span>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    @foreach (var wordInfo in group.Words)
                                    {
                                        <div class="d-flex align-items-center gap-2 py-1">
                                            <small class="text-muted">@wordInfo.Word.NativeLanguageTerm</small>
                                            <span class="badge bg-info">@wordInfo.ResourceCount resources</span>
                                            <span class="badge bg-secondary">@(wordInfo.EncodingScore >= 0.67 ? "Strong" : wordInfo.EncodingScore >= 0.34 ? "Good" : "Basic")</span>
                                            <small class="text-muted">ID: @wordInfo.Word.Id[..8]...</small>
                                        </div>
                                    }
                                </div>
                                <button class="btn btn-sm btn-outline-primary mt-1"
                                        @onclick="() => MergeDuplicateGroup(group)" disabled="@isCleanupRunning">
                                    Merge (keep best)
                                </button>
                            </div>
                        }
                    </div>
                }

                @if (cleanupResults.Count > 0 && !isCleanupRunning)
                {
                    <div class="mt-3">
                        @foreach (var result in cleanupResults)
                        {
                            <div class="alert alert-info py-2 mb-1">@result</div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (filteredWords.Count == 0)
    {
        <div class="text-center p-5">
            <p class="ss-body1 text-secondary-ss mb-4">
                @(allWords.Count > 0 ? "No words match the current filter." : "No vocabulary words yet.")
            </p>
            @if (allWords.Count == 0)
            {
                <button class="btn btn-ss-primary" @onclick="AddWord">Add Your First Word</button>
            }
        </div>
    }
    else
    {
        @if (viewMode == "grid")
        {
        <div class="row g-3">
            @foreach (var item in filteredWords)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card card-ss p-3" role="button" @onclick="() => OnCardClick(item)">
                        @if (isBulkEditMode)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" checked="@(selectedWordIds.Contains(item.Word.Id))" @onclick:stopPropagation="true" @onchange="() => ToggleWordSelection(item.Word.Id)" />
                            </div>
                        }
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="ss-title3 mb-1">@(item.Word.TargetLanguageTerm ?? "")</h6>
                                <span class="ss-body2 text-secondary-ss">@(item.Word.NativeLanguageTerm ?? "")</span>
                            </div>
                            <div class="d-flex gap-1 flex-shrink-0 align-items-center">
                                <span class="badge @GetEncodingBadgeClass(item)">@item.EncodingLabel</span>
                                @if (item.IsKnown)
                                {
                                    <span class="badge bg-success" title="Mastered through practice and verified">Known</span>
                                }
                                else
                                {
                                    <span class="badge @GetStatusBadgeClass(item)" title="@GetStatusTooltip(item)">@item.StatusText</span>
                                }
                            </div>
                        </div>
                        <div class="mt-2 d-flex gap-2 flex-wrap">
                            @if (item.IsOrphaned)
                            {
                                <small class="text-warning"><i class="bi bi-exclamation-triangle"></i> Orphaned</small>
                            }
                            else
                            {
                                <small class="text-secondary-ss"><i class="bi bi-book me-1"></i>@item.AssociatedResources.Count resource(s)</small>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Word.Lemma))
                            {
                                <small class="text-secondary-ss"><i class="bi bi-braces me-1"></i>@item.Word.Lemma</small>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.Word.Tags))
                            {
                                @foreach (var tag in item.Word.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Take(3))
                                {
                                    <span class="badge bg-secondary bg-opacity-50 fw-normal">@tag</span>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        }
        else
        {
        <div class="list-group">
            @foreach (var item in filteredWords)
            {
                <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2" @onclick="() => OnCardClick(item)">
                    @if (isBulkEditMode)
                    {
                        <input class="form-check-input me-1 flex-shrink-0" type="checkbox" checked="@(selectedWordIds.Contains(item.Word.Id))" @onclick:stopPropagation="true" @onchange="() => ToggleWordSelection(item.Word.Id)" />
                    }
                    <span class="fw-semibold" style="min-width:140px;">@(item.Word.TargetLanguageTerm ?? "")</span>
                    <span class="text-secondary-ss flex-grow-1">@(item.Word.NativeLanguageTerm ?? "")</span>
                    <span class="badge @GetEncodingBadgeClass(item)">@item.EncodingLabel</span>
                    @if (item.IsKnown)
                    {
                        <span class="badge bg-success">Known</span>
                    }
                    else
                    {
                        <span class="badge @GetStatusBadgeClass(item)">@item.StatusText</span>
                    }
                </button>
            }
        </div>
        }
    }
}

@code {
    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private VocabularyProgressService ProgressService { get; set; } = default!;
    [Inject] private ISearchQueryParser SearchParser { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private ILogger<Vocabulary> Logger { get; set; } = default!;
    [Inject] private AiService AiSvc { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Progress.ProgressCacheService CacheService { get; set; } = default!;

    [SupplyParameterFromQuery(Name = "q")]
    public string? QueryFromUrl { get; set; }

    private List<VocabularyCardItem> allWords = new();
    private List<VocabularyCardItem> filteredWords = new();
    private int statTotal, statUnknown, statLearning, statFamiliar, statKnown;
    private bool isLoading = true;
    private string viewMode = "grid"; // "grid" or "list"
    private bool isBulkEditMode;
    private HashSet<string> selectedWordIds = new();
    private string bulkStatus = "";
    private bool isBulkSaving;

    // Search query (unified with filter syntax)
    private string searchQuery = "";
    private ParsedQuery? parsedQuery;

    // Autocomplete
    private bool showAutocomplete;
    private List<AutocompleteSuggestion> autocompleteSuggestions = new();

    // Lookup data for autocomplete and filter matching
    private List<LearningResource> availableResources = new();
    private List<string> availableTags = new();
    private List<string> availableLemmas = new();
    private List<string> availableLanguages = new();

    // Cleanup state
    private bool showCleanupPanel;
    private bool showDuplicatePanel;
    private bool isCleanupRunning;
    private string cleanupTitle = "";
    private string cleanupStatus = "";
    private int cleanupProgress;
    private int cleanupTotal;
    private List<DuplicateGroup> duplicateGroups = new();
    private List<string> cleanupResults = new();

    private bool HasActiveFilters => !string.IsNullOrWhiteSpace(searchQuery);

    // Computed dropdown values — read from the parsed search query
    private string CurrentAssociation => GetFilterValue("association");
    private string CurrentStatus => GetFilterValue("status");
    private string CurrentResource => GetFilterValue("resource");
    private string CurrentTag => GetFilterValue("tag");
    private string CurrentLemma => GetFilterValue("lemma");
    private string CurrentLanguage => GetFilterValue("language");
    private string CurrentEncoding => GetFilterValue("encoding");

    private string GetFilterValue(string type) =>
        parsedQuery?.Filters.FirstOrDefault(f => f.Type.Equals(type, StringComparison.OrdinalIgnoreCase))?.Value ?? "";

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrWhiteSpace(QueryFromUrl))
        {
            searchQuery = QueryFromUrl;
            parsedQuery = SearchParser.Parse(searchQuery);
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var wordsTask = ResourceRepo.GetAllVocabularyWordsWithResourcesAsync();
            var progressTask = ProgressService.GetAllProgressDictionaryAsync();
            var resourcesTask = ResourceRepo.GetAllResourcesLightweightAsync();

            await Task.WhenAll(wordsTask, progressTask, resourcesTask);

            var words = await wordsTask;
            var progressData = await progressTask;
            availableResources = await resourcesTask;

            var userResourceIds = new HashSet<string>(availableResources.Select(r => r.Id));

            allWords = words.Select(w =>
            {
                var progress = progressData.TryGetValue(w.Id, out var p) ? p : null;
                var exampleCount = w.ExampleSentences?.Count ?? 0;
                var (score, label) = EncodingScoreHelper.CalculateWithLabel(w, exampleCount);
                return new VocabularyCardItem
                {
                    Word = w,
                    AssociatedResources = w.LearningResources?
                        .Where(r => userResourceIds.Contains(r.Id))
                        .ToList() ?? new(),
                    Progress = progress,
                    EncodingScore = score,
                    EncodingLabel = label
                };
            }).ToList();

            statTotal = allWords.Count;

            // Extract unique tags and lemmas for autocomplete
            availableTags = allWords
                .Where(w => !string.IsNullOrWhiteSpace(w.Word.Tags))
                .SelectMany(w => w.Word.Tags!.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(t => t)
                .ToList();

            availableLemmas = allWords
                .Where(w => !string.IsNullOrWhiteSpace(w.Word.Lemma))
                .Select(w => w.Word.Lemma!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(l => l)
                .ToList();

            availableLanguages = allWords
                .SelectMany(w => w.AssociatedResources)
                .Where(r => !string.IsNullOrWhiteSpace(r.Language))
                .Select(r => r.Language!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(l => l)
                .ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load vocabulary: {ex.Message}");
            Logger.LogError(ex, "Failed to load vocabulary data");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnSearchChanged()
    {
        parsedQuery = SearchParser.Parse(searchQuery);
        UpdateAutocomplete();
        ApplyFilters();
        SyncUrlWithFilters();
    }

    private void UpdateAutocomplete()
    {
        autocompleteSuggestions.Clear();
        showAutocomplete = false;

        if (string.IsNullOrWhiteSpace(searchQuery)) return;

        var (filterType, partialValue) = SearchParser.DetectActiveFilter(searchQuery, searchQuery.Length);
        if (filterType == null) return;

        var partial = partialValue?.ToLower() ?? "";

        switch (filterType)
        {
            case "tag":
                autocompleteSuggestions = availableTags
                    .Where(t => string.IsNullOrEmpty(partial) || t.ToLower().Contains(partial))
                    .Take(10)
                    .Select(t => AutocompleteSuggestion.ForTag(t, allWords.Count(w =>
                        w.Word.Tags?.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                            .Any(tag => tag.Equals(t, StringComparison.OrdinalIgnoreCase)) == true)))
                    .ToList();
                break;

            case "resource":
                autocompleteSuggestions = availableResources
                    .Where(r => string.IsNullOrEmpty(partial) || (r.Title?.ToLower().Contains(partial) == true))
                    .Take(10)
                    .Select(r => AutocompleteSuggestion.ForResource(r.Title ?? "Unknown"))
                    .ToList();
                break;

            case "lemma":
                autocompleteSuggestions = availableLemmas
                    .Where(l => string.IsNullOrEmpty(partial) || l.ToLower().Contains(partial))
                    .Take(10)
                    .Select(l => AutocompleteSuggestion.ForLemma(l, allWords.Count(w =>
                        w.Word.Lemma?.Equals(l, StringComparison.OrdinalIgnoreCase) == true)))
                    .ToList();
                break;

            case "status":
                var statuses = new[] { ("known", "Known"), ("learning", "Learning"), ("unknown", "Unknown") };
                autocompleteSuggestions = statuses
                    .Where(s => string.IsNullOrEmpty(partial) || s.Item1.Contains(partial))
                    .Select(s => AutocompleteSuggestion.ForStatus(s.Item1, s.Item2))
                    .ToList();
                break;
        }

        showAutocomplete = autocompleteSuggestions.Count > 0;
    }

    private void AcceptSuggestion(AutocompleteSuggestion suggestion)
    {
        var value = suggestion.Value.Contains(' ') ? $"\"{suggestion.Value}\"" : suggestion.Value;
        searchQuery = SearchParser.InsertFilter(searchQuery, searchQuery.Length, suggestion.Type, suggestion.Value);
        showAutocomplete = false;
        parsedQuery = SearchParser.Parse(searchQuery);
        ApplyFilters();
    }

    private void RemoveFilter(FilterToken filter)
    {
        searchQuery = SearchParser.RemoveFilter(searchQuery, filter);
        parsedQuery = SearchParser.Parse(searchQuery);
        showAutocomplete = false;
        ApplyFilters();
    }

    private void OnAssociationDropdown(ChangeEventArgs e) => OnDropdownChanged("association", e);
    private void OnStatusDropdown(ChangeEventArgs e) => OnDropdownChanged("status", e);
    private void OnResourceDropdown(ChangeEventArgs e) => OnDropdownChanged("resource", e);
    private void OnTagDropdown(ChangeEventArgs e) => OnDropdownChanged("tag", e);
    private void OnLemmaDropdown(ChangeEventArgs e) => OnDropdownChanged("lemma", e);
    private void OnLanguageDropdown(ChangeEventArgs e) => OnDropdownChanged("language", e);
    private void OnEncodingDropdown(ChangeEventArgs e) => OnDropdownChanged("encoding", e);

    private void OnDropdownChanged(string filterType, ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";

        // Remove existing filter of this type
        var existing = parsedQuery?.Filters.FirstOrDefault(f => f.Type.Equals(filterType, StringComparison.OrdinalIgnoreCase));
        if (existing != null)
            searchQuery = SearchParser.RemoveFilter(searchQuery, existing);

        // Add new filter if a value was selected (not "All"/"")
        if (!string.IsNullOrEmpty(newValue))
        {
            var valueStr = newValue.Contains(' ') ? $"\"{newValue}\"" : newValue;
            searchQuery = (searchQuery.TrimEnd() + $" {filterType}:{valueStr}").Trim();
        }

        parsedQuery = SearchParser.Parse(searchQuery);
        showAutocomplete = false;
        ApplyFilters();
        SyncUrlWithFilters();
    }

    private void SyncUrlWithFilters()
    {
        var url = string.IsNullOrWhiteSpace(searchQuery)
            ? "/vocabulary"
            : $"/vocabulary?q={Uri.EscapeDataString(searchQuery)}";
        NavManager.NavigateTo(url, replace: true);
    }

    private void ApplyFilters()
    {
        var filtered = allWords.AsEnumerable();

        if (parsedQuery != null)
        {
            foreach (var filter in parsedQuery.Filters)
            {
                var val = filter.Value.ToLower();
                filtered = filter.Type.ToLower() switch
                {
                    "association" => val switch
                    {
                        "associated" => filtered.Where(v => v.AssociatedResources.Any()),
                        "orphaned" => filtered.Where(v => !v.AssociatedResources.Any()),
                        _ => filtered
                    },
                    "status" => val switch
                    {
                        "known" => filtered.Where(v => v.StatusText == "Known"),
                        "familiar" => filtered.Where(v => v.StatusText == "Familiar"),
                        "learning" => filtered.Where(v => v.StatusText == "Learning"),
                        "unknown" => filtered.Where(v => v.StatusText == "Unknown"),
                        _ => filtered
                    },
                    "tag" => filtered.Where(v =>
                        v.Word.Tags != null &&
                        v.Word.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                            .Any(t => t.Equals(filter.Value, StringComparison.OrdinalIgnoreCase))),
                    "resource" => filtered.Where(v =>
                        v.AssociatedResources.Any(r =>
                            r.Title != null && r.Title.Equals(filter.Value, StringComparison.OrdinalIgnoreCase))),
                    "lemma" => filtered.Where(v =>
                        v.Word.Lemma != null &&
                        v.Word.Lemma.Equals(filter.Value, StringComparison.OrdinalIgnoreCase)),
                    "language" => filtered.Where(v =>
                        v.AssociatedResources.Any(r =>
                            r.Language != null && r.Language.Equals(filter.Value, StringComparison.OrdinalIgnoreCase))),
                    "encoding" => filtered.Where(v =>
                        v.EncodingLabel.Equals(filter.Value, StringComparison.OrdinalIgnoreCase)),
                    _ => filtered
                };
            }

            // Free text search (non-filter terms)
            foreach (var term in parsedQuery.FreeTextTerms)
            {
                var search = term.ToLower();
                filtered = filtered.Where(v =>
                    (v.Word.TargetLanguageTerm?.ToLower().Contains(search) == true) ||
                    (v.Word.NativeLanguageTerm?.ToLower().Contains(search) == true) ||
                    (v.Word.Tags?.ToLower().Contains(search) == true) ||
                    (v.Word.Lemma?.ToLower().Contains(search) == true));
            }
        }

        filteredWords = filtered.ToList();

        statUnknown = filteredWords.Count(w => w.StatusText == "Unknown");
        statLearning = filteredWords.Count(w => w.StatusText == "Learning");
        statFamiliar = filteredWords.Count(w => w.StatusText == "Familiar");
        statKnown = filteredWords.Count(w => w.StatusText == "Known");
    }

