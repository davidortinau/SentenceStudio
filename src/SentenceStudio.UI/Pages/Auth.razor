@page "/auth"

<PageHeader Title="Welcome" />

<div class="container" style="max-width: 600px;">
    <div class="card card-ss p-4 mt-4">
        <h1 class="ss-title1 mb-2">Welcome to SentenceStudio</h1>
        <p class="ss-body2 text-secondary-ss mb-4">
            Sign in to your account or select a local user to continue.
        </p>

        <div class="d-grid gap-2 mb-4">
            <a href="/auth/login" class="btn btn-ss-primary btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </a>
            <a href="/auth/register" class="btn btn-ss-secondary btn-lg">
                <i class="bi bi-person-plus me-2"></i>Create Account
            </a>
        </div>

        @if (_profiles.Count > 0)
        {
            <hr class="my-3" />
            <h2 class="ss-title3 mb-2">Or choose a local user</h2>
            <div class="d-grid gap-2 mb-3">
                @foreach (var profile in _profiles)
                {
                    var p = profile;
                    <div class="d-flex gap-2 align-items-stretch">
                        <button class="btn btn-ss-secondary btn-lg text-start d-flex align-items-center gap-2 flex-grow-1"
                                @onclick="() => LoginAsAsync(p)">
                            <i class="bi bi-person-circle"></i>
                            <div>
                                <strong>@p.Name</strong>
                                <br />
                                <small class="text-secondary-ss">@p.NativeLanguage &rarr; @p.TargetLanguage</small>
                            </div>
                        </button>
                        <button class="btn btn-outline-danger d-flex align-items-center"
                                title="Delete profile"
                                @onclick="() => DeleteProfileAsync(p)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
            </div>
        }

        <div class="d-grid gap-2">
            <button class="btn btn-outline-secondary btn-lg" @onclick="RegisterLocalAsync">
                <i class="bi bi-plus-circle me-2"></i>Create Local User
            </button>
        </div>
    </div>
</div>

@code {
    public const string AuthenticatedPreferenceKey = "app_is_authenticated";
    public const string ActiveProfileIdKey = "active_profile_id";

    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private UserProfileRepository ProfileRepo { get; set; } = default!;
    [Inject] private IAppState AppState { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ILogger<Auth> Logger { get; set; } = default!;
    [Inject] private IServiceProvider ServiceProvider { get; set; } = default!;

    private List<UserProfile> _profiles = new();

    protected override async Task OnInitializedAsync()
    {
        await ProfileRepo.EnsureMultiUserBackfillAsync();
        _profiles = await ProfileRepo.ListAsync() ?? new();
    }

    private void LoginAsAsync(UserProfile profile)
    {
        Preferences.Set(AuthenticatedPreferenceKey, true);
        Preferences.Set(ActiveProfileIdKey, profile.Id);
        Preferences.Set("is_onboarded", true);
        AppState.CurrentUserProfile = profile;
        NavManager.NavigateTo("/", forceLoad: true);
    }

    private async Task DeleteProfileAsync(UserProfile profile)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Delete profile \"{profile.Name}\"? This removes the user and all associated data. This cannot be undone.");
        if (!confirmed) return;

        try
        {
            // Try to delete the associated Identity user (WebApp only)
            try
            {
                var userManager = ServiceProvider.GetService<Microsoft.AspNetCore.Identity.UserManager<SentenceStudio.Shared.Models.ApplicationUser>>();
                if (userManager is not null)
                {
                    var users = userManager.Users.Where(u => u.UserProfileId == profile.Id).ToList();
                    foreach (var user in users)
                    {
                        await userManager.DeleteAsync(user);
                        Logger.LogInformation("Deleted Identity user {Email} for profile {Id}", user.Email, profile.Id);
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Could not delete Identity user for profile {Id} (may not exist or not in WebApp context)", profile.Id);
            }

            await ProfileRepo.DeleteAsync(profile);

            // Clear active profile if this was the selected one
            var activeId = Preferences.Get("active_profile_id", string.Empty);
            if (activeId == profile.Id)
            {
                Preferences.Remove("active_profile_id");
                Preferences.Remove("app_is_authenticated");
            }

            _profiles.Remove(profile);
            Logger.LogInformation("Deleted profile {Name} ({Id})", profile.Name, profile.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete profile {Id}", profile.Id);
        }
    }

    private void RegisterLocalAsync()
    {
        Preferences.Set(AuthenticatedPreferenceKey, true);
        Preferences.Set("is_onboarded", false);
        NavManager.NavigateTo("/onboarding");
    }
}
