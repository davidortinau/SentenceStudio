@page "/auth"

<PageHeader Title="Welcome" />

<div class="container" style="max-width: 600px;">
    <div class="card card-ss p-4 mt-4">
        <h1 class="ss-title1 mb-2">Welcome to SentenceStudio</h1>
        <p class="ss-body2 text-secondary-ss mb-4">
            Sign in to your account or select a local user to continue.
        </p>

        <div class="d-grid gap-2 mb-4">
            <a href="/auth/login" class="btn btn-ss-primary btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </a>
            <a href="/auth/register" class="btn btn-ss-secondary btn-lg">
                <i class="bi bi-person-plus me-2"></i>Create Account
            </a>
        </div>

        @if (_profiles.Count > 0)
        {
            <hr class="my-3" />
            <h2 class="ss-title3 mb-2">Or choose a local user</h2>
            <div class="d-grid gap-2 mb-3">
                @foreach (var profile in _profiles)
                {
                    var p = profile;
                    <div class="d-flex gap-2 align-items-stretch">
                        <button class="btn btn-ss-secondary btn-lg text-start d-flex align-items-center gap-2 flex-grow-1"
                                @onclick="() => LoginAsAsync(p)">
                            <i class="bi bi-person-circle"></i>
                            <div>
                                <strong>@p.Name</strong>
                                <br />
                                <small class="text-secondary-ss">@p.NativeLanguage &rarr; @p.TargetLanguage</small>
                            </div>
                        </button>
                        <button class="btn btn-outline-danger d-flex align-items-center"
                                title="Delete profile"
                                @onclick="() => RequestDelete(p)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                }
            </div>
        }

        <div class="d-grid gap-2">
            <button class="btn btn-outline-secondary btn-lg" @onclick="RegisterLocalAsync">
                <i class="bi bi-plus-circle me-2"></i>Create Local User
            </button>
        </div>
    </div>
</div>

@if (showDeleteConfirm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content bg-surface">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-error-ss">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="ss-body2">@deleteConfirmMessage</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-ss-secondary" @onclick="CancelDelete">Cancel</button>
                    <button type="button" class="btn btn-ss-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public const string AuthenticatedPreferenceKey = "app_is_authenticated";
    public const string ActiveProfileIdKey = "active_profile_id";

    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private UserProfileRepository ProfileRepo { get; set; } = default!;
    [Inject] private IAppState AppState { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ILogger<Auth> Logger { get; set; } = default!;
    [Inject] private IServiceProvider ServiceProvider { get; set; } = default!;

    private List<UserProfile> _profiles = new();
    private bool showDeleteConfirm;
    private string deleteConfirmMessage = "";
    private bool isDeleting;
    private UserProfile? profileToDelete;

    protected override async Task OnInitializedAsync()
    {
        await ProfileRepo.EnsureMultiUserBackfillAsync();
        _profiles = await ProfileRepo.ListAsync() ?? new();
    }

    private void LoginAsAsync(UserProfile profile)
    {
        Preferences.Set(AuthenticatedPreferenceKey, true);
        Preferences.Set(ActiveProfileIdKey, profile.Id);
        Preferences.Set("is_onboarded", true);
        AppState.CurrentUserProfile = profile;
        NavManager.NavigateTo("/", forceLoad: true);
    }

    private void RequestDelete(UserProfile profile)
    {
        profileToDelete = profile;
        deleteConfirmMessage = $"Are you sure you want to delete profile \"{profile.Name}\"? This removes the user and all associated data. This cannot be undone.";
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        profileToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (profileToDelete == null) return;
        
        isDeleting = true;
        try
        {
            // Try to delete the associated Identity user (WebApp only).
            // Uses reflection to avoid compile-time dependency on ASP.NET Identity
            // which is unavailable on mobile platforms.
            try
            {
                var appUserType = typeof(SentenceStudio.Shared.Models.ApplicationUser);
                var userManagerOpenType = Type.GetType("Microsoft.AspNetCore.Identity.UserManager`1, Microsoft.Extensions.Identity.Core");
                if (userManagerOpenType is not null)
                {
                    var userManagerType = userManagerOpenType.MakeGenericType(appUserType);
                    var userManager = ServiceProvider.GetService(userManagerType);
                    if (userManager is not null)
                    {
                        // Get Users property → filter by UserProfileId → delete each
                        var usersProp = userManagerType.GetProperty("Users");
                        if (usersProp?.GetValue(userManager) is IQueryable<SentenceStudio.Shared.Models.ApplicationUser> users)
                        {
                            var matches = users.Where(u => u.UserProfileId == profileToDelete.Id).ToList();
                            var deleteMethod = userManagerType.GetMethod("DeleteAsync", [appUserType]);
                            foreach (var user in matches)
                            {
                                if (deleteMethod is not null)
                                    await (Task)deleteMethod.Invoke(userManager, [user])!;
                                Logger.LogInformation("Deleted Identity user {Email} for profile {Id}", user.Email, profileToDelete.Id);
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Could not delete Identity user for profile {Id} (may not exist or not in WebApp context)", profileToDelete.Id);
            }

            await ProfileRepo.DeleteAsync(profileToDelete);

            // Clear active profile if this was the selected one
            var activeId = Preferences.Get("active_profile_id", string.Empty);
            if (activeId == profileToDelete.Id)
            {
                Preferences.Remove("active_profile_id");
                Preferences.Remove("app_is_authenticated");
            }

            _profiles.Remove(profileToDelete);
            Logger.LogInformation("Deleted profile {Name} ({Id})", profileToDelete.Name, profileToDelete.Id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to delete profile {Id}", profileToDelete?.Id);
        }
        finally
        {
            isDeleting = false;
            showDeleteConfirm = false;
            profileToDelete = null;
        }
    }

    private void RegisterLocalAsync()
    {
        Preferences.Set(AuthenticatedPreferenceKey, true);
        Preferences.Set("is_onboarded", false);
        NavManager.NavigateTo("/onboarding");
    }
}
