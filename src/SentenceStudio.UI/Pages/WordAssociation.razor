@page "/word-association"
@attribute [Authorize]

<div class="activity-page-wrapper">

<PageHeader Title="Word Association" ShowBack="true" OnBack="GoBack" />

<div class="activity-content">
@if (showSessionSummary)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
        <h2 class="ss-title1 mb-4"><i class="bi bi-trophy me-2"></i>Round Complete!</h2>
        <div class="card card-ss p-4" style="min-width: 340px;">
            <div class="d-flex justify-content-around mb-3">
                <div class="text-center">
                    <div class="ss-title2 text-success">@totalRelated</div>
                    <small class="text-secondary-ss">Related</small>
                </div>
                <div class="text-center">
                    <div class="ss-title2 text-danger">@(totalClueCount - totalRelated)</div>
                    <small class="text-secondary-ss">Not Related</small>
                </div>
                <div class="text-center">
                    <div class="ss-title2" style="color: var(--bs-primary);">@totalScore</div>
                    <small class="text-secondary-ss">Score</small>
                </div>
            </div>
        </div>

        @if (highScoreType == "alltime")
        {
            <div class="alert alert-success mt-3 text-center">
                <i class="bi bi-star-fill me-1"></i> NEW ALL-TIME HIGH SCORE!
            </div>
        }
        else if (highScoreType == "weekly")
        {
            <div class="alert alert-info mt-3 text-center">
                <i class="bi bi-calendar-star me-1"></i> Best score this week!
            </div>
        }

        <button class="btn btn-ss-primary mt-4" @onclick="PlayAgain">Play Again</button>
        <button class="btn btn-ss-secondary mt-2" @onclick="GoBack">Done</button>
    </div>
}
else if (isBusy)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 40vh;">
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <p class="ss-body1 text-secondary-ss">Loading vocabulary...</p>
    </div>
}
else if (words.Any())
{
    <div class="mb-4 px-3">
        <p class="ss-body2 text-secondary-ss mb-1">Word @(currentWordIndex + 1) of @words.Count</p>
        <p class="ss-display" style="line-height: 1.3;">@currentWord?.TargetLanguageTerm</p>
        @if (!string.IsNullOrEmpty(currentWord?.NativeLanguageTerm))
        {
            <p class="ss-body1 text-secondary-ss mt-1">@currentWord.NativeLanguageTerm</p>
        }
    </div>

    @* Clue list *@
    <div class="px-3">
        @if (currentClues.Count == 0 && !isGrading)
        {
            <p class="ss-body2 text-secondary-ss fst-italic">
                Write clues related to this word — synonyms, categories, sentences, anything connected!
                <br /><small class="text-secondary-ss">Each related clue earns 1 point. Full sentences earn 2 points.</small>
            </p>
        }

        @foreach (var clue in currentClues)
        {
            <div class="d-flex align-items-start gap-2 mb-2">
                @if (clue.Graded)
                {
                    <span class="badge @(clue.Related ? "bg-success" : "bg-danger") mt-1">
                        @if (clue.Related)
                        {<i class="bi bi-check-circle-fill"></i>}
                        else
                        {<i class="bi bi-x-circle-fill"></i>}
                    </span>
                    <div class="flex-grow-1">
                        <span class="ss-body1">@clue.Text</span>
                        @if (clue.IsCloze && clue.Related)
                        {
                            <span class="badge bg-info ms-1">2x</span>
                        }
                        @if (!string.IsNullOrEmpty(clue.Explanation))
                        {
                            <br /><small class="text-secondary-ss">@clue.Explanation</small>
                        }
                        @if (!string.IsNullOrEmpty(clue.CorrectedText) && clue.CorrectedText != clue.Text)
                        {
                            <br /><small class="text-muted fst-italic">(Corrected: @clue.CorrectedText)</small>
                        }
                    </div>
                }
                else
                {
                    <span class="badge bg-secondary mt-1"><i class="bi bi-clock"></i></span>
                    <span class="ss-body1 flex-grow-1">@clue.Text</span>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveClue(clue)">
                        <i class="bi bi-x"></i>
                    </button>
                }
            </div>
        }

        @if (isGrading)
        {
            <div class="d-flex align-items-center gap-2 mt-2">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span class="ss-body2 text-secondary-ss">Grading clues...</span>
            </div>
        }

        @if (currentClues.Any(c => c.Graded))
        {
            var wordScore = currentClues.Where(c => c.Graded).Sum(c => c.Related ? (c.IsCloze ? 2 : 1) : 0);
            var wordMax = currentClues.Where(c => c.Graded).Sum(c => c.IsCloze ? 2 : 1);
            <div class="mt-3 ss-body1-strong">
                Word score: @wordScore of @wordMax possible points
            </div>
        }
    </div>
}
else
{
    <div class="text-center p-5">
        <p class="ss-body1 text-secondary-ss">No vocabulary available. Select a Learning Resource first.</p>
        <button class="btn btn-ss-secondary mt-3" @onclick="GoBack">Go Back</button>
    </div>
}
</div>

@if (words.Any() && !showSessionSummary && !isBusy)
{
<div class="activity-input-bar">
    <form @onsubmit="AddClue" @onsubmit:preventDefault class="d-flex gap-2 mb-2">
        <input type="text" class="form-control form-control-ss form-control-lg flex-grow-1"
               @bind="userInput"
               @bind:event="oninput"
               disabled="@isGrading"
               placeholder="Type a clue, word, or sentence..." />
        <button type="submit" class="btn btn-ss-primary">
            <i class="bi bi-plus-lg"></i>
        </button>
    </form>

    @if (currentClues.Any(c => !c.Graded))
    {
        <div class="d-flex justify-content-center mb-2">
            <button class="btn btn-ss-primary w-100" @onclick="GradeCurrentWord" disabled="@isGrading">
                <i class="bi bi-check2-all me-1"></i> Grade Clues
            </button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center">
        <button class="btn btn-sm btn-ss-secondary" @onclick="PreviousWord" disabled="@(currentWordIndex <= 0 || isGrading)">
            <i class="bi bi-chevron-left"></i>
        </button>
        <span class="ss-body2 text-secondary-ss">@(currentWordIndex + 1) / @words.Count</span>
        @if (currentWordIndex < words.Count - 1)
        {
            <button class="btn btn-sm btn-ss-secondary" @onclick="NextWord" disabled="@(isGrading || currentClues.Any(c => !c.Graded))">
                Next <i class="bi bi-chevron-right"></i>
            </button>
        }
        else
        {
            <button class="btn btn-sm btn-ss-primary" @onclick="FinishRound" disabled="@(isGrading || currentClues.Any(c => !c.Graded))">
                Finish Round
            </button>
        }
    </div>
</div>
}

</div>

@code {
    [SupplyParameterFromQuery(Name = "resourceId")]
    public string? ResourceIdParam { get; set; }

    [SupplyParameterFromQuery(Name = "resourceIds")]
    public string? ResourceIdsParam { get; set; }

    [SupplyParameterFromQuery(Name = "skillId")]
    public string? SkillIdParam { get; set; }

    [Inject] private WordAssociationService WordAssocSvc { get; set; } = default!;
    [Inject] private UserActivityRepository ActivityRepo { get; set; } = default!;
    [Inject] private VocabularyProgressService ProgressService { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private ILogger<WordAssociation> Logger { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Progress.ProgressCacheService CacheService { get; set; } = default!;

    private bool isBusy;
    private bool isGrading;
    private bool showSessionSummary;
    private string userInput = "";
    private int currentWordIndex;
    private string? highScoreType;

    private List<VocabularyWord> words = new();
    private VocabularyWord? currentWord => currentWordIndex < words.Count ? words[currentWordIndex] : null;

    // Per-word clue storage: wordIndex → list of clues
    private Dictionary<int, List<ClueEntry>> allClues = new();
    private List<ClueEntry> currentClues => allClues.TryGetValue(currentWordIndex, out var list) ? list : new();

    // Round totals (computed after finish)
    private int totalScore;
    private int totalRelated;
    private int totalClueCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadWords();
    }

    private async Task LoadWords()
    {
        isBusy = true;
        try
        {
            var resourceIds = ResourceIdsParam ?? ResourceIdParam ?? "";
            words = await WordAssocSvc.GetRoundWordsAsync(resourceIds, 5);

            if (words.Any())
            {
                currentWordIndex = 0;
                allClues.Clear();
                for (int i = 0; i < words.Count; i++)
                    allClues[i] = new List<ClueEntry>();
            }
            else
            {
                Toast.ShowWarning("No vocabulary found in selected resources.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading vocabulary words");
            Toast.ShowError($"Error: {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private void AddClue()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isGrading) return;

        if (!allClues.ContainsKey(currentWordIndex))
            allClues[currentWordIndex] = new List<ClueEntry>();

        allClues[currentWordIndex].Add(new ClueEntry { Text = userInput.Trim() });
        userInput = "";
    }

    private void RemoveClue(ClueEntry clue)
    {
        if (allClues.TryGetValue(currentWordIndex, out var list))
            list.Remove(clue);
    }

    private async Task GradeCurrentWord()
    {
        var clues = currentClues.Where(c => !c.Graded).ToList();
        if (clues.Count == 0) return;

        isGrading = true;
        StateHasChanged();

        try
        {
            var userId = Preferences.Get("active_profile_id", "");
            var nativeLanguage = Preferences.Get("native_language", "English");
            var targetLanguage = Preferences.Get("target_language", "Korean");

            var clueTexts = clues.Select(c => c.Text).ToList();
            var result = await WordAssocSvc.GradeCluesAsync(currentWord!, clueTexts, nativeLanguage, targetLanguage);

            // Apply grades
            for (int i = 0; i < clues.Count && i < result.Entries.Count; i++)
            {
                clues[i].Graded = true;
                clues[i].Related = result.Entries[i].Related;
                clues[i].IsCloze = result.Entries[i].IsCloze;
                clues[i].Explanation = result.Entries[i].Explanation;
                clues[i].CorrectedText = result.Entries[i].CorrectedText;
            }

            // Record vocabulary progress
            if (currentWord != null)
            {
                var relatedCount = currentClues.Count(c => c.Graded && c.Related);
                var totalCount = currentClues.Count(c => c.Graded);
                var wasCorrect = totalCount > 0 && (float)relatedCount / totalCount >= 0.5f;

                var updatedProgress = await ProgressService.RecordAttemptAsync(new VocabularyAttempt
                {
                    VocabularyWordId = currentWord.Id,
                    UserId = userId,
                    Activity = "WordAssociation",
                    InputMode = "Text",
                    WasCorrect = wasCorrect,
                    DifficultyWeight = 1.0f,
                    ContextType = "Association"
                });

                // Handle verification probe for Familiar words
                if (updatedProgress.IsFamiliar)
                {
                    await ProgressService.HandleVerificationProbeResultAsync(
                        currentWord.Id, userId, wasCorrect);
                    if (wasCorrect)
                        Toast.ShowSuccess("Confirmed! This one is solid.");
                    else
                        Toast.ShowInfo("This one is tricky in context. A few more reps will help.");
                }

                CacheService.InvalidateVocabSummary();
            }

            // Record user activity
            var activity = new UserActivity
            {
                Activity = "WordAssociation",
                Input = string.Join("; ", clueTexts),
                Accuracy = currentClues.Count(c => c.Graded) > 0
                    ? (double)currentClues.Count(c => c.Graded && c.Related) / currentClues.Count(c => c.Graded) * 100
                    : 0,
                CreatedAt = DateTime.Now,
                UpdatedAt = DateTime.Now
            };
            await ActivityRepo.SaveAsync(activity);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error grading clues");
            Toast.ShowError("Error grading clues. Please try again.");
        }
        finally
        {
            isGrading = false;
            StateHasChanged();
        }
    }

    private async Task NextWord()
    {
        if (currentWordIndex < words.Count - 1)
        {
            currentWordIndex++;
            userInput = "";
        }
    }

    private async Task PreviousWord()
    {
        if (currentWordIndex > 0)
        {
            currentWordIndex--;
            userInput = "";
        }
    }

    private async Task FinishRound()
    {
        // Grade any remaining ungraded clues
        if (currentClues.Any(c => !c.Graded))
            await GradeCurrentWord();

        // Calculate totals across all words
        totalScore = 0;
        totalRelated = 0;
        totalClueCount = 0;

        foreach (var (_, clues) in allClues)
        {
            foreach (var c in clues.Where(c => c.Graded))
            {
                totalClueCount++;
                if (c.Related)
                {
                    totalRelated++;
                    totalScore += c.IsCloze ? 2 : 1;
                }
            }
        }

        // Save score and check for high scores
        var userId = Preferences.Get("active_profile_id", "");
        var wordIds = words.Select(w => w.Id).ToList();

        // Check high score BEFORE saving (so we compare against previous scores)
        highScoreType = await WordAssocSvc.CheckHighScoreAsync(userId, totalScore);

        await WordAssocSvc.SaveRoundScoreAsync(userId, totalScore, totalClueCount, wordIds);

        showSessionSummary = true;
    }

    private async Task PlayAgain()
    {
        showSessionSummary = false;
        highScoreType = null;
        totalScore = 0;
        totalRelated = 0;
        totalClueCount = 0;
        userInput = "";
        await LoadWords();
    }

    private void GoBack() => NavManager.NavigateTo("/");

    private class ClueEntry
    {
        public string Text { get; set; } = "";
        public bool Graded { get; set; }
        public bool Related { get; set; }
        public bool IsCloze { get; set; }
        public string? Explanation { get; set; }
        public string? CorrectedText { get; set; }
    }
}
