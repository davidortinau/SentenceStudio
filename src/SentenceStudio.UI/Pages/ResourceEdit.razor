    private async Task ImportVocabulary()
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource)
        {
            Logger.LogWarning("Attempt to import vocabulary into smart resource {ResourceId} blocked", resource.Id);
            return;
        }

        if (string.IsNullOrWhiteSpace(vocabList))
            return;

        try
        {
            using var mutation = ResourceVocabularyMutation.Begin(resource);
            var newWords = VocabularyWord.ParseVocabularyWords(vocabList, delimiter);
            resource.Vocabulary ??= new List<VocabularyWord>();

            int added = 0;
            foreach (var word in newWords)
            {
                bool isDuplicate = resource.Vocabulary.Any(existing =>
                    existing.TargetLanguageTerm?.Trim().Equals(word.TargetLanguageTerm?.Trim(), StringComparison.OrdinalIgnoreCase) == true);

                if (!isDuplicate)
                {
                    var dbWord = await GetOrCreateWordAsync(
                        word.TargetLanguageTerm?.Trim() ?? "",
                        word.NativeLanguageTerm?.Trim() ?? "");
                    resource.Vocabulary.Add(dbWord);
                    added++;
                }
            }

            // Persist the resource-vocabulary mappings
            var outcome = mutation.Accept(await ResourceRepo.SaveResourceAsync(resource));
            if (!outcome.Succeeded)
            {
                Toast.ShowError($"{string.Format(Localize["ResourceEdit_ImportFailed"], Localize["ResourceEdit_NotFound"])}");
                return;
            }

            vocabList = "";
            Toast.ShowSuccess($"{string.Format(Localize["ResourceEdit_ImportedCount"], added)}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ImportVocabulary error");
            Toast.ShowError($"{string.Format(Localize["ResourceEdit_ImportFailed"], ex.Message)}");
        }
    }

    private async Task HandleFileImport(InputFileChangeEventArgs e)
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource)
        {
            Logger.LogWarning("Attempt to import file into smart resource {ResourceId} blocked", resource.Id);
            return;
        }

        var file = e.File;
        if (file is null) return;

        isImportingFile = true;
        fileImportStatus = "";
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1_048_576);
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            if (string.IsNullOrWhiteSpace(content))
            {
                Toast.ShowError($"{Localize["ResourceEdit_FileEmpty"]}");
                return;
            }

            var newWords = VocabularyWord.ParseVocabularyWords(content, delimiter);
            using var mutation = ResourceVocabularyMutation.Begin(resource);
            resource.Vocabulary ??= new List<VocabularyWord>();

            int added = 0;
            foreach (var word in newWords)
            {
                bool isDuplicate = resource.Vocabulary.Any(existing =>
                    existing.TargetLanguageTerm?.Trim().Equals(word.TargetLanguageTerm?.Trim(), StringComparison.OrdinalIgnoreCase) == true);

                if (!isDuplicate)
                {
                    var dbWord = await GetOrCreateWordAsync(
                        word.TargetLanguageTerm?.Trim() ?? "",
                        word.NativeLanguageTerm?.Trim() ?? "");
                    resource.Vocabulary.Add(dbWord);
                    added++;
                }
            }

            if (added > 0)
            {
                var outcome = mutation.Accept(await ResourceRepo.SaveResourceAsync(resource));
                if (!outcome.Succeeded)
                {
                    Toast.ShowError($"{string.Format(Localize["ResourceEdit_FileImportFailed"], Localize["ResourceEdit_NotFound"])}");
                    return;
                }
                fileImportStatus = $"{string.Format(Localize["ResourceEdit_FileImportStatus"], added, file.Name)}";
                Toast.ShowSuccess($"{string.Format(Localize["ResourceEdit_ImportedFromFile"], added)}");
            }
            else
            {
                Toast.ShowInfo($"{Localize["ResourceEdit_NoDuplicatesInFile"]}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "HandleFileImport error");
            Toast.ShowError($"{string.Format(Localize["ResourceEdit_FileImportFailed"], ex.Message)}");
        }
        finally
        {
            isImportingFile = false;
        }
    }

    private async Task GenerateVocabulary()
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource)
        {
            Logger.LogWarning("Attempt to generate vocabulary for smart resource {ResourceId} blocked", resource.Id);
            return;
        }

        if (string.IsNullOrWhiteSpace(resource.Transcript))
        {
            Toast.ShowError($"{Localize["ResourceEdit_NoTranscript"]}");
            return;
        }

        isGeneratingVocabulary = true;
        StateHasChanged();

        try
        {
            var profile = await ProfileRepo.GetAsync();
            var targetLanguage = !string.IsNullOrWhiteSpace(resource.Language)
                ? resource.Language
                : profile?.TargetLanguage ?? "Korean";
            var nativeLanguage = profile?.NativeLanguage ?? "English";

            string prompt = $@"Extract all {targetLanguage} vocabulary from this transcript for a language learner.
Return a JSON array where each object has:
- ""TargetLanguageTerm"" ({targetLanguage}, dictionary form)
- ""NativeLanguageTerm"" ({nativeLanguage} translation)
- ""Lemma"" (the dictionary root form in {targetLanguage}, e.g. 주문하다 → 주문, 대학교 때 → 대학교)
- ""Language"" (the language of the term, usually ""{targetLanguage}"" but use the actual language if a term is borrowed or mixed)

Include nouns, verbs, adjectives, adverbs, and useful expressions.

Transcript:
{resource.Transcript}
";

            Logger.LogDebug("Generating vocabulary for {Language} transcript ({Length} chars)", targetLanguage, resource.Transcript.Length);

            var vocabulary = await AiSvc.SendPrompt<List<VocabularyWord>>(prompt);

            if (vocabulary == null || !vocabulary.Any())
            {
                Toast.ShowError($"{Localize["ResourceEdit_GenerateFailed"]}");
                return;
            }

            Logger.LogDebug("AI returned {Count} vocabulary words", vocabulary.Count);

            resource.Vocabulary ??= new List<VocabularyWord>();
            using var mutation = ResourceVocabularyMutation.Begin(resource);
            int newWordsCreated = 0;
            int existingWordsLinked = 0;
            int duplicatesSkipped = 0;

            foreach (var wordData in vocabulary)
            {
                if (string.IsNullOrWhiteSpace(wordData.TargetLanguageTerm))
                    continue;

                var targetTerm = wordData.TargetLanguageTerm.Trim();
                var nativeTerm = wordData.NativeLanguageTerm?.Trim() ?? "";

                // Detect swapped terms — only for non-Latin-script target languages
                // (e.g., Korean, Japanese, Chinese, Arabic). For Latin-script targets
                // (Spanish, French, German, etc.) both terms are Latin, so trust the AI.
                if (!IsLatinScriptLanguage(targetLanguage))
                {
                    bool targetIsLatin = IsLikelyLatinScript(targetTerm);
                    bool nativeIsLatin = IsLikelyLatinScript(nativeTerm);

                    if (targetIsLatin && !nativeIsLatin)
                        (targetTerm, nativeTerm) = (nativeTerm, targetTerm);
                    else if (targetIsLatin && nativeIsLatin)
                        continue;
                }

                // Skip if already in resource
                if (resource.Vocabulary.Any(w =>
                    w.TargetLanguageTerm?.Trim().Equals(targetTerm, StringComparison.OrdinalIgnoreCase) == true))
                {
                    duplicatesSkipped++;
                    continue;
                }

                try
                {
                    var word = await GetOrCreateWordAsync(targetTerm, nativeTerm, wordData.Lemma?.Trim(), wordData.Language?.Trim() ?? targetLanguage);
                    resource.Vocabulary.Add(word);

                    if ((DateTime.UtcNow - word.CreatedAt).TotalSeconds < 5)
                        newWordsCreated++;
                    else
                        existingWordsLinked++;
                }
                catch (Exception ex)
                {
                    Logger.LogError(ex, "Error processing word '{Term}'", targetTerm);
                }
            }

            // Save resource with new vocabulary associations
            var outcome = mutation.Accept(await ResourceRepo.SaveResourceAsync(resource));
            if (!outcome.Succeeded)
            {
                Toast.ShowError($"{Localize["ResourceEdit_GenerateFailed"]}");
                return;
            }

            var msg = $"{string.Format(Localize["ResourceEdit_GenerateSuccess"], vocabulary.Count, newWordsCreated, existingWordsLinked)}";
            if (duplicatesSkipped > 0)
                msg += $", {string.Format(Localize["ResourceEdit_SkippedDuplicates"], duplicatesSkipped)}";
            Toast.ShowSuccess(msg);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "GenerateVocabulary error");
            Toast.ShowError($"{string.Format(Localize["ResourceEdit_GenerateFailed"], ex.Message)}");
        }
        finally
        {
            isGeneratingVocabulary = false;
        }
    }

    private async Task<VocabularyWord> GetOrCreateWordAsync(string targetTerm, string nativeTerm, string? lemma = null, string? language = null)
    {
        var existing = await ResourceRepo.GetWordByTargetTermAsync(targetTerm);
        if (existing != null)
        {
            bool changed = false;
            // Backfill lemma if the existing word doesn't have one
            if (!string.IsNullOrWhiteSpace(lemma) && string.IsNullOrWhiteSpace(existing.Lemma))
            {
                existing.Lemma = lemma;
                changed = true;
            }
            // Backfill language if the existing word doesn't have one
            if (!string.IsNullOrWhiteSpace(language) && string.IsNullOrWhiteSpace(existing.Language))
            {
                existing.Language = language;
                changed = true;
            }
            if (changed)
            {
                existing.UpdatedAt = DateTime.UtcNow;
                await ResourceRepo.SaveWordAsync(existing);
            }
            return existing;
        }

        var word = new VocabularyWord
        {
            TargetLanguageTerm = targetTerm,
            NativeLanguageTerm = nativeTerm,
            Lemma = lemma,
            Language = language,
            CreatedAt = DateTime.UtcNow,
            UpdatedAt = DateTime.UtcNow
        };

        var result = await ResourceRepo.SaveWordAsync(word);
        if (result <= 0)
            throw new Exception($"Failed to save word: {targetTerm}");

        return word;
    }

    private static bool IsLikelyLatinScript(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return false;
        int latinCount = 0, totalLetters = 0;
        foreach (char c in text)
        {
            if (char.IsLetter(c))
            {
                totalLetters++;
                if ((c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') ||
                    (c >= '\u00C0' && c <= '\u024F')) // Latin Extended (accented chars)
                    latinCount++;
            }
        }
        return totalLetters > 0 && (latinCount / (double)totalLetters) > 0.8;
    }

    private static bool IsLatinScriptLanguage(string language)
    {
        var latinLanguages = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "English", "Spanish", "French", "German", "Italian", "Portuguese",
            "Dutch", "Swedish", "Norwegian", "Danish", "Finnish",
            "Polish", "Czech", "Romanian", "Hungarian", "Turkish",
            "Vietnamese", "Indonesian", "Malay", "Tagalog", "Swahili"
        };
        // Normalize: strip parenthetical suffixes like "(auto-generated)"
        var normalized = language;
        var parenIndex = language.IndexOf('(');
        if (parenIndex > 0)
            normalized = language[..parenIndex].Trim();
        return latinLanguages.Contains(normalized);
    }

