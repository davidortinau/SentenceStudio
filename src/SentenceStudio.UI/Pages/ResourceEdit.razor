@page "/resources/edit/{Id}"
@attribute [Authorize]
@using SentenceStudio.Services
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (resource is null)
{
    <div class="alert alert-warning" role="alert">
        <i class="bi bi-exclamation-triangle me-2" aria-hidden="true"></i>@Localize["ResourceEdit_NotFound"]
    </div>
    <button class="btn btn-ss-secondary" @onclick="GoBack">@Localize["Common_Back"]</button>
}
else
{
    <PageHeader Title="@(resource.Title ?? "Resource")" ShowBack="true" OnBack="GoBack">
        <PrimaryActions>
            @if (!resource.IsSmartResource)
            {
                <button class="btn btn-ss-primary" @onclick="SaveResource" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    @Localize["Common_Save"]
                </button>
            }
        </PrimaryActions>
        <SecondaryActions>
            @if (!resource.IsSmartResource)
            {
                <li><button class="dropdown-item" @onclick="SaveResource" disabled="@isSaving"><i class="bi bi-check-lg me-2"></i>@Localize["Common_Save"]</button></li>
                <li><hr class="dropdown-divider" /></li>
                <li><button class="dropdown-item text-danger" @onclick="RequestDelete"><i class="bi bi-trash me-2"></i>@Localize["Common_Delete"]</button></li>
            }
        </SecondaryActions>
    </PageHeader>

    @if (resource.IsSmartResource)
    {
        <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-robot"></i>
            <strong>@Localize["ResourceEdit_SmartResource"]</strong>
            <span class="text-secondary-ss">@Localize["ResourceEdit_AutoUpdated"]</span>
        </div>
    }

    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["ResourceEdit_BasicInfo"]</h5>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_Title"]</label>
            <input type="text" class="form-control form-control-ss" @bind="resource.Title" disabled="@resource.IsSmartResource" />
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_Description"]</label>
            <textarea class="form-control form-control-ss" @bind="resource.Description" rows="3" disabled="@resource.IsSmartResource"></textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_MediaType"]</label>
                <select class="form-select form-control-ss" @bind="resource.MediaType" disabled="@resource.IsSmartResource">
                    @foreach (var type in mediaTypes)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_Language"]</label>
                <select class="form-select form-control-ss" @bind="resource.Language" disabled="@resource.IsSmartResource">
                    @foreach (var lang in languages)
                    {
                        <option value="@lang">@lang</option>
                    }
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_MediaUrl"]</label>
            <input type="url" class="form-control form-control-ss" @bind="resource.MediaUrl" disabled="@resource.IsSmartResource" />
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_Tags"]</label>
            <input type="text" class="form-control form-control-ss" @bind="resource.Tags" disabled="@resource.IsSmartResource" />
        </div>

        <div class="row g-2 mt-2">
            <div class="col-4 col-md-2"><strong class="ss-body2 text-secondary-ss">@Localize["ResourceEdit_Created"]</strong></div>
            <div class="col-8 col-md-4 ss-body2">@resource.CreatedAt.ToString("g")</div>

            <div class="col-4 col-md-2"><strong class="ss-body2 text-secondary-ss">@Localize["ResourceEdit_Updated"]</strong></div>
            <div class="col-8 col-md-4 ss-body2">@resource.UpdatedAt.ToString("g")</div>
        </div>
    </div>

    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["ResourceEdit_Transcript"]</h5>
        <textarea class="form-control form-control-ss" @bind="resource.Transcript" rows="6" disabled="@resource.IsSmartResource"></textarea>
    </div>

    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["ResourceEdit_Translation"]</h5>
        <textarea class="form-control form-control-ss" @bind="resource.Translation" rows="6" disabled="@resource.IsSmartResource"></textarea>
    </div>

    @* Vocabulary *@
    <div class="card card-ss p-4 mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="ss-title3 mb-0">@string.Format(Localize["ResourceEdit_VocabularySection"], resource.Vocabulary?.Count ?? 0)</h5>
            @if (!string.IsNullOrWhiteSpace(resource.Transcript) && !resource.IsSmartResource)
            {
                <button class="btn btn-ss-secondary btn-sm" @onclick="GenerateVocabulary"
                        disabled="@isGeneratingVocabulary">
                    @if (isGeneratingVocabulary)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                        <span>@Localize["ResourceEdit_Generating"]</span>
                    }
                    else
                    {
                        <i class="bi bi-stars me-1"></i>
                        <span>@Localize["ResourceEdit_GenerateFromTranscript"]</span>
                    }
                </button>
            }
        </div>

        @if (!resource.IsSmartResource)
        {
            <div class="mb-3">
                <label class="form-label ss-body2 text-secondary-ss" for="quickAddVocabulary">@Localize["ResourceEdit_QuickAddLabel"]</label>
                @if (!CanUseQuickAdd)
                {
                    <input id="quickAddVocabulary" type="text" class="form-control form-control-ss"
                           placeholder='@Localize["ResourceEdit_QuickAddPlaceholder"]' disabled />
                    <div class="form-text text-secondary-ss">@Localize["ResourceEdit_SetLanguageFirst"]</div>
                }
                else
                {
                    <div class="position-relative">
                        <input id="quickAddVocabulary" @ref="quickAddInput" type="text" class="form-control form-control-ss"
                               value="@quickAddQuery" @oninput="HandleQuickAddInput" @onkeydown="HandleQuickAddKeyDown"
                               placeholder='@Localize["ResourceEdit_QuickAddPlaceholder"]'
                               autocomplete="off" disabled="@isQuickAddAttaching" />
                        @if (isQuickAddSearching)
                        {
                            <span class="spinner-border spinner-border-sm text-primary resource-quick-add-spinner"></span>
                        }
                        @if (ShowQuickAddDropdown)
                        {
                            <div class="resource-quick-add-dropdown card card-ss shadow-sm p-1 mt-1" role="listbox">
                                @for (var i = 0; i < quickAddResults.Count; i++)
                                {
                                    var word = quickAddResults[i];
                                    var index = i;
                                    <button type="button" class="@GetQuickAddResultClass(index)" role="option"
                                            aria-selected="@(quickAddHighlightedIndex == index)"
                                            @onclick="() => AddExistingVocabularyAsync(word)">
                                        <div class="d-flex flex-column text-start">
                                            <strong>@word.TargetLanguageTerm</strong>
                                            <span class="@(quickAddHighlightedIndex == index ? "text-white-50" : "text-secondary-ss")">@word.NativeLanguageTerm</span>
                                        </div>
                                    </button>
                                }
                                @if (CanShowCreateSuggestion)
                                {
                                    <div class="px-3 py-2 ss-caption1 text-secondary-ss">@Localize["ResourceEdit_NoMatches"]</div>
                                    <button type="button" class="@GetQuickAddResultClass(quickAddResults.Count)" role="option"
                                            aria-selected="@(quickAddHighlightedIndex == quickAddResults.Count)"
                                            @onclick="ShowQuickAddCreateForm">
                                        @string.Format(Localize["ResourceEdit_AddNewWord"], quickAddQuery.Trim())
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    @if (showQuickAddCreateForm)
                    {
                        <div class="d-flex gap-2 mt-2">
                            <input type="text" class="form-control form-control-ss form-control-sm"
                                   @bind="quickAddNativeTerm" @bind:event="oninput"
                                   placeholder='@Localize["ResourceEdit_NativeTermPrompt"]'
                                   disabled="@isQuickAddAttaching" />
                            <button type="button" class="btn btn-ss-secondary btn-sm" @onclick="ConfirmCreateQuickAddWordAsync"
                                    disabled="@isQuickAddAttaching">
                                @if (isQuickAddAttaching)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                @Localize["ResourceEdit_QuickAddLabel"]
                            </button>
                        </div>
                    }
                }
            </div>

            <div class="border-top pt-3 mb-3">
                <button type="button" class="btn btn-link ss-body2 p-0 text-decoration-none" @onclick="ToggleBulkImport"
                        aria-expanded="@showBulkImport" aria-controls="resourceBulkImport">
                    <i class="bi @(showBulkImport ? "bi-chevron-down" : "bi-chevron-right") me-1"></i>@Localize["ResourceEdit_BulkImportToggle"]
                </button>

                @if (showBulkImport)
                {
                    <div id="resourceBulkImport" class="mt-3">
                        <div class="mb-3">
                            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_ImportVocabLabel"]</label>
                            <textarea class="form-control form-control-ss" @bind="vocabList" rows="4"
                                      placeholder='@Localize["ResourceEdit_VocabPlaceholder"]'></textarea>
                        </div>

                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="editDelimiter" id="editDelimComma"
                                       checked="@(delimiter == "comma")" @onchange="SetDelimiterComma" />
                                <label class="form-check-label ss-body2" for="editDelimComma">@Localize["ResourceEdit_Comma"]</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="editDelimiter" id="editDelimTab"
                                       checked="@(delimiter == "tab")" @onchange="SetDelimiterTab" />
                                <label class="form-check-label ss-body2" for="editDelimTab">@Localize["ResourceEdit_Tab"]</label>
                            </div>
                            <button class="btn btn-ss-secondary btn-sm ms-auto" @onclick="ImportVocabulary"
                                    disabled="@string.IsNullOrWhiteSpace(vocabList)">
                                @Localize["ResourceEdit_Import"]
                            </button>
                        </div>

                        <div class="mb-3">
                            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceEdit_OrImportFile"]</label>
                            <div class="d-flex align-items-center gap-2">
                                <label class="btn btn-ss-secondary btn-sm mb-0" for="fileImportEdit" role="button" style="cursor:pointer">
                                    <i class="bi bi-file-earmark-arrow-up me-1"></i>@Localize["ResourceEdit_ChooseFile"]
                                </label>
                                <InputFile id="fileImportEdit" OnChange="HandleFileImport" accept=".txt,.csv" class="d-none" />
                                @if (isImportingFile)
                                {
                                    <span class="spinner-border spinner-border-sm text-primary"></span>
                                    <span class="ss-body2 text-secondary-ss">@Localize["ResourceEdit_Importing"]</span>
                                }
                                @if (!string.IsNullOrEmpty(fileImportStatus))
                                {
                                    <span class="ss-body2 text-secondary-ss">@fileImportStatus</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @if (resource.Vocabulary?.Count > 0)
        {
            <div class="list-group list-group-flush">
                @foreach (var word in resource.Vocabulary)
                {
                    <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent border-secondary px-0 gap-2">
                        <div>
                            <strong class="ss-body1">@word.TargetLanguageTerm</strong>
                            <span class="text-secondary-ss ms-2">@word.NativeLanguageTerm</span>
                        </div>
                        @if (!resource.IsSmartResource)
                        {
                            <button type="button" class="btn btn-link btn-sm text-secondary-ss p-1" title='@Localize["ResourceEdit_RemoveWord"]'
                                    aria-label='@Localize["ResourceEdit_RemoveWord"]' @onclick="() => RemoveVocabularyWordAsync(word)">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-secondary-ss ss-body2 mb-0">@Localize["ResourceEdit_NoVocabYet"]</p>
        }
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content bg-surface">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-error-ss">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localize["ResourceEdit_ConfirmDelete"]
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="ss-body2">@deleteConfirmMessage</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-ss-secondary" @onclick="CancelDelete">@Localize["Common_Cancel"]</button>
                    <button type="button" class="btn btn-ss-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @Localize["Common_Delete"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private UserProfileRepository ProfileRepo { get; set; } = default!;
    [Inject] private AiService AiSvc { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private ILogger<ResourceEdit> Logger { get; set; } = default!;

    private LearningResource? resource;
    private bool isLoading = true;
    private bool isSaving;
    private bool isGeneratingVocabulary;
    private string vocabList = "";
    private string delimiter = "comma";
    private bool showDeleteConfirm;
    private bool isImportingFile;
    private string fileImportStatus = "";
    private string deleteConfirmMessage = "";
    private bool isDeleting;
    private bool showBulkImport;
    private ElementReference quickAddInput;
    private CancellationTokenSource? quickAddSearchCts;
    private List<VocabularyWord> quickAddResults = new();
    private string quickAddQuery = "";
    private string quickAddNativeTerm = "";
    private int quickAddHighlightedIndex = -1;
    private bool isQuickAddSearching;
    private bool isQuickAddAttaching;
    private bool showQuickAddCreateForm;
    private bool showQuickAddDropdown;

    private bool CanUseQuickAdd => resource is not null
        && !resource.IsSmartResource
        && !string.IsNullOrWhiteSpace(resource.Language)
        && !resource.Language.Equals("Other", StringComparison.OrdinalIgnoreCase);

    private bool CanShowCreateSuggestion => CanUseQuickAdd
        && !isQuickAddSearching
        && !string.IsNullOrWhiteSpace(quickAddQuery)
        && quickAddResults.Count == 0;

    private bool ShowQuickAddDropdown => showQuickAddDropdown && (quickAddResults.Count > 0 || CanShowCreateSuggestion);

    private void SetDelimiterComma() => delimiter = "comma";
    private void SetDelimiterTab() => delimiter = "tab";

    private readonly string[] mediaTypes = SentenceStudio.Common.Constants.MediaTypes;
    private readonly string[] languages = SentenceStudio.Common.Constants.Languages;

    protected override async Task OnInitializedAsync()
    {
        Localize.CultureChanged += OnCultureChanged;
        await LoadResource();
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadResource()
    {
        isLoading = true;
        try
        {
            resource = await ResourceRepo.GetResourceAsync(Id);
            if (resource is null)
                Toast.ShowError($"{Localize["ResourceEdit_NotFound"]}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["ResourceEdit_LoadFailed"], ex.Message)}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack() => NavManager.NavigateTo("/resources");

    private async Task SaveResource()
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource)
        {
            Logger.LogWarning("Attempt to save smart resource {ResourceId} blocked", resource.Id);
            return;
        }

        if (string.IsNullOrWhiteSpace(resource.Title))
        {
            Toast.ShowError($"{Localize["ResourceEdit_TitleRequired"]}");
            return;
        }

        if (string.IsNullOrWhiteSpace(resource.MediaType))
            resource.MediaType = "Other";
        if (string.IsNullOrWhiteSpace(resource.Language))
            resource.Language = "Other";

        isSaving = true;
        try
        {
            resource.UpdatedAt = DateTime.UtcNow;
            var outcome = RepositoryMutationOutcome.From(
                await ResourceRepo.SaveResourceAsync(resource));
            if (!outcome.Succeeded)
            {
                Toast.ShowError($"{string.Format(Localize["ResourceEdit_SaveFailed"], Localize["ResourceEdit_NotFound"])}");
                return;
            }
            Toast.ShowSuccess($"{Localize["ResourceEdit_SavedSuccess"]}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["Common_SaveFailed"], ex.Message)}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void RequestDelete()
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource)
        {
            Logger.LogWarning("Attempt to delete smart resource {ResourceId} blocked", resource.Id);
            return;
        }

        deleteConfirmMessage = $"{Localize["ResourceEdit_DeleteMessage"]}";
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
    }

    private async Task ConfirmDelete()
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource)
        {
            Logger.LogWarning("Attempt to delete smart resource {ResourceId} blocked", resource.Id);
            showDeleteConfirm = false;
            return;
        }

        isDeleting = true;
        try
        {
            var outcome = RepositoryMutationOutcome.From(
                await ResourceRepo.DeleteResourceAsync(resource));
            if (!outcome.Succeeded)
            {
                Toast.ShowError($"{string.Format(Localize["ResourceEdit_DeleteFailed"], Localize["ResourceEdit_NotFound"])}");
                return;
            }
            Toast.ShowSuccess($"{Localize["ResourceEdit_DeletedSuccess"]}");
            NavManager.NavigateTo("/resources");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["Common_DeleteFailed"], ex.Message)}");
        }
        finally
        {
            isDeleting = false;
            showDeleteConfirm = false;
        }
    }

    private void ToggleBulkImport() => showBulkImport = !showBulkImport;

    private async Task HandleQuickAddInput(ChangeEventArgs e)
    {
        if (resource is null)
            return;

        quickAddQuery = e.Value?.ToString() ?? "";
        quickAddNativeTerm = "";
        showQuickAddCreateForm = false;

        quickAddSearchCts?.Cancel();
        quickAddSearchCts?.Dispose();
        quickAddSearchCts = null;

        if (!CanUseQuickAdd || string.IsNullOrWhiteSpace(quickAddQuery))
        {
            ClearQuickAddSearch(keepQuery: true);
            return;
        }

        var cts = new CancellationTokenSource();
        quickAddSearchCts = cts;
        isQuickAddSearching = true;
        showQuickAddDropdown = false;

        try
        {
            await Task.Delay(250, cts.Token);
            var results = await ResourceRepo.SearchVocabularyWordsForResourceAsync(
                quickAddQuery.Trim(),
                resource.Language ?? string.Empty,
                resource.Id);

            if (cts.IsCancellationRequested)
                return;

            quickAddResults = results ?? new List<VocabularyWord>();
            showQuickAddDropdown = true;
            quickAddHighlightedIndex = quickAddResults.Count > 0 || !string.IsNullOrWhiteSpace(quickAddQuery) ? 0 : -1;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Quick-add vocabulary search failed for resource {ResourceId}", resource.Id);
            Toast.ShowError($"{string.Format(Localize["FailedToLoadVocabularyData"], ex.Message)}");
        }
        finally
        {
            if (quickAddSearchCts == cts)
            {
                isQuickAddSearching = false;
                quickAddSearchCts = null;
            }
        }
    }

    private async Task HandleQuickAddKeyDown(KeyboardEventArgs e)
    {
        if (!ShowQuickAddDropdown && e.Key != "Escape")
            return;

        var selectableCount = quickAddResults.Count + (CanShowCreateSuggestion ? 1 : 0);

        switch (e.Key)
        {
            case "ArrowDown":
                if (selectableCount > 0)
                    quickAddHighlightedIndex = (quickAddHighlightedIndex + 1 + selectableCount) % selectableCount;
                break;
            case "ArrowUp":
                if (selectableCount > 0)
                    quickAddHighlightedIndex = (quickAddHighlightedIndex - 1 + selectableCount) % selectableCount;
                break;
            case "Enter":
                if (quickAddHighlightedIndex >= 0 && quickAddHighlightedIndex < quickAddResults.Count)
                    await AddExistingVocabularyAsync(quickAddResults[quickAddHighlightedIndex]);
                else if (CanShowCreateSuggestion && quickAddHighlightedIndex == quickAddResults.Count)
                    ShowQuickAddCreateForm();
                break;
            case "Escape":
                ClearQuickAddSearch();
                break;
        }
    }

    private string GetQuickAddResultClass(int index)
    {
        var active = quickAddHighlightedIndex == index ? " active" : "";
        return $"list-group-item list-group-item-action border-0 rounded-2{active}";
    }

    private void ShowQuickAddCreateForm()
    {
        showQuickAddCreateForm = true;
        showQuickAddDropdown = false;
        quickAddHighlightedIndex = -1;
    }

    private async Task AddExistingVocabularyAsync(VocabularyWord word)
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource || isQuickAddAttaching || string.IsNullOrWhiteSpace(word.Id))
            return;

        isQuickAddAttaching = true;
        try
        {
            var added = await ResourceRepo.AddVocabularyToResourceAsync(resource.Id, word.Id);
            if (added)
            {
                AppendVocabularyWord(word);
                Toast.ShowSuccess($"{Localize["VocabWordEdit_WordAdded"]}");
                isQuickAddAttaching = false;
                ClearQuickAddSearch();
                await InvokeAsync(StateHasChanged);
                await FocusQuickAddInputAsync();
            }
            else
            {
                Toast.ShowError($"{string.Format(Localize["FailedToAssociateVocabulary"], Localize["ResourceEdit_NotFound"])}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Quick-add attach failed for resource {ResourceId} word {VocabularyWordId}", resource.Id, word.Id);
            Toast.ShowError($"{string.Format(Localize["FailedToAssociateVocabulary"], ex.Message)}");
        }
        finally
        {
            isQuickAddAttaching = false;
        }
    }

    private async Task ConfirmCreateQuickAddWordAsync()
    {
        if (resource is null)
            return;

        var targetTerm = quickAddQuery.Trim();
        if (string.IsNullOrWhiteSpace(targetTerm) || resource.IsSmartResource || isQuickAddAttaching)
            return;

        isQuickAddAttaching = true;
        try
        {
            var word = await GetOrCreateWordAsync(targetTerm, quickAddNativeTerm.Trim(), lemma: null, language: resource.Language);
            var added = await ResourceRepo.AddVocabularyToResourceAsync(resource.Id, word.Id);
            if (added)
            {
                AppendVocabularyWord(word);
                Toast.ShowSuccess($"{Localize["VocabWordEdit_WordAdded"]}");
                isQuickAddAttaching = false;
                ClearQuickAddSearch();
                await InvokeAsync(StateHasChanged);
                await FocusQuickAddInputAsync();
            }
            else
            {
                Toast.ShowError($"{string.Format(Localize["FailedToAssociateVocabulary"], Localize["ResourceEdit_NotFound"])}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Quick-add create failed for resource {ResourceId} term {TargetTerm}", resource.Id, targetTerm);
            Toast.ShowError($"{string.Format(Localize["FailedToAssociateVocabulary"], ex.Message)}");
        }
        finally
        {
            isQuickAddAttaching = false;
        }
    }

    private async Task RemoveVocabularyWordAsync(VocabularyWord word)
    {
        if (resource is null)
            return;

        if (resource.IsSmartResource || string.IsNullOrWhiteSpace(word.Id))
            return;

        try
        {
            var removed = await ResourceRepo.RemoveVocabularyFromResourceAsync(resource.Id, word.Id);
            if (removed && resource.Vocabulary is not null)
            {
                resource.Vocabulary.RemoveAll(w => w.Id == word.Id);
                Toast.ShowSuccess($"{Localize["ResourceEdit_RemoveWord"]}");
            }
            else if (!removed)
            {
                Toast.ShowError($"{string.Format(Localize["FailedToDeleteVocabulary"], Localize["ResourceEdit_NotFound"])}");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Remove vocabulary failed for resource {ResourceId} word {VocabularyWordId}", resource.Id, word.Id);
            Toast.ShowError($"{string.Format(Localize["FailedToDeleteVocabulary"], ex.Message)}");
        }
    }

    private void AppendVocabularyWord(VocabularyWord word)
    {
        if (resource is null)
            return;

        resource.Vocabulary ??= new List<VocabularyWord>();
        if (!resource.Vocabulary.Any(existing => existing.Id == word.Id))
            resource.Vocabulary.Add(word);
    }

