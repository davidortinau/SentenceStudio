@page "/import"
@attribute [Authorize]
@using SentenceStudio.Shared.Models
@using SentenceStudio.Services
@implements IDisposable

<PageHeader Title="YouTube Import">
    <PrimaryActions>
        <button class="btn btn-ss-primary" @onclick="AddChannel">
            <i class="bi bi-plus-lg me-1"></i> Add Channel
        </button>
    </PrimaryActions>
    <SecondaryActions>
        <li><button class="dropdown-item" @onclick="AddChannel"><i class="bi bi-plus-lg me-2"></i>Add Channel</button></li>
        <li><button class="dropdown-item" @onclick="RefreshImports"><i class="bi bi-arrow-repeat me-2"></i>Refresh</button></li>
    </SecondaryActions>
</PageHeader>

@* Tab navigation *@
<div class="btn-group w-100 mb-4" role="group">
    <button class="btn @(currentTab == Tab.Channels ? "btn-ss-primary" : "btn-outline-secondary")"
            @onclick="() => SwitchTab(Tab.Channels)">
        <i class="bi bi-youtube me-1"></i> My Channels
    </button>
    <button class="btn @(currentTab == Tab.SingleVideo ? "btn-ss-primary" : "btn-outline-secondary")"
            @onclick="() => SwitchTab(Tab.SingleVideo)">
        <i class="bi bi-link-45deg me-1"></i> Single Video
    </button>
    <button class="btn @(currentTab == Tab.History ? "btn-ss-primary" : "btn-outline-secondary")"
            @onclick="() => SwitchTab(Tab.History)">
        <i class="bi bi-clock-history me-1"></i> Import History
    </button>
</div>

@* ============ MY CHANNELS TAB ============ *@
@if (currentTab == Tab.Channels)
{
    @if (isLoadingChannels)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (channels.Count == 0)
    {
        <div class="text-center p-5">
            <i class="bi bi-youtube fs-1 mb-3 text-secondary-ss"></i>
            <p class="ss-body1 text-secondary-ss mb-4">No channels monitored yet</p>
            <button class="btn btn-ss-primary" @onclick="AddChannel">
                <i class="bi bi-plus-circle me-1"></i> Add Your First Channel
            </button>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var channel in channels)
            {
                <div class="col-12">
                    <div class="card card-ss p-3" role="button" style="cursor:pointer"
                         @onclick="() => EditChannel(channel.Id)">
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi bi-youtube fs-4 text-danger"></i>
                            <div class="flex-grow-1 overflow-hidden">
                                <h6 class="ss-title3 mb-1">
                                    @(channel.ChannelName ?? channel.ChannelHandle ?? "Unnamed Channel")
                                </h6>
                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                    <small class="text-secondary-ss">
                                        @if (!string.IsNullOrEmpty(channel.ChannelHandle))
                                        {
                                            <span>@channel.ChannelHandle</span>
                                        }
                                        @if (!string.IsNullOrEmpty(channel.Language))
                                        {
                                            <span> • @channel.Language</span>
                                        }
                                    </small>
                                    <small class="text-secondary-ss">
                                        Last checked: @(channel.LastCheckedAt?.ToString("g") ?? "Never")
                                    </small>
                                </div>
                            </div>
                            <div class="form-check form-switch fs-4 mb-0" @onclick:stopPropagation="true">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       checked="@channel.IsActive"
                                       @onchange="() => ToggleChannelActive(channel)"
                                       title="@(channel.IsActive ? "Pause monitoring" : "Resume monitoring")" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@* ============ SINGLE VIDEO TAB ============ *@
@if (currentTab == Tab.SingleVideo)
{
    @* Step 1: URL input *@
    <div class="card card-ss p-3 mb-4">
        <label class="form-label text-secondary-ss">YouTube URL</label>
        <div class="d-flex gap-2">
            <input type="text" class="form-control form-control-ss"
                   @bind="videoUrl" @bind:event="oninput"
                   @onkeydown="HandleUrlKeyDown"
                   placeholder="https://www.youtube.com/watch?v=..." />
            <button class="btn btn-ss-primary px-4 text-nowrap" @onclick="FetchTranscripts"
                    disabled="@(isLoadingTranscripts || string.IsNullOrWhiteSpace(videoUrl))">
                @if (isLoadingTranscripts)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Fetch
            </button>
        </div>
    </div>

    @* Step 2: Transcript selection and editing *@
    @if (availableTranscripts.Any())
    {
        <div class="card card-ss p-3 mb-4">
            @* Language selector *@
            @if (availableTranscripts.Count > 1)
            {
                <div class="mb-3">
                    <label class="form-label text-secondary-ss">Transcript Language</label>
                    <select class="form-select form-control-ss" @onchange="OnTranscriptSelected">
                        @foreach (var track in availableTranscripts)
                        {
                            <option value="@track.LanguageCode"
                                    selected="@(track.LanguageCode == selectedTrack?.LanguageCode)">
                                @track.LanguageName @(track.IsAutoGenerated ? "(auto)" : "")
                            </option>
                        }
                    </select>
                </div>
            }
            else
            {
                <p class="ss-body2 text-secondary-ss mb-2">
                    Language: <strong>@availableTranscripts[0].LanguageName</strong>
                    @(availableTranscripts[0].IsAutoGenerated ? " (auto-generated)" : "")
                </p>
            }

            @* Transcript editor *@
            @if (!string.IsNullOrEmpty(transcriptText))
            {
                <div class="mb-3">
                    <label class="form-label text-secondary-ss">Transcript</label>
                    <textarea class="form-control form-control-ss" rows="12"
                              @bind="transcriptText" @bind:event="oninput"
                              style="font-size: 14px; line-height: 1.6;"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-ss-secondary" @onclick="PolishTranscript"
                            disabled="@isPolishing">
                        @if (isPolishing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-stars me-1"></i> Polish with AI
                    </button>
                    <button class="btn btn-ss-primary flex-grow-1" @onclick="SaveAsResource"
                            disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-save me-1"></i> Save as Resource
                    </button>
                </div>
            }
            else if (isLoadingTranscript)
            {
                <div class="d-flex justify-content-center p-3">
                    <div class="spinner-border spinner-border-sm text-secondary" role="status"></div>
                    <span class="ms-2 text-secondary-ss">Downloading transcript...</span>
                </div>
            }
        </div>
    }

    @* Success result *@
    @if (!string.IsNullOrEmpty(savedResourceId))
    {
        <div class="alert alert-success d-flex align-items-center gap-2">
            <span><i class="bi bi-check-circle-fill me-1"></i> Resource saved successfully!</span>
            <button class="btn btn-sm btn-outline-success" @onclick="ViewSavedResource">View Resource</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="Reset">Import Another</button>
        </div>
    }

    @* Error *@
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
}

@* ============ IMPORT HISTORY TAB ============ *@
@if (currentTab == Tab.History)
{
    @if (isLoadingImports)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (imports.Count == 0)
    {
        <div class="text-center p-5">
            <i class="bi bi-clock-history fs-1 mb-3 text-secondary-ss"></i>
            <p class="ss-body1 text-secondary-ss">No import history yet</p>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center mb-3">
            <small class="text-secondary-ss">Showing @displayedImports.Count of @imports.Count imports</small>
        </div>

        <div class="list-group">
            @foreach (var import in displayedImports)
            {
                var isClickable = import.Status == VideoImportStatus.Completed && !string.IsNullOrEmpty(import.LearningResourceId);
                var isFailed = import.Status == VideoImportStatus.Failed;
                <button class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2 @(!isClickable && !isFailed ? "pe-none" : "")"
                        @onclick="() => OnImportRowClick(import)"
                        title="@(isFailed && !string.IsNullOrEmpty(import.ErrorMessage) ? import.ErrorMessage : "")">
                    @RenderStatusBadge(import.Status)
                    <span class="fw-semibold flex-grow-1 text-truncate">@(import.VideoTitle ?? "Untitled")</span>
                    <span class="text-secondary-ss text-truncate d-none d-md-inline" style="max-width:160px;">@GetChannelName(import.MonitoredChannelId)</span>
                    <small class="text-secondary-ss text-nowrap">@import.CreatedAt.ToString("d")</small>
                </button>
            }
        </div>

        @if (displayedImports.Count < imports.Count)
        {
            <div class="text-center mt-3">
                <button class="btn btn-ss-secondary" @onclick="ShowMoreImports">
                    <i class="bi bi-chevron-down me-1"></i> Show More
                </button>
            </div>
        }
    }
}

@code {
    [Inject] private YouTubeImportService ImportSvc { get; set; } = default!;
    [Inject] private TranscriptFormattingService FormattingSvc { get; set; } = default!;
    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private UserProfileRepository ProfileRepo { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private ILogger<Import> Logger { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    
    // NEW: Services for channel monitoring
    [Inject] private ChannelMonitorService? ChannelMonitorSvc { get; set; }
    [Inject] private VideoImportPipelineService? VideoImportPipelineSvc { get; set; }

    private enum Tab { Channels, SingleVideo, History }
    private Tab currentTab = Tab.Channels;

    // Single video import state
    private string videoUrl = "";
    private string transcriptText = "";
    private string errorMessage = "";
    private string preferredLanguage = "ko";
    private bool isLoadingTranscripts;
    private bool isLoadingTranscript;
    private bool isPolishing;
    private bool isSaving;
    private string savedResourceId = "";
    private List<TranscriptTrack> availableTranscripts = new();
    private TranscriptTrack? selectedTrack;
    private string? videoTitle;

    // Channel management state
    private List<MonitoredChannel> channels = new();
    private bool isLoadingChannels = true;

    // Import history state
    private List<VideoImport> imports = new();
    private bool isLoadingImports = true;
    private int importsPageSize = 50;
    private int importsDisplayCount = 50;
    private List<VideoImport> displayedImports => imports.Take(importsDisplayCount).ToList();
    
    // Polling for active imports
    private System.Threading.Timer? pollTimer;
    private bool isPolling;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await ProfileRepo.GetAsync();
            var lang = profile?.TargetLanguage ?? "Korean";
            preferredLanguage = lang.ToLowerInvariant() switch
            {
                "korean" => "ko",
                "japanese" => "ja",
                "chinese" => "zh",
                "spanish" => "es",
                "french" => "fr",
                "german" => "de",
                _ => lang[..Math.Min(2, lang.Length)].ToLowerInvariant()
            };
        }
        catch { }

        // Load channels and imports
        await Task.WhenAll(LoadChannels(), LoadImports());
        
        // Start polling for active imports
        StartPolling();
    }

    private void SwitchTab(Tab tab)
    {
        currentTab = tab;
        errorMessage = "";
    }

    // ============ CHANNEL MANAGEMENT ============
    
    private async Task LoadChannels()
    {
        if (ChannelMonitorSvc == null) 
        {
            isLoadingChannels = false;
            return;
        }
        
        isLoadingChannels = true;
        try
        {
            var userId = Preferences.Get("active_profile_id", "");
            channels = await ChannelMonitorSvc.GetAllAsync(userId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load channels");
            Toast.ShowError("Failed to load channels");
        }
        finally
        {
            isLoadingChannels = false;
        }
    }

    private void AddChannel()
    {
        NavManager.NavigateTo("/import/channel");
    }

    private void EditChannel(string channelId)
    {
        NavManager.NavigateTo($"/import/channel/{channelId}");
    }

    private async Task ToggleChannelActive(MonitoredChannel channel)
    {
        if (ChannelMonitorSvc == null) return;
        
        try
        {
            channel.IsActive = !channel.IsActive;
            await ChannelMonitorSvc.UpdateAsync(channel);
            Toast.ShowSuccess(channel.IsActive ? "Channel monitoring resumed" : "Channel monitoring paused");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to toggle channel active state");
            Toast.ShowError("Failed to update channel");
            channel.IsActive = !channel.IsActive; // Revert
        }
    }

    // ============ IMPORT HISTORY ============

    private async Task LoadImports()
    {
        if (VideoImportPipelineSvc == null) 
        {
            isLoadingImports = false;
            return;
        }
        
        isLoadingImports = true;
        try
        {
            var userId = Preferences.Get("active_profile_id", "");
            imports = await VideoImportPipelineSvc.GetImportHistoryAsync(userId);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load import history");
            Toast.ShowError("Failed to load import history");
        }
        finally
        {
            isLoadingImports = false;
        }
    }

    private async Task RefreshImports()
    {
        await LoadImports();
        Toast.ShowSuccess("Imports refreshed");
    }

    private void ViewResource(string resourceId)
    {
        NavManager.NavigateTo($"/resources/edit/{resourceId}");
    }

    private string GetChannelName(string? monitoredChannelId)
    {
        if (string.IsNullOrEmpty(monitoredChannelId)) return "Manual import";
        var ch = channels.FirstOrDefault(c => c.Id == monitoredChannelId);
        return ch?.ChannelName ?? ch?.ChannelHandle ?? "Channel";
    }

    private void OnImportRowClick(VideoImport import)
    {
        if (import.Status == VideoImportStatus.Completed && !string.IsNullOrEmpty(import.LearningResourceId))
        {
            ViewResource(import.LearningResourceId);
        }
        else if (import.Status == VideoImportStatus.Failed && !string.IsNullOrEmpty(import.ErrorMessage))
        {
            Toast.ShowError(import.ErrorMessage);
        }
    }

    private void ShowMoreImports()
    {
        importsDisplayCount += importsPageSize;
    }

    // ============ POLLING FOR ACTIVE IMPORTS ============

    private void StartPolling()
    {
        // Poll every 5 seconds for imports that are in-progress
        pollTimer = new System.Threading.Timer(async _ =>
        {
            if (isPolling) return; // Prevent overlapping polls
            isPolling = true;
            
            try
            {
                var activeImports = imports.Where(i => 
                    i.Status != VideoImportStatus.Completed && 
                    i.Status != VideoImportStatus.Failed).ToList();

                if (activeImports.Any() && VideoImportPipelineSvc != null)
                {
                    // Refresh status for active imports
                    var userId = Preferences.Get("active_profile_id", "");
                    var updated = await VideoImportPipelineSvc.GetImportHistoryAsync(userId);
                    
                    foreach (var import in imports)
                    {
                        var updatedImport = updated.FirstOrDefault(u => u.Id == import.Id);
                        if (updatedImport != null)
                        {
                            import.Status = updatedImport.Status;
                            import.ErrorMessage = updatedImport.ErrorMessage;
                            import.LearningResourceId = updatedImport.LearningResourceId;
                            import.CompletedAt = updatedImport.CompletedAt;
                        }
                    }
                    
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Polling error");
            }
            finally
            {
                isPolling = false;
            }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    public void Dispose()
    {
        pollTimer?.Dispose();
    }

    // ============ STATUS BADGE RENDERING ============

    private RenderFragment RenderStatusBadge(VideoImportStatus status) => __builder =>
    {
        var (badgeClass, icon, text) = status switch
        {
            VideoImportStatus.Pending => ("badge bg-warning", "bi-hourglass-split", "Pending"),
            VideoImportStatus.FetchingTranscript => ("badge bg-info", "bi-download", "Fetching..."),
            VideoImportStatus.CleaningTranscript => ("badge bg-info", "bi-stars", "Cleaning..."),
            VideoImportStatus.GeneratingVocabulary => ("badge bg-info", "bi-card-text", "Generating..."),
            VideoImportStatus.SavingResource => ("badge bg-info", "bi-save", "Saving..."),
            VideoImportStatus.Completed => ("badge bg-success", "bi-check-circle", "Completed"),
            VideoImportStatus.Failed => ("badge bg-danger", "bi-x-circle", "Failed"),
            _ => ("badge bg-secondary", "bi-question-circle", "Unknown")
        };

        <span class="@badgeClass">
            <i class="@icon me-1"></i>@text
            @if (status >= VideoImportStatus.FetchingTranscript && status < VideoImportStatus.Completed && status != VideoImportStatus.Failed)
            {
                <span class="spinner-border spinner-border-sm ms-1" style="width: 0.75rem; height: 0.75rem;"></span>
            }
        </span>
    };

    // ============ SINGLE VIDEO IMPORT (original logic) ============

    private async Task FetchTranscripts()
    {
        if (string.IsNullOrWhiteSpace(videoUrl)) return;

        isLoadingTranscripts = true;
        errorMessage = "";
        availableTranscripts.Clear();
        transcriptText = "";
        savedResourceId = "";
        StateHasChanged();

        try
        {
            // Get video metadata
            try
            {
                var meta = await ImportSvc.GetVideoMetadataAsync(videoUrl);
                videoTitle = meta?.Title;
            }
            catch { videoTitle = null; }

            var tracks = await ImportSvc.GetAvailableTranscriptsAsync(videoUrl);
            availableTranscripts = tracks ?? new();

            if (!availableTranscripts.Any())
            {
                errorMessage = "No transcripts found for this video.";
                return;
            }

            // Auto-select preferred language
            selectedTrack = availableTranscripts.FirstOrDefault(t =>
                t.LanguageCode.StartsWith(preferredLanguage, StringComparison.OrdinalIgnoreCase))
                ?? availableTranscripts.First();

            await DownloadTranscript();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to fetch transcripts");
            errorMessage = $"Error fetching transcripts: {ex.Message}";
        }
        finally
        {
            isLoadingTranscripts = false;
        }
    }

    private async Task DownloadTranscript()
    {
        if (selectedTrack is null) return;

        isLoadingTranscript = true;
        StateHasChanged();

        try
        {
            var raw = await ImportSvc.DownloadTranscriptTextAsync(selectedTrack);
            transcriptText = FormattingSvc.SmartCleanup(raw, selectedTrack.LanguageCode);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to download transcript");
            errorMessage = "Error downloading transcript.";
        }
        finally
        {
            isLoadingTranscript = false;
        }
    }

    private async Task OnTranscriptSelected(ChangeEventArgs e)
    {
        var code = e.Value?.ToString() ?? "";
        selectedTrack = availableTranscripts.FirstOrDefault(t => t.LanguageCode == code);
        await DownloadTranscript();
    }

    private async Task PolishTranscript()
    {
        if (string.IsNullOrWhiteSpace(transcriptText)) return;

        isPolishing = true;
        StateHasChanged();

        try
        {
            transcriptText = await FormattingSvc.PolishWithAiAsync(transcriptText, selectedTrack?.LanguageCode);
            Toast.ShowSuccess("Transcript polished!");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to polish transcript");
            Toast.ShowError("AI polishing failed. You can still save the current text.");
        }
        finally
        {
            isPolishing = false;
        }
    }

    private async Task SaveAsResource()
    {
        if (string.IsNullOrWhiteSpace(transcriptText)) return;

        isSaving = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var resource = new LearningResource
            {
                Title = videoTitle ?? "YouTube Import",
                MediaUrl = videoUrl,
                Transcript = transcriptText,
                MediaType = "Video",
                Language = NormalizeLanguageName(selectedTrack?.LanguageName ?? "")
            };

            var id = await ResourceRepo.SaveResourceAsync(resource);
            if (string.IsNullOrEmpty(id)) throw new Exception("Save returned no valid resource ID");
            savedResourceId = id;
            Toast.ShowSuccess("Resource saved successfully!");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save resource");
            errorMessage = $"Error saving resource: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ViewSavedResource()
    {
        NavManager.NavigateTo($"/resources/edit/{savedResourceId}");
    }

    private void Reset()
    {
        videoUrl = "";
        transcriptText = "";
        errorMessage = "";
        availableTranscripts.Clear();
        selectedTrack = null;
        savedResourceId = "";
        videoTitle = null;
    }

    private async Task HandleUrlKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await FetchTranscripts();
    }

    private static string NormalizeLanguageName(string language)
    {
        if (string.IsNullOrWhiteSpace(language)) return language;
        // Strip parenthetical suffixes like "(auto-generated)"
        var parenIndex = language.IndexOf('(');
        if (parenIndex > 0)
            language = language[..parenIndex];
        return language.Trim();
    }
}