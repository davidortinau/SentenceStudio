    private async Task PlayAudioAsync()
    {
        if (isPlayingAudio || currentItem == null || string.IsNullOrWhiteSpace(currentItem.AudioCue))
            return;
            
        isPlayingAudio = true;

        try
        {
            var text = currentItem.AudioCue;
            var languageCode = "ko"; // Korean numbers
            var voiceId = VoicePrefs.GetVoiceForLanguage(languageCode);
            var cached = await StreamHistoryRepo.GetStreamHistoryByPhraseAndVoiceAsync(text, voiceId);
            Stream audioStream;

            if (cached != null && !string.IsNullOrEmpty(cached.AudioFilePath) && File.Exists(cached.AudioFilePath))
            {
                audioStream = File.OpenRead(cached.AudioFilePath);
            }
            else if (Connectivity.IsInternetAvailable)
            {
                audioStream = await SpeechService.TextToSpeechAsync(text, voiceId, speed: 1.0f);

                var cacheDir = Path.Combine(FileSystemService.AppDataDirectory, "AudioCache");
                Directory.CreateDirectory(cacheDir);
                var filePath = Path.Combine(cacheDir, $"number_{Guid.NewGuid()}.mp3");
                using (var fs = File.Create(filePath)) { await audioStream.CopyToAsync(fs); }

                await StreamHistoryRepo.SaveStreamHistoryAsync(new StreamHistory
                {
                    Phrase = text,
                    VoiceId = voiceId,
                    AudioFilePath = filePath,
                    CreatedAt = DateTime.UtcNow,
                    UpdatedAt = DateTime.UtcNow
                });

                audioStream = File.OpenRead(filePath);
            }
            else
            {
                Toast.ShowWarning("Audio unavailable offline.");
                return;
            }

            audioPlayer?.Stop();
            audioPlayer?.Dispose();
            audioPlayer = AudioManager.CreatePlayer(audioStream);
            if (audioPlayer != null)
            {
                audioPlayer.Play();
            }
            else
            {
                // JS interop fallback for server-side Blazor (WebApp)
                audioStream.Position = 0;
                using var ms = new MemoryStream();
                await audioStream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                await JS.InvokeVoidAsync("audioInterop.playFromBase64", base64, "audio/mpeg");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to play number audio for '{Text}'", currentItem.AudioCue);
            Toast.ShowError("Failed to play audio.");
        }
        finally
        {
            isPlayingAudio = false;
        }
    }
    
    private async Task SubmitAnswerAsync()
    {
        if (string.IsNullOrWhiteSpace(userAnswer) || currentItem == null || session == null)
            return;
        
        try
        {
            isBusy = true;
            
            var latencyMs = (int)(DateTime.UtcNow - itemStartTime).TotalMilliseconds;
            
            var userGuid = AppState?.CurrentUserProfile?.Id
                ?? (await ProfileRepo.GetAsync())?.Id;
            if (string.IsNullOrEmpty(userGuid))
            {
                errorMessage = "User not found.";
                return;
            }
            
            lastAttemptResult = await SessionService.SubmitAnswerAsync(
                userGuid,
                session.SessionId,
                currentItem,
                userAnswer.Trim(),
                latencyMs
            );
            
            lastGrade = lastAttemptResult.Grade;
            showFeedback = true;
            totalCount++;
            
            if (lastGrade.IsCorrect)
            {
                correctCount++;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit answer: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }
    
    private async Task OverrideAsCorrect()
    {
        // Double-tap protection: disable immediately on first click
        if (_overriding || lastGrade == null || lastAttemptResult == null || currentItem == null)
            return;

        _overriding = true;

        // Update UI feedback immediately
        lastGrade = lastGrade with 
        { 
            IsCorrect = true,
            Verdict = "정확해요! (Overridden)"
        };
        
        // Update session counts (override counts as correct for streak)
        correctCount++;
        
        // Emit telemetry event for grader miss analysis
        Logger.LogInformation(
            "⚠️ NumberDrill grader override: user={UserId} subMode={SubMode} context={Context} " +
            "canonicalAnswer={Canonical} userAnswer={UserAnswer} system={System} counter={Counter} " +
            "digitValue={TargetValue} errorClass={ErrorClass}",
            AppState?.CurrentUserProfile?.Id ?? "unknown",
            currentItem.SubModeCode,
            currentItem.ContextCode,
            lastGrade.CanonicalAnswer,
            lastGrade.UserAnswer,
            currentItem.System,
            currentItem.CounterId ?? "(none)",
            currentItem.DigitValue,
            lastGrade.ErrorClass ?? "(none)"
        );
        
        StateHasChanged();
        
        // Auto-advance after a brief pause to show the override feedback
        await Task.Delay(1500);
        await NextItemAsync();
    }
    
    private async Task NextItemAsync()
    {
        currentIndex++;
        
        if (currentIndex >= session!.Items.Count)
        {
            // End session
            await EndSessionAsync();
        }
        else
        {
            // Move to next item
            currentItem = session.Items[currentIndex];
            userAnswer = "";
            showFeedback = false;
            _overriding = false;  // Reset double-tap protection for next item
            lastGrade = null;
            lastAttemptResult = null;
            itemStartTime = DateTime.UtcNow;
            
            // Reset TapTheCounter state
            selectedCounter = null;
            correctCounter = null;
            
            // Reset Disambiguate state
            selectedAnswerA = null;
            selectedAnswerB = null;
            isCorrectA = false;
            isCorrectB = false;
        }
    }
    
    private async Task EndSessionAsync()
    {
        try
        {
            isBusy = true;
            
            sessionSummary = await SessionService.EndSessionAsync(session!.SessionId);
            
            // Override with our local counts (more accurate for this session)
            sessionSummary = sessionSummary with 
            { 
                CorrectCount = correctCount,
                TotalItems = totalCount
            };
            
            state = State.Summary;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to end session: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }
    
    private void TryAgain()
    {
        state = State.Setup;
        session = null;
        currentIndex = 0;
        currentItem = null;
        sessionSummary = null;
        userAnswer = "";
        showFeedback = false;
        correctCount = 0;
