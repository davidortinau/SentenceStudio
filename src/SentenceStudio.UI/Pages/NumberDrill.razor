    // TapTheCounter methods
    private async Task TapCounter(string counter)
    {
        if (isBusy || currentItem == null) return;
        
        try
        {
            isBusy = true;
            selectedCounter = counter;
            correctCounter = currentItem.CounterText;
            
            var latencyMs = (int)(DateTime.UtcNow - itemStartTime).TotalMilliseconds;
            
            var userGuid = AppState?.CurrentUserProfile?.Id
                ?? (await ProfileRepo.GetAsync())?.Id;
            if (string.IsNullOrEmpty(userGuid))
            {
                errorMessage = "User not found. Please log in.";
                return;
            }
            
            // Submit answer (the counter the user tapped)
            lastAttemptResult = await SessionService.SubmitAnswerAsync(
                userGuid,
                session!.SessionId,
                currentItem,
                counter,
                latencyMs
            );
            
            // Extract grade result
            lastGrade = lastAttemptResult.Grade;
            
            showFeedback = true;
            totalCount++;
            
            if (lastGrade.IsCorrect)
            {
                correctCount++;
            }
            
            // Auto-advance after a beat
            await Task.Delay(1500);
            await NextItemAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit answer: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }
    
    private string GetCounterChipClass(string counter)
    {
        if (selectedCounter == null) return "";
        
        if (counter == correctCounter)
            return "correct";
        else if (counter == selectedCounter)
            return "incorrect";
        
        return "";
    }
    
