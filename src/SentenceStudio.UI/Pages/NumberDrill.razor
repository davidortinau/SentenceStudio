        StateHasChanged();
    }
    
    private void SelectAnswerB(string choice)
    {
        selectedAnswerB = choice;
        StateHasChanged();
    }
    
    private async Task SubmitBothAsync()
    {
        if (isBusy || currentItem == null) return;
        
        try
        {
            isBusy = true;
            
            // Grade both prompts
            isCorrectA = selectedAnswerA == currentItem.CorrectAnswerA;
            isCorrectB = selectedAnswerB == currentItem.CorrectAnswerB;
            
            var bothCorrect = isCorrectA && isCorrectB;
            
            var latencyMs = (int)(DateTime.UtcNow - itemStartTime).TotalMilliseconds;
            
            var userGuid = AppState?.CurrentUserProfile?.Id
                ?? (await ProfileRepo.GetAsync())?.Id;
            if (string.IsNullOrEmpty(userGuid))
            {
                errorMessage = "User not found. Please log in.";
                return;
            }
            
            // Submit combined answer (both-or-nothing for mastery tracking)
            var combinedAnswer = $"{selectedAnswerA} | {selectedAnswerB}";
            lastAttemptResult = await SessionService.SubmitAnswerAsync(
                userGuid,
                session!.SessionId,
                currentItem,
                combinedAnswer,
                latencyMs
            );
            
            // Build custom grade result for UI feedback
            var verdict = bothCorrect ? Localize["NumberDrillBothCorrect"].ToString()
                        : (isCorrectA || isCorrectB) ? Localize["NumberDrillPartialCorrect"].ToString()
                        : Localize["NumberDrillBothIncorrect"].ToString();
            
            lastGrade = new SentenceStudio.Services.Numbers.GradeResult(
                IsCorrect: bothCorrect,
                Verdict: verdict,
                CanonicalAnswer: $"A: {currentItem.CorrectAnswerA}, B: {currentItem.CorrectAnswerB}",
                ErrorClass: bothCorrect ? "" : "system_confusion",
                Tip: bothCorrect ? "" : "Review the hint for each prompt to understand which system applies."
            );
            
            showFeedback = true;
            totalCount++;
            
            if (bothCorrect)
            {
                correctCount++;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to submit answer: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }
    
    private string GetDisambiguateCardClass(bool isPromptA)
    {
        if (!showFeedback) return "";
        
        var isCorrect = isPromptA ? isCorrectA : isCorrectB;
        return isCorrect ? "correct" : "incorrect";
    }
    
