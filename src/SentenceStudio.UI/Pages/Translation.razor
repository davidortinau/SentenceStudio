@page "/translation"
@attribute [Authorize]
@using SentenceStudio.Shared.Services
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IAsyncDisposable

<div class="activity-page-wrapper">

<PageHeader Title='@Localize["Activity_Translate"]' ShowBack="true" OnBack="GoBack" />

<div class="activity-content">
@if (showSessionSummary)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
        <h2 class="ss-title1 mb-4"><i class="bi bi-journal-check me-2"></i>@Localize["Common_SessionComplete"]</h2>
        <div class="card card-ss p-4" style="min-width: 340px;">
            <div class="d-flex justify-content-around mb-3">
                <div class="text-center">
                    <div class="ss-title2 text-success">@sessionGradedCount</div>
                    <small class="text-secondary-ss">@Localize["Common_Graded"]</small>
                </div>
                <div class="text-center">
                    <div class="ss-title2" style="color: var(--bs-primary);">
                        @(sessionGradedCount > 0 ? (int)(sessionAccuracySum / sessionGradedCount) : 0)%
                    </div>
                    <small class="text-secondary-ss">@Localize["Common_AvgAccuracy"]</small>
                </div>
                <div class="text-center">
                    <div class="ss-title2" style="color: var(--bs-info);">
                        @(sessionGradedCount > 0 ? (int)(sessionFluencySum / sessionGradedCount) : 0)%
                    </div>
                    <small class="text-secondary-ss">@Localize["Common_AvgFluency"]</small>
                </div>
            </div>
        </div>
        <button class="btn btn-ss-primary mt-4" @onclick="ContinueAfterSummary">@Localize["Common_ContinuePractice"]</button>
        <button class="btn btn-ss-secondary mt-2" @onclick="GoBack">@Localize["Common_Done"]</button>
    </div>
}
else if (isBusy)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 40vh;">
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <p class="ss-body1 text-secondary-ss">@Localize["Translation_LoadingSentences"]</p>
    </div>
}
else if (showIntro)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
        <h2 class="ss-title1 mb-4"><i class="bi bi-bookmark-star me-2"></i>@Localize["Translation_Intro_Title"]</h2>
        <div class="card card-ss p-4" style="min-width: 340px; max-width: 560px;">
            @if (!string.IsNullOrWhiteSpace(introResourceTitle))
            {
                <p class="ss-caption1 text-secondary-ss mb-3">
                    <strong>@Localize["Translation_Intro_Resource"]:</strong> @introResourceTitle
                </p>
            }

            @if (introVocabulary.Any())
            {
                <h3 class="ss-title3 mb-2"><i class="bi bi-card-list me-2"></i>@Localize["Translation_Intro_Vocabulary"]</h3>
                <ul class="ss-body2 mb-3" style="padding-left: 1.25rem;">
                    @foreach (var word in introVocabulary)
                    {
                        <li>
                            <strong>@word.TargetLanguageTerm</strong>
                            @if (!string.IsNullOrEmpty(word.NativeLanguageTerm))
                            {
                                <span class="text-secondary-ss"> — @word.NativeLanguageTerm</span>
                            }
                        </li>
                    }
                </ul>
            }

            @if (introGrammarBullets.Any())
            {
                <h3 class="ss-title3 mb-2"><i class="bi bi-mortarboard me-2"></i>@Localize["Translation_Intro_GrammarFocus"]</h3>
                <ul class="ss-body2 mb-2" style="padding-left: 1.25rem;">
                    @foreach (var bullet in introGrammarBullets)
                    {
                        <li>@bullet</li>
                    }
                </ul>
            }
        </div>
        <button class="btn btn-ss-primary mt-4" @onclick="StartFromIntro">
            <i class="bi bi-play-fill me-1"></i>@Localize["Translation_Intro_Start"]
        </button>
    </div>
}
else if (sentences.Any())
{
    @* Feedback — minimal chips + collapsible details (matches Writing activity) *@
    @if (showFeedback && lastFeedback != null)
    {
        <div class="card card-ss p-3 mb-3">
            @if (!string.IsNullOrWhiteSpace(lastSubmittedInput))
            {
                <p class="ss-body1 mb-2"><i class="bi bi-chat-quote me-2 text-secondary-ss"></i>@lastSubmittedInput</p>
            }
            <div class="d-flex gap-3 justify-content-end mb-2">
                @if (lastFeedback.Accuracy > 0)
                {
                    <div class="text-center">
                        <div class="ss-body2" style="color: @GetScoreColor(lastFeedback.Accuracy);">@((int)lastFeedback.Accuracy)%</div>
                        <small class="text-secondary-ss">@Localize["Common_Accuracy"]</small>
                    </div>
                }
                @if (lastFeedback.Fluency > 0)
                {
                    <div class="text-center">
                        <div class="ss-body2" style="color: @GetScoreColor(lastFeedback.Fluency);">@((int)lastFeedback.Fluency)%</div>
                        <small class="text-secondary-ss">@Localize["Writing_Fluency"]</small>
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(recommendedTranslation))
            {
                <small class="text-secondary-ss d-block">
                    <strong>@Localize["Common_Suggested"]</strong> @recommendedTranslation
                </small>
            }
            @if (!string.IsNullOrEmpty(lastFeedback.AccuracyExplanation)
                || !string.IsNullOrEmpty(lastFeedback.FluencyExplanation)
                || !string.IsNullOrEmpty(lastFeedback.GrammarNotes?.Explanation))
            {
                <details class="mt-2">
                    <summary class="ss-caption1 text-secondary-ss" style="cursor: pointer;">@Localize["Writing_ShowDetails"]</summary>
                    <div class="mt-1">
                        @if (!string.IsNullOrEmpty(lastFeedback.AccuracyExplanation))
                        {
                            <small class="d-block text-secondary-ss"><strong>@Localize["Common_Accuracy"]:</strong> @lastFeedback.AccuracyExplanation</small>
                        }
                        @if (!string.IsNullOrEmpty(lastFeedback.FluencyExplanation))
                        {
                            <small class="d-block text-secondary-ss"><strong>@Localize["Writing_Fluency"]:</strong> @lastFeedback.FluencyExplanation</small>
                        }
                        @if (!string.IsNullOrEmpty(lastFeedback.GrammarNotes?.Explanation))
                        {
                            <small class="d-block text-secondary-ss"><strong>@Localize["Writing_Notes"]</strong> @lastFeedback.GrammarNotes.Explanation</small>
                        }
                    </div>
                </details>
            }
        </div>
    }
}
else
{
    <div class="text-center p-5">
        <p class="ss-body1 text-secondary-ss">@Localize["Translation_NoSentences"]</p>
        <button class="btn btn-ss-secondary mt-3" @onclick="GoBack">@Localize["Common_GoBack"]</button>
    </div>
}
</div>

@if (sentences.Any() && !showSessionSummary && !showIntro && !isBusy)
{
<div class="activity-input-bar">
    @* Prompt sentence — pinned with input so it remains visible when keyboard is open *@
    <div class="activity-prompt mb-2">
        <p class="ss-title3 mb-0" style="line-height: 1.3;">@currentSentence</p>
    </div>

    @* Input mode: vocab blocks *@
    @if (inputMode == "MultipleChoice" && vocabBlocks.Any())
    {
        <div class="d-flex flex-wrap gap-2 mb-2">
            @foreach (var block in vocabBlocks)
            {
                var b = block;
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => UseVocabBlock(b)">@b</button>
            }
        </div>
    }

    @* Input + actions row *@
    <form @onsubmit="SubmitInput" @onsubmit:preventDefault class="d-flex gap-2 mb-2">
        <input type="text" class="form-control form-control-ss form-control-lg flex-grow-1"
               @bind="userInput"
               placeholder='@string.Format(Localize["Translation_TranslateTo"], targetLanguage)' />
        <button type="button" class="btn btn-ss-secondary" @onclick="ToggleInputMode">
            @(inputMode == "Text" ? Localize["Translation_Blocks"] : Localize["Translation_Type"])
        </button>
        <button type="submit" class="btn btn-ss-primary"
                disabled="@isGrading">
            @if (isGrading)
            {
                <span class="spinner-border spinner-border-sm"></span>
            }
            else
            {
                <span>@Localize["Translation_Grade"]</span>
            }
        </button>
    </form>

    @* Nav row *@
    <div class="d-flex justify-content-between align-items-center">
        <button class="btn btn-sm btn-ss-secondary" @onclick="PreviousSentence" disabled="@(currentIndex <= 0)">
            <i class="bi bi-chevron-left"></i>
        </button>
        <span class="ss-body2 text-secondary-ss">@(currentIndex + 1) / @sentences.Count</span>
        <button class="btn btn-sm btn-ss-secondary" @onclick="NextSentence">
            <i class="bi bi-chevron-right"></i>
        </button>
    </div>
</div>
}

</div>

@code {
    [SupplyParameterFromQuery(Name = "resourceId")]
    public string? ResourceIdParam { get; set; }

    [SupplyParameterFromQuery(Name = "skillId")]
    public string? SkillIdParam { get; set; }

    [SupplyParameterFromQuery(Name = "planItemId")]
    public string? PlanItemId { get; set; }

    [SupplyParameterFromQuery(Name = "FocusVocabularyIds")]
    public string? FocusVocabularyIdsParam { get; set; }

    [Inject] private TranslationService TranslationSvc { get; set; } = default!;
    [Inject] private TeacherService TeacherSvc { get; set; } = default!;
    [Inject] private AiService AiSvc { get; set; } = default!;
    [Inject] private UserActivityRepository ActivityRepo { get; set; } = default!;
    [Inject] private VocabularyProgressService ProgressService { get; set; } = default!;
    [Inject] private SkillProfileRepository SkillProfileRepo { get; set; } = default!;
    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private ILogger<Translation> Logger { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Progress.ProgressCacheService CacheService { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Progress.IProgressService PlanProgressService { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Timer.IActivityTimerService ActivityTimer { get; set; } = default!;
    private SentenceStudio.Services.Timer.ActivityTimerLease? activityTimerLease;

    private bool isBusy;
    private bool isGrading;
    private bool showFeedback;
    private bool showSessionSummary;
    private bool showIntro;
    private string introResourceTitle = "";
    private List<VocabularyWord> introVocabulary = new();
    private List<string> introGrammarBullets = new();
    private string userInput = "";
    private string lastSubmittedInput = "";
    private string currentSentence = "";
    private string recommendedTranslation = "";
    private string targetLanguage = "Korean";
    private string inputMode = "Text";
    private int currentIndex;
    private int sessionGradedCount;
    private double sessionAccuracySum;
    private double sessionFluencySum;
    private GradeResponse? lastFeedback;

    private List<Challenge> sentences = new();
    private List<VocabularyWord>? currentVocabulary;
    private List<VocabularyWord> focusVocabularyWords = new();
    private IReadOnlyList<string> focusVocabularyIds = Array.Empty<string>();
    private List<string> vocabBlocks = new();

    protected override async Task OnInitializedAsync()
    {
        Localize.CultureChanged += OnCultureChanged;
        Logger.LogInformation("Translation initialized — planItemId={PlanItemId}", PlanItemId ?? "(none)");
        activityTimerLease = ActivityTimer.StartSession("Translation", PlanItemId, ResourceIdParam, SkillIdParam);
        await LoadSentences();
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadSentences()
    {
        isBusy = true;
        try
        {
            var resourceId = ResourceIdParam ?? "";
            var skillId = SkillIdParam ?? "";
            focusVocabularyIds = FocusVocabularySelection.ParseFocusVocabularyIds(FocusVocabularyIdsParam);
            if (focusVocabularyIds.Count == 0)
            {
                Logger.LogWarning("Activity {ActivityName} launched without FocusVocabularyIds (planItemId={PlanItemId}); falling back to legacy selection", nameof(Translation), PlanItemId);
            }

            var result = await TranslationSvc.GetTranslationSentences(resourceId, 5, skillId, focusVocabularyIds);
            if (result?.Any() == true)
            {
                sentences = result;
                await BuildIntroAsync(resourceId, skillId);
                showIntro = introVocabulary.Any() || introGrammarBullets.Any() || !string.IsNullOrEmpty(introResourceTitle);
                SetCurrentSentence();
            }
            else
            {
                Toast.ShowWarning("No sentences returned from the translation service.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading sentences");
            Toast.ShowError($"Error loading sentences: {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task BuildIntroAsync(string resourceId, string skillId)
    {
        introResourceTitle = "";
        introVocabulary = new List<VocabularyWord>();
        introGrammarBullets = new List<string>();

        try
        {
            if (!string.IsNullOrEmpty(resourceId))
            {
                var resource = await ResourceRepo.GetResourceAsync(resourceId);
                introResourceTitle = resource?.Title ?? "";
            }

            if (focusVocabularyIds.Count > 0)
            {
                var userVocabulary = await ResourceRepo.GetAllVocabularyWordsWithResourcesAsync();
                focusVocabularyWords = FocusVocabularySelection.SelectFocusWords(userVocabulary, focusVocabularyIds);
            }
            else
            {
                focusVocabularyWords = new List<VocabularyWord>();
            }

            if (!string.IsNullOrEmpty(skillId))
            {
                var profile = await SkillProfileRepo.GetSkillProfileAsync(skillId);
                introGrammarBullets = ParseGrammarBullets(profile?.Description);
            }

            introVocabulary = FocusVocabularySelection.BuildRequiredFirstPromptVocabulary(
                    focusVocabularyWords,
                    sentences.SelectMany(s => s.Vocabulary ?? Enumerable.Empty<VocabularyWord>()),
                    maxVocabularyWords: 12)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to build translation intro context");
        }
    }

    private static List<string> ParseGrammarBullets(string? description)
    {
        if (string.IsNullOrWhiteSpace(description)) return new List<string>();

        var bullets = new List<string>();
        foreach (var raw in description.Split('\n'))
        {
            var line = raw.Trim().TrimStart('-', '*', '•', ' ', '\t');
            if (string.IsNullOrWhiteSpace(line)) continue;
            // Stop at example/heading sections so we don't dump example sentences into the intro
            if (line.StartsWith("###") || line.StartsWith("Examples", StringComparison.OrdinalIgnoreCase)
                || line.StartsWith("Example:", StringComparison.OrdinalIgnoreCase)) break;
            bullets.Add(line);
            if (bullets.Count >= 8) break;
        }
        return bullets;
    }

    private void StartFromIntro()
    {
        showIntro = false;
    }

    private void SetCurrentSentence()
    {
        if (currentIndex < 0 || currentIndex >= sentences.Count) return;

        var challenge = sentences[currentIndex];
        currentSentence = challenge.RecommendedTranslation ?? "";
        currentVocabulary = challenge.Vocabulary;
        recommendedTranslation = "";
        userInput = "";
        lastSubmittedInput = "";
        showFeedback = false;
        lastFeedback = null;
        inputMode = "Text";

        var vocabularyForBlocks = focusVocabularyWords.Any()
            ? FocusVocabularySelection.BuildRequiredFirstPromptVocabulary(focusVocabularyWords, challenge.Vocabulary, maxVocabularyWords: 12)
            : (challenge.Vocabulary ?? new List<VocabularyWord>())
                .Where(FocusVocabularySelection.IsUsableVocabularyWord)
                .OrderBy(_ => Random.Shared.Next())
                .ToList();

        vocabBlocks = vocabularyForBlocks
            .Select(v => v.TargetLanguageTerm)
            .Where(t => !string.IsNullOrEmpty(t))
            .ToList();
    }

    private async Task SubmitInput()
    {
        await GradeMe();
    }

    private async Task GradeMe()
    {
        if (string.IsNullOrWhiteSpace(userInput)) return;

        isGrading = true;
        showFeedback = false;
        lastSubmittedInput = userInput;
        StateHasChanged();

        try
        {
            var challenge = sentences[currentIndex];

            // Use TeacherSvc.GradeTranslation which uses the proper Scriban template
            // with vocabulary_analysis support
            var feedback = await TeacherSvc.GradeTranslation(
                userInput: userInput,
                originalSentence: currentSentence,
                recommendedTranslation: challenge.SentenceText ?? "");

            // The AI typically writes the suggested translation into GrammarNotes.RecommendedTranslation.
            // Fall back there if the top-level property is empty.
            recommendedTranslation = !string.IsNullOrWhiteSpace(feedback.RecommendedTranslation)
                ? feedback.RecommendedTranslation
                : (feedback.GrammarNotes?.RecommendedTranslation ?? "");
            lastFeedback = feedback;
            var accuracy = (int)feedback.Accuracy;

            showFeedback = true;

            sessionGradedCount++;
            sessionAccuracySum += feedback.Accuracy;
            sessionFluencySum += feedback.Fluency;

            // Record activity
            await ActivityRepo.SaveAsync(new UserActivity
            {
                Activity = SentenceStudio.Shared.Models.Activity.Translation.ToString(),
                Input = userInput,
                Accuracy = feedback.Accuracy,
                Fluency = feedback.Fluency,
                CreatedAt = DateTime.Now,
                UpdatedAt = DateTime.Now
            });

            // Record vocabulary progress via shared extraction pipeline
            if (currentVocabulary?.Any() == true)
            {
                var activeUserId = Preferences.Get("active_profile_id", "");
                var scoringResults = await ProgressService.ExtractAndScoreVocabularyAsync(
                    feedback.VocabularyAnalysis, currentVocabulary, activeUserId,
                    activity: "Translation", difficultyWeight: 1.5f);

                if (scoringResults.Any())
                    CacheService.InvalidateVocabSummary();
            }

            Toast.ShowSuccess($"Graded! Accuracy: {accuracy}%");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error grading translation");
            Toast.ShowError("Error grading your translation. Please try again.");
        }
        finally
        {
            isGrading = false;
        }
    }

    private void NextSentence()
    {
        if (currentIndex < sentences.Count - 1)
        {
            currentIndex++;
            SetCurrentSentence();
        }
        else
        {
            showSessionSummary = true;
        }
    }

    private void PreviousSentence()
    {
        if (currentIndex > 0)
        {
            currentIndex--;
            SetCurrentSentence();
        }
    }

    private async Task ContinueAfterSummary()
    {
        showSessionSummary = false;
        sessionGradedCount = 0;
        sessionAccuracySum = 0;
        sessionFluencySum = 0;
        currentIndex = 0;
        sentences.Clear();
        await LoadSentences();
    }

    private async Task LoadMoreSentences()
    {
        try
        {
            var resourceId = ResourceIdParam ?? "";
            var skillId = SkillIdParam ?? "";
            var more = await TranslationSvc.GetTranslationSentences(resourceId, 5, skillId, focusVocabularyIds);
            if (more?.Any() == true)
            {
                sentences.AddRange(more);
                currentIndex = sentences.Count - more.Count;
                SetCurrentSentence();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading more sentences");
        }
    }

    private void UseVocabBlock(string word)
    {
        userInput = string.IsNullOrEmpty(userInput) ? word : $"{userInput} {word}";
    }

    private void ToggleInputMode()
    {
        inputMode = inputMode == "Text" ? "MultipleChoice" : "Text";
    }

    private string GetScoreColor(double score) => score switch
    {
        >= 80 => "var(--bs-success)",
        >= 50 => "var(--bs-warning)",
        _ => "var(--bs-danger)"
    };

    private void GoBack()
    {
        ActivityTimer.PauseAndStopOwnedSession(activityTimerLease);
        NavManager.NavigateTo("/");
    }

    public ValueTask DisposeAsync()
    {
        Localize.CultureChanged -= OnCultureChanged;
        ActivityTimer.PauseAndStopOwnedSession(activityTimerLease);
        return ValueTask.CompletedTask;
    }
}
