@page "/resources/add"
@attribute [Authorize]
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

<PageHeader Title='@Localize["ResourceAdd_Title"]' ShowBack="true" OnBack="Cancel">
    <PrimaryActions>
        <button class="btn btn-ss-primary" @onclick="SaveResource" disabled="@isSaving">
            @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            @Localize["Common_Save"]
        </button>
    </PrimaryActions>
    <SecondaryActions>
        <li><button class="dropdown-item" @onclick="SaveResource" disabled="@isSaving"><i class="bi bi-check-lg me-2"></i>@Localize["Common_Save"]</button></li>
    </SecondaryActions>
</PageHeader>

@if (isSaving)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["ResourceAdd_BasicInfo"]</h5>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_TitleLabel"]</label>
            <input type="text" class="form-control form-control-ss" @bind="resource.Title" placeholder='@Localize["ResourceAdd_TitlePlaceholder"]' />
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_DescriptionLabel"]</label>
            <textarea class="form-control form-control-ss" @bind="resource.Description" rows="3" placeholder='@Localize["ResourceAdd_DescriptionPlaceholder"]'></textarea>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_MediaTypeLabel"]</label>
                <select class="form-select form-control-ss" @bind="resource.MediaType">
                    @foreach (var type in mediaTypes)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_LanguageLabel"]</label>
                <select class="form-select form-control-ss" @bind="resource.Language">
                    @foreach (var lang in languages)
                    {
                        <option value="@lang">@lang</option>
                    }
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_TagsLabel"]</label>
            <input type="text" class="form-control form-control-ss" @bind="resource.Tags" placeholder='@Localize["ResourceAdd_TagsPlaceholder"]' />
        </div>
    </div>

    @if (resource.MediaType != "Vocabulary List")
    {
        <div class="card card-ss p-4 mb-3">
            <h5 class="ss-title3 mb-3">@Localize["ResourceAdd_MediaContent"]</h5>

            <div class="mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_MediaUrlLabel"]</label>
                <input type="url" class="form-control form-control-ss" @bind="resource.MediaUrl" placeholder="https://..." />
            </div>

            <div class="mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_TranscriptLabel"]</label>
                <textarea class="form-control form-control-ss" @bind="resource.Transcript" rows="5" placeholder='@Localize["ResourceAdd_TranscriptPlaceholder"]'></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_TranslationLabel"]</label>
                <textarea class="form-control form-control-ss" @bind="resource.Translation" rows="5" placeholder='@Localize["ResourceAdd_TranslationPlaceholder"]'></textarea>
            </div>
        </div>
    }

    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["ResourceAdd_VocabularySection"]</h5>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_PasteVocabLabel"]</label>
            <textarea class="form-control form-control-ss" @bind="vocabList" rows="6" placeholder='@Localize["ResourceAdd_VocabPlaceholder"]'></textarea>
        </div>

        <div class="d-flex align-items-center gap-3 mb-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" name="delimiter" id="delimComma"
                       checked="@(delimiter == "comma")" @onchange="SetDelimiterComma" />
                <label class="form-check-label ss-body2" for="delimComma">@Localize["ResourceAdd_CommaDelimiter"]</label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="delimiter" id="delimTab"
                       checked="@(delimiter == "tab")" @onchange="SetDelimiterTab" />
                <label class="form-check-label ss-body2" for="delimTab">@Localize["ResourceAdd_TabDelimiter"]</label>
            </div>
            <button class="btn btn-ss-secondary btn-sm ms-auto" @onclick="ImportVocabulary"
                    disabled="@string.IsNullOrWhiteSpace(vocabList)">
                @Localize["ResourceAdd_ImportVocabulary"]
            </button>
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["ResourceAdd_OrImportFile"]</label>
            <div class="d-flex align-items-center gap-2">
                <label class="btn btn-ss-secondary btn-sm mb-0" for="fileImportAdd" role="button" style="cursor:pointer">
                    <i class="bi bi-file-earmark-arrow-up me-1"></i>@Localize["ResourceAdd_ChooseFile"]
                </label>
                <InputFile id="fileImportAdd" OnChange="HandleFileImport" accept=".txt,.csv" class="d-none" />
                @if (isImportingFile)
                {
                    <span class="spinner-border spinner-border-sm text-primary"></span>
                    <span class="ss-body2 text-secondary-ss">@Localize["ResourceAdd_Importing"]</span>
                }
                @if (!string.IsNullOrEmpty(fileImportStatus))
                {
                    <span class="ss-body2 text-secondary-ss">@fileImportStatus</span>
                }
            </div>
        </div>

        @if (resource.Vocabulary?.Count > 0)
        {
            <small class="text-secondary-ss">@string.Format(Localize["ResourceAdd_VocabWordsAdded"], resource.Vocabulary.Count)</small>
        }
    </div>

    <div class="d-flex gap-2 mb-5">
        <button class="btn btn-ss-primary flex-grow-1" @onclick="SaveResource" disabled="@isSaving">
            @if (isSaving)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            @Localize["ResourceAdd_SaveResource"]
        </button>
    </div>
}

@code {
    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;

    private LearningResource resource = new()
    {
        MediaType = SentenceStudio.Common.Constants.MediaTypes[0],
        Language = SentenceStudio.Common.Constants.Languages[0],
        CreatedAt = DateTime.UtcNow,
        UpdatedAt = DateTime.UtcNow
    };

    private bool isSaving;
    private string vocabList = "";
    private string delimiter = "comma";
    private bool isImportingFile;
    private string fileImportStatus = "";

    private readonly string[] mediaTypes = SentenceStudio.Common.Constants.MediaTypes;
    private readonly string[] languages = SentenceStudio.Common.Constants.Languages;

    protected override void OnInitialized()
    {
        Localize.CultureChanged += OnCultureChanged;
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private void SetDelimiterComma() => delimiter = "comma";
    private void SetDelimiterTab() => delimiter = "tab";

    private void Cancel() => NavManager.NavigateTo("/resources");

    private async Task SaveResource()
    {
        if (string.IsNullOrWhiteSpace(resource.Title))
        {
            Toast.ShowError($"{Localize["ResourceAdd_TitleRequired"]}");
            return;
        }

        if (string.IsNullOrWhiteSpace(resource.MediaType))
            resource.MediaType = "Other";
        if (string.IsNullOrWhiteSpace(resource.Language))
            resource.Language = "Other";

        isSaving = true;
        try
        {
            // Import any remaining vocabulary text
            if (!string.IsNullOrWhiteSpace(vocabList))
            {
                AppendVocabularyFromText();
            }

            await ResourceRepo.SaveResourceAsync(resource);
            Toast.ShowSuccess($"{Localize["ResourceAdd_SavedSuccess"]}");
            NavManager.NavigateTo("/resources");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["ResourceAdd_SaveFailed"], ex.Message)}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ImportVocabulary()
    {
        if (string.IsNullOrWhiteSpace(vocabList))
        {
            Toast.ShowError($"{Localize["ResourceAdd_NoVocabToImport"]}");
            return;
        }

        try
        {
            int added = AppendVocabularyFromText();
            if (added > 0)
            {
                vocabList = "";
                Toast.ShowSuccess($"{string.Format(Localize["ResourceAdd_ImportedCount"], added)}");
            }
            else
            {
                Toast.ShowInfo($"{Localize["ResourceAdd_NoDuplicates"]}");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["ResourceAdd_ImportFailed"], ex.Message)}");
        }
    }

    private int AppendVocabularyFromText()
    {
        var newWords = VocabularyWord.ParseVocabularyWords(vocabList, delimiter);
        resource.Vocabulary ??= new List<VocabularyWord>();

        int added = 0;
        foreach (var word in newWords)
        {
            bool isDuplicate = resource.Vocabulary.Any(existing =>
                existing.TargetLanguageTerm?.Trim().Equals(word.TargetLanguageTerm?.Trim(), StringComparison.OrdinalIgnoreCase) == true);

            if (!isDuplicate)
            {
                word.CreatedAt = DateTime.UtcNow;
                word.UpdatedAt = DateTime.UtcNow;
                resource.Vocabulary.Add(word);
                added++;
            }
        }

        return added;
    }

    private async Task HandleFileImport(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        isImportingFile = true;
        fileImportStatus = "";
        StateHasChanged();

        try
        {
            // Cap at 1 MB to prevent abuse
            using var stream = file.OpenReadStream(maxAllowedSize: 1_048_576);
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            if (string.IsNullOrWhiteSpace(content))
            {
                Toast.ShowError($"{Localize["ResourceAdd_FileEmpty"]}");
                return;
            }

            var newWords = VocabularyWord.ParseVocabularyWords(content, delimiter);
            resource.Vocabulary ??= new List<VocabularyWord>();

            int added = 0;
            foreach (var word in newWords)
            {
                bool isDuplicate = resource.Vocabulary.Any(existing =>
                    existing.TargetLanguageTerm?.Trim().Equals(word.TargetLanguageTerm?.Trim(), StringComparison.OrdinalIgnoreCase) == true);

                if (!isDuplicate)
                {
                    word.CreatedAt = DateTime.UtcNow;
                    word.UpdatedAt = DateTime.UtcNow;
                    resource.Vocabulary.Add(word);
                    added++;
                }
            }

            if (added > 0)
            {
                fileImportStatus = $"{string.Format(Localize["ResourceAdd_FileImportStatus"], added, file.Name)}";
                Toast.ShowSuccess($"{string.Format(Localize["ResourceAdd_ImportedFromFile"], added)}");
            }
            else
            {
                Toast.ShowInfo($"{Localize["ResourceAdd_NoDuplicatesInFile"]}");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["ResourceAdd_FileImportFailed"], ex.Message)}");
        }
        finally
        {
            isImportingFile = false;
        }
    }

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }
}
