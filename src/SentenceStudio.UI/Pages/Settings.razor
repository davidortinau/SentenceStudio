@page "/settings"
@attribute [Authorize]
@using System.Reflection
@inject ThemeService ThemeService
@inject IJSRuntime JS
@inject SentenceStudio.Services.ReleaseNotesService ReleaseNotesService
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

<PageHeader Title='@Localize["Settings_Title"]' />

@* Appearance *@
<div class="card card-ss p-4 mb-3">
    <h5 class="ss-title3 mb-3">@Localize["Settings_AppearanceSection"]</h5>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["Settings_ThemeLabel"]</label>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var theme in ThemeService.AvailableThemes)
            {
                var (primary, accent) = ThemeService.GetThemeColors(theme, ThemeService.CurrentMode);
                var isSelected = ThemeService.CurrentTheme == theme;

                <button type="button" 
                        class="theme-swatch @(isSelected ? "selected" : "")"
                        @onclick="() => OnThemeSelected(theme)"
                        title="@ThemeService.GetThemeDisplayName(theme)">
                    <div class="theme-swatch-colors">
                        <div class="color-primary" style="background-color: @primary"></div>
                        <div class="color-accent" style="background-color: @accent"></div>
                    </div>
                    <div class="theme-swatch-label">@ThemeService.GetThemeDisplayName(theme)</div>
                </button>
            }
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["Settings_ModeLabel"]</label>
        <div class="btn-group w-100" role="group">
            <input type="radio" class="btn-check" name="themeMode" id="modeLight" 
                   checked="@(!ThemeService.IsDarkMode)" 
                   @onchange="@(() => OnModeChanged("light"))" />
            <label class="btn btn-outline-secondary" for="modeLight">
                <i class="bi bi-sun me-1"></i> @Localize["Settings_LightMode"]
            </label>
            
            <input type="radio" class="btn-check" name="themeMode" id="modeDark" 
                   checked="@ThemeService.IsDarkMode" 
                   @onchange="@(() => OnModeChanged("dark"))" />
            <label class="btn btn-outline-secondary" for="modeDark">
                <i class="bi bi-moon me-1"></i> @Localize["Settings_DarkMode"]
            </label>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">
            @string.Format(Localize["Settings_TextSizeLabel"], (int)(fontScale * 100))
        </label>
        <input type="range" class="form-range" min="0.85" max="1.5" step="0.05"
               value="@fontScale" @oninput="OnFontScaleInput" />
        <div class="d-flex justify-content-between">
            <small class="text-secondary-ss">85%</small>
            <small class="text-secondary-ss">150%</small>
        </div>
    </div>
</div>

@* Voice & Quiz Settings *@
<div class="card card-ss p-4 mb-3">
    <h5 class="ss-title3 mb-3">@Localize["Settings_VoiceQuizSection"]</h5>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["Settings_LanguageLabel"]</label>
        <select class="form-select form-control-ss" @bind="selectedLanguage" @bind:after="OnLanguageChanged">
            <option value="Korean">Korean</option>
            <option value="English">English</option>
            <option value="French">French</option>
            <option value="German">German</option>
            <option value="Spanish">Spanish</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["Settings_VoiceLabel"]</label>
        @if (isLoadingVoices)
        {
            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        }
        else
        {
            <select class="form-select form-control-ss" @bind="selectedVoiceId">
                @foreach (var voice in availableVoices)
                {
                    <option value="@voice.Id">@voice.Name</option>
                }
            </select>
        }
    </div>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["Settings_PromptLanguageLabel"]</label>
        <div class="btn-group w-100" role="group">
            <input type="radio" class="btn-check" name="quizDir" id="dirForward" value="TargetToNative" @onchange="@(() => SetQuizDirection("TargetToNative"))" checked="@(quizDirection == "TargetToNative")" />
            <label class="btn btn-outline-secondary" for="dirForward">@Localize["Settings_TargetLanguage"]</label>
            <input type="radio" class="btn-check" name="quizDir" id="dirReverse" value="NativeToTarget" @onchange="@(() => SetQuizDirection("NativeToTarget"))" checked="@(quizDirection == "NativeToTarget")" />
            <label class="btn btn-outline-secondary" for="dirReverse">@Localize["Settings_NativeLanguage"]</label>
            <input type="radio" class="btn-check" name="quizDir" id="dirMixed" value="Mixed" @onchange="@(() => SetQuizDirection("Mixed"))" checked="@(quizDirection == "Mixed")" />
            <label class="btn btn-outline-secondary" for="dirMixed">@Localize["Settings_Mixed"]</label>
        </div>
        <div class="ss-caption1 text-secondary-ss mt-2">@Localize["Settings_PromptLanguageHelp"]</div>
    </div>

    <div class="form-check form-switch mb-2">
        <input class="form-check-input" type="checkbox" id="autoplay" @bind="quizAutoplay" />
        <label class="form-check-label ss-body2" for="autoplay">@Localize["Settings_AutoplayAudio"]</label>
    </div>

    <div class="form-check form-switch mb-2">
        <input class="form-check-input" type="checkbox" id="showMnemonic" @bind="quizShowMnemonic" />
        <label class="form-check-label ss-body2" for="showMnemonic">@Localize["Settings_ShowMnemonics"]</label>
    </div>

    <div class="mb-3 mt-3">
        <label class="form-label ss-body2 text-secondary-ss">@Localize["Settings_PromptModalitiesLabel"]</label>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="useTextPrompt" @bind="quizUseTextPrompt" />
            <label class="form-check-label ss-body2" for="useTextPrompt">@Localize["Settings_TextModality"]</label>
        </div>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="useAudioPrompt" @bind="quizUseAudioPrompt" />
            <label class="form-check-label ss-body2" for="useAudioPrompt">@Localize["Settings_AudioModality"]</label>
        </div>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="usePhotoPrompt" @bind="quizUsePhotoPrompt" />
            <label class="form-check-label ss-body2" for="usePhotoPrompt">@Localize["Settings_PhotoModality"]</label>
        </div>
        <div class="ss-caption1 text-secondary-ss">@Localize["Settings_ModalitiesHelp"]</div>
    </div>

    <div class="mb-3">
        <label class="form-label ss-body2 text-secondary-ss">
            @string.Format(Localize["Settings_AutoAdvanceDurationLabel"], quizAutoAdvanceDuration)
        </label>
        <input type="range" class="form-range" min="1" max="10" step="0.5"
               @bind="quizAutoAdvanceDuration" @bind:event="oninput" />
    </div>

    <button class="btn btn-ss-primary" @onclick="SavePreferences">@Localize["Settings_SavePreferences"]</button>
</div>

@* Data Management *@
<div class="card card-ss p-4 mb-3">
    <h5 class="ss-title3 mb-3">@Localize["Settings_DataManagementSection"]</h5>

    <button class="btn btn-ss-secondary w-100" @onclick="ExportData" disabled="@isExporting">
        @if (isExporting)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
        }
        @Localize["Settings_ExportData"]
    </button>
</div>

@if (isDebugBuild)
{
    @* Database Migrations - Dev Only *@
    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["Settings_DatabaseMigrationsSection"]</h5>

        @if (streakMigrationComplete)
        {
            <div class="alert alert-success ss-body2">@Localize["Settings_StreakMigrationComplete"]</div>
        }
        else
        {
            <button class="btn btn-ss-secondary w-100" @onclick="RunStreakMigration" disabled="@isMigrating">
                @if (isMigrating)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                @Localize["Settings_RunStreakMigration"]
            </button>
        }

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <p class="ss-caption1 mt-2">@statusMessage</p>
        }
    </div>
}

@* About *@
<div class="card card-ss p-4 mb-3">
    <h5 class="ss-title3 mb-2">@Localize["Settings_AboutSection"]</h5>
    <p class="ss-caption1 text-muted-ss">@string.Format(Localize["Settings_VersionLabel"], currentVersion)</p>
    <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="ShowReleaseNotes">
        <i class="bi bi-megaphone me-1"></i> @Localize["Settings_WhatsNew"]
    </button>
</div>

<WhatsNewModal 
    IsVisible="@showWhatsNew" 
    Title="@whatsNewTitle"
    Version="@whatsNewVersion"
    Content="@whatsNewContent"
    OnDismissed="@DismissWhatsNew" />

@code {
    [Inject] private IVocabularyProgressService VocabProgressService { get; set; }
    [Inject] private DataExportService ExportService { get; set; }
    [Inject] private SentenceStudio.Services.Speech.IVoiceDiscoveryService VoiceDiscovery { get; set; }
    [Inject] private SpeechVoicePreferences VoicePrefs { get; set; }
    [Inject] private VocabularyQuizPreferences QuizPrefs { get; set; }
    [Inject] private ToastService Toast { get; set; }

    private IJSObjectReference? jsModule;

    private string selectedLanguage = "Korean";
    private string selectedVoiceId = "";
    private List<VoiceInfo> availableVoices = new();
    private bool isLoadingVoices;
    private string quizDirection = "TargetToNative";
    private bool quizAutoplay;
    private bool quizShowMnemonic;
    private bool quizUseTextPrompt = true;
    private bool quizUseAudioPrompt = true;
    private bool quizUsePhotoPrompt;
    private double quizAutoAdvanceDuration = 3.0;
    private double fontScale = 1.0;
    private bool isExporting;
    private bool isMigrating;
    private bool streakMigrationComplete;
    private string statusMessage = "";
    private string currentVersion = "1.0";
    private bool isDebugBuild;
    private bool showWhatsNew;
    private string whatsNewTitle = "What's New";
    private string whatsNewVersion = "";
    private string whatsNewContent = "";
    private record VoiceInfo(string Id, string Name);

    protected override async Task OnInitializedAsync()
    {
        Localize.CultureChanged += OnCultureChanged;
        fontScale = ThemeService.FontScale;
        var asm = typeof(Settings).Assembly;
        var infoVersion = asm.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion;
        currentVersion = infoVersion ?? asm.GetName().Version?.ToString() ?? "1.0";
#if DEBUG
        isDebugBuild = true;
#endif
        LoadPreferences();
        await LoadVoicesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/SentenceStudio.UI/js/app.js");
        await jsModule.InvokeVoidAsync("setFontScale", fontScale);
        await jsModule.InvokeVoidAsync("applyTheme", ThemeService.CurrentTheme, ThemeService.CurrentMode);
    }

    private async Task OnThemeSelected(string theme)
    {
        ThemeService.SetTheme(theme);
        await ApplyThemeToDOM();
        StateHasChanged();
    }

    private async Task OnModeChanged(string mode)
    {
        ThemeService.SetMode(mode);
        await ApplyThemeToDOM();
        StateHasChanged();
    }

    private async Task OnFontScaleInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), System.Globalization.NumberStyles.Any, 
            System.Globalization.CultureInfo.InvariantCulture, out var scale))
        {
            fontScale = scale;
            ThemeService.SetFontScale(fontScale);
            if (jsModule != null)
                await jsModule.InvokeVoidAsync("setFontScale", fontScale);
        }
    }

    private async Task ApplyThemeToDOM()
    {
        if (jsModule != null)
        {
            await jsModule.InvokeVoidAsync("applyTheme", ThemeService.CurrentTheme, ThemeService.CurrentMode);
        }
    }

    private void LoadPreferences()
    {
        quizDirection = QuizPrefs.DisplayDirection;
        quizAutoplay = QuizPrefs.AutoPlayVocabAudio;
        quizShowMnemonic = QuizPrefs.ShowMnemonicImage;
        quizUseTextPrompt = QuizPrefs.UseTextPrompt;
        quizUseAudioPrompt = QuizPrefs.UseAudioPrompt;
        quizUsePhotoPrompt = QuizPrefs.UsePhotoPrompt;
        quizAutoAdvanceDuration = QuizPrefs.AutoAdvanceDuration / 1000.0;
        selectedLanguage = "Korean";
        selectedVoiceId = VoicePrefs.GetVoiceForLanguage(selectedLanguage) ?? "";
    }

    private async Task LoadVoicesAsync()
    {
        isLoadingVoices = true;
        try
        {
            var voices = await VoiceDiscovery.GetVoicesForLanguageAsync(selectedLanguage);
            availableVoices = voices.Select(v => new VoiceInfo(v.VoiceId, v.Name)).ToList();
            if (!availableVoices.Any(v => v.Id == selectedVoiceId) && availableVoices.Any())
                selectedVoiceId = availableVoices.First().Id;
        }
        catch { }
        finally
        {
            isLoadingVoices = false;
        }
    }

    private async Task OnLanguageChanged()
    {
        await LoadVoicesAsync();
    }

    private void SavePreferences()
    {
        if (!quizUseTextPrompt && !quizUseAudioPrompt && !quizUsePhotoPrompt)
        {
            quizUseTextPrompt = true;
            Toast.ShowInfo($"{Localize["Settings_ModalityRequired"]}");
        }

        QuizPrefs.DisplayDirection = quizDirection;
        QuizPrefs.AutoPlayVocabAudio = quizAutoplay;
        QuizPrefs.ShowMnemonicImage = quizShowMnemonic;
        QuizPrefs.UseTextPrompt = quizUseTextPrompt;
        QuizPrefs.UseAudioPrompt = quizUseAudioPrompt;
        QuizPrefs.UsePhotoPrompt = quizUsePhotoPrompt;
        QuizPrefs.AutoAdvanceDuration = (int)(quizAutoAdvanceDuration * 1000);
        VoicePrefs.SetVoiceForLanguage(selectedLanguage, selectedVoiceId);
        Toast.ShowSuccess($"{Localize["Settings_PreferencesSaved"]}");
    }

    private void SetQuizDirection(string direction)
    {
        quizDirection = direction;
    }

    private async Task ExportData()
    {
        isExporting = true;
        try
        {
            await ExportService.ExportAllDataAsZipAsync();
            Toast.ShowSuccess($"{Localize["Settings_ExportSuccess"]}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["Settings_ExportFailed"], ex.Message)}");
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task RunStreakMigration()
    {
        isMigrating = true;
        statusMessage = "Running migration...";
        try
        {
            await VocabProgressService.MigrateToStreakBasedScoringAsync();
            streakMigrationComplete = true;
            statusMessage = "Migration completed successfully";
            Toast.ShowSuccess($"{Localize["Settings_MigrationComplete"]}");
        }
        catch (Exception ex)
        {
            statusMessage = $"{string.Format(Localize["Settings_MigrationFailed"], ex.Message)}";
            Toast.ShowError(statusMessage);
        }
        finally
        {
            isMigrating = false;
        }
    }

    private async Task ShowReleaseNotes()
    {
        try
        {
            var releaseNote = await ReleaseNotesService.GetNotesForVersionAsync(currentVersion);
            if (releaseNote != null)
            {
                whatsNewVersion = releaseNote.Version;
                whatsNewTitle = $"{Localize["Settings_WhatsNew"]}";
                whatsNewContent = ConvertMarkdownToHtml(releaseNote.MarkdownContent);
                showWhatsNew = true;
            }
            else
            {
                Toast.ShowInfo($"{Localize["Settings_NoReleaseNotes"]}");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["Settings_ReleaseNotesFailed"], ex.Message)}");
        }
    }

    private async Task DismissWhatsNew()
    {
        showWhatsNew = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }

    private string ConvertMarkdownToHtml(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
            return "";

        var html = markdown
            .Replace("&", "&amp;")
            .Replace("<", "&lt;")
            .Replace(">", "&gt;");

        // Headers
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^### (.+)$", "<h5>$1</h5>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^## (.+)$", "<h4>$1</h4>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^# (.+)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);

        // Bold and italic
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*(.+?)\*", "<em>$1</em>");

        // Links
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\[(.+?)\]\((.+?)\)", "<a href=\"$2\">$1</a>");

        // Lists
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^- (.+)$", "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"(<li>.*</li>\n?)+", "<ul class=\"ss-body2 mb-3\">$0</ul>", System.Text.RegularExpressions.RegexOptions.Singleline);

        // Paragraphs
        var lines = html.Split('\n');
        var result = new System.Text.StringBuilder();
        var inList = false;

        foreach (var line in lines)
        {
            if (line.Trim().StartsWith("<ul"))
                inList = true;
            else if (line.Trim().StartsWith("</ul>"))
                inList = false;

            if (!string.IsNullOrWhiteSpace(line) && !line.Trim().StartsWith("<h") && !line.Trim().StartsWith("<li") && !line.Trim().StartsWith("<ul") && !line.Trim().StartsWith("</ul>") && !inList)
                result.AppendLine($"<p class=\"ss-body2 mb-2\">{line.Trim()}</p>");
            else
                result.AppendLine(line);
        }

        return result.ToString();
    }
}
