    private void GoBack()
    {
        var queryParts = new List<string>();

        if (!string.IsNullOrWhiteSpace(ReturnQuery))
            queryParts.Add($"q={Uri.EscapeDataString(ReturnQuery)}");

        if (!string.IsNullOrWhiteSpace(ReturnDuplicateTerm))
            queryParts.Add($"duplicateTerm={Uri.EscapeDataString(ReturnDuplicateTerm)}");

        if (!string.IsNullOrWhiteSpace(ReturnFocusWordId))
            queryParts.Add($"focusWordId={Uri.EscapeDataString(ReturnFocusWordId)}");

        var url = queryParts.Count == 0
            ? "/vocabulary"
            : $"/vocabulary?{string.Join("&", queryParts)}";
        NavManager.NavigateTo(url);
    }

    private void OpenDuplicateManager()
    {
        if (!IsExistingWord || string.IsNullOrWhiteSpace(targetLanguageTerm))
            return;

        var queryParts = new List<string>();

        if (!string.IsNullOrWhiteSpace(ReturnQuery))
            queryParts.Add($"q={Uri.EscapeDataString(ReturnQuery)}");

        queryParts.Add($"duplicateTerm={Uri.EscapeDataString(targetLanguageTerm.Trim())}");

        if (!string.IsNullOrWhiteSpace(word.Id))
            queryParts.Add($"focusWordId={Uri.EscapeDataString(word.Id)}");

        NavManager.NavigateTo($"/vocabulary?{string.Join("&", queryParts)}");
    }

    private async Task SetStatus(SentenceStudio.Shared.Models.LearningStatus status)
    {
        if (isSettingStatus || string.IsNullOrEmpty(Id) || Id == "0") return;
        if (currentLearningStatus == status) return;

        isSettingStatus = true;
        try
        {
            var userId = Preferences.Get("active_profile_id", "");
            progress = await ProgressService.SetUserDeclaredStatusAsync(Id, userId, status);
            CacheService.InvalidateVocabSummary();
            UpdateProgressDisplay();

            if (status == SentenceStudio.Shared.Models.LearningStatus.Familiar)
                Toast.ShowInfo($"{Localize["VocabWordEdit_FamiliarMessage"]}");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"{string.Format(Localize["VocabWordEdit_StatusUpdateFailed"], ex.Message)}");
            Logger.LogError(ex, "Failed to set word status for {WordId}", Id);
        }
        finally
        {
            isSettingStatus = false;
        }
    }

    private async Task OnStatusSelectChanged(ChangeEventArgs e)
    {
        if (e.Value is string statusStr && Enum.TryParse<SentenceStudio.Shared.Models.LearningStatus>(statusStr, out var status))
        {
            await SetStatus(status);
        }
    }

