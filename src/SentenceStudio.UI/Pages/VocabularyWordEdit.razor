    private async Task<List<VocabularyWord>> LoadConstituentsAsync(string phraseWordId)
    {
        using var scope = _serviceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

        var constituents = await db.PhraseConstituents
            .Where(pc => pc.PhraseWordId == phraseWordId && pc.ConstituentWordId != null)
            .Include(pc => pc.ConstituentWord)
            .Select(pc => pc.ConstituentWord!)
            .ToListAsync();

        return constituents;
    }

    private void OnTypeChanged()
    {
        if (previousLexicalUnitType != selectedLexicalUnitType)
        {
            // Show warning if changing FROM phrase/sentence to word and there are constituents
            if ((previousLexicalUnitType == LexicalUnitType.Phrase || previousLexicalUnitType == LexicalUnitType.Sentence) 
                && selectedLexicalUnitType == LexicalUnitType.Word 
                && selectedConstituents.Count > 0)
            {
                typeChangeWarning = $"Changing to Word will remove {selectedConstituents.Count} constituent link(s) on save.";
            }
            else
            {
                typeChangeWarning = "";
            }
            previousLexicalUnitType = selectedLexicalUnitType;
        }
    }

    private async void OnConstituentSearchChanged()
    {
        constituentSuggestions.Clear();
        showConstituentAutocomplete = false;

        if (string.IsNullOrWhiteSpace(constituentSearchQuery) || constituentSearchQuery.Length < 2)
            return;

        try
        {
            using var scope = _serviceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

            var query = constituentSearchQuery.ToLower();
            var currentLanguage = wordLanguage;

            var suggestions = await db.VocabularyWords
                .Where(w => w.Id != word.Id) // Don't suggest the current word
                .Where(w => string.IsNullOrEmpty(currentLanguage) || w.Language == currentLanguage) // Same language
                .Where(w => (w.TargetLanguageTerm != null && w.TargetLanguageTerm.ToLower().Contains(query)) ||
                            (w.NativeLanguageTerm != null && w.NativeLanguageTerm.ToLower().Contains(query)))
                .OrderBy(w => w.TargetLanguageTerm)
                .Take(10)
                .ToListAsync();

            // Filter out already selected
            constituentSuggestions = suggestions
                .Where(s => !selectedConstituents.Any(c => c.Id == s.Id))
                .ToList();

            showConstituentAutocomplete = constituentSuggestions.Count > 0;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to search constituent words");
        }
    }

    private void AddConstituent(VocabularyWord constituent)
    {
        if (!selectedConstituents.Any(c => c.Id == constituent.Id))
        {
            selectedConstituents.Add(constituent);
            constituentSearchQuery = "";
            constituentSuggestions.Clear();
            showConstituentAutocomplete = false;
        }
    }

    private void RemoveConstituent(string constituentId)
    {
        selectedConstituents.RemoveAll(c => c.Id == constituentId);
    }

    private async Task SaveWord()
    {
        isSaving = true;
        errorMessage = "";

        try
        {
            var target = targetLanguageTerm.Trim();
            var native = nativeLanguageTerm.Trim();

            if (string.IsNullOrEmpty(target) || string.IsNullOrEmpty(native))
            {
                errorMessage = $"{Localize["VocabWordEdit_BothRequired"]}";
                return;
            }

            // Duplicate check
            var existing = await ResourceRepo.FindDuplicateVocabularyWordAsync(target, native);
            if (existing != null && existing.Id != word.Id)
            {
                errorMessage = $"{Localize["VocabWordEdit_DuplicateExists"]}";
                return;
            }

            word.TargetLanguageTerm = target;
            word.NativeLanguageTerm = native;
            word.Lemma = lemma.Trim();
            word.Tags = tags.Trim();
            word.Language = string.IsNullOrWhiteSpace(wordLanguage) ? null : wordLanguage.Trim();
            word.MnemonicText = mnemonicText.Trim();
            word.MnemonicImageUri = mnemonicImageUri.Trim();
            word.LexicalUnitType = selectedLexicalUnitType;
            word.UpdatedAt = DateTime.UtcNow;

            var saveResult = await ResourceRepo.SaveWordAsync(word);
            if (saveResult < 0)
            {
                errorMessage = $"{Localize["VocabWordEdit_SaveFailed"]}";
                return;
            }

            // Handle resource associations
            if (!string.IsNullOrEmpty(word.Id))
            {
                foreach (var resourceId in originalResourceIds.Except(selectedResourceIds))
                    await ResourceRepo.RemoveVocabularyFromResourceAsync(resourceId, word.Id);

                foreach (var resourceId in selectedResourceIds.Except(originalResourceIds))
                    await ResourceRepo.AddVocabularyToResourceAsync(resourceId, word.Id);
            }
            else
            {
                foreach (var resourceId in selectedResourceIds)
                    await ResourceRepo.AddVocabularyToResourceAsync(resourceId, word.Id);
            }

            // Handle constituents (only for Phrase/Sentence types)
            if (!string.IsNullOrEmpty(word.Id))
            {
                if (selectedLexicalUnitType == LexicalUnitType.Phrase || selectedLexicalUnitType == LexicalUnitType.Sentence)
                {
                    using var scope = _serviceProvider.CreateScope();
                    var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

                    // Get existing constituents
                    var existingConstituents = await db.PhraseConstituents
                        .Where(pc => pc.PhraseWordId == word.Id)
                        .ToListAsync();

                    var existingIds = new HashSet<string>(existingConstituents
                        .Where(pc => pc.ConstituentWordId != null)
                        .Select(pc => pc.ConstituentWordId!));
                    var selectedIds = new HashSet<string>(selectedConstituents.Select(c => c.Id));

                    // Remove deleted constituents
                    foreach (var toRemove in existingConstituents.Where(ec => ec.ConstituentWordId != null && !selectedIds.Contains(ec.ConstituentWordId!)))
                    {
                        db.PhraseConstituents.Remove(toRemove);
                    }

                    // Add new constituents
                    foreach (var newId in selectedIds.Except(existingIds))
                    {
                        db.PhraseConstituents.Add(new PhraseConstituent
                        {
                            PhraseWordId = word.Id,
                            ConstituentWordId = newId,
                            CreatedAt = DateTime.UtcNow
                        });
                    }

                    await db.SaveChangesAsync();
                }
                else if (selectedLexicalUnitType == LexicalUnitType.Word)
                {
                    // Remove all constituents if changed to Word type
                    using var scope = _serviceProvider.CreateScope();
                    var db = scope.ServiceProvider.GetRequiredService<ApplicationDbContext>();

                    var existingConstituents = await db.PhraseConstituents
                        .Where(pc => pc.PhraseWordId == word.Id)
                        .ToListAsync();

                    if (existingConstituents.Count > 0)
                    {
                        db.PhraseConstituents.RemoveRange(existingConstituents);
                        await db.SaveChangesAsync();
                    }
                }
            }

            Toast.ShowSuccess(string.IsNullOrEmpty(Id) || Id == "0" ? $"{Localize["VocabWordEdit_AddedSuccess"]}" : $"{Localize["VocabWordEdit_UpdatedSuccess"]}");
            GoBack();
        }
        catch (Exception ex)
        {
            errorMessage = $"{string.Format(Localize["Common_SaveFailed"], ex.Message)}";
            Logger.LogError(ex, "Failed to save vocabulary word");
        }
        finally
        {
            isSaving = false;
        }
    }

