@page "/auth/login"
@attribute [AllowAnonymous]
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

<EnvironmentBadge />
<div class="d-flex vh-100 align-items-center justify-content-center">
    <div class="w-100" style="max-width: 440px; padding: 1rem;">
        <div class="text-center mb-4">
            <h1 class="text-primary-ss fs-3 fw-bold">
                <i class="bi bi-translate me-2"></i>SentenceStudio
            </h1>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
        <h2 class="card-title text-center mb-4">@Localize["Login_SignIn"]</h2>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger mb-3" role="alert">
                @errorMessage
            </div>
        }

        <div class="mb-3">
            <label class="form-label" for="email">@Localize["Common_Email"]</label>
            <input type="email" id="email" class="form-control"
                   @bind="email" @bind:event="oninput" placeholder='@Localize["Common_EmailPlaceholder"]' disabled="@isBusy" />
        </div>

        <div class="mb-3">
            <label class="form-label" for="password">@Localize["Common_Password"]</label>
            <div class="input-group">
                <input type="@(showPassword ? "text" : "password")" id="password" class="form-control"
                       @bind="password" @bind:event="oninput" placeholder='@Localize["Common_PasswordPlaceholder"]' disabled="@isBusy" />
                <button class="btn btn-outline-secondary" type="button" @onclick="() => showPassword = !showPassword" disabled="@isBusy">
                    <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                </button>
            </div>
        </div>

        <div class="mb-3 form-check">
            <input type="checkbox" class="form-check-input" id="rememberMe" @bind="rememberMe" disabled="@isBusy" />
            <label class="form-check-label" for="rememberMe">
                @Localize["Common_RememberMe"]
            </label>
        </div>

        <div class="d-grid gap-2 mb-3">
            <button class="btn btn-primary w-100" @onclick="HandleLogin" disabled="@(!CanSubmit)">
                @if (isBusy)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>@Localize["Login_SigningIn"]</span>
                }
                else
                {
                    <span>@Localize["Login_SignIn"]</span>
                }
            </button>
        </div>

        <hr />
        <div class="text-center">
            <p class="mb-2">
                <a href="/auth/forgot-password">@Localize["Login_ForgotPassword"]</a>
            </p>
            <p>
                @Localize["Login_NoAccountCreateOne"]
                <a href="/auth/register">@Localize["Login_CreateOne"]</a>
            </p>
        </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ILogger<LoginPage> Logger { get; set; } = default!;

    private string email = "";
    private string password = "";
    private string? errorMessage;
    private bool isBusy;
    private bool showPassword;
    private bool rememberMe;

    protected override void OnInitialized()
    {
        Localize.CultureChanged += OnCultureChanged;
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private bool CanSubmit => !isBusy
        && !string.IsNullOrWhiteSpace(email)
        && !string.IsNullOrWhiteSpace(password);

    private async Task HandleLogin()
    {
        if (!CanSubmit) return;

        isBusy = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await AuthService.SignInAsync(email.Trim(), password);

            if (result is not null)
            {
                Logger.LogInformation("Signed in as {User}", result.UserName);

                Preferences.Set("app_is_authenticated", true);
                
                if (rememberMe)
                {
                    Preferences.Set("remember_me", true);
                    Preferences.Set("remember_email", email.Trim());
                }

                // Determine where to send the user — onboarding if not yet completed
                var returnUrl = Preferences.Get("is_onboarded", false) ? "/" : "/onboarding";

                // If the token contains a userId|token pair, redirect to HTTP sign-in endpoint
                // (Blazor Server can't set cookies over WebSocket)
                if (result.AccessToken?.Contains('|') == true)
                {
                    var parts = result.AccessToken.Split('|', 2);
                    var signInUrl = $"/account-action/AutoSignIn?userId={Uri.EscapeDataString(parts[0])}&token={Uri.EscapeDataString(parts[1])}&returnUrl={Uri.EscapeDataString(returnUrl)}";
                    NavManager.NavigateTo(signInUrl, forceLoad: true);
                }
                else
                {
                    NavManager.NavigateTo(returnUrl, forceLoad: true);
                }
            }
            else
            {
                errorMessage = Localize["Login_InvalidCredentials"];
            }
        }
        catch (NotSupportedException)
        {
            errorMessage = Localize["Login_NotAvailable"];
        }
        catch (HttpRequestException ex)
        {
            Logger.LogError(ex, "Login connectivity error");
            errorMessage = Localize["Login_ConnectionError"];
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Login failed");
            errorMessage = Localize["Login_UnexpectedError"];
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }
}
