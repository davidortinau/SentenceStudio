@page "/auth/forgot-password"
@attribute [AllowAnonymous]
@using System.Net.Http.Json
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

<EnvironmentBadge />
<div class="d-flex vh-100 align-items-center justify-content-center">
    <div class="w-100" style="max-width: 440px; padding: 1rem;">
        <div class="text-center mb-4">
            <h1 class="text-primary-ss fs-3 fw-bold">
                <i class="bi bi-translate me-2"></i>SentenceStudio
            </h1>
        </div>
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="card-title text-center mb-4">@Localize["ForgotPassword_Title"]</h2>

                @if (resetSent)
                {
                    <div class="alert alert-success" role="alert">
                        @Localize["ForgotPassword_ResetSent"]
                    </div>
                    <div class="text-center mt-3">
                        <a href="/auth/login" class="btn btn-primary w-100">@Localize["ForgotPassword_BackToSignIn"]</a>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger mb-3" role="alert">
                            @errorMessage
                        </div>
                    }

                    <p class="text-muted mb-3">
                        @Localize["ForgotPassword_Instructions"]
                    </p>

                    <div class="mb-3">
                        <label class="form-label" for="email">@Localize["Common_Email"]</label>
                        <input type="email" id="email" class="form-control"
                               @bind="email" @bind:event="oninput" placeholder='@Localize["Common_EmailPlaceholder"]' disabled="@isBusy" />
                    </div>

                    <div class="d-grid gap-2 mb-3">
                        <button class="btn btn-primary w-100" @onclick="HandleForgotPassword" disabled="@(!CanSubmit)">
                            @if (isBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>@Localize["ForgotPassword_Sending"]</span>
                            }
                            else
                            {
                                <span>@Localize["ForgotPassword_SendResetLink"]</span>
                            }
                        </button>
                    </div>

                    <hr />
                    <div class="text-center">
                        <a href="/auth/login">@Localize["ForgotPassword_BackToSignIn"]</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IHttpClientFactory HttpClientFactory { get; set; } = default!;
    [Inject] private ILogger<ForgotPasswordPage> Logger { get; set; } = default!;

    private string email = "";
    private string? errorMessage;
    private bool isBusy;
    private bool resetSent;

    private bool CanSubmit => !isBusy && !string.IsNullOrWhiteSpace(email);

    protected override void OnInitialized()
    {
        Localize.CultureChanged += OnCultureChanged;
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private async Task HandleForgotPassword()
    {
        if (!CanSubmit) return;

        isBusy = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("AuthClient");
            var response = await client.PostAsJsonAsync("/api/auth/forgot-password", new { Email = email.Trim() });

            // Always show success message to avoid email enumeration
            resetSent = true;

            if (!response.IsSuccessStatusCode)
            {
                Logger.LogWarning("Forgot password returned {Status}", response.StatusCode);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Forgot password request failed");
            // Still show success to avoid enumeration
            resetSent = true;
        }
        finally
        {
            isBusy = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }
}
