@page "/"
@attribute [Authorize]
@using SentenceStudio.Services.Progress
@using SentenceStudio.Data
@implements IAsyncDisposable

@if (isNewUser)
{
    <PageHeader Title="Welcome" />
}
else if (isTodaysPlanMode)
{
    <PageHeader Title="Dashboard">
        <ToolbarActions>
            <button class="btn btn-sm btn-icon" @onclick="RefreshDashboardAsync" disabled="@isRefreshing" title="Refresh">
                <i class="bi bi-arrow-clockwise @(isRefreshing ? "spin" : "")" style="font-size: 1.25rem;"></i>
            </button>
        </ToolbarActions>
        <SecondaryActions>
            <button class="dropdown-item" @onclick="RegeneratePlanAsync">
                <i class="bi bi-arrow-clockwise me-2"></i>Regenerate Plan
            </button>
        </SecondaryActions>
    </PageHeader>
}
else
{
    <PageHeader Title="Dashboard">
        <ToolbarActions>
            <button class="btn btn-sm btn-icon" @onclick="RefreshDashboardAsync" disabled="@isRefreshing" title="Refresh">
                <i class="bi bi-arrow-clockwise @(isRefreshing ? "spin" : "")" style="font-size: 1.25rem;"></i>
            </button>
        </ToolbarActions>
    </PageHeader>
}

@* ============ GETTING STARTED (new user) ============ *@
@if (isNewUser)
{
    <div class="d-flex flex-column align-items-center text-center px-3" style="max-width: 640px; margin: 0 auto;">
        <i class="bi bi-translate fs-1 mb-3" style="color: var(--bs-primary);"></i>
        <h1 class="ss-title1 mb-2">Start Your Language Journey</h1>
        <p class="ss-body1 text-secondary-ss mb-4">
            Set up your first learning resource and vocabulary so you can dive into
            activities like quizzes, conversation practice, and writing exercises.
        </p>

        @if (!string.IsNullOrEmpty(starterError))
        {
            <div class="alert alert-danger w-100 mb-3" role="alert">
                <i class="bi bi-exclamation-triangle me-1"></i>@starterError
            </div>
        }

        <div class="row g-3 w-100 mb-4">
            <div class="col-12 col-md-6">
                <div class="card card-ss p-4 h-100 text-center">
                    <i class="bi bi-rocket-takeoff fs-2 mb-2" style="color: var(--bs-primary);"></i>
                    <h2 class="ss-title3 mb-2">Quick Start</h2>
                    <p class="text-secondary-ss small mb-3">
                        Create a starter Korean resource with 20 common vocabulary words
                        so you can begin practicing immediately.
                    </p>
                    <button class="btn btn-ss-primary mt-auto" @onclick="CreateStarterResourceAsync" disabled="@isCreatingStarter">
                        @if (isCreatingStarter)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            <span>Setting up...</span>
                        }
                        else
                        {
                            <i class="bi bi-plus-circle me-1"></i>
                            <span>Create Starter Resource</span>
                        }
                    </button>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="card card-ss p-4 h-100 text-center">
                    <i class="bi bi-pencil-square fs-2 mb-2" style="color: var(--bs-primary);"></i>
                    <h2 class="ss-title3 mb-2">Create Your Own</h2>
                    <p class="text-secondary-ss small mb-3">
                        Choose your own language, add custom vocabulary, or import from
                        a podcast transcript or article.
                    </p>
                    <a class="btn btn-outline-secondary mt-auto" href="/resources/add">
                        <i class="bi bi-arrow-right me-1"></i>
                        <span>Add a Resource</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else
{

@if (AppState?.CurrentUserProfile?.Name is { Length: > 0 })
{
    <div class="mb-3 d-none d-md-block">
        <h1 class="ss-title1 mb-1">@WelcomeMessage</h1>
    </div>
}

@* ============ MODE SWITCHER ============ *@
<div class="btn-group w-100 mb-4" role="group" aria-label="Dashboard mode">
    <button type="button"
            class="btn @(isTodaysPlanMode ? "btn-ss-primary" : "btn-outline-secondary")"
            @onclick="() => SetMode(true)">
        <i class="bi bi-calendar-check me-1"></i>Today's Plan
    </button>
    <button type="button"
            class="btn @(!isTodaysPlanMode ? "btn-ss-primary" : "btn-outline-secondary")"
            @onclick="() => SetMode(false)">
        <i class="bi bi-sliders me-1"></i>Choose My Own
    </button>
</div>

@if (isTodaysPlanMode)
{
    @* ============ TODAY'S PLAN MODE ============ *@
    @if (isPlanLoading)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (todaysPlan is not null)
    {
        @* Streak badge *@
        @if (todaysPlan.Streak is { CurrentStreak: > 0 } streak)
        {
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="badge bg-warning text-dark fs-6">
                    <i class="bi bi-fire me-1"></i>@streak.CurrentStreak day streak
                </span>
                @if (streak.LongestStreak > streak.CurrentStreak)
                {
                    <span class="text-secondary-ss small">Best: @streak.LongestStreak days</span>
                }
            </div>
        }

        @* Progress summary *@
        <div class="card card-ss p-3 mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="ss-body1 fw-semibold">Today's Progress</span>
                <span class="text-secondary-ss small">
                    @todaysPlan.CompletedCount / @todaysPlan.TotalCount activities
                    &middot; @(todaysPlan.Items.Sum(i => i.MinutesSpent)) / @todaysPlan.EstimatedTotalMinutes min
                </span>
            </div>
            <div class="progress" style="height: 8px;">
                <div class="progress-bar bg-success" role="progressbar"
                     style="width: @(todaysPlan.CompletionPercentage)%"
                     aria-valuenow="@todaysPlan.CompletionPercentage"
                     aria-valuemin="0" aria-valuemax="100"></div>
            </div>
            @{
                var resourceNames = todaysPlan.Items
                    .Where(i => !string.IsNullOrEmpty(i.ResourceTitle))
                    .Select(i => i.ResourceTitle!)
                    .Distinct()
                    .ToList();
            }
            @if (resourceNames.Any())
            {
                <div class="text-secondary-ss small mt-2 mb-0">
                    <i class="bi bi-book me-1"></i>@string.Join(", ", resourceNames)
                </div>
            }
            @if (!string.IsNullOrEmpty(todaysPlan.Rationale))
            {
                <p class="text-secondary-ss small mt-1 mb-0">@todaysPlan.Rationale</p>
            }
        </div>

        @* Plan items *@
        <div class="d-flex flex-column gap-2 mb-4">
            @foreach (var item in todaysPlan.Items)
            {
                <div class="card card-ss p-3 @(item.IsCompleted ? "opacity-75" : "")"
                     role="button"
                     @onclick="() => LaunchPlanItem(item)">
                    <div class="d-flex align-items-center gap-3">
                        <div>
                            @if (item.IsCompleted)
                            {
                                <i class="bi bi-check-circle-fill text-success fs-4"></i>
                            }
                            else
                            {
                                <i class="bi @GetActivityIcon(item.ActivityType) fs-4" style="color: var(--bs-primary);"></i>
                            }
                        </div>
                        <div class="flex-grow-1">
                            <div class="ss-body1 fw-semibold @(item.IsCompleted ? "text-decoration-line-through" : "")">
                                @GetActivityLabel(item.ActivityType)
                            </div>
                            <div class="text-secondary-ss small">
                                @if (!string.IsNullOrEmpty(item.ResourceTitle))
                                {
                                    <span>@item.ResourceTitle</span>
                                    <span class="mx-1">&middot;</span>
                                }
                                @if (item.MinutesSpent > 0)
                                {
                                    <span class="@(item.IsCompleted ? "text-success" : "")">@item.MinutesSpent / @item.EstimatedMinutes min</span>
                                }
                                else
                                {
                                    <span>~@(item.EstimatedMinutes) min</span>
                                }
                                @if (item.VocabDueCount.HasValue && item.VocabDueCount > 0)
                                {
                                    <span class="mx-1">&middot;</span>
                                    <span>@item.VocabDueCount words</span>
                                }
                            </div>
                            @if (item.MinutesSpent > 0 && !item.IsCompleted)
                            {
                                <div class="progress mt-1" style="height: 4px;">
                                    <div class="progress-bar bg-primary" role="progressbar"
                                         style="width: @(Math.Min(100, item.EstimatedMinutes > 0 ? (int)((double)item.MinutesSpent / item.EstimatedMinutes * 100) : 0))%"></div>
                                </div>
                            }
                        </div>
                        <i class="bi bi-chevron-right text-secondary-ss"></i>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card card-ss p-4 mb-4 text-center">
            <i class="bi bi-calendar-plus fs-1 text-secondary-ss mb-2"></i>
            <p class="ss-body1 mb-3">No plan for today yet.</p>
            @if (!string.IsNullOrEmpty(planError))
            {
                <div class="alert alert-warning mb-3" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@planError
                </div>
            }
            <button class="btn btn-ss-primary mx-auto" style="max-width: 200px;" @onclick="GeneratePlanAsync" disabled="@isPlanLoading">
                @if (isPlanLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                <i class="bi bi-magic me-1"></i>Generate Plan
            </button>
        </div>
    }
}
else
{
    @* ============ CHOOSE MY OWN MODE ============ *@
    <div class="card card-ss p-3 mb-4">
        <div class="mb-3">
            <label class="ss-body2 fw-semibold mb-1">Learning Resources</label>
            <select id="resourceSelect" multiple></select>
        </div>
        <div>
            <label class="ss-body2 fw-semibold mb-1">Skill Profile</label>
            <select id="skillSelect"></select>
        </div>
    </div>

    @* Activity cards *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="ss-title2 mb-0">Activities</h2>
        <button class="btn btn-sm btn-outline-secondary d-md-none" @onclick="ToggleActivitiesExpanded">
            @if (showAllActivities)
            {
                <span>Show Less <i class="bi bi-chevron-up"></i></span>
            }
            else
            {
                <span>See All <i class="bi bi-chevron-down"></i></span>
            }
        </button>
    </div>
    <div class="row g-3 mb-4">
        @for (int i = 0; i < activities.Length; i++)
        {
            var activity = activities[i];
            var hiddenOnMobile = i >= 6 && !showAllActivities; // Hide beyond 6 on mobile when collapsed
            <div class="col-6 col-md-4 col-lg-3 @(hiddenOnMobile ? "d-none d-md-block" : "")">
                <div class="card card-ss p-3 text-center h-100" role="button"
                     @onclick="() => NavigateToActivity(activity.Route)">
                    <div class="fs-2 mb-2"><i class="bi @activity.Icon"></i></div>
                    <div class="ss-body1 fw-semibold">@activity.Label</div>
                </div>
            </div>
        }
    </div>
}

@* ============ VOCABULARY STATS ============ *@
<h2 class="ss-title2 mb-3">Vocabulary</h2>

@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (vocabSummary is not null)
{
    var total = vocabSummary.New + vocabSummary.Learning + vocabSummary.Familiar + vocabSummary.Review + vocabSummary.Known;
    <div class="row g-3 mb-4">
        <div class="col-6 col-md">
            <div class="card card-ss p-3 text-center">
                <div class="fs-3 fw-bold" style="color: var(--bs-primary);">@vocabSummary.New</div>
                <div class="text-secondary-ss small">New</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="card card-ss p-3 text-center">
                <div class="fs-3 fw-bold text-warning-ss">@vocabSummary.Learning</div>
                <div class="text-secondary-ss small">Learning</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="card card-ss p-3 text-center">
                <div class="fs-3 fw-bold" style="color: var(--bs-info);">@vocabSummary.Familiar</div>
                <div class="text-secondary-ss small"><i class="bi bi-star me-1"></i>Familiar</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="card card-ss p-3 text-center">
                <div class="fs-3 fw-bold text-warning-ss">@vocabSummary.Review</div>
                <div class="text-secondary-ss small">Review</div>
            </div>
        </div>
        <div class="col-6 col-md">
            <div class="card card-ss p-3 text-center">
                <div class="fs-3 fw-bold text-success-ss">@vocabSummary.Known</div>
                <div class="text-secondary-ss small">Known</div>
            </div>
        </div>
    </div>

    @if (total > 0)
    {
        <div class="card card-ss p-3 mb-4">
            <div class="d-flex justify-content-between align-items-center">
                <span class="ss-body1">Total words: <strong>@total</strong></span>
                <span class="text-secondary-ss">7-day accuracy: <strong>@(Math.Round(vocabSummary.SuccessRate7d * 100))%</strong></span>
            </div>
        </div>
    }
}
else
{
    <div class="card card-ss p-4 mb-4 text-center">
        <p class="text-secondary-ss mb-0">No vocabulary data yet. Start practicing!</p>
    </div>
}

} @* end of isNewUser else *@

@code {
    private const string PREF_DASHBOARD_MODE = "DashboardMode";
    private const string PREF_SELECTED_RESOURCE_IDS = "SelectedResourceIds";
    private const string PREF_SELECTED_SKILL_PROFILE_ID = "SelectedSkillProfileId";

    [Inject] private IAppState AppState { get; set; } = default!;
    [Inject] private IProgressService ProgressService { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ILogger<Index> Logger { get; set; } = default!;
    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private SkillProfileRepository SkillRepo { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private SentenceStudio.Services.ISyncService? SyncService { get; set; }

    private IJSObjectReference? jsModule;
    private DotNetObjectReference<Index>? dotNetRef;

    private bool isLoading;
    private bool isPlanLoading;
    private bool isRefreshing;
    private bool isTodaysPlanMode = true;
    private bool showAllActivities = false;
    private VocabProgressSummary? vocabSummary;
    private TodaysPlan? todaysPlan;

    private bool isNewUser;
    private bool isCreatingStarter;
    private string? starterError;
    private string? planError;

    private List<LearningResource>? allResources;
    private List<SkillProfile>? allSkills;
    private List<string> selectedResourceIds = new();
    private string? selectedSkillId;

    private string WelcomeMessage =>
        AppState?.CurrentUserProfile?.Name is { Length: > 0 } name
            ? $"Welcome, {name}!"
            : "Dashboard";

    private readonly record struct ActivityInfo(string Label, string Icon, string Route);

    private static readonly ActivityInfo[] activities =
    [
        new("Conversation", "bi-chat-dots", "conversation"),
        new("Describe a Scene", "bi-image", "scene"),
        new("Translate", "bi-translate", "translation"),
        new("Cloze", "bi-puzzle", "cloze"),
        new("Writing", "bi-pencil-square", "writing"),
        new("Reading", "bi-book", "reading"),
        new("Vocabulary Quiz", "bi-card-checklist", "vocab-quiz"),
        new("Vocabulary Matching", "bi-grid-3x3-gap", "vocab-matching"),
        new("Shadowing", "bi-soundwave", "shadowing"),
        new("How Do You Say", "bi-chat-left-dots", "how-do-you-say"),
        new("Minimal Pairs", "bi-ear", "minimal-pairs"),
        new("Word Association", "bi-lightbulb", "word-association"),
    ];

    protected override async Task OnInitializedAsync()
    {
        await CheckNewUserAsync();
        if (isNewUser) return;

        var savedMode = Preferences.Get(PREF_DASHBOARD_MODE, "TodaysPlan");
        isTodaysPlanMode = savedMode == "TodaysPlan";

        await LoadVocabStatsAsync();

        if (isTodaysPlanMode)
            await LoadPlanAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/SentenceStudio.UI/js/app.js");
            dotNetRef = DotNetObjectReference.Create(this);

            if (!isTodaysPlanMode)
                await InitChooseOwnSelectorsAsync();
        }
    }

    private async void SetMode(bool todaysPlan)
    {
        if (isTodaysPlanMode == todaysPlan) return;
        isTodaysPlanMode = todaysPlan;
        Preferences.Set(PREF_DASHBOARD_MODE, todaysPlan ? "TodaysPlan" : "ChooseOwn");
        StateHasChanged();

        if (todaysPlan)
        {
            await LoadPlanAsync();
        }
        else
        {
            // Wait for DOM to render the select elements, then init Tom Select
            await Task.Yield();
            StateHasChanged();
            await Task.Delay(50);
            await InitChooseOwnSelectorsAsync();
        }
    }

    // ---- New User Check ----

    private async Task CheckNewUserAsync()
    {
        try
        {
            var resources = await ResourceRepo.GetAllResourcesLightweightAsync();
            var skills = await SkillRepo.ListAsync();
            var vocab = await ResourceRepo.GetAllVocabularyWordsAsync();

            isNewUser = resources.Count == 0 && vocab.Count == 0;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to check new-user status");
            isNewUser = false;
        }
    }

    private async Task CreateStarterResourceAsync()
    {
        isCreatingStarter = true;
        starterError = null;
        StateHasChanged();

        try
        {
            // 1. Ensure a skill profile exists
            var skills = await SkillRepo.ListAsync();
            if (skills.Count == 0)
            {
                var skill = new SkillProfile
                {
                    Title = "Korean Basics",
                    Description = "Foundational Korean vocabulary and grammar",
                    Language = "Korean"
                };
                await SkillRepo.SaveAsync(skill);
            }

            // 2. Create vocabulary words
            var starterWords = GetStarterVocabulary();
            foreach (var word in starterWords)
            {
                await ResourceRepo.SaveWordAsync(word);
            }

            // 3. Create the learning resource and associate vocab
            var resource = new LearningResource
            {
                Title = "Korean Starter Pack",
                Description = "Common everyday Korean words to get you started",
                MediaType = "Vocabulary List",
                Language = "Korean",
                Tags = "starter,beginner,korean",
                Vocabulary = starterWords
            };

            var savedId = await ResourceRepo.SaveResourceAsync(resource);
            if (string.IsNullOrEmpty(savedId))
            {
                starterError = "Failed to create the starter resource. Please try again.";
                return;
            }

            // Re-check — transition to normal dashboard
            isNewUser = false;

            // Load normal dashboard data
            var savedMode = Preferences.Get(PREF_DASHBOARD_MODE, "TodaysPlan");
            isTodaysPlanMode = savedMode == "TodaysPlan";
            await LoadVocabStatsAsync();
            if (isTodaysPlanMode)
                await LoadPlanAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create starter resource");
            starterError = "Something went wrong creating the starter resource. Please try again.";
        }
        finally
        {
            isCreatingStarter = false;
            StateHasChanged();
        }
    }

    private static List<VocabularyWord> GetStarterVocabulary()
    {
        return new List<VocabularyWord>
        {
            new() { TargetLanguageTerm = "안녕하세요", NativeLanguageTerm = "Hello", Language = "Korean", Tags = "greeting" },
            new() { TargetLanguageTerm = "감사합니다", NativeLanguageTerm = "Thank you", Language = "Korean", Tags = "greeting" },
            new() { TargetLanguageTerm = "네", NativeLanguageTerm = "Yes", Language = "Korean", Tags = "basic" },
            new() { TargetLanguageTerm = "아니요", NativeLanguageTerm = "No", Language = "Korean", Tags = "basic" },
            new() { TargetLanguageTerm = "물", NativeLanguageTerm = "Water", Language = "Korean", Tags = "food" },
            new() { TargetLanguageTerm = "밥", NativeLanguageTerm = "Rice / Meal", Language = "Korean", Tags = "food" },
            new() { TargetLanguageTerm = "사람", NativeLanguageTerm = "Person", Language = "Korean", Tags = "people" },
            new() { TargetLanguageTerm = "친구", NativeLanguageTerm = "Friend", Language = "Korean", Tags = "people" },
            new() { TargetLanguageTerm = "학교", NativeLanguageTerm = "School", Language = "Korean", Tags = "places" },
            new() { TargetLanguageTerm = "집", NativeLanguageTerm = "House / Home", Language = "Korean", Tags = "places" },
            new() { TargetLanguageTerm = "좋아요", NativeLanguageTerm = "Good / I like it", Language = "Korean", Tags = "adjective" },
            new() { TargetLanguageTerm = "많이", NativeLanguageTerm = "A lot / Much", Language = "Korean", Tags = "adverb" },
            new() { TargetLanguageTerm = "지금", NativeLanguageTerm = "Now", Language = "Korean", Tags = "time" },
            new() { TargetLanguageTerm = "오늘", NativeLanguageTerm = "Today", Language = "Korean", Tags = "time" },
            new() { TargetLanguageTerm = "내일", NativeLanguageTerm = "Tomorrow", Language = "Korean", Tags = "time" },
            new() { TargetLanguageTerm = "먹다", NativeLanguageTerm = "To eat", Language = "Korean", Tags = "verb" },
            new() { TargetLanguageTerm = "가다", NativeLanguageTerm = "To go", Language = "Korean", Tags = "verb" },
            new() { TargetLanguageTerm = "오다", NativeLanguageTerm = "To come", Language = "Korean", Tags = "verb" },
            new() { TargetLanguageTerm = "하다", NativeLanguageTerm = "To do", Language = "Korean", Tags = "verb" },
            new() { TargetLanguageTerm = "보다", NativeLanguageTerm = "To see / To watch", Language = "Korean", Tags = "verb" },
        };
    }

    // ---- Today's Plan ----

    private async Task LoadPlanAsync()
    {
        isPlanLoading = true;
        planError = null;
        StateHasChanged();
        try
        {
            todaysPlan = await ProgressService.GetCachedPlanAsync(DateTime.UtcNow.Date);
            todaysPlan ??= await ProgressService.GenerateTodaysPlanAsync();
        }
        catch (HttpRequestException ex)
        {
            Logger.LogWarning(ex, "Failed to load today's plan - network error");
            planError = "Network error. Please check your connection.";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load today's plan");
            planError = "Unable to load plan. Please try refreshing.";
        }
        finally
        {
            isPlanLoading = false;
            StateHasChanged();
        }
    }

    private async Task GeneratePlanAsync()
    {
        isPlanLoading = true;
        planError = null;
        StateHasChanged();
        try
        {
            todaysPlan = await ProgressService.GenerateTodaysPlanAsync();
            if (todaysPlan == null)
            {
                planError = "Unable to generate plan. Please try again.";
            }
        }
        catch (HttpRequestException ex)
        {
            Logger.LogWarning(ex, "Failed to generate plan - network error");
            planError = "Network error. Please check your connection and try again.";
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to generate plan");
            planError = "Unable to generate plan. Please try again later.";
        }
        finally
        {
            isPlanLoading = false;
            StateHasChanged();
        }
    }

    private async Task RegeneratePlanAsync()
    {
        isPlanLoading = true;
        StateHasChanged();
        try
        {
            await ProgressService.ClearCachedPlanAsync(DateTime.Today);
            todaysPlan = await ProgressService.GenerateTodaysPlanAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to regenerate plan");
        }
        finally
        {
            isPlanLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshDashboardAsync()
    {
        isRefreshing = true;
        StateHasChanged();
        try
        {
            // On mobile: trigger sync first
            // Use runtime detection instead of compile-time since shared Razor components
            // don't get platform-specific preprocessor symbols
            if (SyncService != null && DeviceInfo.Platform != DevicePlatform.Unknown)
            {
                Logger.LogInformation("Triggering CoreSync from dashboard refresh (Platform: {Platform})", DeviceInfo.Platform);
                await SyncService.TriggerSyncAsync();
                Logger.LogInformation("CoreSync completed");
            }
            
            // Reload dashboard data
            Logger.LogInformation("Reloading dashboard data...");
            await LoadVocabStatsAsync();
            if (isTodaysPlanMode)
            {
                await LoadPlanAsync();
            }
            
            Logger.LogInformation("Dashboard refresh complete");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to refresh dashboard");
        }
        finally
        {
            isRefreshing = false;
            StateHasChanged();
        }
    }

    private void LaunchPlanItem(DailyPlanItem item)
    {
        var route = MapActivityRoute(item.ActivityType);
        // Pass resource/skill via query params when available
        var query = new List<string>();
        var multiResourceRoutes = new HashSet<string> { "vocab-quiz", "vocab-matching" };
        if (!string.IsNullOrEmpty(item.ResourceId))
        {
            if (multiResourceRoutes.Contains(route))
                query.Add($"resourceIds={item.ResourceId}");
            else
                query.Add($"resourceId={item.ResourceId}");
        }
        if (!string.IsNullOrEmpty(item.SkillId))
            query.Add($"skillId={item.SkillId}");
        query.Add($"planItemId={item.Id}");

        var url = $"/{route}" + (query.Count > 0 ? "?" + string.Join("&", query) : "");
        NavManager.NavigateTo(url);
    }

    // ---- Choose My Own ----

    private async Task InitChooseOwnSelectorsAsync()
    {
        if (jsModule is null) return;

        try
        {
            // Load data if needed
            allResources ??= await ResourceRepo.GetAllResourcesLightweightAsync();
            allSkills ??= await SkillRepo.ListAsync();

            // Load saved selections
            var savedResIds = Preferences.Get(PREF_SELECTED_RESOURCE_IDS, "");
            selectedResourceIds = string.IsNullOrEmpty(savedResIds)
                ? new List<string>()
                : savedResIds.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
            selectedSkillId = Preferences.Get(PREF_SELECTED_SKILL_PROFILE_ID, "");

            // Init resource multi-select
            var resOptions = allResources.Select(r => new { value = r.Id.ToString(), text = r.Title ?? $"Resource {r.Id}" }).ToArray();
            await jsModule.InvokeVoidAsync("initTomSelect", "resourceSelect", resOptions, true, dotNetRef, "OnResourceSelectionChanged");

            // Set initial values if saved
            if (selectedResourceIds.Count > 0)
            {
                await jsModule.InvokeVoidAsync("setTomSelectValues", "resourceSelect", selectedResourceIds.ToArray());
            }

            // Init skill dropdown
            var skillOptions = allSkills.Select(s => new { value = s.Id.ToString(), text = s.Title ?? $"Skill {s.Id}" }).ToArray();
            await jsModule.InvokeVoidAsync("initTomSelect", "skillSelect", skillOptions, false, dotNetRef, "OnSkillSelectionChanged");

            // Set initial value if saved
            if (!string.IsNullOrEmpty(selectedSkillId))
                await jsModule.InvokeVoidAsync("setTomSelectValues", "skillSelect", new[] { selectedSkillId });
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to initialize Choose My Own selectors");
        }
    }

    [JSInvokable]
    public void OnResourceSelectionChanged(string[] values)
    {
        selectedResourceIds = values.ToList();
        var csv = string.Join(",", values);
        if (!string.IsNullOrEmpty(csv))
            Preferences.Set(PREF_SELECTED_RESOURCE_IDS, csv);
        else
            Preferences.Remove(PREF_SELECTED_RESOURCE_IDS);
    }

    [JSInvokable]
    public void OnSkillSelectionChanged(string[] values)
    {
        selectedSkillId = values.FirstOrDefault();
        if (!string.IsNullOrEmpty(selectedSkillId))
            Preferences.Set(PREF_SELECTED_SKILL_PROFILE_ID, selectedSkillId);
        else
            Preferences.Remove(PREF_SELECTED_SKILL_PROFILE_ID);
    }

    // ---- Shared ----

    private async Task LoadVocabStatsAsync()
    {
        isLoading = true;
        try
        {
            var fromUtc = DateTime.UtcNow.AddDays(-30);
            vocabSummary = await ProgressService.GetVocabSummaryAsync(fromUtc);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load vocabulary stats");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToActivity(string route)
    {
        var query = new List<string>();

        // Activities that support multiple resources
        var multiResourceRoutes = new HashSet<string> { "vocab-quiz", "vocab-matching", "word-association" };

        if (selectedResourceIds.Count > 0)
        {
            if (multiResourceRoutes.Contains(route))
                query.Add($"resourceIds={string.Join(",", selectedResourceIds)}");
            else
                query.Add($"resourceId={selectedResourceIds.First()}");
        }
        if (!string.IsNullOrEmpty(selectedSkillId))
            query.Add($"skillId={selectedSkillId}");

        var url = $"/{route}" + (query.Count > 0 ? "?" + string.Join("&", query) : "");
        NavManager.NavigateTo(url);
    }

