    protected override async Task OnInitializedAsync()
    {
        Localize.CultureChanged += OnCultureChanged;
        Logger.LogInformation("VocabQuiz initialized — planItemId={PlanItemId}", PlanItemId ?? "(none)");
        var firstResourceId = ResourceIdsParam?.Split(',', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        ActivityTimer.StartSession("VocabularyReview", PlanItemId, firstResourceId, SkillIdParam);

        var userProfile = await UserProfileRepo.GetAsync();
        nativeLanguage = userProfile?.NativeLanguage ?? "English";
        targetLanguage = userProfile?.TargetLanguage ?? "Korean";
        showTextWithPhoto = userProfile?.VocabQuizShowTextWithPhoto ?? false;

        focusVocabularyIds = FocusVocabularySelection.ParseFocusVocabularyIds(FocusVocabularyIdsParam);
        launchContextKey = VocabQuizSessionSnapshot.BuildLaunchContextKey(
            PlanItemId,
            focusVocabularyIds,
            ParseResourceIds(),
            DueOnly,
            SkillIdParam);

        var activeUserId = GetActiveUserId();
        if (!string.IsNullOrWhiteSpace(activeUserId))
        {
            var session = await SessionService.GetResumableAsync(activeUserId, "VocabularyReview", launchContextKey);
            if (session != null && TryDeserializeSnapshot(session.StateJson, out _))
            {
                resumableSession = session;
                showResumePrompt = true;
                return;
            }
        }

        await LoadVocabulary();
    }

    private async Task LoadVocabulary()
    {
        isBusy = true;
        sessionMarkedComplete = false;
        try
        {
            var allWords = await LoadVocabularyWordsForCurrentLaunchAsync();

            if (!allWords.Any())
            {
                Toast.ShowWarning("No vocabulary found in the selected resources.");
                isBusy = false;
                return;
            }

            allWords = allWords
                .Where(FocusVocabularySelection.IsUsableVocabularyWord)
                .GroupBy(w => w.Id, StringComparer.Ordinal).Select(g => g.First()).ToList();

            distractorScope = allWords;

            var activeUserId = Preferences.Get("active_profile_id", "");
            var wordIds = allWords.Select(w => w.Id).ToList();
            var progressDict = await ProgressService.GetProgressForWordsAsync(wordIds, activeUserId);

            var quizCandidates = allWords.Select(word =>
            {
                var progress = progressDict.ContainsKey(word.Id) ? progressDict[word.Id]
                    : new SentenceStudio.Shared.Models.VocabularyProgress
                    {
                        VocabularyWordId = word.Id, MasteryScore = 0.0f,
                        TotalAttempts = 0, CorrectAttempts = 0
                    };
                return new VocabularyQuizItem { Word = word, Progress = progress };
            });

            if (!usingFocusVocabularyIds)
            {
                quizCandidates = quizCandidates
                    .Where(i => !(i.IsKnown))
                    .Where(i => !(i.Progress?.IsInGracePeriod ?? false));

                if (DueOnly)
                {
                    // Compare in local frame (DateTime.Now): NextReviewDate is written
                    // and read with DateTime.Now elsewhere (VocabularyProgressService,
                    // IsDueForReview). On the webapp Now == UtcNow; on a non-UTC device
                    // this stays consistent with the stored local-frame value.
                    var now = DateTime.Now; // allow:srs-local-frame — match NextReviewDate writers + IsDueForReview
                    quizCandidates = quizCandidates.Where(i =>
                    {
                        var totalAttempts = i.Progress?.TotalAttempts ?? 0;
                        var nextReview = i.Progress?.NextReviewDate;

                        if (totalAttempts == 0)
                            return true;

                        if (nextReview.HasValue && nextReview.Value <= now)
                            return true;

                        return false;
                    });
                }
            }

            batchPool = usingFocusVocabularyIds
                ? quizCandidates.Take(BatchSize).ToList()
                : quizCandidates
                    .OrderBy(i => i.Progress?.MasteryScore ?? 0f)
                    .ThenBy(_ => Guid.NewGuid())
                    .Take(BatchSize)
                    .ToList();
            
            // Fix 3: Mark items with DueOnly session flag
            foreach (var item in batchPool)
            {
                item.IsDueOnlySession = DueOnly;
                item.RequiresFullSessionDemonstration = usingFocusVocabularyIds;
                if (item.RequiresFullSessionDemonstration)
                    item.CaptureKnownWordShortcutBaseline();
            }

            if (!batchPool.Any())
            {
                Toast.ShowInfo("All vocabulary in this resource is mastered!");
                isBusy = false;
                return;
            }

            await SetupNewRound();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load vocabulary");
            Toast.ShowError($"Error loading vocabulary: {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task<List<VocabularyWord>> LoadVocabularyWordsForCurrentLaunchAsync()
    {
        focusVocabularyIds = FocusVocabularySelection.ParseFocusVocabularyIds(FocusVocabularyIdsParam);
        usingFocusVocabularyIds = focusVocabularyIds.Count > 0;
        var allWords = new List<VocabularyWord>();

        async Task LoadLegacyVocabularyAsync()
        {
            Logger.LogWarning("Activity {ActivityName} launched without FocusVocabularyIds (planItemId={PlanItemId}); falling back to legacy selection", nameof(VocabQuiz), PlanItemId);

            var resourceIds = DueOnly ? Array.Empty<string>() : ParseResourceIds();
            if (resourceIds.Length > 0)
            {
                foreach (var id in resourceIds)
                {
                    var resource = await ResourceRepo.GetResourceAsync(id);
                    if (resource?.Vocabulary?.Any() == true)
                        allWords.AddRange(resource.Vocabulary);
                }
            }
            else
            {
                var words = await ResourceRepo.GetAllVocabularyWordsWithResourcesAsync();
                allWords.AddRange(words);
            }
        }

        if (usingFocusVocabularyIds)
        {
            var userVocabulary = await ResourceRepo.GetAllVocabularyWordsWithResourcesAsync();
            allWords.AddRange(FocusVocabularySelection.SelectFocusWords(userVocabulary, focusVocabularyIds));

            if (allWords.Count == 0)
            {
                Logger.LogWarning("Activity {ActivityName} received FocusVocabularyIds but no matching vocabulary was found (planItemId={PlanItemId}); falling back to legacy selection", nameof(VocabQuiz), PlanItemId);
                usingFocusVocabularyIds = false;
                await LoadLegacyVocabularyAsync();
            }
        }
        else
        {
            await LoadLegacyVocabularyAsync();
        }

        return allWords
            .Where(FocusVocabularySelection.IsUsableVocabularyWord)
            .GroupBy(w => w.Id, StringComparer.Ordinal)
            .Select(g => g.First())
            .ToList();
    }

    private async Task ResumePreviousSessionAsync()
    {
        if (resumableSession == null)
        {
            showResumePrompt = false;
            await LoadVocabulary();
            return;
        }

        try
        {
            var snapshot = VocabQuizSessionSnapshot.Deserialize(resumableSession.StateJson);
            var allWords = await LoadVocabularyWordsForCurrentLaunchAsync();
            if (!allWords.Any())
            {
                showResumePrompt = false;
                await LoadVocabulary();
                return;
            }

            distractorScope = allWords;
            var activeUserId = GetActiveUserId();
            var allWordIds = allWords.Select(w => w.Id).ToList();
            var progressDict = await ProgressService.GetProgressForWordsAsync(allWordIds, activeUserId);

            var itemsById = allWords.ToDictionary(
                word => word.Id,
                word =>
                {
                    var progress = progressDict.TryGetValue(word.Id, out var existingProgress)
                        ? existingProgress
                        : new SentenceStudio.Shared.Models.VocabularyProgress
                        {
                            VocabularyWordId = word.Id,
                            MasteryScore = 0.0f,
                            TotalAttempts = 0,
                            CorrectAttempts = 0
                        };

                    return new VocabularyQuizItem { Word = word, Progress = progress };
                },
                StringComparer.Ordinal);

            foreach (var itemSnapshot in snapshot.BatchPool)
            {
                if (!itemsById.TryGetValue(itemSnapshot.WordId, out var item))
                    continue;

                item.SessionCorrectCount = itemSnapshot.SessionCorrectCount;
                item.SessionMCCorrect = itemSnapshot.SessionMCCorrect;
                item.SessionTextCorrect = itemSnapshot.SessionTextCorrect;
                item.PendingRecognitionCheck = itemSnapshot.PendingRecognitionCheck;
                item.LostKnownThisSession = itemSnapshot.LostKnownThisSession;
                item.WasCorrectThisSession = itemSnapshot.WasCorrectThisSession;
                item.IsDueOnlySession = itemSnapshot.IsDueOnlySession;
                item.RequiresFullSessionDemonstration = itemSnapshot.RequiresFullSessionDemonstration;
                item.UseKnownWordShortcut = itemSnapshot.UseKnownWordShortcut;
                item.RecognitionDemonstrationsBaseline = itemSnapshot.RecognitionDemonstrationsBaseline;
                item.ProductionDemonstrationsBaseline = itemSnapshot.ProductionDemonstrationsBaseline;
            }

            batchPool = snapshot.BatchPool
                .Select(itemSnapshot => itemsById.TryGetValue(itemSnapshot.WordId, out var item) ? item : null)
                .Where(item => item != null)
                .Cast<VocabularyQuizItem>()
                .ToList();

            if (!batchPool.Any())
            {
                Logger.LogWarning("Vocabulary quiz session {SessionId} had no resumable words after refresh", resumableSession.Id);
                showResumePrompt = false;
                await LoadVocabulary();
                return;
            }

            roundWordOrder = snapshot.RoundWordOrder
                .Select(wordId => itemsById.TryGetValue(wordId, out var item) ? item : null)
                .Where(item => item != null)
                .Cast<VocabularyQuizItem>()
                .ToList();

            vocabItems = roundWordOrder.Count > 0
                ? roundWordOrder.DistinctBy(item => item.Word.Id).ToList()
                : batchPool.Take(ActiveWordCount).ToList();

            sessionItems = snapshot.SessionItemsWordIds
                .Select(wordId => itemsById.TryGetValue(wordId, out var item) ? item : null)
                .Where(item => item != null)
                .Cast<VocabularyQuizItem>()
                .ToList();

            roundCursor = snapshot.RoundCursor;
            currentTurnInRound = snapshot.CurrentTurnInRound;
            roundsCompleted = snapshot.RoundsCompleted;
            wordsMastered = snapshot.WordsMastered;
            totalTurns = snapshot.TotalTurns;
            correctCount = snapshot.CorrectCount;
            promptUsesNativeLanguage = snapshot.PromptUsesNativeLanguage;
            userMode = string.IsNullOrWhiteSpace(snapshot.UserMode) ? "MultipleChoice" : snapshot.UserMode;
            activeSessionId = resumableSession.Id;
            sessionMarkedComplete = false;
            showResumePrompt = false;

            if (roundWordOrder.Count == 0 || currentTurnInRound >= roundWordOrder.Count || currentTurnInRound >= TurnsPerRound)
            {
                if (!sessionItems.Any())
                    sessionItems = vocabItems.ToList();

                showSessionSummary = true;
                currentItem = null;
                return;
            }

            currentTurnInRound = Math.Clamp(currentTurnInRound, 0, Math.Max(roundWordOrder.Count - 1, 0));
            await LoadCurrentItem(preservePromptState: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to resume vocabulary quiz session {SessionId}", resumableSession.Id);
            showResumePrompt = false;
            await LoadVocabulary();
        }
    }

    private async Task StartFreshSessionAsync()
    {
        if (resumableSession != null)
        {
            try
            {
                await SessionService.AbandonAsync(GetActiveUserId(), resumableSession.Id);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to abandon vocabulary quiz session {SessionId}", resumableSession.Id);
            }
        }

        resumableSession = null;
        activeSessionId = null;
        sessionMarkedComplete = false;
        showResumePrompt = false;
        await LoadVocabulary();
    }

    private async Task PersistSnapshotAsync()
    {
        var activeUserId = GetActiveUserId();
        if (sessionMarkedComplete || showResumePrompt || string.IsNullOrWhiteSpace(activeUserId) || string.IsNullOrWhiteSpace(launchContextKey))
            return;

        try
        {
            var snapshot = new VocabQuizSessionSnapshot
            {
                PlanItemId = PlanItemId,
                FocusVocabularyIds = focusVocabularyIds,
                ResourceIds = ParseResourceIds(),
                DueOnly = DueOnly,
                SkillId = SkillIdParam,
                BatchPool = batchPool.Select(CreateBatchItemSnapshot).ToList(),
                RoundWordOrder = roundWordOrder.Select(item => item.Word.Id).ToList(),
                RoundCursor = roundCursor,
                CurrentTurnInRound = currentTurnInRound,
                RoundsCompleted = roundsCompleted,
                WordsMastered = wordsMastered,
                TotalTurns = totalTurns,
                CorrectCount = correctCount,
                SessionItemsWordIds = sessionItems.Select(item => item.Word.Id).ToList(),
                PromptUsesNativeLanguage = promptUsesNativeLanguage,
                UserMode = userMode
            };

            var session = await SessionService.SaveSnapshotAsync(
                activeUserId,
                "VocabularyReview",
                launchContextKey,
                snapshot.Serialize());

            activeSessionId = session?.Id;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to persist vocabulary quiz session snapshot");
        }
    }

    private static VocabQuizBatchItemSnapshot CreateBatchItemSnapshot(VocabularyQuizItem item) => new()
    {
        WordId = item.Word.Id,
        SessionCorrectCount = item.SessionCorrectCount,
        SessionMCCorrect = item.SessionMCCorrect,
        SessionTextCorrect = item.SessionTextCorrect,
        PendingRecognitionCheck = item.PendingRecognitionCheck,
        LostKnownThisSession = item.LostKnownThisSession,
        WasCorrectThisSession = item.WasCorrectThisSession,
        IsDueOnlySession = item.IsDueOnlySession,
        RequiresFullSessionDemonstration = item.RequiresFullSessionDemonstration,
        UseKnownWordShortcut = item.UseKnownWordShortcut,
        RecognitionDemonstrationsBaseline = item.RecognitionDemonstrationsBaseline,
        ProductionDemonstrationsBaseline = item.ProductionDemonstrationsBaseline
    };

    private async Task CompleteActiveSessionAsync()
    {
        if (string.IsNullOrWhiteSpace(GetActiveUserId()) || string.IsNullOrWhiteSpace(launchContextKey))
        {
            sessionMarkedComplete = true;
            return;
        }

        try
        {
            await SessionService.CompleteAsync(GetActiveUserId(), "VocabularyReview", launchContextKey);
            activeSessionId = null;
            resumableSession = null;
            sessionMarkedComplete = true;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to complete vocabulary quiz session for context {LaunchContextKey}", launchContextKey);
        }
    }

    private bool TryDeserializeSnapshot(string stateJson, out VocabQuizSessionSnapshot? snapshot)
    {
        try
        {
            snapshot = VocabQuizSessionSnapshot.Deserialize(stateJson);
            return true;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Ignoring invalid vocabulary quiz session snapshot");
            snapshot = null;
            return false;
        }
    }

    private string GetActiveUserId() => Preferences.Get("active_profile_id", "");

    private async Task SetupNewRound()
    {
        showSessionSummary = false;

        // Remove mastered words from the batch pool
        batchPool.RemoveAll(i => i.ReadyToRotateOut);

        if (!batchPool.Any())
        {
            Toast.ShowSuccess("All words mastered! Session complete.");
            await CompleteActiveSessionAsync();
            await GoBack();
            return;
        }

        // F1: need-weighted sampling WITHOUT replacement across rounds.
        // batchPool stays in SRS-need order (most-overdue first) from plan selection,
        // so a rotating window preserves overdue priority while guaranteeing every word
        // is shown before any repeats — fixes "same 10 every round / never see all 20".
        // Within-round order is always shuffled so the sequence isn't memorizable.
        // Legacy (non-plan) path keeps its full-pool random draw.
        if (usingFocusVocabularyIds)
        {
            var (window, nextCursor) = RoundSampler.NextWindow(batchPool, roundCursor, ActiveWordCount);
            roundCursor = nextCursor;
            vocabItems = window;
        }
        else
        {
            vocabItems = batchPool
                .OrderBy(_ => Guid.NewGuid())
                .Take(ActiveWordCount)
                .ToList();
        }

        roundWordOrder = vocabItems.OrderBy(_ => Guid.NewGuid()).ToList();
        currentTurnInRound = 0;
        await LoadCurrentItem();
        await PersistSnapshotAsync();
    }

    private async Task LoadCurrentItem(bool preservePromptState = false)
    {
        if (currentTurnInRound >= roundWordOrder.Count || currentTurnInRound >= TurnsPerRound)
        {
            // Round complete
            roundsCompleted++;
            await HandleMasteredWords();

            sessionItems = vocabItems.ToList();
            showSessionSummary = true;
            return;
        }

        currentItem = roundWordOrder[currentTurnInRound];
        ResetSentenceShortcutState();
        if (!preservePromptState)
            promptUsesNativeLanguage = ShouldUseNativePrompt();

        questionText = GetPromptText(currentItem.Word);
        correctAnswer = GetAnswerText(currentItem.Word);
        userInput = "";
        userGuess = "";
        showAnswer = false;
        feedbackMessage = "";
        isCorrect = false;
        requireCorrectTyping = false;

        if (!preservePromptState || string.IsNullOrWhiteSpace(userMode))
            userMode = currentItem.ChooseInteractionMode();

        if (userMode == "MultipleChoice")
        {
            choiceOptions = GenerateChoiceOptions(currentItem);
            audioAnswerModeAvailable = await CanUseAudioAnswerModeAsync(choiceOptions);
        }
        else
        {
            choiceOptions = Array.Empty<QuizChoiceOption>();
            audioAnswerModeAvailable = false;
        }

        // #193 — availability check must follow the prompt side (native or target), not always target.
        audioPromptAvailable = await CanPlayAudioAsync(GetPromptAudioText(currentItem.Word), GetPromptAudioLanguage(currentItem.Word));
        ApplyPromptPreferences();

        responseTimer.Restart();

        if (QuizPrefs.AutoPlayVocabAudio && audioPromptAvailable)
        {
            _ = InvokeAsync(PlayWordAudio);
        }
    }

    private void ResetSentenceShortcutState()
    {
        isSentenceShortcutMode = false;
        isSentenceShortcutSubmitting = false;
        sentenceShortcutInput = "";
        sentenceShortcutSuccessCount = 0;
        sentenceShortcutResults.Clear();
    }

    private void OpenSentenceShortcut()
    {
        if (currentItem?.Word == null)
            return;

        autoAdvanceCts?.Cancel();
        pendingAttempt = null;
        isSentenceShortcutMode = true;
        isSentenceShortcutSubmitting = false;
        sentenceShortcutInput = "";
        sentenceShortcutSuccessCount = 0;
        sentenceShortcutResults.Clear();
    }

    private void CancelSentenceShortcut()
    {
        if (isSentenceShortcutSubmitting)
            return;

        isSentenceShortcutMode = false;
        sentenceShortcutInput = "";
        sentenceShortcutSuccessCount = 0;
        sentenceShortcutResults.Clear();
    }

    private async Task ContinueAfterSentenceShortcut()
    {
        if (isSentenceShortcutSubmitting)
            return;

        ResetSentenceShortcutState();
        await NextItem();
    }

    private string GetSentenceShortcutPlaceholder()
    {
        var targetWord = currentItem?.Word?.TargetLanguageTerm ?? "the word";
        return string.Format(Localize["VocabQuiz_SentencePlaceholder"], targetWord);
    }

    private async Task SubmitSentenceShortcut()
    {
        if (currentItem?.Word == null)
            return;

        var sentenceEntries = SplitSentenceEntries(sentenceShortcutInput);
        if (sentenceEntries.Count == 0)
        {
            Toast.ShowWarning("Write at least one sentence first.");
            return;
        }

        isSentenceShortcutSubmitting = true;
        sentenceShortcutResults.Clear();
        sentenceShortcutSuccessCount = 0;
        StateHasChanged();

        try
        {
            var activeUserId = Preferences.Get("active_profile_id", "");
            var updatedProgress = currentItem.Progress;
            var responseTimeMs = responseTimer.IsRunning ? (int)responseTimer.ElapsedMilliseconds : 0;
            var gradedResults = new List<SentenceShortcutResult>(sentenceEntries.Count);
            var gradingFailureCount = 0;

            foreach (var sentenceText in sentenceEntries)
            {
                try
                {
                    var grade = await TeacherSvc.GradeTargetWordSentence(sentenceText, currentItem.Word, targetLanguage, nativeLanguage);
                    var targetAnalysis = GetTargetWordAnalysis(grade, currentItem.Word);

                    if (targetAnalysis == null)
                    {
                        gradingFailureCount++;
                        gradedResults.Add(new SentenceShortcutResult(
                            sentenceText,
                            false,
                            $"We couldn't confirm usage of \"{currentItem.Word.TargetLanguageTerm}\" in this sentence. Try rewriting it and submit again.",
                            grade?.Accuracy ?? 0,
                            grade?.Fluency ?? 0,
                            grade?.AccuracyExplanation ?? string.Empty,
                            grade?.FluencyExplanation ?? string.Empty,
                            grade?.GrammarNotes?.RecommendedTranslation ?? string.Empty,
                            grade?.GrammarNotes?.Explanation ?? string.Empty));
                        continue;
                    }

                    var usageCorrect = targetAnalysis.UsageCorrect;
                    var usageExplanation = string.IsNullOrWhiteSpace(targetAnalysis.UsageExplanation)
                        ? usageCorrect
                            ? $"\"{currentItem.Word.TargetLanguageTerm}\" is used meaningfully here."
                            : $"This doesn't yet show a clear, correct use of \"{currentItem.Word.TargetLanguageTerm}\"."
                        : targetAnalysis.UsageExplanation;

                    gradedResults.Add(new SentenceShortcutResult(
                        sentenceText,
                        usageCorrect,
                        usageExplanation,
                        grade?.Accuracy ?? 0,
                        grade?.Fluency ?? 0,
                        grade?.AccuracyExplanation ?? string.Empty,
                        grade?.FluencyExplanation ?? string.Empty,
                        grade?.GrammarNotes?.RecommendedTranslation ?? string.Empty,
                        grade?.GrammarNotes?.Explanation ?? string.Empty));
                }
                catch (Exception sentenceEx)
                {
                    Logger.LogWarning(sentenceEx, "Failed to grade sentence \"{Sentence}\" for word {Word}", sentenceText, currentItem.Word.TargetLanguageTerm);
                    gradingFailureCount++;
                    gradedResults.Add(new SentenceShortcutResult(
                        sentenceText,
                        false,
                        "We couldn't grade this sentence right now. Please try again.",
                        0, 0, string.Empty, string.Empty, string.Empty, string.Empty));
                }
            }

            var creditedResults = gradedResults
                .Where(result => result.UsageCorrect)
                .ToList();

            sentenceShortcutSuccessCount = creditedResults.Count;

            foreach (var result in creditedResults)
            {
                updatedProgress = await ProgressService.RecordAttemptAsync(new VocabularyAttempt
                {
                    VocabularyWordId = currentItem.Word.Id,
                    UserId = activeUserId,
                    Activity = "VocabularyQuiz",
                    InputMode = InputMode.Text.ToString(),
                    WasCorrect = result.UsageCorrect,
                    DifficultyWeight = 2.5f,
                    ContextType = "Sentence",
                    UserInput = result.Sentence,
                    ExpectedAnswer = currentItem.Word.TargetLanguageTerm,
                    ResponseTimeMs = responseTimeMs
                });

                currentItem.Progress = updatedProgress;

                // Update session counters for sentence shortcut
                currentItem.SessionCorrectCount++;
                currentItem.SessionTextCorrect++;

                if (updatedProgress.IsFamiliar)
                {
                    await ProgressService.HandleVerificationProbeResultAsync(
                        currentItem.Word.Id, activeUserId, true);
                }
            }

            sentenceShortcutResults.Clear();
            sentenceShortcutResults.AddRange(gradedResults);
            
            // Fix 1: Mark as correct if any sentences passed
            if (sentenceShortcutSuccessCount > 0)
                currentItem.WasCorrectThisSession = true;
            
            totalTurns += sentenceEntries.Count;
            correctCount += sentenceShortcutSuccessCount;
            CacheService.InvalidateVocabSummary();
            sentenceShortcutInput = string.Empty;

            if (sentenceShortcutSuccessCount == sentenceShortcutResults.Count)
            {
                Toast.ShowSuccess($"Nice! {sentenceShortcutSuccessCount} sentence(s) counted toward mastery.");
            }
            else if (sentenceShortcutSuccessCount > 0)
            {
                var suffix = gradingFailureCount > 0 ? " See details below for sentences we couldn't grade." : string.Empty;
                Toast.ShowInfo($"{sentenceShortcutSuccessCount} of {sentenceShortcutResults.Count} sentence(s) counted toward mastery.{suffix}");
            }
            else if (gradingFailureCount == sentenceShortcutResults.Count)
            {
                Toast.ShowWarning("We couldn't grade your sentences right now. Please try again.");
            }
            else
            {
                Toast.ShowWarning($"Not yet—try another sentence using {currentItem.Word.TargetLanguageTerm}.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to grade sentence shortcut for word {Word}", currentItem.Word.TargetLanguageTerm);
            Toast.ShowError("We couldn't grade that sentence right now. No progress was changed. Please try again.");
        }
        finally
        {
            isSentenceShortcutSubmitting = false;
        }
    }

    private static List<string> SplitSentenceEntries(string input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return new List<string>();

        return System.Text.RegularExpressions.Regex
            .Split(input.Trim(), @"(?:\r?\n)+|(?<=[.!?。！？])")
            .Select(part => part.Trim())
            .Where(part => !string.IsNullOrWhiteSpace(part))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static VocabularyAnalysis? GetTargetWordAnalysis(GradeResponse? grade, VocabularyWord word)
    {
        var targetTerm = NormalizeTargetWordValue(word.TargetLanguageTerm);
        if (grade?.VocabularyAnalysis?.Any() != true || string.IsNullOrWhiteSpace(targetTerm))
            return null;

        foreach (var item in grade.VocabularyAnalysis)
        {
            if (NormalizeTargetWordValue(item.DictionaryForm) == targetTerm
                || NormalizeTargetWordValue(item.UsedForm) == targetTerm)
            {
                return item;
            }

            var usedFormTokens = System.Text.RegularExpressions.Regex
                .Split(item.UsedForm ?? string.Empty, @"[\s\p{P}\p{S}]+")
                .Select(NormalizeTargetWordValue)
                .Where(token => !string.IsNullOrWhiteSpace(token));

            if (usedFormTokens.Any(token => token == targetTerm))
            {
                return item;
            }
        }

        return null;
    }

    private static string NormalizeTargetWordValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var normalized = value.Trim().Normalize(System.Text.NormalizationForm.FormKC);
        var builder = new System.Text.StringBuilder(normalized.Length);

        foreach (var ch in normalized)
        {
            if (char.IsLetterOrDigit(ch) || char.IsWhiteSpace(ch))
            {
                builder.Append(char.ToLowerInvariant(ch));
            }
        }

        return builder.ToString().Trim();
    }

    private QuizChoiceOption[] GenerateChoiceOptions(VocabularyQuizItem item)
    {
        var correctOption = CreateChoiceOption(item);

        // #190 — sample distractors from the FULL vocabulary scope (resource-filtered or all user vocab),
        // not just the active round. This guarantees a full set of 4 options even when remaining-to-learn
        // shrinks to 1. Falls back to vocabItems if the scope hasn't been populated yet (defensive).
        var pool = distractorScope.Count > 0
            ? (IEnumerable<VocabularyWord>)distractorScope
            : vocabItems.Select(v => v.Word);

        var options = pool
            .Where(w => w.Id != item.Word.Id)
            .Select(w => CreateChoiceOptionForWord(w))
            .Where(option => !string.IsNullOrWhiteSpace(option.Text))
            .Where(option => !string.Equals(option.Text, correctOption.Text, StringComparison.OrdinalIgnoreCase))
            .GroupBy(option => option.Text, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .OrderBy(_ => Guid.NewGuid())
            .Take(3)
            .ToList();

        // Edge case: if the full scope has fewer than 4 unique words, we degrade gracefully —
        // we ship whatever distinct distractors we have plus the correct answer. This is
        // deterministic by construction (no synthetic options injected) and avoids leaking
        // "filler" answers that aren't real vocabulary.
        options.Add(correctOption);
        return options.OrderBy(_ => Guid.NewGuid()).ToArray();
    }

    private QuizChoiceOption CreateChoiceOption(VocabularyQuizItem item)
        => CreateChoiceOptionForWord(item.Word);

    private QuizChoiceOption CreateChoiceOptionForWord(VocabularyWord word)
    {
        var answerText = GetAnswerText(word);
        var answerLanguage = promptUsesNativeLanguage
            ? word.Language ?? targetLanguage
            : nativeLanguage;

        return new QuizChoiceOption(answerText, answerText, answerLanguage);
    }

    private async Task SelectMultipleChoice(string option)
    {
        if (showAnswer) return;
        userGuess = option;
        await CheckAnswer();
    }

    private async Task SubmitTextInput()
    {
        if (requireCorrectTyping)
            await NextItem();
        else
            await CheckAnswer();
    }

    private async Task CheckAnswer()
    {
        if (currentItem == null) return;
        responseTimer.Stop();

        string answer = userMode == "MultipleChoice" ? userGuess : userInput;
        if (string.IsNullOrWhiteSpace(answer)) return;

        // Use fuzzy matching for text mode; exact match for multiple choice (options are pre-set)
        string? fuzzyCompleteForm = null;
        if (userMode == "Text")
        {
            var matchResult = FuzzyMatcher.Evaluate(answer, correctAnswer);
            isCorrect = matchResult.IsCorrect;
            fuzzyCompleteForm = matchResult.CompleteForm;
            // TODO: Log near-misses (IsCorrect == false but low Levenshtein distance) for future training data (#150)
        }
        else
        {
            isCorrect = string.Equals(answer.Trim(), correctAnswer.Trim(), StringComparison.OrdinalIgnoreCase);
        }
        showAnswer = true;

        // Update session counters (cumulative — never reset on wrong answers, spec §1.2.3)
        if (isCorrect)
        {
            currentItem.SessionCorrectCount++;
            if (userMode == "MultipleChoice")
            {
                currentItem.SessionMCCorrect++;
                // Correct MC clears gentle demotion flag (spec §1.2.1)
                currentItem.PendingRecognitionCheck = false;
            }
            else
            {
                currentItem.SessionTextCorrect++;
            }
        }
        else
        {
            // Wrong text answer → gentle demotion: force MC next appearance (spec §1.2.1)
            if (userMode == "Text")
                currentItem.PendingRecognitionCheck = true;
            // Wrong MC does NOT clear PendingRecognitionCheck — stays set (spec §2.2)

            // LostKnownThisSession is set in RecordPendingAttemptAsync AFTER recording,
            // when we know whether IsKnown was actually lost (spec §4.3.1)
        }

        if (isCorrect) currentItem.WasCorrectThisSession = true;

        if (isCorrect && fuzzyCompleteForm != null)
            feedbackMessage = $"Correct! Full form: {fuzzyCompleteForm}";
        else if (isCorrect)
            feedbackMessage = "Correct!";
        else
            feedbackMessage = $"The answer is: {correctAnswer}";

        showMnemonicTextHint = showAnswer && isCorrect && QuizPrefs.ShowMnemonicImage
            && !string.IsNullOrWhiteSpace(currentItem.Word.MnemonicText);

        if (HasPromptImage && QuizPrefs.ShowMnemonicImage)
        {
            showPhotoPromptControl = true;
            showMnemonicImage = QuizPrefs.UsePhotoPrompt || isCorrect;
        }

        // Defer recording — allows user to override before persisting
        pendingAttempt = new VocabularyAttempt
        {
            VocabularyWordId = currentItem.Word.Id,
            UserId = Preferences.Get("active_profile_id", ""),
            Activity = "VocabularyQuiz",
            InputMode = userMode,
            WasCorrect = isCorrect,
            DifficultyWeight = userMode == "Text" ? 1.5f : 1.0f,
            ContextType = "Isolated",
            UserInput = answer,
            ExpectedAnswer = correctAnswer,
            ResponseTimeMs = (int)responseTimer.ElapsedMilliseconds
        };

        totalTurns++;
        if (isCorrect) correctCount++;

        if (!isCorrect && userMode == "Text")
        {
            requireCorrectTyping = true;
            userInput = "";
        }

        // Auto-advance after showing the answer (skip if user must retype)
        if (!requireCorrectTyping)
        {
            autoAdvanceCts?.Cancel();
            autoAdvanceCts = new CancellationTokenSource();
            var token = autoAdvanceCts.Token;
            _ = InvokeAsync(async () =>
            {
                try
                {
                    await Task.Delay(QuizPrefs.AutoAdvanceDuration, token);
                    if (!token.IsCancellationRequested)
                    {
                        await NextItem();
                        StateHasChanged();
                    }
                }
                catch (TaskCanceledException) { }
            });
        }
    }

    private async Task NextItem()
    {
        autoAdvanceCts?.Cancel();
        await RecordPendingAttemptAsync();

        // Immediate rotation check (spec §1.3): remove word mid-round if mastered
        if (currentItem != null && currentItem.ReadyToRotateOut)
        {
            roundWordOrder.Remove(currentItem);
            batchPool.Remove(currentItem);
            wordsMastered++;

            // If that was the last word in the round, trigger round summary
            if (roundWordOrder.Count == 0 || currentTurnInRound >= roundWordOrder.Count)
            {
                roundsCompleted++;
                sessionItems = vocabItems.ToList();
                showSessionSummary = true;
                requireCorrectTyping = false;
                showMnemonicImage = false;
                showInfoPanel = false;
                isImageFullscreen = false;
                pendingFocusIntoFullscreen = false;
                pendingFocusRestoreToThumbnail = false;
                await PersistSnapshotAsync();
                return;
            }
            // Don't increment currentTurnInRound — next word slides into current index
        }
        else
        {
            currentTurnInRound++;
        }

        requireCorrectTyping = false;
        showMnemonicImage = false;
        showInfoPanel = false;
        isImageFullscreen = false;
        pendingFocusIntoFullscreen = false;
        pendingFocusRestoreToThumbnail = false;
        await LoadCurrentItem();
        await PersistSnapshotAsync();
    }

    /// <summary>
    /// Persists the deferred quiz attempt. Called once per question — either
    /// as-is (incorrect) when advancing, or after the user overrides to correct.
    /// </summary>
    private async Task RecordPendingAttemptAsync()
    {
        if (pendingAttempt == null) return;
        var attempt = pendingAttempt;
        pendingAttempt = null;

        try
        {
            // Snapshot IsKnown state before recording to detect loss (spec §4.3.1)
            var wasKnownBefore = currentItem?.Progress?.IsKnown ?? false;

            var updatedProgress = await ProgressService.RecordAttemptAsync(attempt);
            if (currentItem != null)
            {
                currentItem.Progress = updatedProgress;

                // Track IsKnown loss this session (spec §4.3.1)
                if (wasKnownBefore && !updatedProgress.IsKnown)
                    currentItem.LostKnownThisSession = true;

                // IsKnown re-qualification with shorter 14-day interval (spec §4.3.1)
                if (currentItem.LostKnownThisSession && updatedProgress.IsKnown)
                {
                    updatedProgress.ReviewInterval = 14;
                    updatedProgress.NextReviewDate = DateTime.Now.AddDays(14); // allow:srs-local-frame — match NextReviewDate writers + IsDueForReview
                    // Persist the shorter interval
                    await ProgressService.UpdateProgressAsync(updatedProgress);
                }
            }

            if (updatedProgress.IsFamiliar)
            {
                // Still record the verification-probe result for SRS; no per-answer toast —
                // inline feedback ("Correct!" / "The answer is: …") already covers it.
                await ProgressService.HandleVerificationProbeResultAsync(
                    attempt.VocabularyWordId, attempt.UserId, attempt.WasCorrect);
            }

            CacheService.InvalidateVocabSummary();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to record attempt");
        }
    }

    private async Task OverrideAsCorrect()
    {
        autoAdvanceCts?.Cancel();
        isCorrect = true;
        requireCorrectTyping = false;
        feedbackMessage = "Marked correct ✓";

        // Apply session-state mutations via the shared method on
        // VocabularyQuizItem so the regression tests bind to the same code.
        // Clears PendingRecognitionCheck for both modes — see method docs.
        currentItem.ApplyOverrideAsCorrect(userMode);

        // Update the deferred attempt to correct and persist it
        if (pendingAttempt != null)
        {
            pendingAttempt.WasCorrect = true;
        }
        await RecordPendingAttemptAsync();

        correctCount++;
        StateHasChanged();

        // Auto-advance after override
        autoAdvanceCts = new CancellationTokenSource();
        var token = autoAdvanceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(QuizPrefs.AutoAdvanceDuration, token);
                if (!token.IsCancellationRequested)
                {
                    await NextItem();
                    StateHasChanged();
                }
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task HandleMasteredWords()
    {
        var mastered = vocabItems.Where(i => i.ReadyToRotateOut).ToList();
        foreach (var item in mastered)
        {
            vocabItems.Remove(item);
            batchPool.Remove(item);
            wordsMastered++;
        }
    }

    private string[] ParseResourceIds()
    {
        if (string.IsNullOrEmpty(ResourceIdsParam)) return Array.Empty<string>();
        return ResourceIdsParam.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s)).ToArray();
    }

