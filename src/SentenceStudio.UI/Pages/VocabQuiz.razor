@page "/vocab-quiz"
@attribute [Authorize]
@using Plugin.Maui.Audio
@using SentenceStudio.Shared.Services
@implements IAsyncDisposable

<div class="activity-page-wrapper">

@if (!isSentenceShortcutMode && !showAnswer && !requireCorrectTyping)
{
    <PageHeader Title="Vocabulary Quiz" ShowBack="true" OnBack="GoBack">
        <SecondaryActions>
            <li>
                <button class="dropdown-item" @onclick="OpenSentenceShortcut">
                    <i class="bi bi-pencil-square me-2"></i>Use in a sentence
                </button>
            </li>
        </SecondaryActions>
    </PageHeader>
}
else
{
    <PageHeader Title="Vocabulary Quiz" ShowBack="true" OnBack="GoBack" />
}

<div class="activity-content">
@if (showSessionSummary)
{
    <div class="d-flex flex-column align-items-center justify-content-center" style="min-height: 60vh;">
        <h2 class="ss-title1 mb-4"><i class="bi bi-journal-check me-2"></i>Session Summary</h2>
        <div class="card card-ss p-4" style="min-width: 340px;">
            <div class="d-flex justify-content-around mb-3">
                <div class="text-center">
                    <div class="ss-title2 text-success">@correctCount</div>
                    <small class="text-secondary-ss">Correct</small>
                </div>
                <div class="text-center">
                    <div class="ss-title2">@totalTurns</div>
                    <small class="text-secondary-ss">Total</small>
                </div>
                <div class="text-center">
                    <div class="ss-title2 text-success">@wordsMastered</div>
                    <small class="text-secondary-ss">Mastered</small>
                </div>
                <div class="text-center">
                    <div class="ss-title2">@roundsCompleted</div>
                    <small class="text-secondary-ss">Rounds</small>
                </div>
            </div>
            @if (sessionItems.Any())
            {
                <hr class="border-secondary" />
                @foreach (var item in sessionItems)
                {
                    var iconClass = item.WasCorrectThisSession
                        ? (item.ReadyToRotateOut ? "bi-check-circle-fill text-success" : "bi-check-circle text-success")
                        : "bi-x-circle text-danger";
                    <div class="d-flex align-items-center gap-2 py-1">
                        <i class="bi @iconClass"></i>
                        <span class="ss-body1 fw-bold" style="color: var(--bs-primary);">@item.Word.TargetLanguageTerm</span>
                        <span class="text-secondary-ss">→</span>
                        <span class="ss-body1">@item.Word.NativeLanguageTerm</span>
                    </div>
                }
            }
        </div>
        <button class="btn btn-ss-primary mt-4" @onclick="SetupNewRound">Continue</button>
        <button class="btn btn-ss-secondary mt-2" @onclick="GoBack">Done</button>
    </div>
}
else if (isBusy)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else if (currentItem != null)
{
    @if (isSentenceShortcutMode)
    {
        <div class="mx-auto" style="max-width: 720px;">
            <div class="card card-ss p-4 mb-3">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-3">
                    <div>
                        <span class="badge bg-primary-subtle text-primary-emphasis mb-2">Sentence shortcut</span>
                        <h2 class="ss-title2 mb-1" style="color: var(--bs-primary);">@currentItem.Word.TargetLanguageTerm</h2>
                        <p class="ss-body2 text-secondary-ss mb-0">@currentItem.Word.NativeLanguageTerm</p>
                    </div>
                    @if (sentenceShortcutResults.Any())
                    {
                        <button type="button"
                                class="btn btn-sm btn-ss-secondary align-self-start"
                                disabled="@isSentenceShortcutSubmitting"
                                @onclick="ContinueAfterSentenceShortcut">
                            <i class="bi bi-arrow-right me-1"></i>Continue quiz
                        </button>
                    }
                    else
                    {
                        <button type="button"
                                class="btn btn-sm btn-ss-secondary align-self-start"
                                disabled="@isSentenceShortcutSubmitting"
                                @onclick="CancelSentenceShortcut">
                            <i class="bi bi-x-lg me-1"></i>Cancel
                        </button>
                    }
                </div>

                <p class="ss-body1 mb-2">
                    Write one or more sentences using <strong>@currentItem.Word.TargetLanguageTerm</strong>.
                </p>
                <p class="ss-body2 text-secondary-ss mb-3">
                    Only meaningful usage of the target word counts toward mastery. Broader grammar feedback is still shown, but it won't penalize you by itself.
                </p>

                <form @onsubmit="SubmitSentenceShortcut" @onsubmit:preventDefault>
                    <textarea class="form-control form-control-ss mb-2"
                              rows="5"
                              @bind="sentenceShortcutInput"
                              @bind:event="oninput"
                              disabled="@isSentenceShortcutSubmitting"
                              placeholder="@GetSentenceShortcutPlaceholder()"></textarea>

                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                        <span class="ss-caption1 text-secondary-ss">Separate multiple sentences with a new line or punctuation.</span>
                        <button type="submit"
                                class="btn btn-ss-primary"
                                disabled="@(isSentenceShortcutSubmitting || string.IsNullOrWhiteSpace(sentenceShortcutInput))">
                            @if (isSentenceShortcutSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <span><i class="bi bi-send me-1"></i>Grade sentences</span>
                            }
                        </button>
                    </div>
                </form>
            </div>

            @if (sentenceShortcutResults.Any())
            {
                <div class="alert @(sentenceShortcutSuccessCount > 0 ? "alert-success" : "alert-warning") py-2">
                    <strong>@sentenceShortcutSuccessCount of @sentenceShortcutResults.Count</strong> sentence(s) counted toward mastery for
                    <strong>@currentItem.Word.TargetLanguageTerm</strong>.
                </div>

                @foreach (var result in sentenceShortcutResults)
                {
                    <div class="card card-ss p-3 mb-2">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                    <span class="badge @(result.UsageCorrect ? "bg-success" : "bg-warning text-dark")">
                                        @(result.UsageCorrect ? "Counts toward mastery" : "Needs another try")
                                    </span>
                                    <span class="ss-caption1 text-secondary-ss">@((int)result.Accuracy)% accuracy • @((int)result.Fluency)% fluency</span>
                                </div>
                                <p class="ss-body1 mb-1">@result.Sentence</p>
                                <small class="d-block text-secondary-ss"><strong>Target-word feedback:</strong> @result.UsageExplanation</small>

                                @if (!string.IsNullOrWhiteSpace(result.RecommendedSentence))
                                {
                                    <small class="d-block text-secondary-ss mt-1"><strong>Suggested:</strong> @result.RecommendedSentence</small>
                                }
                            </div>

                            <i class="bi @(result.UsageCorrect ? "bi-check-circle-fill text-success" : "bi-exclamation-circle-fill text-warning") fs-4"></i>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(result.AccuracyExplanation)
                            || !string.IsNullOrWhiteSpace(result.FluencyExplanation)
                            || !string.IsNullOrWhiteSpace(result.GrammarNotes))
                        {
                            <details class="mt-2">
                                <summary class="ss-caption1 text-secondary-ss" style="cursor: pointer;">Show details</summary>
                                <div class="mt-1">
                                    @if (!string.IsNullOrWhiteSpace(result.AccuracyExplanation))
                                    {
                                        <small class="d-block text-secondary-ss"><strong>Accuracy:</strong> @result.AccuracyExplanation</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(result.FluencyExplanation))
                                    {
                                        <small class="d-block text-secondary-ss"><strong>Fluency:</strong> @result.FluencyExplanation</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(result.GrammarNotes))
                                    {
                                        <small class="d-block text-secondary-ss"><strong>Notes:</strong> @result.GrammarNotes</small>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="text-center my-4">
            <h1 class="ss-display mb-2" style="color: var(--bs-primary);">@(showTextPrompt ? questionText : promptTitle)</h1>

            <div class="d-flex justify-content-center gap-3 mb-2">
                @if (showAudioPromptControl)
                {
                    <button class="btn btn-outline-secondary btn-sm rounded-circle"
                            style="width: 44px; height: 44px;"
                            title="Play audio"
                            disabled="@isPlayingAudio"
                            @onclick="PlayWordAudio">
                        <i class="bi @(isPlayingAudio ? "bi-volume-up-fill" : "bi-volume-up")"></i>
                    </button>
                }
                @if (showPhotoPromptControl)
                {
                    <button class="btn btn-outline-secondary btn-sm rounded-circle"
                            style="width: 44px; height: 44px;"
                            title="@(showMnemonicImage ? "Hide image" : "Show image")"
                            @onclick="ToggleMnemonicImage">
                        <i class="bi @(showMnemonicImage ? "bi-eye-slash" : "bi-image")"></i>
                    </button>
                }
                <button id="quiz-info-button" class="btn btn-outline-secondary btn-sm rounded-circle"
                        style="width: 44px; height: 44px;"
                        title="Word learning details"
                        @onclick="() => showInfoPanel = true">
                    <i class="bi bi-info-circle"></i>
                </button>
            </div>

            @if (showMnemonicImage && !string.IsNullOrWhiteSpace(currentItem?.Word?.MnemonicImageUri))
            {
                <div class="mb-3">
                    <img src="@currentItem.Word.MnemonicImageUri" alt="Mnemonic hint"
                         class="rounded shadow-sm" style="max-height: 160px; object-fit: contain;" />
                </div>
            }

            @if (showMnemonicTextHint && !string.IsNullOrWhiteSpace(currentItem?.Word?.MnemonicText))
            {
                <div class="alert alert-info py-2 px-3 mb-3 mx-auto" style="max-width: 560px;">
                    <strong>Mnemonic:</strong> @currentItem.Word.MnemonicText
                </div>
            }

            @if (showAnswer)
            {
                <p class="ss-title2">@correctAnswer</p>
            }
        </div>

        @* Feedback *@
        @if (!string.IsNullOrEmpty(feedbackMessage))
        {
            <div class="alert @(isCorrect ? "alert-success" : "alert-danger") text-center py-2 mb-3">
                @feedbackMessage
            </div>
        }

        @* Input section *@
        @if (userMode == "MultipleChoice")
        {
            @* @key on wrapper forces Blazor to destroy+recreate the entire container on turn change,
               preventing iOS WebView from carrying touch-highlight state to new buttons *@
            <div @key="@($"mc-turn-{currentTurnInRound}")" class="d-flex flex-column gap-2 mx-auto" style="max-width: 500px;">
                @for (var optionIndex = 0; optionIndex < choiceOptions.Length; optionIndex++)
                {
                    var optCopy = choiceOptions[optionIndex];
                    var optionText = optCopy.Text;
                    var optionLabel = $"Option {(char)('A' + optionIndex)}";
                    var optionId = $"quiz-option-{(char)('a' + optionIndex)}";
                    var bgClass = "";
                    var borderStyle = "";

                    if (showAnswer)
                    {
                        if (string.Equals(optionText, correctAnswer, StringComparison.OrdinalIgnoreCase))
                        {
                            bgClass = "bg-success text-white";
                            borderStyle = "border-color: var(--bs-success) !important;";
                        }
                        else if (string.Equals(optionText, userGuess, StringComparison.OrdinalIgnoreCase))
                        {
                            bgClass = "bg-danger text-white";
                            borderStyle = "border-color: var(--bs-danger) !important;";
                        }
                    }
                    else if (string.Equals(optionText, userGuess, StringComparison.OrdinalIgnoreCase))
                    {
                        borderStyle = "border-color: var(--bs-primary) !important;";
                        bgClass = "bg-opacity-10";
                    }

                    @if (ShowAudioChoiceControls)
                    {
                        <div class="d-flex align-items-stretch gap-2">
                            <button type="button"
                                    class="btn btn-outline-secondary px-3"
                                    title="Play answer audio"
                                    aria-label="@($"Play {optionLabel.ToLowerInvariant()}")"
                                    disabled="@isPlayingAudio"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => PlayChoiceAudio(optCopy)">
                                <i class="bi @(isPlayingAudio ? "bi-volume-up-fill" : "bi-volume-up")"></i>
                            </button>

                            <button class="btn btn-outline-secondary quiz-choice-btn py-3 ss-title3 flex-grow-1 @bgClass"
                                    id="@optionId"
                                    style="@borderStyle"
                                    title="Select this answer"
                                    aria-label="@($"Choose {optionLabel.ToLowerInvariant()}")"
                                    disabled="@showAnswer"
                                    @onclick="() => SelectMultipleChoice(optionText)">
                                @optionLabel
                            </button>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-outline-secondary quiz-choice-btn py-3 ss-title3 @bgClass"
                                id="@optionId"
                                style="@borderStyle"
                                disabled="@showAnswer"
                                @onclick="() => SelectMultipleChoice(optionText)">
                            @optionText
                        </button>
                    }
                }
            </div>
        }
        else
        {
            <form @onsubmit="SubmitTextInput" @onsubmit:preventDefault class="mx-auto" style="max-width: 500px;">
                <label class="form-label text-secondary-ss">Type the translation</label>
                <input id="quiz-text-input" type="text" class="form-control form-control-ss form-control-lg"
                       @bind="userInput"
                       disabled="@(showAnswer && !requireCorrectTyping)"
                       placeholder="@(requireCorrectTyping ? "Type the correct answer to continue" : "Type your answer")" />
            </form>
        }

        @* Next / Override buttons *@
        @if (showAnswer && !requireCorrectTyping)
        {
            <div class="text-center mt-4">
                <button class="btn btn-ss-primary px-5" @onclick="NextItem">Next <i class="bi bi-chevron-right ms-1"></i></button>
            </div>
        }
        else if (showAnswer && requireCorrectTyping)
        {
            <div class="text-center mt-3">
                <button class="btn btn-outline-success btn-sm" @onclick="OverrideAsCorrect">
                    <i class="bi bi-check2 me-1"></i>I was correct
                </button>
            </div>
        }
    }
}
else
{
    <div class="text-center p-5">
        <p class="ss-body1 text-secondary-ss">No vocabulary loaded.</p>
        <button class="btn btn-ss-secondary mt-3" @onclick="GoBack">Go Back</button>
    </div>
}
</div> @* end activity-content *@

@if (currentItem != null && !showSessionSummary && !isSentenceShortcutMode)
{
    <div class="activity-footer d-flex justify-content-between align-items-center">
        <span id="quiz-progress" class="ss-body1 text-secondary-ss">@(currentTurnInRound + 1) / @roundWordOrder.Count</span>
        <span id="quiz-correct-count" class="badge bg-success rounded-pill px-3"><i class="bi bi-check-lg me-1"></i>@correctCount correct</span>
    </div>
}

@* Word info diagnostic panel *@
@if (showInfoPanel && currentItem != null)
{
    <div id="quiz-info-panel" class="offcanvas offcanvas-bottom show" tabindex="-1"
         style="height: auto; max-height: 70vh; border-radius: var(--bs-border-radius-xl) var(--bs-border-radius-xl) 0 0; z-index: 1050;">
        <div class="offcanvas-header pb-1 border-bottom">
            <h5 class="ss-title3 mb-0"><i class="bi bi-info-circle me-2"></i>Learning Details</h5>
            <button type="button" class="btn-close" @onclick="() => showInfoPanel = false"></button>
        </div>
        <div class="offcanvas-body pt-2" style="overflow-y: auto;">
            @{
                var p = currentItem.Progress;
                var statusText = p?.Status.ToString() ?? "Unknown";
                var statusBadge = statusText switch
                {
                    "Known" => "bg-success",
                    "Learning" => "bg-warning text-dark",
                    "Familiar" => "bg-info text-dark",
                    _ => "bg-secondary"
                };
            }
            <div class="mb-3">
                <h6 class="ss-body1 fw-bold mb-1" style="color: var(--bs-primary);">@currentItem.Word.TargetLanguageTerm</h6>
                <span class="ss-body2 text-secondary-ss">@currentItem.Word.NativeLanguageTerm</span>
                <span class="badge @statusBadge ms-2">@statusText</span>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-6">
                    <small class="text-secondary-ss d-block">IsKnown</small>
                    <span class="ss-body2 fw-bold">@(p?.IsKnown == true ? "Yes" : "No")</span>
                </div>
                <div class="col-6">
                    <small class="text-secondary-ss d-block">IsUserDeclared</small>
                    <span class="ss-body2 fw-bold">@(p?.IsUserDeclared == true ? "Yes" : "No")</span>
                </div>
                <div class="col-6">
                    <small class="text-secondary-ss d-block">VerificationState</small>
                    <span class="ss-body2 fw-bold">@(p?.VerificationState.ToString() ?? "None")</span>
                </div>
                <div class="col-6">
                    <small class="text-secondary-ss d-block">MasteryScore</small>
                    <span class="ss-body2 fw-bold">@((p?.MasteryScore ?? 0f).ToString("P0"))</span>
                </div>
            </div>

            <hr class="border-secondary my-2" />

            <div class="row g-2 mb-3">
                <div class="col-4">
                    <small class="text-secondary-ss d-block">CurrentStreak</small>
                    <span class="ss-body2 fw-bold">@(p?.CurrentStreak.ToString("F1") ?? "0")</span>
                </div>
                <div class="col-4">
                    <small class="text-secondary-ss d-block">ProductionInStreak</small>
                    <span class="ss-body2 fw-bold">@(p?.ProductionInStreak ?? 0) / 2</span>
                </div>
                <div class="col-4">
                    <small class="text-secondary-ss d-block">TotalAttempts</small>
                    <span class="ss-body2 fw-bold">@(p?.TotalAttempts ?? 0)</span>
                </div>
                <div class="col-4">
                    <small class="text-secondary-ss d-block">CorrectAttempts</small>
                    <span class="ss-body2 fw-bold">@(p?.CorrectAttempts ?? 0)</span>
                </div>
                <div class="col-4">
                    <small class="text-secondary-ss d-block">Accuracy</small>
                    <span class="ss-body2 fw-bold">@((p?.Accuracy ?? 0f).ToString("P0"))</span>
                </div>
            </div>

            <hr class="border-secondary my-2" />
            <h6 class="ss-caption1 text-secondary-ss mb-2">SRS Schedule</h6>
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <small class="text-secondary-ss d-block">NextReviewDate</small>
                    <span class="ss-body2 fw-bold">@(p?.NextReviewDate?.ToString("MMM d, yyyy") ?? "Not scheduled")</span>
                </div>
                <div class="col-6">
                    <small class="text-secondary-ss d-block">ReviewInterval</small>
                    <span class="ss-body2 fw-bold">@(p?.ReviewInterval ?? 1) days</span>
                </div>
                <div class="col-6">
                    <small class="text-secondary-ss d-block">EaseFactor</small>
                    <span class="ss-body2 fw-bold">@((p?.EaseFactor ?? 2.5f).ToString("F2"))</span>
                </div>
                <div class="col-6">
                    <small class="text-secondary-ss d-block">IsDueForReview</small>
                    <span class="ss-body2 fw-bold @(p?.IsDueForReview == true ? "text-warning" : "")">@(p?.IsDueForReview == true ? "Yes" : "No")</span>
                </div>
            </div>

            <hr class="border-secondary my-2" />
            <h6 class="ss-caption1 text-secondary-ss mb-2">Quiz Context</h6>
            <div class="row g-2">
                <div class="col-6">
                    <small class="text-secondary-ss d-block">Quiz Mode</small>
                    <span class="ss-body2 fw-bold">@userMode</span>
                </div>
                <div class="col-6">
                    <small class="text-secondary-ss d-block">DueOnly Filter</small>
                    <span class="ss-body2 fw-bold">@(DueOnly ? "Yes" : "No")</span>
                </div>
                <div class="col-12">
                    <small class="text-secondary-ss d-block">Why This Mode</small>
                    <span class="ss-body2 fw-bold">
                        @if (currentItem.PendingRecognitionCheck)
                        {
                            <text>Recognition check (wrong text answer earlier)</text>
                        }
                        else if (userMode == "Text")
                        {
                            @if ((currentItem.Progress?.CurrentStreak ?? 0f) >= 3f)
                            {
                                <text>Lifetime streak >= 3 (global progress)</text>
                            }
                            else
                            {
                                <text>MasteryScore >= 50% (global progress)</text>
                            }
                        }
                        else
                        {
                            <text>Still building recognition (streak &lt; 3, mastery &lt; 50%)</text>
                        }
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="offcanvas-backdrop fade show" style="z-index: 1049;" @onclick="() => showInfoPanel = false"></div>
}

</div> @* end activity-page-wrapper *@

@code {
    [SupplyParameterFromQuery(Name = "resourceIds")]
    public string? ResourceIdsParam { get; set; }

    [SupplyParameterFromQuery(Name = "skillId")]
    public string? SkillIdParam { get; set; }

    [SupplyParameterFromQuery(Name = "planItemId")]
    public string? PlanItemId { get; set; }

    [SupplyParameterFromQuery(Name = "DueOnly")]
    public bool DueOnly { get; set; }

    [Inject] private LearningResourceRepository ResourceRepo { get; set; } = default!;
    [Inject] private VocabularyProgressService ProgressService { get; set; } = default!;
    [Inject] private TeacherService TeacherSvc { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private ILogger<VocabQuiz> Logger { get; set; } = default!;
    [Inject] private ElevenLabsSpeechService SpeechService { get; set; } = default!;
    [Inject] private IAudioManager AudioManager { get; set; } = default!;
    [Inject] private StreamHistoryRepository StreamHistoryRepo { get; set; } = default!;
    [Inject] private SentenceStudio.Services.SpeechVoicePreferences VoicePrefs { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IConnectivityService Connectivity { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IFileSystemService FileSystemService { get; set; } = default!;
    [Inject] private SentenceStudio.Services.VocabularyQuizPreferences QuizPrefs { get; set; } = default!;
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Progress.ProgressCacheService CacheService { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Progress.IProgressService PlanProgressService { get; set; } = default!;
    [Inject] private SentenceStudio.Services.Timer.IActivityTimerService ActivityTimer { get; set; } = default!;
    [Inject] private UserProfileRepository UserProfileRepo { get; set; } = default!;

    private const int BatchSize = 20;
    private const int ActiveWordCount = 10;
    private const int TurnsPerRound = 10;

    // State
    private bool isBusy;
    private bool showAnswer;
    private bool isCorrect;
    private bool showSessionSummary;
    private bool requireCorrectTyping;
    private bool isPlayingAudio;
    private bool showMnemonicImage;
    private bool promptUsesNativeLanguage;
    private bool showTextPrompt = true;
    private bool showAudioPromptControl = true;
    private bool showPhotoPromptControl;
    private bool showMnemonicTextHint;
    private bool audioPromptAvailable = true;
    private bool audioAnswerModeAvailable = true;
    private bool showInfoPanel;
    private IAudioPlayer? audioPlayer;
    private CancellationTokenSource? autoAdvanceCts;
    private string userInput = "";
    private string userGuess = "";
    private string userMode = "MultipleChoice";
    private string promptTitle = "";
    private string questionText = "";
    private string correctAnswer = "";
    private string feedbackMessage = "";
    private QuizChoiceOption[] choiceOptions = Array.Empty<QuizChoiceOption>();

    private List<VocabularyQuizItem> batchPool = new();
    private List<VocabularyQuizItem> vocabItems = new();
    private List<VocabularyQuizItem> sessionItems = new();
    private List<VocabularyQuizItem> roundWordOrder = new();
    private VocabularyQuizItem? currentItem;

    private int currentTurnInRound;
    private int roundsCompleted;
    private int wordsMastered;
    private int totalTurns;
    private int correctCount;
    private string nativeLanguage = "English";
    private string targetLanguage = "Korean";
    private bool isSentenceShortcutMode;
    private bool isSentenceShortcutSubmitting;
    private string sentenceShortcutInput = "";
    private int sentenceShortcutSuccessCount;
    private List<SentenceShortcutResult> sentenceShortcutResults = new();

    private readonly Random random = new();
    private System.Diagnostics.Stopwatch responseTimer = new();
    private VocabularyAttempt? pendingAttempt;

    private sealed record QuizChoiceOption(string Text, string AudioText, string AudioLanguage);
    private sealed record SentenceShortcutResult(
        string Sentence,
        bool UsageCorrect,
        string UsageExplanation,
        double Accuracy,
        double Fluency,
        string AccuracyExplanation,
