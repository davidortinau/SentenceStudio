        string RecommendedSentence,
        string GrammarNotes);

    private bool ShowAudioChoiceControls => userMode == "MultipleChoice"
        && promptUsesNativeLanguage
        && QuizPrefs.UseAudioPrompt
        && audioAnswerModeAvailable;


    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("🎯 VocabQuiz initialized — planItemId={PlanItemId}", PlanItemId ?? "(none)");
        if (!string.IsNullOrEmpty(PlanItemId))
            ActivityTimer.StartSession("VocabularyReview", PlanItemId);

        var userProfile = await UserProfileRepo.GetAsync();
        nativeLanguage = userProfile?.NativeLanguage ?? "English";
        targetLanguage = userProfile?.TargetLanguage ?? "Korean";
        await LoadVocabulary();
    }

    private async Task LoadVocabulary()
    {
        isBusy = true;
        try
        {
            // DEFENSE IN DEPTH: When DueOnly=true (SRS mode), ignore ResourceIds even if passed
            // This ensures VocabularyReview always loads from full user vocabulary pool
            var resourceIds = DueOnly ? Array.Empty<string>() : ParseResourceIds();
            var allWords = new List<VocabularyWord>();

            if (resourceIds.Length > 0)
            {
                foreach (var id in resourceIds)
                {
                    var resource = await ResourceRepo.GetResourceAsync(id);
                    if (resource?.Vocabulary?.Any() == true)
                        allWords.AddRange(resource.Vocabulary);
                }
            }
            else
            {
                // No specific resources — load all user vocabulary (e.g. from daily plan fallback)
                var words = await ResourceRepo.GetAllVocabularyWordsWithResourcesAsync();
                allWords.AddRange(words);
            }

            if (!allWords.Any())
            {
                Toast.ShowWarning("No vocabulary found in the selected resources.");
                isBusy = false;
                return;
            }

            // Deduplicate
            allWords = allWords
                .Where(w => !string.IsNullOrWhiteSpace(w.NativeLanguageTerm) && !string.IsNullOrWhiteSpace(w.TargetLanguageTerm))
                .GroupBy(w => w.Id).Select(g => g.First()).ToList();

            // Get progress
            var wordIds = allWords.Select(w => w.Id).ToList();
            var progressDict = await ProgressService.GetProgressForWordsAsync(wordIds);

            var quizCandidates = allWords.Select(word =>
            {
                var progress = progressDict.ContainsKey(word.Id) ? progressDict[word.Id]
                    : new SentenceStudio.Shared.Models.VocabularyProgress
                    {
                        VocabularyWordId = word.Id, MasteryScore = 0.0f,
                        TotalAttempts = 0, CorrectAttempts = 0
                    };
                return new VocabularyQuizItem { Word = word, Progress = progress };
            })
            .Where(i => !(i.IsKnown))  // Bug A fix: use IsKnown (computed) not IsCompleted (stale persisted bool)
            .Where(i => !(i.Progress?.IsInGracePeriod ?? false));

            // Fix 2: when SRS plan sends DueOnly=true, only include words actually due for review
            if (DueOnly)
            {
                var now = DateTime.Now;
                quizCandidates = quizCandidates.Where(i =>
                {
                    var totalAttempts = i.Progress?.TotalAttempts ?? 0;
                    var nextReview = i.Progress?.NextReviewDate;
                    
                    // Include truly unseen words (never attempted)
                    if (totalAttempts == 0)
                        return true;
                    
                    // Include words due for review (NextReviewDate <= now)
                    if (nextReview.HasValue && nextReview.Value <= now)
                        return true;
                    
                    // EXCLUDE words not yet due (NextReviewDate > now AND TotalAttempts > 0)
                    return false;
                });
            }

            batchPool = quizCandidates
            .OrderBy(i => i.Progress?.MasteryScore ?? 0f)
            .ThenBy(_ => Guid.NewGuid())
            .Take(BatchSize)
            .ToList();
            
            // Fix 3: Mark items with DueOnly session flag
            foreach (var item in batchPool)
            {
                item.IsDueOnlySession = DueOnly;
            }

            if (!batchPool.Any())
            {
                Toast.ShowInfo("All vocabulary in this resource is mastered!");
                isBusy = false;
                return;
            }

            await SetupNewRound();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load vocabulary");
            Toast.ShowError($"Error loading vocabulary: {ex.Message}");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SetupNewRound()
    {
        showSessionSummary = false;

        // Remove mastered words from the batch pool
        batchPool.RemoveAll(i => i.ReadyToRotateOut);

        if (!batchPool.Any())
        {
            Toast.ShowSuccess("All words mastered! Session complete.");
            GoBack();
            return;
        }

        // Each round: randomly select up to ActiveWordCount from the full batch pool
        vocabItems = batchPool
            .OrderBy(_ => Guid.NewGuid())
            .Take(ActiveWordCount)
            .ToList();

        // Shuffle for round presentation order
        roundWordOrder = vocabItems.OrderBy(_ => Guid.NewGuid()).ToList();
        currentTurnInRound = 0;
        await LoadCurrentItem();
    }

    private async Task LoadCurrentItem()
    {
        if (currentTurnInRound >= roundWordOrder.Count || currentTurnInRound >= TurnsPerRound)
        {
            // Round complete
            roundsCompleted++;
            await HandleMasteredWords();

            sessionItems = vocabItems.ToList();
            showSessionSummary = true;
            return;
        }

        currentItem = roundWordOrder[currentTurnInRound];
        ResetSentenceShortcutState();
        promptUsesNativeLanguage = ShouldUseNativePrompt();
        questionText = GetPromptText(currentItem.Word);
        correctAnswer = GetAnswerText(currentItem.Word);
        userInput = "";
        userGuess = "";
        showAnswer = false;
        feedbackMessage = "";
        isCorrect = false;
        requireCorrectTyping = false;

        // Unified mode-selection algorithm (spec §1.2)
        // Priority 1: Gentle demotion override — must prove recognition first
        if (currentItem.PendingRecognitionCheck)
            userMode = "MultipleChoice";
        // Priority 2: Lifetime progress indicates production readiness
        else if ((currentItem.Progress?.CurrentStreak ?? 0f) >= 3f
                 || (currentItem.Progress?.MasteryScore ?? 0f) >= 0.50f)
            userMode = "Text";
        // Priority 3: Default — still learning
        else
            userMode = "MultipleChoice";

        if (userMode == "MultipleChoice")
        {
            choiceOptions = GenerateChoiceOptions(currentItem);
            audioAnswerModeAvailable = await CanUseAudioAnswerModeAsync(choiceOptions);
        }
        else
        {
            choiceOptions = Array.Empty<QuizChoiceOption>();
            audioAnswerModeAvailable = false;
        }

        audioPromptAvailable = await CanPlayAudioAsync(GetTargetAudioText(currentItem.Word), GetTargetAudioLanguage(currentItem.Word));
        ApplyPromptPreferences();

        responseTimer.Restart();

        if (QuizPrefs.AutoPlayVocabAudio && audioPromptAvailable)
        {
            _ = InvokeAsync(PlayWordAudio);
        }
    }

    private void ResetSentenceShortcutState()
    {
        isSentenceShortcutMode = false;
        isSentenceShortcutSubmitting = false;
        sentenceShortcutInput = "";
        sentenceShortcutSuccessCount = 0;
        sentenceShortcutResults.Clear();
    }

    private void OpenSentenceShortcut()
    {
        if (currentItem?.Word == null)
            return;

        autoAdvanceCts?.Cancel();
        pendingAttempt = null;
        isSentenceShortcutMode = true;
        isSentenceShortcutSubmitting = false;
        sentenceShortcutInput = "";
        sentenceShortcutSuccessCount = 0;
        sentenceShortcutResults.Clear();
    }

    private void CancelSentenceShortcut()
    {
        if (isSentenceShortcutSubmitting)
            return;

        isSentenceShortcutMode = false;
        sentenceShortcutInput = "";
        sentenceShortcutSuccessCount = 0;
        sentenceShortcutResults.Clear();
    }

    private async Task ContinueAfterSentenceShortcut()
    {
        if (isSentenceShortcutSubmitting)
            return;

        ResetSentenceShortcutState();
        await NextItem();
    }

    private string GetSentenceShortcutPlaceholder()
    {
        var targetWord = currentItem?.Word?.TargetLanguageTerm ?? "the word";
        return $"Write one or more sentences using \"{targetWord}\".\nFor example: {targetWord} ...";
    }

    private async Task SubmitSentenceShortcut()
    {
        if (currentItem?.Word == null)
            return;

        var sentenceEntries = SplitSentenceEntries(sentenceShortcutInput);
        if (sentenceEntries.Count == 0)
        {
            Toast.ShowWarning("Write at least one sentence first.");
            return;
        }

        isSentenceShortcutSubmitting = true;
        sentenceShortcutResults.Clear();
        sentenceShortcutSuccessCount = 0;
        StateHasChanged();

        try
        {
            var activeUserId = Preferences.Get("active_profile_id", "");
            var updatedProgress = currentItem.Progress;
            var responseTimeMs = responseTimer.IsRunning ? (int)responseTimer.ElapsedMilliseconds : 0;
            var gradedResults = new List<SentenceShortcutResult>(sentenceEntries.Count);

            foreach (var sentenceText in sentenceEntries)
            {
                var grade = await TeacherSvc.GradeTargetWordSentence(sentenceText, currentItem.Word, targetLanguage, nativeLanguage);
                var targetAnalysis = GetTargetWordAnalysis(grade, currentItem.Word);
                if (targetAnalysis == null)
                {
                    throw new InvalidOperationException($"Target-word grading was unavailable for \"{currentItem.Word.TargetLanguageTerm}\".");
                }

                var usageCorrect = targetAnalysis.UsageCorrect;
                var usageExplanation = string.IsNullOrWhiteSpace(targetAnalysis.UsageExplanation)
                    ? usageCorrect
                        ? $"\"{currentItem.Word.TargetLanguageTerm}\" is used meaningfully here."
                        : $"This doesn't yet show a clear, correct use of \"{currentItem.Word.TargetLanguageTerm}\"."
                    : targetAnalysis.UsageExplanation;

                gradedResults.Add(new SentenceShortcutResult(
                    sentenceText,
                    usageCorrect,
                    usageExplanation,
                    grade?.Accuracy ?? 0,
                    grade?.Fluency ?? 0,
                    grade?.AccuracyExplanation ?? string.Empty,
                    grade?.FluencyExplanation ?? string.Empty,
                    grade?.GrammarNotes?.RecommendedTranslation ?? string.Empty,
                    grade?.GrammarNotes?.Explanation ?? string.Empty));
            }

            var creditedResults = gradedResults
                .Where(result => result.UsageCorrect)
                .ToList();

            sentenceShortcutSuccessCount = creditedResults.Count;

            foreach (var result in creditedResults)
            {
                updatedProgress = await ProgressService.RecordAttemptAsync(new VocabularyAttempt
                {
                    VocabularyWordId = currentItem.Word.Id,
                    UserId = activeUserId,
                    Activity = "VocabularyQuiz",
                    InputMode = InputMode.Text.ToString(),
                    WasCorrect = result.UsageCorrect,
                    DifficultyWeight = 2.5f,
                    ContextType = "Sentence",
                    UserInput = result.Sentence,
                    ExpectedAnswer = currentItem.Word.TargetLanguageTerm,
                    ResponseTimeMs = responseTimeMs
                });

                currentItem.Progress = updatedProgress;

                // Update session counters for sentence shortcut
                currentItem.SessionCorrectCount++;
                currentItem.SessionTextCorrect++;

                if (updatedProgress.IsFamiliar)
                {
                    await ProgressService.HandleVerificationProbeResultAsync(
                        currentItem.Word.Id, activeUserId, true);
                }
            }

            sentenceShortcutResults.Clear();
            sentenceShortcutResults.AddRange(gradedResults);
            
            // Fix 1: Mark as correct if any sentences passed
            if (sentenceShortcutSuccessCount > 0)
                currentItem.WasCorrectThisSession = true;
            
            totalTurns += sentenceEntries.Count;
            correctCount += sentenceShortcutSuccessCount;
            CacheService.InvalidateVocabSummary();
            sentenceShortcutInput = string.Empty;

            if (sentenceShortcutSuccessCount == sentenceShortcutResults.Count)
            {
                Toast.ShowSuccess($"Nice! {sentenceShortcutSuccessCount} sentence(s) counted toward mastery.");
            }
            else if (sentenceShortcutSuccessCount > 0)
            {
                Toast.ShowInfo($"{sentenceShortcutSuccessCount} of {sentenceShortcutResults.Count} sentence(s) counted toward mastery.");
            }
            else
            {
                Toast.ShowWarning($"Not yet—try another sentence using {currentItem.Word.TargetLanguageTerm}.");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to grade sentence shortcut for word {Word}", currentItem.Word.TargetLanguageTerm);
            Toast.ShowError("We couldn't grade that sentence right now. No progress was changed. Please try again.");
        }
        finally
        {
            isSentenceShortcutSubmitting = false;
        }
    }

    private static List<string> SplitSentenceEntries(string input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return new List<string>();

        return System.Text.RegularExpressions.Regex
            .Split(input.Trim(), @"(?:\r?\n)+|(?<=[.!?。！？])")
            .Select(part => part.Trim())
            .Where(part => !string.IsNullOrWhiteSpace(part))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private static VocabularyAnalysis? GetTargetWordAnalysis(GradeResponse? grade, VocabularyWord word)
    {
        var targetTerm = NormalizeTargetWordValue(word.TargetLanguageTerm);
        if (grade?.VocabularyAnalysis?.Any() != true || string.IsNullOrWhiteSpace(targetTerm))
            return null;

        foreach (var item in grade.VocabularyAnalysis)
        {
            if (NormalizeTargetWordValue(item.DictionaryForm) == targetTerm
                || NormalizeTargetWordValue(item.UsedForm) == targetTerm)
            {
                return item;
            }

            var usedFormTokens = System.Text.RegularExpressions.Regex
                .Split(item.UsedForm ?? string.Empty, @"[\s\p{P}\p{S}]+")
                .Select(NormalizeTargetWordValue)
                .Where(token => !string.IsNullOrWhiteSpace(token));

            if (usedFormTokens.Any(token => token == targetTerm))
            {
                return item;
            }
        }

        return null;
    }

    private static string NormalizeTargetWordValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var normalized = value.Trim().Normalize(System.Text.NormalizationForm.FormKC);
        var builder = new System.Text.StringBuilder(normalized.Length);

        foreach (var ch in normalized)
        {
            if (char.IsLetterOrDigit(ch) || char.IsWhiteSpace(ch))
            {
                builder.Append(char.ToLowerInvariant(ch));
            }
        }

        return builder.ToString().Trim();
    }

    private QuizChoiceOption[] GenerateChoiceOptions(VocabularyQuizItem item)
    {
        var correctOption = CreateChoiceOption(item);

        var options = vocabItems
            .Where(i => i != item)
            .Select(CreateChoiceOption)
            .Where(option => !string.IsNullOrWhiteSpace(option.Text))
            .Where(option => !string.Equals(option.Text, correctOption.Text, StringComparison.OrdinalIgnoreCase))
            .GroupBy(option => option.Text, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.First())
            .OrderBy(_ => Guid.NewGuid())
            .Take(3)
            .ToList();

        options.Add(correctOption);
        return options.OrderBy(_ => Guid.NewGuid()).ToArray();
    }

    private QuizChoiceOption CreateChoiceOption(VocabularyQuizItem item)
    {
        var answerText = GetAnswerText(item.Word);
        var answerLanguage = promptUsesNativeLanguage
            ? item.Word.Language ?? targetLanguage
            : nativeLanguage;

        return new QuizChoiceOption(answerText, answerText, answerLanguage);
    }

    private async Task SelectMultipleChoice(string option)
    {
        if (showAnswer) return;
        userGuess = option;
        await CheckAnswer();
    }

    private async Task SubmitTextInput()
    {
        if (requireCorrectTyping)
            await NextItem();
        else
            await CheckAnswer();
    }

    private async Task CheckAnswer()
    {
        if (currentItem == null) return;
        responseTimer.Stop();

        string answer = userMode == "MultipleChoice" ? userGuess : userInput;
        if (string.IsNullOrWhiteSpace(answer)) return;

        // Use fuzzy matching for text mode; exact match for multiple choice (options are pre-set)
        string? fuzzyCompleteForm = null;
        if (userMode == "Text")
        {
            var matchResult = FuzzyMatcher.Evaluate(answer, correctAnswer);
            isCorrect = matchResult.IsCorrect;
            fuzzyCompleteForm = matchResult.CompleteForm;
            // TODO: Log near-misses (IsCorrect == false but low Levenshtein distance) for future training data (#150)
        }
        else
        {
            isCorrect = string.Equals(answer.Trim(), correctAnswer.Trim(), StringComparison.OrdinalIgnoreCase);
        }
        showAnswer = true;

        // Update session counters (cumulative — never reset on wrong answers, spec §1.2.3)
        if (isCorrect)
        {
            currentItem.SessionCorrectCount++;
            if (userMode == "MultipleChoice")
            {
                currentItem.SessionMCCorrect++;
                // Correct MC clears gentle demotion flag (spec §1.2.1)
                currentItem.PendingRecognitionCheck = false;
            }
            else
            {
                currentItem.SessionTextCorrect++;
            }
        }
        else
        {
            // Wrong text answer → gentle demotion: force MC next appearance (spec §1.2.1)
            if (userMode == "Text")
                currentItem.PendingRecognitionCheck = true;
            // Wrong MC does NOT clear PendingRecognitionCheck — stays set (spec §2.2)

            // LostKnownThisSession is set in RecordPendingAttemptAsync AFTER recording,
            // when we know whether IsKnown was actually lost (spec §4.3.1)
        }

        if (isCorrect) currentItem.WasCorrectThisSession = true;

        if (isCorrect && fuzzyCompleteForm != null)
            feedbackMessage = $"Correct! Full form: {fuzzyCompleteForm}";
        else if (isCorrect)
            feedbackMessage = "Correct!";
        else
            feedbackMessage = $"The answer is: {correctAnswer}";

        showMnemonicTextHint = showAnswer && isCorrect && QuizPrefs.ShowMnemonicImage
            && !string.IsNullOrWhiteSpace(currentItem.Word.MnemonicText);

        if (HasPromptImage && QuizPrefs.ShowMnemonicImage)
        {
            showPhotoPromptControl = true;
            showMnemonicImage = QuizPrefs.UsePhotoPrompt || isCorrect;
        }

        // Defer recording — allows user to override before persisting
        pendingAttempt = new VocabularyAttempt
        {
            VocabularyWordId = currentItem.Word.Id,
            UserId = Preferences.Get("active_profile_id", ""),
            Activity = "VocabularyQuiz",
            InputMode = userMode,
            WasCorrect = isCorrect,
            DifficultyWeight = userMode == "Text" ? 1.5f : 1.0f,
            ContextType = "Isolated",
            UserInput = answer,
            ExpectedAnswer = correctAnswer,
            ResponseTimeMs = (int)responseTimer.ElapsedMilliseconds
        };

        totalTurns++;
        if (isCorrect) correctCount++;

        if (!isCorrect && userMode == "Text")
        {
            requireCorrectTyping = true;
            userInput = "";
        }

        // Auto-advance after showing the answer (skip if user must retype)
        if (!requireCorrectTyping)
        {
            autoAdvanceCts?.Cancel();
            autoAdvanceCts = new CancellationTokenSource();
            var token = autoAdvanceCts.Token;
            _ = InvokeAsync(async () =>
            {
                try
                {
                    await Task.Delay(QuizPrefs.AutoAdvanceDuration, token);
                    if (!token.IsCancellationRequested)
                    {
                        await NextItem();
                        StateHasChanged();
                    }
                }
                catch (TaskCanceledException) { }
            });
        }
    }

    private async Task NextItem()
    {
        autoAdvanceCts?.Cancel();
        await RecordPendingAttemptAsync();

        // Immediate rotation check (spec §1.3): remove word mid-round if mastered
        if (currentItem != null && currentItem.ReadyToRotateOut)
        {
            roundWordOrder.Remove(currentItem);
            batchPool.Remove(currentItem);
            wordsMastered++;

            // If that was the last word in the round, trigger round summary
            if (roundWordOrder.Count == 0 || currentTurnInRound >= roundWordOrder.Count)
            {
                roundsCompleted++;
                sessionItems = vocabItems.ToList();
                showSessionSummary = true;
                requireCorrectTyping = false;
                showMnemonicImage = false;
                showInfoPanel = false;
                return;
            }
            // Don't increment currentTurnInRound — next word slides into current index
        }
        else
        {
            currentTurnInRound++;
        }

        requireCorrectTyping = false;
        showMnemonicImage = false;
        showInfoPanel = false;
        await LoadCurrentItem();
    }

    /// <summary>
    /// Persists the deferred quiz attempt. Called once per question — either
    /// as-is (incorrect) when advancing, or after the user overrides to correct.
    /// </summary>
    private async Task RecordPendingAttemptAsync()
    {
        if (pendingAttempt == null) return;
        var attempt = pendingAttempt;
        pendingAttempt = null;

        try
        {
            // Snapshot IsKnown state before recording to detect loss (spec §4.3.1)
            var wasKnownBefore = currentItem?.Progress?.IsKnown ?? false;

            var updatedProgress = await ProgressService.RecordAttemptAsync(attempt);
            if (currentItem != null)
            {
                currentItem.Progress = updatedProgress;

                // Track IsKnown loss this session (spec §4.3.1)
                if (wasKnownBefore && !updatedProgress.IsKnown)
                    currentItem.LostKnownThisSession = true;

                // IsKnown re-qualification with shorter 14-day interval (spec §4.3.1)
                if (currentItem.LostKnownThisSession && updatedProgress.IsKnown)
                {
                    updatedProgress.ReviewInterval = 14;
                    updatedProgress.NextReviewDate = DateTime.Now.AddDays(14);
                    // Persist the shorter interval
                    await ProgressService.UpdateProgressAsync(updatedProgress);
                }
            }

            if (updatedProgress.IsFamiliar)
            {
                await ProgressService.HandleVerificationProbeResultAsync(
                    attempt.VocabularyWordId, attempt.UserId, attempt.WasCorrect);
                if (attempt.WasCorrect)
                    Toast.ShowSuccess("Confirmed! This one is solid.");
                else
                    Toast.ShowInfo("This one is tricky in context. A few more reps will help.");
            }

            CacheService.InvalidateVocabSummary();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to record attempt");
        }
    }

    private async Task OverrideAsCorrect()
    {
        autoAdvanceCts?.Cancel();
        isCorrect = true;
        requireCorrectTyping = false;
        feedbackMessage = "Marked correct ✓";

        // Update session counters (override counts as correct)
        currentItem.SessionCorrectCount++;
        if (userMode == "MultipleChoice")
        {
            currentItem.SessionMCCorrect++;
            currentItem.PendingRecognitionCheck = false;
        }
        else
        {
            currentItem.SessionTextCorrect++;
        }

        // Fix 1: Also mark as correct in session
        currentItem.WasCorrectThisSession = true;

        // Update the deferred attempt to correct and persist it
        if (pendingAttempt != null)
        {
            pendingAttempt.WasCorrect = true;
        }
        await RecordPendingAttemptAsync();

        correctCount++;
        StateHasChanged();

        // Auto-advance after override
        autoAdvanceCts = new CancellationTokenSource();
        var token = autoAdvanceCts.Token;
        _ = InvokeAsync(async () =>
        {
            try
            {
                await Task.Delay(QuizPrefs.AutoAdvanceDuration, token);
                if (!token.IsCancellationRequested)
                {
                    await NextItem();
                    StateHasChanged();
                }
            }
            catch (TaskCanceledException) { }
        });
    }

    private async Task HandleMasteredWords()
    {
        var mastered = vocabItems.Where(i => i.ReadyToRotateOut).ToList();
        foreach (var item in mastered)
        {
            vocabItems.Remove(item);
            batchPool.Remove(item);
            wordsMastered++;
        }
    }

    private string[] ParseResourceIds()
    {
        if (string.IsNullOrEmpty(ResourceIdsParam)) return Array.Empty<string>();
        return ResourceIdsParam.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s)).ToArray();
    }

    private void GoBack()
    {
        if (ActivityTimer.IsActive) { ActivityTimer.Pause(); ActivityTimer.StopSession(); }
        NavManager.NavigateTo("/");
    }

    private void ToggleMnemonicImage() => showMnemonicImage = !showMnemonicImage;

    private async Task PlayWordAudio()
    {
        if (currentItem?.Word == null) return;

        await PlayAudioTextAsync(GetTargetAudioText(currentItem.Word), GetTargetAudioLanguage(currentItem.Word));
    }

    private Task PlayChoiceAudio(QuizChoiceOption option) => PlayAudioTextAsync(option.AudioText, option.AudioLanguage);

    private async Task PlayAudioTextAsync(string text, string language)
    {
        if (isPlayingAudio || string.IsNullOrWhiteSpace(text)) return;
        isPlayingAudio = true;

        try
        {
            var voiceId = VoicePrefs.GetVoiceForLanguage(language);
            var cached = await StreamHistoryRepo.GetStreamHistoryByPhraseAndVoiceAsync(text, voiceId);
            Stream audioStream;

            if (cached != null && !string.IsNullOrEmpty(cached.AudioFilePath) && File.Exists(cached.AudioFilePath))
            {
                audioStream = File.OpenRead(cached.AudioFilePath);
            }
            else if (Connectivity.IsInternetAvailable)
            {
                audioStream = await SpeechService.TextToSpeechAsync(text, voiceId, 0.5f, 0.75f, 0.85f);

                var cacheDir = Path.Combine(FileSystemService.AppDataDirectory, "AudioCache");
                Directory.CreateDirectory(cacheDir);
                var filePath = Path.Combine(cacheDir, $"word_{Guid.NewGuid()}.mp3");
                using (var fs = File.Create(filePath)) { await audioStream.CopyToAsync(fs); }

                await StreamHistoryRepo.SaveStreamHistoryAsync(new StreamHistory
                {
                    Phrase = text, VoiceId = voiceId, AudioFilePath = filePath,
                    CreatedAt = DateTime.UtcNow, UpdatedAt = DateTime.UtcNow
                });

                audioStream = File.OpenRead(filePath);
            }
            else
            {
                await EnableTextFallbackAsync();
                Toast.ShowWarning("Audio unavailable offline.");
                return;
            }

            audioPlayer?.Stop();
            audioPlayer?.Dispose();
            audioPlayer = AudioManager.CreatePlayer(audioStream);
            if (audioPlayer != null)
            {
                audioPlayer.Play();
            }
            else
            {
                // JS interop fallback for server-side Blazor (WebApp)
                audioStream.Position = 0;
                using var ms = new MemoryStream();
                await audioStream.CopyToAsync(ms);
                var base64 = Convert.ToBase64String(ms.ToArray());
                await JS.InvokeVoidAsync("audioInterop.playFromBase64", base64, "audio/mpeg");
            }
        }
        catch (Exception ex)
        {
            await EnableTextFallbackAsync();
            Logger.LogError(ex, "Failed to play quiz audio for '{Text}'", text);
        }
        finally
        {
            isPlayingAudio = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await RecordPendingAttemptAsync();
        if (ActivityTimer.IsActive) { ActivityTimer.Pause(); ActivityTimer.StopSession(); }
        autoAdvanceCts?.Cancel();
        autoAdvanceCts?.Dispose();
        audioPlayer?.Stop();
        audioPlayer?.Dispose();
        audioPlayer = null;
    }

    private void ApplyPromptPreferences()
    {
        showTextPrompt = QuizPrefs.UseTextPrompt || (QuizPrefs.UseAudioPrompt && !audioPromptAvailable);
        showAudioPromptControl = QuizPrefs.UseAudioPrompt && audioPromptAvailable;
        showPhotoPromptControl = HasPromptImage && QuizPrefs.UsePhotoPrompt;
        showMnemonicTextHint = false;

        if (!showTextPrompt && !showAudioPromptControl && !showPhotoPromptControl)
        {
            showTextPrompt = true;
        }

        showMnemonicImage = HasPromptImage && QuizPrefs.UsePhotoPrompt;
        promptTitle = showTextPrompt
            ? questionText
            : showPhotoPromptControl && showAudioPromptControl
                ? "Listen and look, then answer"
                : showPhotoPromptControl
                    ? "Look and answer"
                    : "Listen and answer";
    }

    private bool HasPromptImage => !string.IsNullOrWhiteSpace(currentItem?.Word?.MnemonicImageUri);

    private string GetTargetAudioText(VocabularyWord word) => word.TargetLanguageTerm ?? "";

    private string GetTargetAudioLanguage(VocabularyWord word) => word.Language ?? targetLanguage;

    private async Task<bool> CanUseAudioAnswerModeAsync(IEnumerable<QuizChoiceOption> options)
    {
        if (!promptUsesNativeLanguage || !QuizPrefs.UseAudioPrompt)
            return false;

        foreach (var option in options)
        {
            if (!await CanPlayAudioAsync(option.AudioText, option.AudioLanguage))
                return false;
        }

        return true;
    }

    private async Task<bool> CanPlayAudioAsync(string text, string language)
    {
        if (string.IsNullOrWhiteSpace(text))
            return false;

        if (Connectivity.IsInternetAvailable)
            return true;

        var voiceId = VoicePrefs.GetVoiceForLanguage(language);
        var cached = await StreamHistoryRepo.GetStreamHistoryByPhraseAndVoiceAsync(text, voiceId);

        return cached != null
            && !string.IsNullOrWhiteSpace(cached.AudioFilePath)
            && File.Exists(cached.AudioFilePath);
    }

    private async Task EnableTextFallbackAsync()
    {
        audioPromptAvailable = false;
        audioAnswerModeAvailable = false;
        ApplyPromptPreferences();
        await InvokeAsync(StateHasChanged);
    }

    private bool ShouldUseNativePrompt() => QuizPrefs.DisplayDirection switch
    {
        "NativeToTarget" => true,
        "Mixed" => random.Next(2) == 0,
        _ => false
    };

    private string GetPromptText(VocabularyWord word) => promptUsesNativeLanguage
        ? word.NativeLanguageTerm ?? ""
        : word.TargetLanguageTerm ?? "";

    private string GetAnswerText(VocabularyWord word) => promptUsesNativeLanguage
        ? word.TargetLanguageTerm ?? ""
        : word.NativeLanguageTerm ?? "";
}
