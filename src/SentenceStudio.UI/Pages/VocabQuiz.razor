    private async Task OpenImageFullscreen()
    {
        if (isImageFullscreen) return;

        // Try native photo viewer first; fall back to Razor overlay if unavailable
        if (SentenceStudio.Abstractions.PhotoViewerRequest.TryCreate(
                currentItem?.Word?.MnemonicImageUri,
                $"{Localize["VocabQuiz_PhotoHint"]}",
                out var request))
        {
            var handledByNative = await PhotoViewer.TryShowNativeAsync(request);
            if (handledByNative)
                return;
        }

        isImageFullscreen = true;
        pendingFocusIntoFullscreen = true;
        pendingFocusRestoreToThumbnail = false;
    }

    private void CloseImageFullscreen()
    {
        if (!isImageFullscreen) return;
        isImageFullscreen = false;
        pendingFocusIntoFullscreen = false;
        pendingFocusRestoreToThumbnail = true;
    }

    private void HandleFullscreenKeydown(KeyboardEventArgs e)
    {
        if (string.Equals(e.Key, "Escape", StringComparison.OrdinalIgnoreCase))
            CloseImageFullscreen();
    }

    // Render-safe one-shot focus lifecycle for the fullscreen photo overlay.
    // - Moves focus to the close button after the overlay renders so Escape
    //   (bubbling from the focused child up to @onkeydown on the overlay div)
    //   closes immediately without requiring Tab.
    // - Restores focus to the invoking thumbnail after the overlay unmounts.
    // Both flags are cleared before awaiting so a second render can queue the
    // next transition without racing. Framework refs:
    //   https://learn.microsoft.com/aspnet/core/blazor/components/element-references
    //   https://learn.microsoft.com/aspnet/core/blazor/components/lifecycle#after-component-render-onafterrenderasync
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (pendingFocusIntoFullscreen && isImageFullscreen)
        {
            pendingFocusIntoFullscreen = false;
            try
            {
                await fullscreenCloseButtonRef.FocusAsync();
            }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
            catch (Microsoft.JSInterop.JSException) { }
            catch (TaskCanceledException) { }
        }
        else if (pendingFocusRestoreToThumbnail && !isImageFullscreen)
        {
            pendingFocusRestoreToThumbnail = false;
            if (showMnemonicImage
                && !string.IsNullOrWhiteSpace(currentItem?.Word?.MnemonicImageUri))
            {
                try
                {
                    await thumbnailButtonRef.FocusAsync();
                }
                catch (Microsoft.JSInterop.JSDisconnectedException) { }
                catch (ObjectDisposedException) { }
                catch (Microsoft.JSInterop.JSException) { }
                catch (TaskCanceledException) { }
            }
        }
    }

    private async Task ToggleShowTextWithPhotoAsync()
    {
        if (isSavingTextToggle) return;
        isSavingTextToggle = true;

        var previousValue = showTextWithPhoto;
        showTextWithPhoto = !showTextWithPhoto;

        try
        {
            var activeUserId = GetActiveUserId();
            if (string.IsNullOrWhiteSpace(activeUserId))
            {
                Logger.LogWarning("ToggleShowTextWithPhoto: no active user id — reverting");
                showTextWithPhoto = previousValue;
                Toast.ShowError($"{Localize["VocabQuiz_TextToggleSaveFailed"]}");
