@page "/profile"
@attribute [Authorize]
@implements IDisposable
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize

<PageHeader Title="@Localize["Profile_PageTitle"]" />

@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    @* Personal Info *@
    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["Profile_PersonalInformation"]</h5>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_Name"]</label>
            <input type="text" class="form-control form-control-ss" @bind="name" placeholder="@Localize["Profile_NamePlaceholder"]" />
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_Email"]</label>
            <input type="email" class="form-control form-control-ss" @bind="email" placeholder="@Localize["Profile_EmailPlaceholder"]" />
        </div>
    </div>

    @* Language Settings *@
    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["Profile_LanguageSettings"]</h5>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_NativeLanguage"]</label>
            <select class="form-select form-control-ss" @bind="nativeLanguage">
                @foreach (var lang in languages)
                {
                    <option value="@lang">@lang</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_TargetLanguage"]</label>
            <select class="form-select form-control-ss" @bind="targetLanguage">
                @foreach (var lang in languages)
                {
                    <option value="@lang">@lang</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_DisplayLanguage"]</label>
            <select class="form-select form-control-ss" @bind="displayLanguage">
                <option value="English">@Localize["Profile_DisplayLanguage_English"]</option>
                <option value="Korean">@Localize["Profile_DisplayLanguage_Korean"]</option>
            </select>
        </div>
    </div>

    @* Learning Preferences *@
    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["Profile_LearningPreferences"]</h5>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_SessionDuration"]</label>
            <div class="d-flex flex-column flex-md-row gap-2" role="group">
                @foreach (var min in sessionOptions)
                {
                    <button class="btn @(preferredSessionMinutes == min ? "btn-ss-primary" : "btn-ss-secondary")"
                            @onclick="() => preferredSessionMinutes = min">
                        @min
                    </button>
                }
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_TargetCEFRLevel"]</label>
            <div class="d-flex flex-column flex-md-row gap-2" role="group">
                @foreach (var level in cefrLevels)
                {
                    <button class="btn @(targetCEFRLevel == level ? "btn-ss-primary" : "btn-ss-secondary")"
                            @onclick="() => targetCEFRLevel = level">
                        @level
                    </button>
                }
            </div>
        </div>
    </div>

    @* Actions *@
    <div class="d-flex gap-2 mb-3">
        <button class="btn btn-ss-primary flex-grow-1" @onclick="SaveProfile">@Localize["Profile_SaveProfile"]</button>
    </div>

    @* Change Password *@
    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3"><i class="bi bi-key me-2"></i>@Localize["Profile_ChangePassword"]</h5>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_CurrentPassword"]</label>
            <input type="password" class="form-control form-control-ss" @bind="currentPassword"
                   @bind:event="oninput" placeholder="@Localize["Profile_CurrentPasswordPlaceholder"]" />
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_NewPassword"]</label>
            <input type="password" class="form-control form-control-ss" @bind="newPassword"
                   @bind:event="oninput" placeholder="@Localize["Profile_NewPasswordPlaceholder"]" />
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["Profile_ConfirmNewPassword"]</label>
            <input type="password" class="form-control form-control-ss" @bind="confirmNewPassword"
                   @bind:event="oninput" placeholder="@Localize["Profile_ConfirmNewPasswordPlaceholder"]" />
        </div>

        <button class="btn btn-ss-primary w-100" @onclick="ChangePassword"
                disabled="@(isChangingPassword || !CanChangePassword)">
            @if (isChangingPassword)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            <i class="bi bi-lock me-1"></i>@Localize["Profile_ChangePassword"]
        </button>
    </div>

    @* Export *@
    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["Profile_DataExport"]</h5>
        <button class="btn btn-ss-secondary w-100" @onclick="ExportData" disabled="@isExporting">
            @if (isExporting)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
                <span>@exportProgressMessage</span>
            }
            else
            {
                <span>@Localize["Profile_ExportAllData"]</span>
            }
        </button>
    </div>

    @* Danger Zone *@
    <div class="card card-ss p-4 border border-danger mb-5">
        <h5 class="ss-title3 text-error-ss mb-3">@Localize["Profile_DangerZone"]</h5>
        <p class="ss-body2 text-secondary-ss mb-3">
            @Localize["Profile_DangerZoneDescription"]
        </p>
        <button class="btn btn-ss-danger w-100" @onclick="RequestDelete">@Localize["Profile_DeleteMyAccount"]</button>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content bg-surface">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-error-ss">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localize["Profile_ConfirmDelete"]
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="ss-body2">@Localize["Profile_DeleteConfirmationMessage"]</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-ss-secondary" @onclick="CancelDelete">@Localize["Profile_Cancel"]</button>
                    <button type="button" class="btn btn-ss-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @Localize["Profile_Delete"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Inject] private UserProfileRepository ProfileRepo { get; set; }
    [Inject] private DataExportService ExportService { get; set; }
    [Inject] private ToastService Toast { get; set; }
    [Inject] private IJSRuntime JS { get; set; }
    [Inject] private IAppState AppState { get; set; }
    [Inject] private SentenceStudio.Abstractions.IPreferencesService Preferences { get; set; } = default!;
    [Inject] private SentenceStudio.Services.IAuthService AuthService { get; set; } = default!;
    [Inject] private ILogger<Profile> Logger { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;

    private bool isLoading = true;
    private string name = "";
    private string email = "";
    private string nativeLanguage = "English";
    private string targetLanguage = "Korean";
    private string displayLanguage = "English";
    private int preferredSessionMinutes = 15;
    private string targetCEFRLevel = "A2";
    private bool isExporting;
    private string exportProgressMessage = "";
    private bool showDeleteConfirm;
    private bool isDeleting;

    private string currentPassword = "";
    private string newPassword = "";
    private string confirmNewPassword = "";
    private bool isChangingPassword;

    private bool CanChangePassword =>
        !string.IsNullOrWhiteSpace(currentPassword)
        && !string.IsNullOrWhiteSpace(newPassword)
        && !string.IsNullOrWhiteSpace(confirmNewPassword);

    private readonly string[] languages = { "English", "Korean", "French", "German", "Spanish", "Japanese", "Chinese" };
    private readonly int[] sessionOptions = { 5, 10, 15, 20, 30, 45 };
    private readonly string[] cefrLevels = { "A1", "A2", "B1", "B2", "C1", "C2" };

    protected override async Task OnInitializedAsync()
    {
        Localize.CultureChanged += OnCultureChanged;
        await LoadProfile();
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }

    private async Task LoadProfile()
    {
        isLoading = true;
        try
        {
            var profile = await ProfileRepo.GetAsync();
            if (profile != null)
            {
                name = profile.Name ?? "";
                email = profile.Email ?? "";
                nativeLanguage = profile.NativeLanguage ?? "English";
                targetLanguage = profile.TargetLanguage ?? "Korean";
                displayLanguage = profile.DisplayLanguage ?? "English";
                preferredSessionMinutes = profile.PreferredSessionMinutes > 0 ? profile.PreferredSessionMinutes : 15;
                targetCEFRLevel = profile.TargetCEFRLevel ?? "A2";
            }
            else
            {
                Logger.LogWarning("LoadProfile: no active profile found");
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "LoadProfile failed");
            Toast.ShowError(Localize["Profile_LoadFailed"]);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProfile()
    {
        try
        {
            var profile = await ProfileRepo.GetAsync() ?? new UserProfile();
            profile.Name = name;
            profile.Email = email;
            profile.NativeLanguage = nativeLanguage;
            profile.TargetLanguage = targetLanguage;
            profile.DisplayLanguage = displayLanguage;
            profile.PreferredSessionMinutes = preferredSessionMinutes;
            profile.TargetCEFRLevel = targetCEFRLevel;

            await ProfileRepo.SaveAsync(profile);
            AppState.CurrentUserProfile = profile;

            // Apply the new display culture end-to-end.
            var culture = profile.DisplayCulture;
            var cultureInfo = new System.Globalization.CultureInfo(culture);

            // 1) Flip this Blazor circuit's culture so subscribed components re-render now.
            Localize.SetCulture(cultureInfo);

            // 2) Persist the choice.
            var baseUri = NavManager.BaseUri;
            var isWeb = !baseUri.StartsWith("app://") && !baseUri.Contains("0.0.0.0");
            if (isWeb)
            {
                // WebApp: Blazor Server circuits can't write cookies over WebSocket.
                // Redirect through an account endpoint that writes .AspNetCore.Culture
                // and sends us back, so subsequent requests restore the language.
                Toast.ShowSuccess(Localize["Profile_Saved"]);
                NavManager.NavigateTo(
                    $"/account-action/SetCulture?culture={Uri.EscapeDataString(culture)}&returnUrl=/profile",
                    forceLoad: true);
                return;
            }
            else
            {
                // MAUI Blazor Hybrid: apply process-wide culture via the singleton so
                // MauiReactor views and any non-Blazor surfaces update too.
                SentenceStudio.LocalizationManager.Instance.SetCulture(cultureInfo);
            }

            Toast.ShowSuccess(Localize["Profile_Saved"]);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save profile");
            Toast.ShowError(Localize.Get("Profile_SaveFailed", ex.Message));
        }
    }

    private async Task ExportData()
    {
        isExporting = true;
        exportProgressMessage = Localize["Profile_Exporting"];
        try
        {
            await ExportService.ExportAllDataAsZipAsync();
            Toast.ShowSuccess(Localize["Profile_ExportSuccess"]);
        }
        catch (Exception ex)
        {
            Toast.ShowError(Localize.Get("Profile_ExportFailed", ex.Message));
        }
        finally
        {
            isExporting = false;
            exportProgressMessage = "";
        }
    }

    private async Task ChangePassword()
    {
        if (newPassword != confirmNewPassword)
        {
            Toast.ShowError(Localize["Profile_PasswordsDoNotMatch"]);
            return;
        }

        if (newPassword.Length < 8)
        {
            Toast.ShowError(Localize["Profile_PasswordTooShort"]);
            return;
        }

        isChangingPassword = true;
        try
        {
            var success = await AuthService.ChangePasswordAsync(currentPassword, newPassword);
            if (success)
            {
                currentPassword = "";
                newPassword = "";
                confirmNewPassword = "";
                Toast.ShowSuccess(Localize["Profile_PasswordChanged"]);
            }
            else
            {
                Toast.ShowError(Localize["Profile_PasswordChangeFailed"]);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Password change failed");
            Toast.ShowError(Localize.Get("Profile_PasswordChangeError", ex.Message));
        }
        finally
        {
            isChangingPassword = false;
        }
    }

    private void RequestDelete()
    {
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        try
        {
            var profileId = Preferences.Get("active_profile_id", string.Empty);
            AppState.CurrentUserProfile = null;
            Toast.ShowSuccess(Localize["Profile_AccountDeleted"]);
            // Redirect to HTTP endpoint that can properly sign out and delete
            NavManager.NavigateTo($"/account-action/DeleteAccount?profileId={Uri.EscapeDataString(profileId)}", forceLoad: true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Account deletion failed");
            Toast.ShowError(Localize.Get("Profile_DeletionFailed", ex.Message));
        }
        finally
        {
            isDeleting = false;
            showDeleteConfirm = false;
        }
    }
}
