@page "/import-content"
@attribute [Authorize]
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@inject IContentImportService ImportService
@inject LearningResourceRepository ResourceRepo
@inject UserProfileRepository UserProfileRepo
@inject NavigationManager NavManager
@inject ToastService Toast
@inject ILogger<ImportContent> Logger
@inject IImportResultStore ImportResultStore
@implements IDisposable
@using SentenceStudio.WebUI.Services

<PageHeader Title='@Localize["Import_Content_Title"]' ShowBack="false">
    <PrimaryActions>
        @if (currentStep == ImportStep.Preview && previewResult != null)
        {
            <button class="btn btn-ss-primary" @onclick="CommitImport" disabled="@isCommitting">
                @if (isCommitting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                @Localize["Import_CommitButton"]
            </button>
        }
    </PrimaryActions>
</PageHeader>

<div class="container-fluid px-3 px-md-4 py-3">
    @if (isCommitting)
    {
        <div class="d-flex justify-content-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (importResult != null)
    {
        @* Step 7: Results Summary *@
        <div class="card card-ss p-4 mb-3">
            <h5 class="ss-title3 mb-3"><i class="bi bi-check-circle-fill text-success me-2"></i>@Localize["Import_ImportComplete"]</h5>
            
            <div class="row mb-3">
                <div class="col-6 col-md-3 mb-2">
                    <div class="text-center p-3 bg-light rounded">
                        <div class="ss-title2 text-success">@importResult.CreatedCount</div>
                        <small class="text-secondary-ss">@Localize["Import_Created"]</small>
                    </div>
                </div>
                <div class="col-6 col-md-3 mb-2">
                    <div class="text-center p-3 bg-light rounded">
                        <div class="ss-title2 text-info">@importResult.SkippedCount</div>
                        <small class="text-secondary-ss">@Localize["Import_Skipped"]</small>
                    </div>
                </div>
                <div class="col-6 col-md-3 mb-2">
                    <div class="text-center p-3 bg-light rounded">
                        <div class="ss-title2 text-warning">@importResult.UpdatedCount</div>
                        <small class="text-secondary-ss">@Localize["Import_Updated"]</small>
                    </div>
                </div>
                <div class="col-6 col-md-3 mb-2">
                    <div class="text-center p-3 bg-light rounded">
                        <div class="ss-title2 text-danger">@importResult.FailedCount</div>
                        <small class="text-secondary-ss">@Localize["Import_Failed"]</small>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-ss-primary" @onclick="ViewResource">
                    <i class="bi bi-book me-1"></i> @Localize["Import_ViewResource"]
                </button>
                <button class="btn btn-ss-secondary" @onclick="StartNewImport">
                    <i class="bi bi-arrow-repeat me-1"></i> @Localize["Import_ImportMore"]
                </button>
            </div>
        </div>

        @* Per-row detail table *@
        @if (importResult.Items.Any())
        {
            <div class="card card-ss p-4 mb-3">
                <h6 class="ss-title3 mb-3"><i class="bi bi-list-ul me-2"></i>@Localize["Import_ResultDetails"]</h6>

                @* Filter pills *@
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <button class="btn btn-sm @(resultFilter == null ? "btn-primary" : "btn-outline-primary")"
                            @onclick="() => SetResultFilter(null)">
                        @Localize["Import_FilterAll"] <span class="badge bg-light text-dark ms-1">@importResult.Items.Count</span>
                    </button>
                    @if (importResult.CreatedCount > 0)
                    {
                        <button class="btn btn-sm @(resultFilter == ImportItemStatus.Created ? "btn-success" : "btn-outline-success")"
                                @onclick="() => SetResultFilter(ImportItemStatus.Created)">
                            @Localize["Import_Created"] <span class="badge bg-light text-dark ms-1">@importResult.CreatedCount</span>
                        </button>
                    }
                    @if (importResult.UpdatedCount > 0)
                    {
                        <button class="btn btn-sm @(resultFilter == ImportItemStatus.Updated ? "btn-warning text-dark" : "btn-outline-warning")"
                                @onclick="() => SetResultFilter(ImportItemStatus.Updated)">
                            @Localize["Import_Updated"] <span class="badge bg-light text-dark ms-1">@importResult.UpdatedCount</span>
                        </button>
                    }
                    @if (importResult.SkippedCount > 0)
                    {
                        <button class="btn btn-sm @(resultFilter == ImportItemStatus.Skipped ? "btn-info" : "btn-outline-info")"
                                @onclick="() => SetResultFilter(ImportItemStatus.Skipped)">
                            @Localize["Import_Skipped"] <span class="badge bg-light text-dark ms-1">@importResult.SkippedCount</span>
                        </button>
                    }
                    @if (importResult.FailedCount > 0)
                    {
                        <button class="btn btn-sm @(resultFilter == ImportItemStatus.Failed ? "btn-danger" : "btn-outline-danger")"
                                @onclick="() => SetResultFilter(ImportItemStatus.Failed)">
                            @Localize["Import_Failed"] <span class="badge bg-light text-dark ms-1">@importResult.FailedCount</span>
                        </button>
                    }
                </div>

                @* Desktop: table  |  Mobile: stacked cards *@
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-sm table-bordered align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>@Localize["Import_ColLemma"]</th>
                                <th>@Localize["Import_ColNative"]</th>
                                <th style="width:100px;">@Localize["Import_ColType"]</th>
                                <th style="width:110px;">@Localize["Import_ColStatus"]</th>
                                <th>@Localize["Import_ColReason"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in FilteredResultItems)
                            {
                                var isClickable = item.Status != ImportItemStatus.Failed && !string.IsNullOrEmpty(item.VocabularyWordId);
                                <tr class="@(isClickable ? "cursor-pointer" : "")"
                                    @onclick="() => NavigateToVocabDetail(item)"
                                    style="@(isClickable ? "cursor:pointer;" : "")">
                                    <td>
                                        @item.Lemma
                                        @if (isClickable)
                                        {
                                            <i class="bi bi-box-arrow-up-right ms-1 text-secondary-ss" style="font-size:0.75rem;"></i>
                                        }
                                    </td>
                                    <td>@item.NativeLanguageTerm</td>
                                    <td>@RenderTypeBadge(item.Type)</td>
                                    <td>@RenderStatusBadge(item.Status)</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.Reason))
                                        {
                                            <span title="@item.Reason" class="text-truncate d-inline-block" style="max-width:220px;">@item.Reason</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Mobile card layout *@
                <div class="d-md-none">
                    @foreach (var item in FilteredResultItems)
                    {
                        var isClickable = item.Status != ImportItemStatus.Failed && !string.IsNullOrEmpty(item.VocabularyWordId);
                        <div class="border rounded p-3 mb-2 @(isClickable ? "" : "")"
                             @onclick="() => NavigateToVocabDetail(item)"
                             style="@(isClickable ? "cursor:pointer;" : "")">
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <span class="ss-body1 fw-bold">@item.Lemma</span>
                                @RenderStatusBadge(item.Status)
                            </div>
                            <div class="ss-body2 text-secondary-ss mb-1">@item.NativeLanguageTerm</div>
                            <div class="d-flex align-items-center gap-2">
                                @RenderTypeBadge(item.Type)
                                @if (isClickable)
                                {
                                    <small class="text-primary-ss"><i class="bi bi-box-arrow-up-right"></i> @Localize["Import_ViewVocab"]</small>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(item.Reason))
                            {
                                <div class="mt-1 ss-caption1 text-danger">@item.Reason</div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        @* Steps 1-6: Import Wizard *@
        
        @* Step 1: Source *@
        <div class="card card-ss p-4 mb-3">
            <h5 class="ss-title3 mb-3">@Localize["Import_Step1_Title"]</h5>
            
            <div class="mb-3">
                <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_PasteContentLabel"]</label>
                <textarea class="form-control form-control-ss" 
                          @bind="rawText" 
                          @bind:event="oninput"
                          rows="8" 
                          placeholder='@Localize["Import_PastePlaceholder"]'
                          disabled="@(currentStep > ImportStep.Source)"></textarea>
                <small class="form-text text-secondary-ss">@Localize["Import_PasteHint"]</small>
            </div>
        </div>

        @* Step 2: Format Hints *@
        <div class="card card-ss p-4 mb-3">
            <h5 class="ss-title3 mb-3">@Localize["Import_Step2_Title"]</h5>
            
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_ContentTypeLabel"]</label>
                    <select class="form-select form-control-ss" 
                            @bind="contentType"
                            disabled="@(currentStep > ImportStep.Source)">
                        <option value="Vocabulary">@Localize["Import_ContentType_Vocabulary"]</option>
                        <option value="Phrases">@Localize["Import_ContentType_Phrases"]</option>
                        <option value="Sentences">Sentences</option>
                        <option value="Transcript">@Localize["Import_ContentType_Transcript"]</option>
                        <option value="Auto">@Localize["Import_ContentType_Auto"]</option>
                    </select>
                </div>
                
                <div class="col-md-4 mb-3">
                    <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_DelimiterLabel"]</label>
                    <select class="form-select form-control-ss" 
                            @bind="delimiter"
                            disabled="@(currentStep > ImportStep.Source)">
                        <option value="auto">@Localize["Import_Delimiter_Auto"]</option>
                        <option value=",">@Localize["Import_Delimiter_Comma"]</option>
                        <option value="\t">@Localize["Import_Delimiter_Tab"]</option>
                        <option value="|">@Localize["Import_Delimiter_Pipe"]</option>
                    </select>
                </div>
                
                <div class="col-md-4 mb-3 d-flex align-items-end">
                    <div class="form-check">
                        <input class="form-check-input" 
                               type="checkbox" 
                               id="hasHeaderRow" 
                               @bind="hasHeaderRow"
                               disabled="@(currentStep > ImportStep.Source)" />
                        <label class="form-check-label ss-body2" for="hasHeaderRow">
                            @Localize["Import_HasHeaderRow"]
                        </label>
                    </div>
                </div>
            </div>
            
            <div class="d-flex justify-content-end">
                <button class="btn btn-ss-primary" 
                        @onclick="ParseContent" 
                        disabled="@(string.IsNullOrWhiteSpace(rawText) || isParsing)">
                    @if (isParsing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    @Localize["Import_PreviewButton"]
                </button>
            </div>
        </div>

        @* Auto-detect: Confidence gate (shown when auto-detect was used) *@
        @if (autoDetectResult != null && currentStep >= ImportStep.Harvest)
        {
            @if (autoDetectConfidenceBand == ConfidenceBand.High)
            {
                <div class="alert alert-info d-flex align-items-center mb-3" role="alert">
                    <i class="bi bi-stars me-2 fs-5"></i>
                    <div class="flex-grow-1">
                        <strong>Auto-detected:</strong> @FormatContentType(autoDetectResult.ContentType) 
                        (@FormatConfidence(autoDetectResult.Confidence) confidence)
                    </div>
                    <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="OpenTypeChooser">
                        <i class="bi bi-pencil me-1"></i>Change
                    </button>
                </div>
            }
            else if (autoDetectConfidenceBand == ConfidenceBand.Medium)
            {
                <div class="alert alert-warning mb-3" role="alert">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-question-circle me-2 fs-5"></i>
                        <strong>We're not 100% sure.</strong>
                    </div>
                    <p class="mb-2">
                        Looks like <strong>@FormatContentType(autoDetectResult.ContentType)</strong> 
                        (@FormatConfidence(autoDetectResult.Confidence) confidence). 
                        Please confirm or pick the correct type:
                    </p>
                    @if (!autoDetectConfirmed)
                    {
                        <div class="d-flex flex-wrap gap-2">
                            <button class="btn btn-sm btn-primary" @onclick="ConfirmAutoDetect">
                                <i class="bi bi-check-lg me-1"></i>Yes, it's @FormatContentType(autoDetectResult.ContentType)
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="OpenTypeChooser">
                                <i class="bi bi-pencil me-1"></i>Pick a different type
                            </button>
                        </div>
                    }
                    else
                    {
                        <small class="text-success"><i class="bi bi-check-circle me-1"></i>Confirmed as @FormatContentType(resolvedContentType)</small>
                    }
                </div>
            }
            else
            {
                @* Low confidence *@
                <div class="alert alert-secondary mb-3" role="alert">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-exclamation-circle me-2 fs-5"></i>
                        <strong>Couldn't auto-detect the content type.</strong>
                    </div>
                    @if (!string.IsNullOrEmpty(autoDetectResult.Note))
                    {
                        <p class="mb-2 text-secondary-ss"><small>Hint: might be @FormatContentType(autoDetectResult.ContentType), but confidence is low (@FormatConfidence(autoDetectResult.Confidence)).</small></p>
                    }
                    <p class="mb-2">Please select the content type:</p>
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-sm @(resolvedContentType == ContentType.Vocabulary ? "btn-primary" : "btn-outline-primary")" 
                                @onclick='() => OverrideContentType(ContentType.Vocabulary)'>
                            Vocabulary
                        </button>
                        <button class="btn btn-sm @(resolvedContentType == ContentType.Phrases ? "btn-primary" : "btn-outline-primary")" 
                                @onclick='() => OverrideContentType(ContentType.Phrases)'>
                            Phrases
                        </button>
                        <button class="btn btn-sm @(resolvedContentType == ContentType.Sentences ? "btn-primary" : "btn-outline-primary")" 
                                @onclick='() => OverrideContentType(ContentType.Sentences)'>
                            Sentences
                        </button>
                        <button class="btn btn-sm @(resolvedContentType == ContentType.Transcript ? "btn-primary" : "btn-outline-primary")" 
                                @onclick='() => OverrideContentType(ContentType.Transcript)'>
                            Transcript
                        </button>
                    </div>
                </div>
            }
        }

        @* Type override chooser (shown when [Change] is clicked) *@
        @if (showTypeChooser)
        {
            <div class="card card-ss p-4 mb-3 border-warning">
                <h6 class="ss-body1 mb-3">Select content type:</h6>
                <div class="d-flex flex-wrap gap-2 mb-2">
                    <button class="btn btn-sm @(resolvedContentType == ContentType.Vocabulary ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => OverrideContentType(ContentType.Vocabulary)'>
                        Vocabulary
                    </button>
                    <button class="btn btn-sm @(resolvedContentType == ContentType.Phrases ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => OverrideContentType(ContentType.Phrases)'>
                        Phrases
                    </button>
                    <button class="btn btn-sm @(resolvedContentType == ContentType.Sentences ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => OverrideContentType(ContentType.Sentences)'>
                        Sentences
                    </button>
                    <button class="btn btn-sm @(resolvedContentType == ContentType.Transcript ? "btn-primary" : "btn-outline-primary")" 
                            @onclick='() => OverrideContentType(ContentType.Transcript)'>
                        Transcript
                    </button>
                </div>
                <button class="btn btn-sm btn-link text-secondary-ss p-0" @onclick="CloseTypeChooser">Cancel</button>
            </div>
        }

        @* Harvest Step: What to extract *@
        @if (currentStep >= ImportStep.Harvest && harvestStepReady)
        {
            <div class="card card-ss p-4 mb-3">
                <h5 class="ss-title3 mb-3">What should we harvest?</h5>
                <p class="ss-body2 text-secondary-ss mb-3">Select what to extract from this content. At least one option must be checked.</p>

                <div class="form-check mb-2">
                    <input class="form-check-input" 
                           type="checkbox" 
                           id="harvestTranscript" 
                           @bind="harvestTranscript" />
                    <label class="form-check-label ss-body2" for="harvestTranscript">
                        <strong>This is a Transcript</strong>
                        <small class="d-block text-secondary-ss">Store the full text on the learning resource</small>
                    </label>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" 
                           type="checkbox" 
                           id="harvestSentences" 
                           @bind="harvestSentences" />
                    <label class="form-check-label ss-body2" for="harvestSentences">
                        <strong>Harvest Sentences</strong>
                        <small class="d-block text-secondary-ss">Extract complete sentences (subject + verb + terminal punctuation), often pipe-delimited with translations</small>
                    </label>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" 
                           type="checkbox" 
                           id="harvestPhrases" 
                           @bind="harvestPhrases" />
                    <label class="form-check-label ss-body2" for="harvestPhrases">
                        <strong>Harvest Phrases</strong>
                        <small class="d-block text-secondary-ss">Extract phrase-level entries for practice activities</small>
                    </label>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" 
                           type="checkbox" 
                           id="harvestWords" 
                           @bind="harvestWords" />
                    <label class="form-check-label ss-body2" for="harvestWords">
                        <strong>Harvest Words</strong>
                        <small class="d-block text-secondary-ss">Extract individual vocabulary words</small>
                    </label>
                </div>

                @if (showHarvestValidationError)
                {
                    <div class="alert alert-danger py-2 mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        Please select at least one harvest option before continuing.
                    </div>
                }
            </div>
        }

        @if (previewResult != null && currentStep >= ImportStep.Preview)
        {
            @* Preview Table *@
            <div class="card card-ss p-4 mb-3">
                <h5 class="ss-title3 mb-3">@Localize["Import_Step3_Title"]</h5>
                
                <div class="mb-3">
                    <small class="text-secondary-ss">
                        @Localize["Import_DetectedFormat"]: <strong>@previewResult.DetectedFormat</strong>
                    </small>
                    @if (previewResult.Warnings.Any())
                    {
                        <div class="alert alert-warning mt-2 mb-0 p-2">
                            <small>
                                @foreach (var warning in previewResult.Warnings)
                                {
                                    <div><i class="bi bi-exclamation-triangle me-1"></i>@warning</div>
                                }
                            </small>
                        </div>
                    }
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center" style="width: 40px;">
                                    <input type="checkbox" 
                                           class="form-check-input" 
                                           @bind="selectAllRows" 
                                           @bind:after="ToggleSelectAll" />
                                </th>
                                <th style="width: 60px;">#</th>
                                <th>@Localize["Import_TargetLanguageTerm"]</th>
                                <th>@Localize["Import_NativeLanguageTerm"]</th>
                                <th style="width: 100px;">@Localize["Import_Status"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in editableRows)
                            {
                                <tr class="@(row.Status == RowStatus.Error ? "table-danger" : row.Status == RowStatus.Warning ? "table-warning" : "")">
                                    <td class="text-center">
                                        <input type="checkbox" 
                                               class="form-check-input" 
                                               @bind="row.IsSelected" 
                                               disabled="@(row.Status == RowStatus.Error)" />
                                    </td>
                                    <td class="text-secondary-ss">@row.RowNumber</td>
                                    <td>
                                        <input type="text" 
                                               class="form-control form-control-sm" 
                                               @bind="row.TargetLanguageTerm" />
                                    </td>
                                    <td>
                                        <input type="text" 
                                               class="form-control form-control-sm" 
                                               @bind="row.NativeLanguageTerm" />
                                        @if (row.IsAiTranslated)
                                        {
                                            <span class="badge bg-info text-dark mt-1" title="@Localize["Import_AiTranslated_Tooltip"]">
                                                <i class="bi bi-stars"></i> @Localize["Import_AiTranslated_Badge"]
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (row.Status == RowStatus.Ok)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-lg"></i> OK</span>
                                        }
                                        else if (row.Status == RowStatus.Warning)
                                        {
                                            <span class="badge bg-warning text-dark" title="@row.Error">
                                                <i class="bi bi-exclamation-triangle"></i> Warning
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger" title="@row.Error">
                                                <i class="bi bi-x-lg"></i> Error
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <small class="text-secondary-ss">
                    @Localize["Import_SelectedCount"]: <strong>@editableRows.Count(r => r.IsSelected)</strong> / @editableRows.Count
                </small>
            </div>

            @* Step 5: Target *@
            <div class="card card-ss p-4 mb-3">
                <h5 class="ss-title3 mb-3">@Localize["Import_Step5_Title"]</h5>
                
                <div class="mb-3">
                    <div class="form-check mb-2">
                        <input class="form-check-input" 
                               type="radio" 
                               name="targetMode" 
                               id="targetNew" 
                               value="New"
                               checked="@(targetMode == ImportTargetMode.New)"
                               @onchange="() => SetTargetMode(ImportTargetMode.New)" />
                        <label class="form-check-label ss-body2" for="targetNew">
                            @Localize["Import_CreateNewResource"]
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" 
                               type="radio" 
                               name="targetMode" 
                               id="targetExisting" 
                               value="Existing"
                               checked="@(targetMode == ImportTargetMode.Existing)"
                               @onchange="() => SetTargetMode(ImportTargetMode.Existing)" />
                        <label class="form-check-label ss-body2" for="targetExisting">
                            @Localize["Import_AddToExistingResource"]
                        </label>
                    </div>
                </div>

                @if (targetMode == ImportTargetMode.New)
                {
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_ResourceTitleLabel"]</label>
                            <input type="text" 
                                   class="form-control form-control-ss" 
                                   @bind="newResourceTitle" 
                                   placeholder='@Localize["Import_ResourceTitlePlaceholder"]' />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_ResourceDescriptionLabel"]</label>
                            <input type="text" 
                                   class="form-control form-control-ss" 
                                   @bind="newResourceDescription" 
                                   placeholder='@Localize["Import_ResourceDescriptionPlaceholder"]' />
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_TargetLanguageLabel"]</label>
                            <select class="form-select form-control-ss" @bind="targetLanguage">
                                @foreach (var lang in languages)
                                {
                                    <option value="@lang">@lang</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_NativeLanguageLabel"]</label>
                            <select class="form-select form-control-ss" @bind="nativeLanguage">
                                @foreach (var lang in languages)
                                {
                                    <option value="@lang">@lang</option>
                                }
                            </select>
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-3">
                        <label class="form-label ss-body2 text-secondary-ss">@Localize["Import_SelectExistingResourceLabel"]</label>
                        <select class="form-select form-control-ss" @bind="selectedResourceId">
                            <option value="">-- @Localize["Import_SelectResourcePlaceholder"] --</option>
                            @foreach (var resource in availableResources)
                            {
                                <option value="@resource.Id">@resource.Title (@resource.Language)</option>
                            }
                        </select>
                    </div>
                }
            </div>

            @* Step 6: Dedup Mode *@
            <div class="card card-ss p-4 mb-3">
                <h5 class="ss-title3 mb-3">@Localize["Import_Step6_Title"]</h5>
                
                <div class="form-check mb-2">
                    <input class="form-check-input" 
                           type="radio" 
                           name="dedupMode" 
                           id="dedupSkip" 
                           value="Skip"
                           checked="@(dedupMode == DedupMode.Skip)"
                           @onchange="() => SetDedupMode(DedupMode.Skip)" />
                    <label class="form-check-label ss-body2" for="dedupSkip">
                        <strong>@Localize["Import_DedupMode_Skip"]</strong>
                        <small class="d-block text-secondary-ss">@Localize["Import_DedupMode_Skip_Help"]</small>
                    </label>
                </div>
                
                <div class="form-check mb-2">
                    <input class="form-check-input" 
                           type="radio" 
                           name="dedupMode" 
                           id="dedupUpdate" 
                           value="Update"
                           checked="@(dedupMode == DedupMode.Update)"
                           @onchange="() => SetDedupMode(DedupMode.Update)" />
                    <label class="form-check-label ss-body2" for="dedupUpdate">
                        <strong>@Localize["Import_DedupMode_Update"]</strong>
                        <small class="d-block text-warning">@Localize["Import_DedupMode_Update_Help"]</small>
                    </label>
                </div>
                
                <div class="form-check">
                    <input class="form-check-input" 
                           type="radio" 
                           name="dedupMode" 
                           id="dedupImportAll" 
                           value="ImportAll"
                           checked="@(dedupMode == DedupMode.ImportAll)"
                           @onchange="() => SetDedupMode(DedupMode.ImportAll)" />
                    <label class="form-check-label ss-body2" for="dedupImportAll">
                        <strong>@Localize["Import_DedupMode_ImportAll"]</strong>
                        <small class="d-block text-secondary-ss">@Localize["Import_DedupMode_ImportAll_Help"]</small>
                    </label>
                </div>
            </div>
        }
    }
</div>

@code {
    private enum ImportStep { Source, Harvest, Preview, Commit, Complete }
    private enum ConfidenceBand { High, Medium, Low }

    [SupplyParameterFromQuery(Name = "completed")]
    public string? CompletedKey { get; set; }

    private ImportStep currentStep = ImportStep.Source;
    
    // Result detail filter
    private ImportItemStatus? resultFilter;
    private IReadOnlyList<ContentImportItemResult> FilteredResultItems =>
        importResult?.Items == null ? Array.Empty<ContentImportItemResult>()
        : resultFilter == null ? importResult.Items
        : importResult.Items.Where(i => i.Status == resultFilter.Value).ToList();
    
    // Step 1: Source
    private string rawText = string.Empty;
    
    // Step 2: Format Hints
    private string contentType = "Vocabulary";
    private string delimiter = "auto";
    private bool hasHeaderRow = false;
    
    // Auto-detect state
    private ContentTypeDetectionResult? autoDetectResult;
    private ConfidenceBand autoDetectConfidenceBand;
    private bool autoDetectConfirmed;
    private ContentType resolvedContentType = ContentType.Vocabulary;
    private bool showTypeChooser;

    // Harvest checkboxes
    private bool harvestTranscript;
    private bool harvestSentences;
    private bool harvestPhrases;
    private bool harvestWords = true;
    private bool showHarvestValidationError;
    private bool harvestStepReady;

    // Preview
    private bool isParsing;
    private bool selectAllRows = true;
    private ContentImportPreview? previewResult;
    private List<ImportRow> editableRows = new();
    
    // Target
    private ImportTargetMode targetMode = ImportTargetMode.New;
    private string newResourceTitle = string.Empty;
    private string newResourceDescription = string.Empty;
    private string targetLanguage = "Korean";
    private string nativeLanguage = "English";
    private string selectedResourceId = string.Empty;
    private List<LearningResource> availableResources = new();
    
    // Dedup
    private DedupMode dedupMode = DedupMode.Skip;
    
    // Commit
    private bool isCommitting;
    private ContentImportResult? importResult;
    
    private readonly string[] languages = SentenceStudio.Common.Constants.Languages;

    protected override async Task OnInitializedAsync()
    {
        Localize.CultureChanged += OnCultureChanged;
        await LoadAvailableResources();

        // Hydrate from store if navigated back with ?completed={guid}
        if (Guid.TryParse(CompletedKey, out var key))
        {
            var cached = ImportResultStore.TryGet(key);
            if (cached != null)
            {
                importResult = cached;
                currentStep = ImportStep.Complete;
            }
        }
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadAvailableResources()
    {
        try
        {
            var profile = await UserProfileRepo.GetAsync();
            if (profile == null) return;

            var allResources = await ResourceRepo.GetAllResourcesLightweightAsync();
            availableResources = allResources
                .Where(r => !r.IsSmartResource && r.UserProfileId == profile.Id)
                .OrderBy(r => r.Title)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load available resources");
        }
    }

    private async Task ParseContent()
    {
        isParsing = true;
        showHarvestValidationError = false;

        try
        {
            var selectedType = Enum.Parse<ContentType>(contentType);

            // Auto-detect path: run classifier BEFORE preview
            if (selectedType == ContentType.Auto)
            {
                var classificationResult = await ImportService.ClassifyContentAsync(rawText, null);
                autoDetectResult = new ContentTypeDetectionResult
                {
                    ContentType = classificationResult.ContentType,
                    Confidence = classificationResult.Confidence,
                    Note = classificationResult.Reasoning
                };
                autoDetectConfidenceBand = ClassifyConfidence(autoDetectResult.Confidence);
                autoDetectConfirmed = false;
                showTypeChooser = false;

                if (autoDetectConfidenceBand == ConfidenceBand.High)
                {
                    resolvedContentType = autoDetectResult.ContentType;
                    autoDetectConfirmed = true;
                    ApplyHarvestDefaults(resolvedContentType);
                    harvestStepReady = true;
                }
                else if (autoDetectConfidenceBand == ConfidenceBand.Medium)
                {
                    resolvedContentType = autoDetectResult.ContentType;
                    harvestStepReady = false; // User must confirm first
                    currentStep = ImportStep.Harvest;
                    return; // Don't run preview yet
                }
                else
                {
                    resolvedContentType = ContentType.Vocabulary; // Placeholder until user picks
                    harvestStepReady = false;
                    currentStep = ImportStep.Harvest;
                    return; // Don't run preview yet
                }
            }
            else
            {
                resolvedContentType = selectedType;
                autoDetectResult = null;
                ApplyHarvestDefaults(resolvedContentType);
                harvestStepReady = true;
            }

            await RunPreview();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to parse content");
            Toast.ShowError($"{Localize["Import_ParseError"]}: {ex.Message}");
        }
        finally
        {
            isParsing = false;
        }
    }

    private async Task RunPreview()
    {
        isParsing = true;
        try
        {
            var request = new ContentImportRequest
            {
                RawText = rawText,
                ContentType = resolvedContentType,
                DelimiterOverride = delimiter == "auto" ? null : delimiter == "\\t" ? '\t' : delimiter[0],
                HasHeaderRow = hasHeaderRow,
                TargetLanguage = targetLanguage,
                NativeLanguage = nativeLanguage,
                HarvestTranscript = harvestTranscript,
                HarvestSentences = harvestSentences,
                HarvestPhrases = harvestPhrases,
                HarvestWords = harvestWords
            };

            previewResult = await ImportService.ParseContentAsync(request);
            editableRows = previewResult.Rows.Select(r => new ImportRow
            {
                RowNumber = r.RowNumber,
                TargetLanguageTerm = r.TargetLanguageTerm,
                NativeLanguageTerm = r.NativeLanguageTerm,
                Status = r.Status,
                Error = r.Error,
                IsSelected = r.IsSelected,
                IsAiTranslated = r.IsAiTranslated,
                LexicalUnitType = r.LexicalUnitType
            }).ToList();

            currentStep = ImportStep.Preview;
            selectAllRows = editableRows.All(r => r.IsSelected);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to parse content");
            Toast.ShowError($"{Localize["Import_ParseError"]}: {ex.Message}");
        }
        finally
        {
            isParsing = false;
        }
    }

    private void ApplyHarvestDefaults(ContentType type)
    {
        switch (type)
        {
            case ContentType.Vocabulary:
                harvestTranscript = false;
                harvestSentences = false;
                harvestPhrases = false;
                harvestWords = true;
                break;
            case ContentType.Phrases:
                harvestTranscript = false;
                harvestSentences = false;
                harvestPhrases = true;
                harvestWords = true;
                break;
            case ContentType.Sentences:
                harvestTranscript = false;
                harvestSentences = true;
                harvestPhrases = false;
                harvestWords = true;
                break;
            case ContentType.Transcript:
                harvestTranscript = true;
                harvestSentences = false;
                harvestPhrases = false;
                harvestWords = true;
                break;
            case ContentType.Auto:
                harvestTranscript = false;
                harvestSentences = false;
                harvestPhrases = false;
                harvestWords = false;
                break;
            default:
                harvestWords = true;
                break;
        }
    }

    private void ConfirmAutoDetect()
    {
        autoDetectConfirmed = true;
        ApplyHarvestDefaults(resolvedContentType);
        harvestStepReady = true;
        _ = RunPreview();
    }

    private void OpenTypeChooser()
    {
        showTypeChooser = true;
    }

    private void CloseTypeChooser()
    {
        showTypeChooser = false;
    }

    private void OverrideContentType(ContentType type)
    {
        resolvedContentType = type;
        autoDetectConfirmed = true;
        showTypeChooser = false;
        ApplyHarvestDefaults(type);
        harvestStepReady = true;
        _ = RunPreview();
    }

    private bool ValidateHarvestCheckboxes()
    {
        var valid = harvestTranscript || harvestSentences || harvestPhrases || harvestWords;
        showHarvestValidationError = !valid;
        return valid;
    }

    private static ConfidenceBand ClassifyConfidence(float confidence)
    {
        if (confidence >= 0.85f) return ConfidenceBand.High;
        if (confidence >= 0.70f) return ConfidenceBand.Medium;
        return ConfidenceBand.Low;
    }

    private static string FormatContentType(ContentType type) => type switch
    {
        ContentType.Vocabulary => "Vocabulary",
        ContentType.Phrases => "Phrases",
        ContentType.Sentences => "Sentences",
        ContentType.Transcript => "Transcript",
        _ => type.ToString()
    };

    private static string FormatConfidence(float confidence) => $"{confidence * 100:F0}%";

    private void ToggleSelectAll()
    {
        foreach (var row in editableRows.Where(r => r.Status != RowStatus.Error))
        {
            row.IsSelected = selectAllRows;
        }
    }

    private void SetTargetMode(ImportTargetMode mode)
    {
        targetMode = mode;
    }

    private void SetDedupMode(DedupMode mode)
    {
        dedupMode = mode;
    }

    private async Task CommitImport()
    {
        // Validate harvest checkboxes
        if (!ValidateHarvestCheckboxes())
        {
            Toast.ShowError("Please select at least one harvest option.");
            return;
        }

        // Validation
        if (targetMode == ImportTargetMode.New && string.IsNullOrWhiteSpace(newResourceTitle))
        {
            Toast.ShowError($"{Localize["Import_ResourceTitleRequired"]}");
            return;
        }

        if (targetMode == ImportTargetMode.Existing && string.IsNullOrWhiteSpace(selectedResourceId))
        {
            Toast.ShowError($"{Localize["Import_SelectResourceRequired"]}");
            return;
        }

        if (!editableRows.Any(r => r.IsSelected))
        {
            Toast.ShowError($"{Localize["Import_NoRowsSelected"]}");
            return;
        }

        if (dedupMode == DedupMode.Update)
        {
            Toast.ShowWarning($"{Localize["Import_UpdateModeWarning"]}");
        }

        isCommitting = true;
        try
        {
            var profile = await UserProfileRepo.GetAsync();
            if (profile == null)
            {
                Toast.ShowError($"{Localize["Import_ProfileNotFound"]}");
                return;
            }

            var updatedPreview = new ContentImportPreview
            {
                Rows = editableRows,
                DetectedFormat = previewResult!.DetectedFormat,
                DetectedContentType = previewResult.DetectedContentType,
                Warnings = previewResult.Warnings,
                SourceText = previewResult.SourceText
            };

            var target = targetMode == ImportTargetMode.New
                ? new ImportTarget
                {
                    Mode = ImportTargetMode.New,
                    NewResourceTitle = newResourceTitle,
                    NewResourceDescription = newResourceDescription,
                    TargetLanguage = targetLanguage,
                    NativeLanguage = nativeLanguage
                }
                : new ImportTarget
                {
                    Mode = ImportTargetMode.Existing,
                    ExistingResourceId = selectedResourceId
                };

            var commit = new ContentImportCommit
            {
                Preview = updatedPreview,
                Target = target,
                DedupMode = dedupMode,
                HarvestTranscript = harvestTranscript,
                HarvestSentences = harvestSentences,
                HarvestPhrases = harvestPhrases,
                HarvestWords = harvestWords
            };

            importResult = await ImportService.CommitImportAsync(commit);
            currentStep = ImportStep.Complete;

            // Persist in memory store so back-nav re-hydrates the view
            var storeKey = ImportResultStore.Save(importResult);
            NavManager.NavigateTo($"/import-content?completed={storeKey}", forceLoad: false);

            Toast.ShowSuccess($"{Localize["Import_ImportSuccess"]}");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to commit import");
            Toast.ShowError($"{Localize["Import_CommitError"]}: {ex.Message}");
        }
        finally
        {
            isCommitting = false;
        }
    }

    private void ViewResource()
    {
        if (importResult != null && !string.IsNullOrEmpty(importResult.ResourceId))
        {
            NavManager.NavigateTo($"/resources/edit/{importResult.ResourceId}");
        }
    }

    private void StartNewImport()
    {
        currentStep = ImportStep.Source;
        rawText = string.Empty;
        contentType = "Vocabulary";
        delimiter = "auto";
        hasHeaderRow = false;
        previewResult = null;
        editableRows.Clear();
        selectAllRows = true;
        targetMode = ImportTargetMode.New;
        newResourceTitle = string.Empty;
        newResourceDescription = string.Empty;
        selectedResourceId = string.Empty;
        dedupMode = DedupMode.Skip;
        importResult = null;
        resultFilter = null;
        autoDetectResult = null;
        autoDetectConfirmed = false;
        showTypeChooser = false;
        harvestTranscript = false;
        harvestSentences = false;
        harvestPhrases = false;
        harvestWords = true;
        showHarvestValidationError = false;
        harvestStepReady = false;

        NavManager.NavigateTo("/import-content", forceLoad: false);
    }

    // --- Import Complete helpers ---

    private void SetResultFilter(ImportItemStatus? status) => resultFilter = status;

    private void NavigateToVocabDetail(ContentImportItemResult item)
    {
        if (item.Status == ImportItemStatus.Failed || string.IsNullOrEmpty(item.VocabularyWordId))
            return;
        NavManager.NavigateTo($"/vocabulary/edit/{item.VocabularyWordId}");
    }

    private static RenderFragment RenderTypeBadge(LexicalUnitType type) => type switch
    {
        LexicalUnitType.Word => (__builder) =>
        {
            <span class="badge bg-primary bg-opacity-10 text-primary"><i class="bi bi-fonts me-1"></i>Word</span>
        },
        LexicalUnitType.Phrase => (__builder) =>
        {
            <span class="badge bg-purple bg-opacity-10 text-purple" style="--bs-purple:#6f42c1;color:var(--bs-purple);background-color:rgba(111,66,193,0.1);"><i class="bi bi-chat-quote me-1"></i>Phrase</span>
        },
        LexicalUnitType.Sentence => (__builder) =>
        {
            <span class="badge bg-info bg-opacity-10 text-info"><i class="bi bi-body-text me-1"></i>Sentence</span>
        },
        _ => (__builder) =>
        {
            <span class="badge bg-secondary bg-opacity-10 text-secondary"><i class="bi bi-question-circle me-1"></i>Unknown</span>
        }
    };

    private static RenderFragment RenderStatusBadge(ImportItemStatus status) => status switch
    {
        ImportItemStatus.Created => (__builder) =>
        {
            <span class="badge bg-success"><i class="bi bi-plus-circle me-1"></i>Created</span>
        },
        ImportItemStatus.Updated => (__builder) =>
        {
            <span class="badge bg-warning text-dark"><i class="bi bi-pencil me-1"></i>Updated</span>
        },
        ImportItemStatus.Skipped => (__builder) =>
        {
            <span class="badge bg-info"><i class="bi bi-skip-forward me-1"></i>Skipped</span>
        },
        ImportItemStatus.Failed => (__builder) =>
        {
            <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Failed</span>
        },
        _ => (__builder) =>
        {
            <span class="badge bg-secondary">Unknown</span>
        }
    };

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }
}
