@page "/skills/edit/{Id}"
@attribute [Authorize]
@inject SentenceStudio.WebUI.Services.BlazorLocalizationService Localize
@implements IDisposable

@if (isLoading)
{
    <div class="d-flex justify-content-center p-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    <PageHeader Title='@Localize["SkillEdit_Title"]' ShowBack="true" OnBack="GoBack">
        <PrimaryActions>
            <button class="btn btn-ss-primary" @onclick="SaveProfile" disabled="@isSaving">
                @if (isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                @Localize["Common_Save"]
            </button>
        </PrimaryActions>
        <SecondaryActions>
            <li><button class="dropdown-item" @onclick="SaveProfile" disabled="@isSaving"><i class="bi bi-check-lg me-2"></i>@Localize["Common_Save"]</button></li>
            <li><hr class="dropdown-divider" /></li>
            <li><button class="dropdown-item text-danger" @onclick="RequestDelete"><i class="bi bi-trash me-2"></i>@Localize["Common_Delete"]</button></li>
        </SecondaryActions>
    </PageHeader>

    <div class="card card-ss p-4 mb-3 mt-3">
        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["SkillAdd_TitleLabel"]</label>
            <input type="text" class="form-control form-control-ss" @bind="title" />
        </div>

        <div class="mb-3">
            <label class="form-label ss-body2 text-secondary-ss">@Localize["SkillAdd_DescriptionLabel"]</label>
            <textarea class="form-control form-control-ss" @bind="description" rows="6"></textarea>
        </div>
    </div>

    <div class="card card-ss p-4 mb-3">
        <h5 class="ss-title3 mb-3">@Localize["SkillEdit_DetailsTitle"]</h5>
        <div class="row g-2">
            <div class="col-4 col-md-2"><strong class="ss-body2">@Localize["SkillEdit_Created"]</strong></div>
            <div class="col-8 col-md-4 ss-body2">@profile.CreatedAt.ToString("g")</div>

            <div class="col-4 col-md-2"><strong class="ss-body2">@Localize["SkillEdit_Updated"]</strong></div>
            <div class="col-8 col-md-4 ss-body2">@profile.UpdatedAt.ToString("g")</div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content bg-surface">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-error-ss">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Localize["SkillEdit_ConfirmDelete"]
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="ss-body2">@deleteConfirmMessage</p>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-ss-secondary" @onclick="CancelDelete">@Localize["Common_Cancel"]</button>
                    <button type="button" class="btn btn-ss-danger" @onclick="ConfirmDelete" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        @Localize["Common_Delete"]
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    [Inject] private SkillProfileRepository SkillRepo { get; set; } = default!;
    [Inject] private NavigationManager NavManager { get; set; } = default!;
    [Inject] private ToastService Toast { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private SkillProfile profile = new();
    private string title = "";
    private string description = "";
    private bool isLoading = true;
    private bool isSaving;
    private bool showDeleteConfirm;
    private string deleteConfirmMessage = "";
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        isLoading = true;
        try
        {
            var loaded = await SkillRepo.GetSkillProfileAsync(Id);
            if (loaded != null)
            {
                profile = loaded;
                title = profile.Title ?? "";
                description = profile.Description ?? "";
            }
            else
            {
                Toast.ShowError($"{Localize["SkillEdit_NotFound"]}");
                NavManager.NavigateTo("/skills");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError(string.Format(Localize["SkillEdit_LoadFailed"], ex.Message));
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoBack() => NavManager.NavigateTo("/skills");

    private async Task SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(title))
        {
            Toast.ShowError($"{Localize["SkillAdd_TitleRequired"]}");
            return;
        }

        isSaving = true;
        try
        {
            profile.Title = title;
            profile.Description = description;

            var result = await SkillRepo.SaveAsync(profile);
            if (!string.IsNullOrEmpty(result))
            {
                Toast.ShowSuccess($"{Localize["SkillEdit_SavedSuccess"]}");
            }
            NavManager.NavigateTo("/skills");
        }
        catch (Exception ex)
        {
            Toast.ShowError(string.Format(Localize["SkillEdit_SaveFailed"], ex.Message));
        }
        finally
        {
            isSaving = false;
        }
    }

    private void RequestDelete()
    {
        deleteConfirmMessage = $"{Localize["SkillEdit_DeleteMessage"]}";
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        try
        {
            await SkillRepo.DeleteAsync(profile);
            Toast.ShowSuccess($"{Localize["SkillEdit_DeletedSuccess"]}");
            NavManager.NavigateTo("/skills");
        }
        catch (Exception ex)
        {
            Toast.ShowError(string.Format(Localize["SkillEdit_DeleteFailed"], ex.Message));
        }
        finally
        {
            isDeleting = false;
            showDeleteConfirm = false;
        }
    }

    protected override void OnInitialized()
    {
        Localize.CultureChanged += OnCultureChanged;
    }

    private void OnCultureChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Localize.CultureChanged -= OnCultureChanged;
    }
}
