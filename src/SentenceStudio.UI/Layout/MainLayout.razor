@inherits LayoutComponentBase
@using Microsoft.Extensions.DependencyInjection
@inject ThemeService ThemeService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@inject SentenceStudio.Abstractions.IPreferencesService Preferences
@inject UserProfileRepository ProfileRepo
@inject SentenceStudio.Services.ReleaseNotesService ReleaseNotesService
@inject IServiceProvider ServiceProvider
@inject SentenceStudio.Services.ISyncService SyncService
@implements IDisposable

<div class="d-flex vh-100">
    <EnvironmentBadge />
    @if (!isOnboarding && isAuthenticated)
    {
        @* Sidebar navigation (desktop only) *@
        <nav class="d-none d-md-flex flex-column flex-shrink-0 bg-surface sidebar-nav @(sidebarCollapsed ? "collapsed" : "")"
             style="border-right: 1px solid var(--bs-border-color);">
            <div class="flex-grow-1 overflow-auto">
                <NavMenu />
            </div>
            <div class="p-2 border-top" style="border-color: var(--bs-border-color) !important;">
                <button class="btn btn-sm btn-icon d-flex align-items-center @(sidebarCollapsed ? "justify-content-center w-100" : "ms-auto")"
                        title="@(sidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")"
                        @onclick="ToggleSidebar">
                    <i class="bi @(sidebarCollapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
                </button>
            </div>
        </nav>
    }

    <div class="d-flex flex-column flex-grow-1 overflow-hidden">
        @if (isUpdateAvailable)
        {
            <UpdateAvailableBanner LatestVersion="@latestVersion" IsUpdateAvailable="true" />
        }
        @* Main content — PageHeader renders as sticky mobile navbar inside here *@
        <main class="flex-grow-1 overflow-auto p-3 main-content">
            @Body
        </main>
    </div>

    @if (!isOnboarding && isAuthenticated)
    {
        @* Mobile offcanvas navigation *@
        <div class="offcanvas offcanvas-start bg-surface" tabindex="-1" id="mobileNav"
             style="border-right: 1px solid var(--bs-border-color);">
            <div class="offcanvas-header border-bottom"
                 style="border-color: var(--bs-border-color) !important; padding-top: calc(env(safe-area-inset-top, 0px) + 12px);">
                <h5 class="offcanvas-title text-primary-ss">SentenceStudio</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>
            <div class="offcanvas-body p-0">
                <NavMenu />
            </div>
        </div>
    }

    <ToastContainer />
    
    <WhatsNewModal 
        IsVisible="@showWhatsNew" 
        Title="@whatsNewTitle"
        Version="@whatsNewVersion"
        Content="@whatsNewContent"
        OnDismissed="@DismissWhatsNew" />

    @if (isSyncing)
    {
        <div class="sync-overlay">
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Syncing...</span>
                </div>
                <h4 class="text-white mb-2">Syncing Your Profile</h4>
                <p class="text-white-50 mb-0">Downloading your vocabulary, resources, and progress.<br/>This may take a moment.</p>
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private IJSObjectReference? jsModule;
    private bool sidebarCollapsed;
    private bool isOnboarding;
    private bool isAuthenticated;
    private bool showWhatsNew;
    private string whatsNewTitle = "What's New";
    private string whatsNewVersion = "";
    private string whatsNewContent = "";
    private bool isUpdateAvailable;
    private string latestVersion = "";
    private bool isSyncing;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        
        isSyncing = SyncService.IsInitialSyncInProgress;
        SyncService.InitialSyncCompleted += OnInitialSyncCompleted;

        // Resolve authentication state from CascadingAuthenticationState
        if (AuthStateTask is not null)
        {
            var authState = await AuthStateTask;
            isAuthenticated = authState.User?.Identity?.IsAuthenticated ?? false;
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var isOnboardingPath = uri.AbsolutePath.StartsWith("/onboarding", StringComparison.OrdinalIgnoreCase);

        // Only redirect to onboarding when authenticated but not yet onboarded
        if (isAuthenticated && !Preferences.Get("is_onboarded", false) && !isOnboardingPath)
        {
            // Check if this is a returning user with existing profile data
            // (e.g., fresh deploy/rebuild cleared device-local preferences)
            var existingProfile = await ProfileRepo.GetAsync();
            if (existingProfile is not null
                && !string.IsNullOrEmpty(existingProfile.TargetLanguage)
                && !string.IsNullOrEmpty(existingProfile.NativeLanguage)
                && !string.IsNullOrEmpty(existingProfile.Name))
            {
                Preferences.Set("is_onboarded", true);
            }
            else
            {
                isOnboarding = true;
                NavigationManager.NavigateTo("/onboarding");
            }
        }

        isOnboarding = isOnboardingPath || isOnboarding;
        sidebarCollapsed = Preferences.Get("SidebarCollapsed", false);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/SentenceStudio.UI/js/app.js");
            await jsModule.InvokeVoidAsync("applyTheme", ThemeService.CurrentTheme, ThemeService.CurrentMode);
            await jsModule.InvokeVoidAsync("setFontScale", ThemeService.FontScale);
            ThemeService.ThemeChanged += OnThemeChanged;

            // Check for version updates and show What's New if needed
            if (isAuthenticated)
            {
                await CheckVersionAndShowWhatsNew();
                await CheckForAppUpdate();
            }
        }
    }

    private async Task CheckVersionAndShowWhatsNew()
    {
        try
        {
            var currentVersion = typeof(MainLayout).Assembly.GetName().Version?.ToString(2) ?? "1.0";
            var lastSeenVersion = Preferences.Get("last_seen_version", "");

            if (lastSeenVersion != currentVersion)
            {
                var releaseNote = await ReleaseNotesService.GetNotesForVersionAsync(currentVersion);
                if (releaseNote != null)
                {
                    whatsNewVersion = releaseNote.Version;
                    whatsNewTitle = "What's New";
                    whatsNewContent = ConvertMarkdownToHtml(releaseNote.MarkdownContent);
                    showWhatsNew = true;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch
        {
            // Silently fail if release notes service is unavailable
        }
    }

    private async Task DismissWhatsNew()
    {
        showWhatsNew = false;
        var currentVersion = typeof(MainLayout).Assembly.GetName().Version?.ToString(2) ?? "1.0";
        Preferences.Set("last_seen_version", currentVersion);
        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckForAppUpdate()
    {
        try
        {
            // VersionCheckService is only registered on mobile (via AppLib)
            // Use service provider to optionally resolve — not available on web
            var versionCheck = ServiceProvider.GetService<SentenceStudio.Services.VersionCheckService>();
            if (versionCheck == null) return;

            var currentVersion = typeof(MainLayout).Assembly.GetName().Version?.ToString(2) ?? "1.0";
            await versionCheck.CheckForUpdateAsync(currentVersion);
            
            if (versionCheck.IsUpdateAvailable)
            {
                isUpdateAvailable = true;
                latestVersion = versionCheck.LatestVersion;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Version check is non-critical — fail silently
        }
    }

    private string ConvertMarkdownToHtml(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown))
            return "";

        var html = markdown
            .Replace("&", "&amp;")
            .Replace("<", "&lt;")
            .Replace(">", "&gt;");

        // Headers
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^### (.+)$", "<h5>$1</h5>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^## (.+)$", "<h4>$1</h4>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^# (.+)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);

        // Bold and italic
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*(.+?)\*", "<em>$1</em>");

        // Links
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\[(.+?)\]\((.+?)\)", "<a href=\"$2\">$1</a>");

        // Lists
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^- (.+)$", "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"(<li>.*</li>\n?)+", "<ul class=\"ss-body2 mb-3\">$0</ul>", System.Text.RegularExpressions.RegexOptions.Singleline);

        // Paragraphs
        var lines = html.Split('\n');
        var result = new System.Text.StringBuilder();
        var inList = false;

        foreach (var line in lines)
        {
            if (line.Trim().StartsWith("<ul"))
                inList = true;
            else if (line.Trim().StartsWith("</ul>"))
                inList = false;

            if (!string.IsNullOrWhiteSpace(line) && !line.Trim().StartsWith("<h") && !line.Trim().StartsWith("<li") && !line.Trim().StartsWith("<ul") && !line.Trim().StartsWith("</ul>") && !inList)
                result.AppendLine($"<p class=\"ss-body2 mb-2\">{line.Trim()}</p>");
            else
                result.AppendLine(line);
        }

        return result.ToString();
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
        Preferences.Set("SidebarCollapsed", sidebarCollapsed);
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var newUri = NavigationManager.ToAbsoluteUri(e.Location);
        var path = newUri.AbsolutePath;

        isOnboarding = path.StartsWith("/onboarding", StringComparison.OrdinalIgnoreCase);

        try
        {
            if (jsModule != null)
                await jsModule.InvokeVoidAsync("resetScroll");
        }
        catch { /* component may be disposed */ }

        await InvokeAsync(StateHasChanged);
    }

    private async void OnThemeChanged(object? sender, ThemeChangedEventArgs e)
    {
        if (jsModule != null)
        {
            await jsModule.InvokeVoidAsync("applyTheme", e.Theme, e.Mode);
            await jsModule.InvokeVoidAsync("setFontScale", e.FontScale);
        }
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
        SyncService.InitialSyncCompleted -= OnInitialSyncCompleted;
        jsModule?.DisposeAsync();
    }

    private void OnInitialSyncCompleted()
    {
        isSyncing = false;
        InvokeAsync(StateHasChanged);
    }
}
