@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@using System.Reflection

@if (!string.IsNullOrEmpty(envLabel))
{
    <div class="env-bar env-bar-@envClass" title="@envDetail">
        <div class="env-bar-left">
            <span class="env-bar-appname">SentenceStudio</span>
            <span class="env-bar-pill">@envLabel</span>
            @if (!string.IsNullOrEmpty(apiHost))
            {
                <span class="env-bar-apihost">
                    <i class="bi bi-hdd-network" aria-hidden="true"></i> @apiHost
                </span>
            }
        </div>
        <div class="env-bar-right">
            <span class="env-bar-version">@appVersion</span>
        </div>
    </div>
}

@code {
    private string envLabel = "";
    private string envClass = "";
    private string envDetail = "";
    private string appVersion = "";
    private string apiHost = "";

    protected override void OnInitialized()
    {
        // Check Aspire service discovery env vars (set when launched from Aspire)
        var aspireApiUrl = Environment.GetEnvironmentVariable("services__api__https__0")
                        ?? Environment.GetEnvironmentVariable("services__api__http__0");

        // Check config-based API URL
        var configApiUrl = Configuration["ApiBaseUrl"] ?? "";

        // Check Services fallback section (check both https and http)
        var fallbackUrl = Configuration["Services:api:https:0"]
                       ?? Configuration["Services:api:http:0"]
                       ?? "";

        // Collect all known URLs to check for production indicators
        var allUrls = $"{aspireApiUrl} {configApiUrl} {fallbackUrl}";

        string? resolvedApiUrl = null;

        if (allUrls.Contains("azurecontainerapps.io"))
        {
            // Production Azure — no bar needed, this is the normal state
            return;
        }
        else if (!string.IsNullOrEmpty(aspireApiUrl))
        {
            resolvedApiUrl = aspireApiUrl;
            if (aspireApiUrl.Contains("devtunnels.ms"))
            {
                envLabel = "DEV TUNNEL";
                envClass = "dev";
            }
            else
            {
                envLabel = "LOCAL";
                envClass = "local";
            }
        }
        else if (configApiUrl.Contains("localhost") || fallbackUrl.Contains("localhost"))
        {
            envLabel = "LOCAL";
            envClass = "local";
            resolvedApiUrl = string.IsNullOrEmpty(configApiUrl) ? fallbackUrl : configApiUrl;
        }
        else if (configApiUrl.Contains("devtunnels.ms") || fallbackUrl.Contains("devtunnels.ms"))
        {
            envLabel = "DEV TUNNEL";
            envClass = "dev";
            resolvedApiUrl = string.IsNullOrEmpty(configApiUrl) ? fallbackUrl : configApiUrl;
        }
        else
        {
            // Fallback: check ASPNETCORE_ENVIRONMENT / DOTNET_ENVIRONMENT
            var env = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT")
                   ?? Environment.GetEnvironmentVariable("DOTNET_ENVIRONMENT");
            if (string.Equals(env, "Development", StringComparison.OrdinalIgnoreCase))
            {
                envLabel = "DEV";
                envClass = "dev";
            }
        }

        if (string.IsNullOrEmpty(envLabel)) return;

        // Extract hostname for display (most useful dogfooding info — tells you which backend you're hitting)
        if (!string.IsNullOrEmpty(resolvedApiUrl) && Uri.TryCreate(resolvedApiUrl, UriKind.Absolute, out var uri))
        {
            apiHost = uri.IsDefaultPort ? uri.Host : $"{uri.Host}:{uri.Port}";
            envDetail = $"API: {resolvedApiUrl}";
        }

        // App version from assembly (SentenceStudio.UI.csproj <Version>)
        var version = typeof(EnvironmentBadge).Assembly.GetName().Version;
        appVersion = version is not null ? $"v{version.ToString(3)}" : "";

        // Include full informational version (with build timestamp) in tooltip
        var infoVersion = typeof(EnvironmentBadge).Assembly
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion;
        if (!string.IsNullOrEmpty(infoVersion))
            envDetail = string.IsNullOrEmpty(envDetail) ? infoVersion : $"{envDetail} | {infoVersion}";
    }
}
